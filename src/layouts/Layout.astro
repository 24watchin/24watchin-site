---
// ページによってサイドバーを切り替える機能 ＋ SEO強化版
const { title, description = '24Watchinは、世界中の最新ニュースを日本語でお届けするグローバルメディアです。', sidebarType = 'top' } = Astro.props;
import '../styles/global.css'; 
import Footer from '../components/Footer.astro';
import Sidebar from '../components/Sidebar.astro';
import CategorySidebar from '../components/CategorySidebar.astro';
import ArticleSidebar from '../components/ArticleSidebar.astro';
---
<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title ? `${title} | 24Watchin` : '24Watchin'}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title ? `${title} | 24Watchin` : '24Watchin'} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="24Watchin" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
      body { font-family: sans-serif; margin: 0; background-color: #f8f9fa; color: #333; }
      .container { max-width: 1200px; margin: 0 auto; padding: 0 15px; }
      header { background: #fff; border-bottom: 2px solid #1e3a8a; position: sticky; top: 0; z-index: 100; }
      .top-bar { display: flex; justify-content: space-between; align-items: center; padding: 10px 0; border-bottom: 1px solid #eee; }
      .logo { font-size: 28px; font-weight: bold; color: #1e3a8a; text-decoration: none; }
      .nav-categories { display: flex; list-style: none; padding: 0; margin: 0; overflow-x: auto; white-space: nowrap; }
      .nav-categories li a { display: block; padding: 15px 20px; color: #333; text-decoration: none; font-weight: bold; font-size: 14px; }
      
      @media (max-width: 900px) { 
        .main-layout { grid-template-columns: 1fr !important; } 
      }
    </style>
  </head>
  <body>
    <header>
      <div class="container">
        <div class="top-bar">
          <a href="/" class="logo">24Watchin</a>
          <button style="background:#f97316; color:white; border:none; padding:8px 15px; border-radius:4px; font-weight:bold;">申し込み</button>
        </div>
        <nav>
          <ul class="nav-categories">
            <li><a href="/">TOP</a></li>
            <li><a href="/category/international">国際</a></li>
            <li><a href="/category/business">ビジネス</a></li>
            <li><a href="/category/science">科学</a></li>
            <li><a href="/category/local">地域</a></li>
            <li><a href="/category/politics">政治経済</a></li>
            <li><a href="/category/industry">産業</a></li>
            <li><a href="/category/life">ライフ・教養</a></li>
            <li><a href="/category/special">特集</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <div class="container">
      <slot name="top-full" />
      
      <div class="main-layout" style="display: grid; grid-template-columns: 1fr 300px; gap: 40px; margin-top: 20px; align-items: flex-start;">
        
        {/* ▼▼▼ ここが今回の修正ポイントです！ ▼▼▼ */}
        {/* marginやpaddingを0にし、強制的に幅を100%（830px）に広げる魔法をかけました */}
        <main style="margin: 0; padding: 0; width: 100%; max-width: none;">
          <slot />
        </main>
        
        {/* 右サイドバー側にも、念のため同じ魔法をかけておきます */}
        <aside style="margin: 0; padding: 0; width: 100%; max-width: none;">
          {sidebarType === 'category' ? <CategorySidebar /> : 
           sidebarType === 'article' ? <ArticleSidebar /> : 
           <Sidebar />}
        </aside>
        {/* ▲▲▲ ここまで ▲▲▲ */}

      </div>
      
      <slot name="bottom-wide" />
    </div>
    <Footer />
  </body>
</html>
