---
const {
  title,
  description = '24Watchinは、世界の最新ニュースをわかりやすく届けるグローバルニュースメディアです。',
  sidebarType = 'top'
} = Astro.props;

import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Sidebar from '../components/Sidebar.astro';
import CategorySidebar from '../components/CategorySidebar.astro';
import ArticleSidebar from '../components/ArticleSidebar.astro';
// 【追加】天気専用サイドバーを読み込みます
import WeatherSidebar from '../components/WeatherSidebar.astro';
---
<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title ? `${title} | 24Watchin` : '24Watchin'}</title>
    <meta name="description" content={description} />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
      body { font-family: sans-serif; margin: 0; background-color: #f8f9fa; color: #333; }
      .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }
      .page-shell { margin-top: 30px; }
      .main-layout { display: grid; grid-template-columns: minmax(0, 1fr) 300px; gap: 40px; align-items: start; }
      .content-area, .sidebar-area { display: block; width: 100%; min-width: 0; margin: 0; padding: 0; align-self: start; }
      .bottom-wide { margin-top: 50px; width: 100%; }

      @media (max-width: 900px) {
        .main-layout { grid-template-columns: minmax(0, 1fr); }
        .sidebar-area { display: none; }
      }
      @media (max-width: 640px) { .container { padding: 0 14px; } }
    </style>
  </head>

  <body>
    <Header />

    <div class="container page-shell">
      <slot name="top-full" />

      <div class="main-layout">
        <main class="content-area">
          <slot />
        </main>

        <aside class="sidebar-area">
          {sidebarType === 'category'
            ? <CategorySidebar />
            : sidebarType === 'article'
              ? <ArticleSidebar />
              : sidebarType === 'weather'  /* 天気ページ専用 */
                ? <WeatherSidebar />
                : <Sidebar />}
        </aside>
      </div>

      <div class="bottom-wide">
        <slot name="bottom-wide" />
      </div>
    </div>

    <Footer />

    <!-- 右クリック禁止 -->
    <script>
      document.addEventListener('contextmenu', e => e.preventDefault());
    </script>

    <!-- 遅延読み込み -->
    <script>
      document.querySelectorAll('img').forEach(img => {
        img.setAttribute('loading', 'lazy');
      });
    </script>
  </body>
</html>
