---
// デザイン画像に基づいた共通レイアウト（Pattern A：シンプルな箱バージョン）
const { title } = Astro.props;
import '../styles/global.css'; 
import Footer from '../components/Footer.astro'; // 新しいフッターを読み込む
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title ? `${title} | 24Watchin` : '24Watchin - 全世界の最新ニュース'}</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
      /* 全体の基本設定 */
      body { font-family: 'Helvetica Neue', Arial, 'Hiragino Kaku Gothic ProN', 'Hiragino Sans', Meiryo, sans-serif;
      margin: 0; background-color: #f8f9fa; color: #333; }
      
      /* 共通の横幅設定 */
      .container { max-width: 1200px; margin: 0 auto; padding: 0 15px; }

      /* ヘッダー部分 */
      header { background: #fff; border-bottom: 2px solid #1e3a8a; position: sticky; top: 0; z-index: 100; }
      .top-bar { display: flex; justify-content: space-between; align-items: center; padding: 10px 0; border-bottom: 1px solid #eee; }
      .logo { font-size: 28px; font-weight: bold; color: #1e3a8a; text-decoration: none; }
      
      /* ナビゲーション */
      .nav-categories { display: flex; list-style: none; padding: 0; margin: 0; overflow-x: auto; white-space: nowrap; }
      .nav-categories li a { display: block; padding: 15px 20px; color: #333; text-decoration: none; font-weight: bold; font-size: 14px; }
      .nav-categories li a:hover { color: #1e3a8a; border-bottom: 2px solid #1e3a8a; }

      /* メインエリア：Pattern A に基づき、グリッド（2列設定）を削除しました */
    </style>
  </head>
  <body>
    <header>
      <div class="container">
        <div class="top-bar">
          <a href="/" class="logo">24Watchin</a>
          <div class="header-tools">
            <button style="background:#f97316; color:white; border:none; padding:8px 15px; border-radius:4px; font-weight:bold;">申し込み</button>
          </div>
        </div>
    
        <nav>
          <ul class="nav-categories">
            <li><a href="/">TOP</a></li>
            <li><a href="/category/international">国際</a></li>
            <li><a href="/category/business">ビジネス</a></li>
            <li><a href="/category/science">科学</a></li>
            <li><a href="/category/local">地域</a></li>
            <li><a href="/category/politics">政治経済</a></li>
            <li><a href="/category/industry">産業</a></li>
            <li><a href="/category/life">ライフ・教養</a></li>
            <li><a href="/category/special">特集</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <div class="container">
      {/* ページ上部の全幅スロット */}
      <div style="margin-top: 20px;">
        <slot name="top-full" />
      </div>

      {/* メインコンテンツエリア：ここで強制的に aside（サイドバー）を出すのをやめました */}
      <main style="margin-top: 20px;">
        <slot />
      </main>
      
      {/* ページ下部の全幅スロット */}
      <div style="margin-top: 40px;">
        <slot name="bottom-wide" />
      </div>
    </div>

    {/* 新しいフッター部品 */}
    <Footer />
  </body>
</html>
