const tx = t[lang] ?? t['en'];
const pageTitle = titles[lang] ?? titles['en'];
const pageDescription = descriptions[lang] ?? descriptions['en'];
---

<Layout title={pageTitle} description={pageDescription} sidebarType="article">
  <div class="info-container">
    <h1 class="info-title">{pageTitle}</h1>
    <div class="info-content">

      <p>{tx.intro1}</p>
      <p>{tx.intro2}</p>

      <section>
        <h2>{tx.beforeTitle}</h2>
        <ul>
          <li>{tx.before1}</li>
          <li>{tx.before2}</li>
          <li>{tx.before3}</li>
          <li>{tx.before4}</li>
        </ul>
      </section>

      <section>
        <h2>{tx.privacyTitle}</h2>
        <p>
          {tx.privacyText}
          <a href={`/${lang}/${country}/privacy/`}>{tx.privacyLink}</a>
          {tx.privacyEnd}
        </p>
      </section>

      <section>
        <h2>{tx.formTitle}</h2>

        <div id="form-success" class="form-success" style="display:none;">
          <p>✅ {tx.successTitle}</p>
          <p>{tx.successText}</p>
        </div>

        <div id="form-error" class="form-error" style="display:none;">
          <p>⚠️ {tx.errorText}</p>
        </div>

        <form id="contact-form" class="contact-form">

          <div class="form-group">
            <label class="form-label">
              {tx.typeLabel} <span class="required">{tx.required}</span>
            </label>
            <select name="type" required class="form-select">
              <option value="">{tx.typePlaceholder}</option>
              {tx.typeOptions.map((opt: string) => (
                <option value={opt}>{opt}</option>
              ))}
            </select>
          </div>

          <div class="form-group">
            <label class="form-label">{tx.nameLabel} <span class="required">{tx.required}</span></label>
            <input type="text" name="name" required placeholder={tx.namePlaceholder} class="form-input" />
          </div>

          <div class="form-group">
            <label class="form-label">{tx.emailLabel} <span class="required">{tx.required}</span></label>
            <input type="email" name="email" required placeholder={tx.emailPlaceholder} class="form-input" />
          </div>

          <div class="form-group">
            <label class="form-label">{tx.companyLabel} <span class="optional">{tx.optional}</span></label>
            <input type="text" name="company" placeholder={tx.companyPlaceholder} class="form-input" />
          </div>

          <div class="form-group">
            <label class="form-label">{tx.subjectLabel} <span class="required">{tx.required}</span></label>
            <input type="text" name="subject" required placeholder={tx.subjectPlaceholder} class="form-input" />
          </div>

          <div class="form-group">
            <label class="form-label">{tx.urlLabel} <span class="optional">{tx.optional}</span></label>
            <input type="url" name="pageUrl" placeholder={tx.urlPlaceholder} class="form-input" />
            <p class="form-note">{tx.urlNote}</p>
          </div>

          <div class="form-group">
            <label class="form-label">{tx.messageLabel} <span class="required">{tx.required}</span></label>
            <textarea name="message" required rows={6} placeholder={tx.messagePlaceholder} class="form-textarea"></textarea>
          </div>

          <div class="form-group">
            <label class="form-checkbox">
              <input type="checkbox" name="agreement" required />
              <span>{tx.agreementText}</span>
            </label>
          </div>

          <div class="form-submit">
            <button type="submit" class="submit-btn" id="submit-btn" data-send={tx.submitBtn} data-sending={tx.sending}>
              {tx.submitBtn}
            </button>
          </div>

        </form>
      </section>

    </div>
  </div>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const successMsg = document.getElementById('form-success') as HTMLDivElement;
  const errorMsg = document.getElementById('form-error') as HTMLDivElement;
  const sendLabel = submitBtn.dataset.send || 'Send';
  const sendingLabel = submitBtn.dataset.sending || 'Sending...';

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = sendingLabel;
    successMsg.style.display = 'none';
    errorMsg.style.display = 'none';

    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    try {
      const response = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (response.ok) {
        form.reset();
        successMsg.style.display = 'block';
        successMsg.scrollIntoView({ behavior: 'smooth' });
      } else {
        errorMsg.style.display = 'block';
      }
    } catch {
      errorMsg.style.display = 'block';
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = sendLabel;
    }
  });
</script>

