---
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import Layout from '../../../../layouts/Layout.astro';
import CategoryHero from '../../../../components/CategoryHero.astro';
import NewsList from '../../../../components/NewsList.astro';
import { categoryLabelMap } from '../../../../lib/categoryLabels';

export async function getStaticPaths() {
  const slugs = categoryLabelMap.jp.allCategories.map(cat => cat.slug);
  return slugs.map((slug) => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;
const API_KEY = import.meta.env.API_KEY;
const BLOG_ID = import.meta.env.BLOG_ID;
const url = `https://www.googleapis.com/blogger/v3/blogs/${BLOG_ID}/posts?key=${API_KEY}&maxResults=100`;

const response = await fetch(url).catch(() => null);
const data = response ? await response.json() : { items: [] };
const allPosts = data.items || [];

const catData = categoryLabelMap.jp.allCategories.find(c => c.slug === slug);
const categoryName = catData ? catData.label : 'ニュース';
const keywords = catData ? catData.keywords : [slug];

// 海外タグを弾くフィルタ
const isForeignPost = (post) => {
  if (!post.labels) return false;
  return post.labels.some(label => /^[a-z]{2}-ja$/.test(label) && label !== 'jp-ja');
};

// 安全な記事（国内向け）のみを抽出
const mainSitePosts = allPosts.filter(post => !isForeignPost(post));

// カテゴリに合致する記事を抽出
const categoryPosts = mainSitePosts.filter(post => {
  if (!post.labels) return false;
  return post.labels.some(label => keywords.some(key => label.includes(key)));
});

// 画像URLを取得する関数
const getImageUrl = (content) => {
  const match = (content || '').match(/<img[^>]+src="([^">]+)"/);
  return match ? match[1] : 'https://placehold.co/600x400/eeeeee/999999?text=No+Image';
};
---

<Layout title={categoryName} sidebarType="category">
  <Breadcrumb
    countryLabel="日本"
    countryHref="/jp/jp/"
    categoryLabel={categoryName}
    categoryHref={`/jp/jp/category/${slug}/`}
  />

  {categoryPosts.length > 0 ? (
    <>
      <CategoryHero posts={categoryPosts} categoryName={categoryName} getImageUrl={getImageUrl} />
      <hr class="divider" />
      <h2 class="section-title">その他の{categoryName}ニュース</h2>
      <NewsList posts={categoryPosts.slice(5)} getImageUrl={getImageUrl} />
    </>
  ) : (
    <p class="empty-message">現在、この記事は準備中です。</p>
  )}
</Layout>

<style>
  .divider { border: 0; border-top: 1px solid #eee; margin: 1rem 0 1.5rem; }
  .section-title { font-size: 1.5rem; border-left: 5px solid #1e3a8a; padding-left: 1rem; font-weight: bold; margin-bottom: 1.25rem; color: #1a1a1a; }
  .empty-message { color: #666; font-size: 16px; margin: 20px 0 0; }
</style>
