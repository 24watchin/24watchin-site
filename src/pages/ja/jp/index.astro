---
import Layout from '../../../layouts/Layout.astro';
// ▼ 綺麗なデザインの部品「NewsList」を呼び出します
import NewsList from '../../../components/NewsList.astro';

const BLOG_ID = import.meta.env.BLOG_ID_JA;
const API_KEY = import.meta.env.API_KEY;
// もっと見るボタンが動くように、多めに20件取得します
const url = `https://www.googleapis.com/blogger/v3/blogs/${BLOG_ID}/posts?key=${API_KEY}&maxResults=20`;

const response = await fetch(url);
const data = await response.json();
const posts = data.items || [];

// ▼ 記事本文から最初の画像を抜き出す専用の関数です
const getImageUrl = (htmlContent) => {
  if (!htmlContent) return '/images/logo-24watchin.png'; // 画像がない場合はロゴを出す
  const match = htmlContent.match(/<img[^>]+src="([^">]+)"/);
  return match ? match[1] : '/images/logo-24watchin.png';
};
---

<Layout title="日本ニュース - 24Watchin'">
  <main class="main-content">
    <h1 class="page-title">日本 ニュース</h1>
    
    {/* ▼ NewsListに、取得した記事と画像抜き出し機能を渡して表示させます */}
    <NewsList posts={posts} getImageUrl={getImageUrl} />
    
  </main>
</Layout>

<style>
  .main-content {
    max-width: 1000px;
    margin: 0 auto;
    padding: 20px;
  }
  .page-title {
    font-size: 24px;
    border-bottom: 3px solid #872732;
    padding-bottom: 10px;
    margin-bottom: 30px;
    color: #1a1a1a;
    font-weight: bold;
  }
</style>
