---
import Layout from '../../../layouts/Layout.astro';
import NewsCard from '../../../components/NewsCard.astro';

// ▼ ここを BLOG_ID_JA にしました
const BLOG_ID = import.meta.env.BLOG_ID_JA;
const API_KEY = import.meta.env.API_KEY;
const url = `https://www.googleapis.com/blogger/v3/blogs/${BLOG_ID}/posts?key=${API_KEY}&maxResults=10`;

const response = await fetch(url);
const data = await response.json();
const posts = data.items || [];
---

<Layout title="日本ニュース - 24Watchin'">
  <main>
    <h1>日本 ニュース</h1>
    <div class="news-grid">
      {posts.map((post) => (
        <NewsCard 
          id={post.id} 
          title={post.title} 
          published={post.published}
          {/* ▼ リンク先を /ja/jp/ に固定 */}
          href={`/ja/jp/news/${post.id}/`}
        />
      ))}
    </div>
  </main>
</Layout>