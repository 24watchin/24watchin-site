---
import Layout from '../../../layouts/Layout.astro';
import NewsCard from '../../../components/NewsCard.astro';

// 日本の合鍵（JA）を使用
const BLOG_ID = import.meta.env.BLOG_ID_JA;
const API_KEY = import.meta.env.API_KEY;
const url = `https://www.googleapis.com/blogger/v3/blogs/${BLOG_ID}/posts?key=${API_KEY}&maxResults=10`;

const response = await fetch(url);
const data = await response.json();
const posts = data.items || [];
---

<Layout title="日本ニュース - 24Watchin'">
  <main>
    <div class="news-grid">
      {posts.map((post) => (
        <NewsCard 
          id={post.id} 
          title={post.title} 
          published={post.published}
          {/* リンク先を ja/jp に固定 */}
          href={`/ja/jp/news/${post.id}/`}
        />
      ))}
    </div>
  </main>
</Layout>

<style>
  .news-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 24px;
    margin-top: 20px;
  }
</style>
