---
import Layout from '../../../layouts/Layout.astro';
import CategoryNews from '../../../components/CategoryNews.astro';
import MainNewsLayout from '../../../components/MainNewsLayout.astro';
import TrendScroll from '../../../components/TrendScroll.astro';
import GoogleAdBanner from '../../../components/GoogleAdBanner.astro';
import GlobalRegionNews from '../../../components/GlobalRegionNews.astro';
import { categoryLabelMap } from '../../../lib/categoryLabels';

const API_KEY = import.meta.env.API_KEY;
const BLOG_ID = import.meta.env.BLOG_ID;
const url = `https://www.googleapis.com/blogger/v3/blogs/${BLOG_ID}/posts?key=${API_KEY}&maxResults=100`;

const response = await fetch(url).catch(() => null);
const data = response ? await response.json() : { items: [] };
const allPosts = data.items || [];

const lang = 'ja';
const country = 'jp';

const isForeignPost = (post) => {
  if (!post.labels) return false;
  return post.labels.some(label => /^ja-[a-z]{2}$/.test(label) && label !== 'ja-jp');
};

const mainSitePosts = allPosts.filter(post => !isForeignPost(post));

const filterByCategory = (slug, count = 3) => {
  const catData = categoryLabelMap.jp.allCategories.find(c => c.slug === slug);
  const keywords = catData ? catData.keywords : [slug];
  return mainSitePosts.filter(post => 
    post.labels?.some(label => keywords.some(key => label.includes(key)))
  ).slice(0, count);
};
---

{/* allPosts を Layout に渡すことで、フッターに情報が伝わります */}
<Layout title="日本のニュース" allPosts={allPosts}>
  <div slot="top-full">
    <MainNewsLayout posts={mainSitePosts} />
    <TrendScroll />
  </div>

  <GoogleAdBanner position="上部" />

  <div class="genre-grid">
    <CategoryNews title="政治" slug="politics" posts={filterByCategory("politics", 3)} />
    <CategoryNews title="社会" slug="society" posts={filterByCategory("society", 3)} />
    <CategoryNews title="国際" slug="international" posts={filterByCategory("international", 3)} />
    <CategoryNews title="経済" slug="economy" posts={filterByCategory("economy", 3)} />
    <CategoryNews title="環境・エネルギー" slug="environment-energy" posts={filterByCategory("environment-energy", 3)} />
    <CategoryNews title="ビジネス" slug="business" posts={filterByCategory("business", 3)} />
    <CategoryNews title="テクノロジー・AI" slug="technology-ai" posts={filterByCategory("technology-ai", 3)} />
    <CategoryNews title="文化・エンタメ" slug="entertainment" posts={filterByCategory("entertainment", 3)} />
    <CategoryNews title="スポーツ" slug="sports" posts={filterByCategory("sports", 3)} />
    <CategoryNews title="健康・ライフ" slug="health-life" posts={filterByCategory("health-life", 3)} />
    <CategoryNews title="天気" slug="weather" posts={filterByCategory("weather", 3)} />
    <CategoryNews title="交通" slug="traffic" posts={filterByCategory("traffic", 3)} />
  </div>

  <GoogleAdBanner position="下部" />

  <div slot="bottom-wide">
    <GlobalRegionNews lang={lang} country={country} allPosts={allPosts} />
  </div>
</Layout>

<style>
  .genre-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 30px; margin-top: 20px; }
  @media (max-width: 900px) { .genre-grid { grid-template-columns: 1fr; } }
</style>
