---
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const API_KEY = import.meta.env.API_KEY;
  const BLOG_ID = import.meta.env.BLOG_ID;
  const url = `https://www.googleapis.com/blogger/v3/blogs/${BLOG_ID}/posts?key=${API_KEY}&maxResults=50`;
  const response = await fetch(url);
  const data = await response.json();
  const posts = data.items || [];

  return posts.map((post) => ({
    params: { id: post.id },
    props: { 
      post,
      recentPosts: posts.slice(0, 6)
    },
  }));
}

const { post, recentPosts } = Astro.props;

const getImageUrl = (content) => {
  const match = content.match(/<img[^>]+src="([^">]+)"/);
  return match ? match[1] : 'https://placehold.co/400x300/eeeeee/999999?text=No+Image';
};
---

<Layout title={post.title} sidebarType="article">
  <article class="post-container">
    <header class="post-header">
      <div class="post-meta">
        <span class="category-tag">ニュース</span>
        <time class="post-date">{new Date(post.published).toLocaleDateString('ja-JP')}</time>
      </div>
      <h1 class="post-title">{post.title}</h1>
      
      <div class="share-buttons">
        <span class="share-icon" style="background:#000;">X</span>
        <span class="share-icon" style="background:#1877f2;">F</span>
        <span class="share-icon" style="background:#00c300;">L</span>
      </div>
    </header>

    <div class="post-content" set:html={post.content} />
  </article>

  <div slot="bottom-wide">
    
    <div class="bottom-section">
      <h3 class="section-title">関連記事</h3>
      <div class="related-grid">
        {recentPosts.map((rp) => (
          <a href={`/news/${rp.id}/`} class="related-card">
            <div class="related-img-wrapper">
              <img src={getImageUrl(rp.content)} alt={rp.title} />
            </div>
            <div class="related-text">
              <h4>{rp.title}</h4>
              <span class="tag-link"># 関連ニュース</span>
            </div>
          </a>
        ))}
      </div>
    </div>

    <div class="editor-picks-section">
      <h3 class="section-title">編集部のおすすめ</h3>
      <div class="scroll-wrapper">
        <div class="scroll-container">
          {recentPosts.map((rp) => (
            <a href={`/news/${rp.id}/`} class="scroll-item">
              <div class="scroll-img-wrapper">
                <img src={getImageUrl(rp.content)} alt={rp.title} />
              </div>
              <div class="scroll-text">
                <h4>{rp.title}</h4>
                <span class="tag-link"># おすすめ</span>
              </div>
            </a>
          ))}
        </div>
        <div class="scroll-arrow"><i class="fas fa-chevron-right"></i></div>
      </div>
    </div>

    <div class="bottom-section sponsored-section">
      <div class="sponsored-header">
        <h3 class="section-title">あわせて読みたい</h3>
        <span class="sponsor-credit">by Taboola <i class="fas fa-caret-right"></i></span>
      </div>
      <div class="sponsored-grid">
        {[1, 2, 3, 4, 5, 6].map((item) => (
          <a href="#" class="sponsored-card">
            <div class="sponsored-img-wrapper">広告画像が入ります</div>
            <div class="sponsored-text">
              <h4>「歯を失った人は必ずやって」後悔する前に！インプラントという選択肢。</h4>
              <div class="sponsored-bottom">
                <span class="sponsor-name">あんしんインプラント</span>
                <span class="sponsor-btn">こちらをクリック</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>

  </div>
  <style>
    /* 記事上部のデザイン */
    .post-container { background: #fff; padding: 30px; border-radius: 4px; border: 1px solid #eee; margin-bottom: 40px; }
    .post-header { border-bottom: 2px solid #f4f4f4; padding-bottom: 20px; margin-bottom: 20px; }
    .post-meta { display: flex; align-items: center; gap: 15px; margin-bottom: 15px; }
    .category-tag { color: #1e3a8a; font-weight: bold; font-size: 14px; border: 1px solid #1e3a8a; padding: 2px 8px; }
    .post-date { color: #666; font-size: 14px; }
    .post-title { font-size: 28px; line-height: 1.4; margin: 0 0 15px; color: #111; }
    .share-buttons { display: flex; gap: 10px; }
    .share-icon { width: 30px; height: 30px; border-radius: 50%; color: #fff; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 14px; cursor: pointer; }

    /* 記事本文のデザイン */
    .post-content { font-size: 16px; line-height: 1.8; color: #333; margin-bottom: 50px; }
    .post-content img { max-width: 100%; height: auto; display: block; margin: 20px 0; }

    /* 共通の見出しデザイン */
    .section-title { font-size: 22px; color: #333; margin-bottom: 20px; border-bottom: 3px solid #1e3a8a; padding-bottom: 10px; display: inline-block; }
    .tag-link { font-size: 12px; color: #d97706; font-weight: bold; margin-top: 10px; display: block; }

    /* 1. 関連記事のデザイン */
    .bottom-section { margin-bottom: 50px; }
    /* ★4列（または3列）に広々と並べる設定にしています */
    .related-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 20px; }
    .related-card { text-decoration: none; color: #333; display: block; }
    .related-img-wrapper { height: 160px; overflow: hidden; background: #eee; margin-bottom: 10px; }
    .related-img-wrapper img { width: 100%; height: 100%; object-fit: cover; }
    .related-text h4 { font-size: 15px; margin: 0; line-height: 1.4; }

    /* 2. 編集部のおすすめ（横スクロール）のデザイン */
    .editor-picks-section { background: #e5e7eb; padding: 40px; margin: 0 0 50px; border-radius: 8px; }
    .scroll-wrapper { position: relative; }
    .scroll-container { display: flex; gap: 20px; overflow-x: auto; padding-bottom: 15px; scroll-snap-type: x mandatory; }
    .scroll-container::-webkit-scrollbar { display: none; } 
    .scroll-item { min-width: 280px; flex-shrink: 0; background: #fff; scroll-snap-align: start; text-decoration: none; color: #333; display: flex; flex-direction: column; border-radius: 4px; overflow: hidden; }
    .scroll-img-wrapper { height: 180px; overflow: hidden; background: #ddd; }
    .scroll-img-wrapper img { width: 100%; height: 100%; object-fit: cover; }
    .scroll-text { padding: 15px; }
    .scroll-text h4 { font-size: 16px; margin: 0; line-height: 1.4; }
    .scroll-arrow { position: absolute; right: -15px; top: 40%; transform: translateY(-50%); background: rgba(0,0,0,0.7); color: #fff; width: 45px; height: 45px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 20px; cursor: pointer; box-shadow: 0 4px 6px rgba(0,0,0,0.3); z-index: 10; }

    /* 3. あわせて読みたい（広告）のデザイン */
    .sponsored-header { display: flex; justify-content: space-between; align-items: flex-end; border-bottom: 1px solid #ddd; margin-bottom: 20px; }
    .sponsored-header .section-title { border-bottom: none; margin-bottom: 5px; padding-bottom: 0; }
    .sponsor-credit { font-size: 12px; color: #007bff; font-weight: bold; margin-bottom: 5px; }
    /* ★これも4列くらいで画面いっぱいに広がる設定です */
    .sponsored-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; }
    .sponsored-card { background: #fff; border: 1px solid #eee; text-decoration: none; color: #333; display: flex; flex-direction: column; }
    .sponsored-img-wrapper { height: 160px; background: #ddd; display: flex; align-items: center; justify-content: center; color: #999; font-size: 12px; }
    .sponsored-text { padding: 15px; flex-grow: 1; display: flex; flex-direction: column; justify-content: space-between; }
    .sponsored-text h4 { font-size: 14px; margin: 0 0 15px; line-height: 1.5; font-weight: bold; }
    .sponsored-bottom { display: flex; justify-content: space-between; align-items: center; }
    .sponsor-name { font-size: 11px; color: #888; }
    .sponsor-btn { font-size: 11px; border: 1px solid #333; padding: 2px 8px; border-radius: 2px; }

    /* スマホ画面の調整 */
    @media (max-width: 768px) {
      .post-container { padding: 15px; }
      .related-grid, .sponsored-grid { grid-template-columns: 1fr; }
      .editor-picks-section { padding: 20px 15px; }
    }
  </style>
</Layout>
