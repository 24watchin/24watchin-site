---
import DesktopView from '../components/DesktopView.astro';
import MobileView from '../components/MobileView.astro';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>24watchin | Global Gateway</title>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@300;400;600&display=swap" rel="stylesheet" />
    <style is:global>
      /* サイト全体の基本的なデザインルール */
      :root {
        --bg-color: #0d0d0d;
        --text-main: #f0f0f0;
        --font-sans: 'Noto Sans', sans-serif;
      }
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      body {
        background-color: var(--bg-color);
        color: var(--text-main);
        font-family: var(--font-sans);
        margin: 0;
      }
      body.is-locked {
        overflow: hidden; /* PC版ではスクロールをロック */
      }
      @media (max-width: 768px) {
        body.is-locked {
          overflow: auto; /* スマホ版では自由にスクロール可能にする */
        }
      }
    </style>
  </head>

  <body class="is-locked">
    <DesktopView />

    <MobileView />
  </body>
</html>
