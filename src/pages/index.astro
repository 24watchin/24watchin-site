---
// メインサイト（ルート）のページです
import RootLayout from '../layouts/RootLayout.astro';
import RootNewsBlock from '../components/RootNewsBlock.astro';
// ▼ 【追加】先ほど作った魔法の地図部品を読み込みます
import WorldMap from '../components/WorldMap.astro';
import { getCountryLabel } from '../lib/countryData.ts';
import { getBlogId } from '../lib/siteRoutes.ts';

// メインサイトは日本語を基準としてデータを取得します
const lang = 'ja'; 
const API_KEY = import.meta.env.API_KEY;
const BLOG_ID = getBlogId(lang);

// ▼ APIパンク対策の強力なキャッシュ
if (!globalThis.bloggerApiCache) {
  globalThis.bloggerApiCache = {};
}

let allPosts = [];
if (API_KEY && BLOG_ID) {
  if (!globalThis.bloggerApiCache[BLOG_ID]) {
    const url = `https://www.googleapis.com/blogger/v3/blogs/${BLOG_ID}/posts?key=${API_KEY}&maxResults=100`;
    globalThis.bloggerApiCache[BLOG_ID] = fetch(url)
      .then(res => res.ok ? res.json() : null)
      .then(data => data && data.items ? data.items : [])
      .catch(() => []);
  }
  allPosts = await globalThis.bloggerApiCache[BLOG_ID];
}

// 国ごとの記事を絞り込む関数
const filterByCountryTag = (countryCode, count = 3) => {
  const tag = `${lang}-${countryCode}`;
  return allPosts.filter(post => post.labels?.includes(tag)).slice(0, count);
};

// 地域と国のグループ設定（GlobalRegionNewsと同じ分け方です）
const regionsTemplate = [
  { key: 'asia', title: 'アジア版', cities: [
    { name: getCountryLabel('jp', lang), code: 'jp' }, { name: getCountryLabel('tw', lang), code: 'tw' },
    { name: getCountryLabel('kr', lang), code: 'kr' }, { name: getCountryLabel('sg', lang), code: 'sg' },
    { name: getCountryLabel('cn', lang), code: 'cn' }, { name: getCountryLabel('th', lang), code: 'th' },
  ]},
  { key: 'europe', title: 'ヨーロッパ版', cities: [
    { name: getCountryLabel('de', lang), code: 'de' }, { name: getCountryLabel('fr', lang), code: 'fr' },
    { name: getCountryLabel('gb', lang), code: 'gb' }, { name: getCountryLabel('it', lang), code: 'it' },
  ]},
  { key: 'americas', title: '南北アメリカ版', cities: [
    { name: getCountryLabel('us', lang), code: 'us' }, { name: getCountryLabel('ca', lang), code: 'ca' },
  ]}
];

// 記事が存在する国だけを残す処理
const activeRegions = regionsTemplate.map(region => {
  const activeCities = region.cities
    .map(city => ({ ...city, posts: filterByCountryTag(city.code) }))
    .filter(city => city.posts.length > 0);
  return { title: region.title, cities: activeCities };
}).filter(region => region.cities.length > 0);

const themeColor = '#872732'; // メインサイトのテーマカラー（赤茶）
---

<RootLayout title="24Watchin Global News | 世界のニュースをあなたに">
  <main class="root-page-container" style={`--theme-color: ${themeColor};`}>
    
    {/* ▼ 世界地図エリア（完成版） */}
    <section class="world-map-section">
      <WorldMap />
    </section>

    {/* ▼ メインニュースエリア（1大＋2小レイアウト） */}
    <section class="root-news-section">
      {activeRegions.length > 0 ? (
        activeRegions.map(region => (
          <RootNewsBlock 
            lang={lang}
            title={region.title}
            cityData={region.cities}
          />
        ))
      ) : (
        <p>記事を読み込み中です...</p>
      )}
    </section>

  </main>
</RootLayout>

<style>
  .root-page-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 0 40px 0;
  }

  .world-map-section {
    width: 100%;
    margin-bottom: 40px;
  }

  .root-news-section {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
</style>
