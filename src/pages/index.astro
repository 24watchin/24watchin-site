---
// モックアップ用データ
const latestStories = [
  { id: 1, category: 'Politics', country: 'United States', title: 'New Economic Policies Reshape the Global Market', excerpt: 'An in-depth look at the recent shifts in international trade agreements.', image: 'linear-gradient(135deg, #1a1c29 0%, #2a3b4c 100%)' },
  { id: 2, category: 'Economy', country: 'Taiwan', title: 'Tech Giants Announce Next-Generation Semiconductor', excerpt: 'Would you like to see what happened in Taiwan?', image: 'linear-gradient(135deg, #2c2519 0%, #4a3f2c 100%)' },
  { id: 3, category: 'Society', country: 'France', title: 'Urban Renewal Projects Transform Historic Districts', excerpt: 'Paris sets a new standard for eco-friendly city planning.', image: 'linear-gradient(135deg, #1d2b22 0%, #2e4436 100%)' },
  { id: 4, category: 'Environment', country: 'Brazil', title: 'Amazon Conservation Efforts Show Promising Results', excerpt: 'Deforestation rates drop as new monitoring technologies are deployed.', image: 'linear-gradient(135deg, #2b1d1d 0%, #442e2e 100%)' },
];

const languages = [
  { code: 'ja', name: '日本語', color: '#872732', url: '/ja/' },
  { code: 'en', name: 'English', color: '#1A365D', url: '/en/' },
  { code: 'zh-cn', name: '简体中文', color: '#C53030', url: '/zh-cn/' },
  { code: 'zh-tw', name: '繁體中文', color: '#2C5282', url: '/zh-tw/' },
  { code: 'es', name: 'Español', color: '#B7791F', url: '/es/' },
  { code: 'fr', name: 'Français', color: '#2B6CB0', url: '/fr/' },
  { code: 'de', name: 'Deutsch', color: '#276749', url: '/de/' },
  { code: 'ru', name: 'Русский', color: '#744210', url: '/ru/' },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>24watchin | Global Gateway</title>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@300;400;600&display=swap" rel="stylesheet">
  </head>
  <body class="no-scroll-body">

    <header class="global-header" id="main-header">
      <div class="header-band">
        <div class="logo-area">
          <img src="/images/24Watchin-white.png" alt="24Watchin Logo" class="header-logo-img" />
        </div>
        <button class="menu-trigger" id="menu-open">
          <span class="burger-line"></span>
          <span class="burger-line"></span>
          <span class="burger-line"></span>
        </button>
      </div>
    </header>

    <nav class="side-menu" id="side-menu">
      <button class="menu-close" id="menu-close">&times;</button>
      <div class="menu-inner">
        <h3>CHOOSE YOUR LANGUAGE</h3>
        <div class="menu-grid">
          {languages.map(lang => (
            <a href={lang.url} class="menu-lang-card" style={`--accent: ${lang.color}`}>
              <span class="lang-name">{lang.name}</span>
            </a>
          ))}
        </div>
      </div>
    </nav>

    <main class="gateway-main" id="main-scroll">
      
      <div class="desktop-split-wrapper">
        <div class="sticky-view">
          
          <div class="left-track track">
            <div class="panel p1">
              <div class="bg-layer" style="background-image: url('/images/conflict.jpg');"></div>
              <div class="word-band-container"><div class="word-band"><h2>CONFLICT</h2></div></div>
            </div>
            <div class="panel p2">
              <div class="bg-layer" style="background-image: url('/images/cities.jpg');"></div>
              <div class="word-band-container"><div class="word-band"><h2>CITIES</h2></div></div>
            </div>
            <div class="panel p3">
              <div class="bg-layer" style="background-image: url('/images/innovation.jpg');"></div>
              <div class="word-band-container"><div class="word-band"><h2>INNOVATION</h2></div></div>
            </div>
          </div>
          
          <div class="right-track track">
            <div class="panel p1">
              <div class="bg-layer" style="background-image: url('/images/crisis.png');"></div>
              <div class="word-band-container"><div class="word-band"><h2>CRISIS</h2></div></div>
            </div>
            <div class="panel p2">
              <div class="bg-layer" style="background-image: url('/images/people.webp');"></div>
              <div class="word-band-container"><div class="word-band"><h2>PEOPLE</h2></div></div>
            </div>
            <div class="panel p3">
              <div class="bg-layer" style="background-image: url('/images/frontier.jpg');"></div>
              <div class="word-band-container"><div class="word-band"><h2>FRONTIER</h2></div></div>
            </div>
          </div>
        </div>

        <div class="scroll-blocks">
          <div class="snap-point"></div>
          <div class="snap-point"></div>
          <div class="snap-point"></div>
        </div>
      </div>

      <div class="mobile-stack-wrapper">
        {['conflict.jpg', 'crisis.png', 'cities.jpg', 'people.webp', 'innovation.jpg', 'frontier.jpg'].map((img, i) => (
          <div class="mobile-panel observer-mobile snap-point">
            <div class="bg-layer" style={`background-image: url('/images/${img}');`}></div>
            <div class="dark-overlay"></div>
            <div class="word-band-container"><div class="word-band"><h2>{['CONFLICT', 'CRISIS', 'CITIES', 'PEOPLE', 'INNOVATION', 'FRONTIER'][i]}</h2></div></div>
          </div>
        ))}
      </div>

      <section class="brand-section snap-point" id="screen-4">
        <div class="brand-bg" style="background-image: url('/images/explanation.png');"></div>
        <div class="brand-bg-overlay"></div>
        <div class="brand-content observer-target">
          <h1 class="brand-logo fade-item">24watchin</h1>
          <h2 class="brand-catch fade-item">Watch the world with clarity.</h2>
          <div class="brand-desc fade-item">
            <p>Global news. Explained clearly. In your language.</p>
          </div>
        </div>
      </section>

      <section class="carousel-section snap-point" id="screen-5">
        <div class="section-header">
          <h2>Latest Stories</h2>
        </div>
        <div class="carousel-container" id="story-carousel">
          <div class="carousel-spacer"></div>
          {latestStories.map((story) => (
            <a href={`/en/story/${story.id}`} class="story-card observer-card">
              <div class="card-bg" style={`background: ${story.image};`}></div>
              <div class="card-content">
                <div class="card-meta"><span class="category">{story.category}</span><span class="country">{story.country}</span></div>
                <h3 class="card-title">{story.title}</h3>
                <p class="card-excerpt">{story.excerpt}</p>
                <div class="cta-link">Read story <span>&rarr;</span></div>
              </div>
            </a>
          ))}
          <div class="carousel-spacer"></div>
        </div>
      </section>

      <section class="carousel-section lang-section snap-point" id="screen-6">
        <div class="section-header">
          <h2>CHOOSE YOUR LANGUAGE</h2>
          <p class="sub-header">Check the news in your own language.</p>
        </div>
        <div class="carousel-container" id="lang-carousel">
          <div class="carousel-spacer"></div>
          {languages.map((lang) => (
            <a href={lang.url} class="lang-card observer-card">
              <div class="lang-bg" style={`background-color: ${lang.color};`}>
                <div class="map-pattern"></div>
              </div>
              <div class="lang-content">
                <div class="lang-logo">24watchin</div>
                <h3 class="lang-name">{lang.name}</h3>
                <div class="lang-border"></div>
              </div>
            </a>
          ))}
          <div class="carousel-spacer"></div>
        </div>
      </section>

      <footer class="snap-point" style="height: 300px; display: flex; align-items: center; justify-content: center; background: #0a0a0a; border-top: 1px solid #333;">
        <p style="color: #666; font-size: 14px;">[ 既存のフッター領域（国リンクボタン等） ]</p>
      </footer>

    </main>

    <style>
      :root { --bg-color: #0d0d0d; --text-main: #f0f0f0; --font-sans: 'Noto Sans', sans-serif; }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      
      /* スクロールの土台設定 */
      .no-scroll-body { background-color: var(--bg-color); color: var(--text-main); font-family: var(--font-sans); overflow: hidden; height: 100vh; width: 100vw; }
      .gateway-main { height: 100vh; overflow-y: scroll; scroll-snap-type: y mandatory; scroll-behavior: smooth; }
      .snap-point { scroll-snap-align: start; width: 100%; }

      /* ヘッダー */
      .global-header { position: fixed; top: 0; left: 0; width: 100%; z-index: 200; transition: opacity 0.5s; }
      .header-band { display: flex; justify-content: space-between; align-items: center; padding: 20px 50px; background: rgba(0,0,0,0.6); backdrop-filter: blur(10px); }
      .header-logo-img { height: 32px; width: auto; }
      .menu-trigger { background: none; border: none; cursor: pointer; display: flex; flex-direction: column; gap: 6px; }
      .burger-line { width: 30px; height: 2px; background: #fff; border-radius: 2px; }

      /* サイドメニュー */
      .side-menu { position: fixed; top: 0; right: -100%; width: 100%; height: 100%; background: rgba(10,10,10,0.95); z-index: 300; transition: right 0.6s cubic-bezier(0.2, 0.8, 0.2, 1); padding: 80px 40px; display: flex; justify-content: center; }
      .side-menu.is-open { right: 0; }
      .menu-close { position: absolute; top: 30px; right: 40px; font-size: 40px; background: none; border: none; color: #fff; cursor: pointer; }
      .menu-inner { max-width: 1000px; width: 100%; text-align: center; }
      .menu-inner h3 { font-size: 14px; letter-spacing: 4px; margin-bottom: 50px; color: #888; }
      .menu-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; }
      .menu-lang-card { padding: 40px; border: 1px solid rgba(255,255,255,0.1); border-radius: 4px; transition: 0.3s; background: linear-gradient(135deg, rgba(255,255,255,0.05) 0%, transparent 100%); text-decoration: none; color: white;}
      .menu-lang-card:hover { border-color: var(--accent); transform: translateY(-5px); }

      /* PCスプリットスクロール（抜けていた高さを追加しました！） */
      .desktop-split-wrapper { position: relative; height: 300vh; }
      .sticky-view { position: sticky; top: 0; height: 100vh; display: flex; overflow: hidden; }
      .scroll-blocks { position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; display: flex; flex-direction: column; }
      .scroll-blocks .snap-point { height: 100vh; }
      
      .track { width: 50vw; height: 100vh; position: relative; }
      .panel { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; overflow: hidden; }
      
      /* 画像の重なり順と初期の隠し方 */
      .left-track .p1 { clip-path: inset(0 0 0 0); z-index: 1; }
      .left-track .p2 { clip-path: inset(100% 0 0 0); z-index: 2; }
      .left-track .p3 { clip-path: inset(100% 0 0 0); z-index: 3; }

      .right-track .p1 { clip-path: inset(0 0 0 0); z-index: 1; }
      .right-track .p2 { clip-path: inset(0 0 100% 0); z-index: 2; }
      .right-track .p3 { clip-path: inset(0 0 100% 0); z-index: 3; }

      .bg-layer { position: absolute; inset: 0; background-size: cover; background-position: center; }

      /* 文字の黒い座布団とスライドアニメーション */
      .word-band-container { 
        position: absolute; top: 50%; left: 50%; 
        transform: translate(-50%, -50%); 
        overflow: hidden; 
        z-index: 10;
      }
      .word-band { 
        background: rgba(0,0,0,0.6); backdrop-filter: blur(8px);
        padding: 15px 50px; border-radius: 4px;
        transition: transform 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
      }
      .word-band h2 { color: #fff; font-weight: 300; font-size: clamp(2rem, 4vw, 3rem); letter-spacing: 0.15em; margin: 0; text-shadow: 0 2px 10px rgba(0,0,0,0.5); }
      
      .left-track .word-band { transform: translateX(-101%); }
      .right-track .word-band { transform: translateX(101%); }
      .panel.is-active .word-band { transform: translateX(0); transition-delay: 0.4s; }

      /* スマホ用 */
      @media (max-width: 768px) {
        .desktop-split-wrapper { display: none; }
        .mobile-stack-wrapper { display: block; }
        .mobile-panel { height: 100vh; position: relative; display: flex; align-items: center; justify-content: center; overflow: hidden; }
        .mobile-panel .bg-layer { opacity: 0; transform: scale(1.1); transition: 1.5s; }
        .mobile-panel.is-visible .bg-layer { opacity: 1; transform: scale(1); }
        .dark-overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.3); }
        
        .mobile-panel .word-band-container { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); overflow: hidden; }
        .mobile-panel .word-band { transform: translateY(100%); transition: transform 0.8s ease; }
        .mobile-panel.is-visible .word-band { transform: translateY(0); transition-delay: 0.5s; }
        
        .header-band { padding: 15px 20px; }
      }

      /* 4画面目以降 */
      .brand-section { height: 100vh; position: relative; display: flex; align-items: center; justify-content: center; text-align: center; }
      .brand-bg { position: absolute; inset: 0; background-size: cover; background-position: center; opacity: 0.5; }
      .brand-bg-overlay { position: absolute; inset: 0; background: radial-gradient(circle, transparent 0%, #000 100%); }
      .brand-content { position: relative; z-index: 3; }
      .brand-logo { font-size: 2rem; color: #888; margin-bottom: 20px; }
      .brand-catch { font-size: 3rem; margin-bottom: 30px; text-shadow: 0 4px 20px rgba(0,0,0,0.8); }
      .fade-item { opacity: 0; transform: translateY(20px); transition: 1s; }
      .observer-target.is-visible .fade-item { opacity: 1; transform: translateY(0); }

      .carousel-section { display: flex; flex-direction: column; justify-content: center; padding: 100px 0; min-height: 100vh; }
      .section-header { text-align: center; margin-bottom: 60px; padding: 0 20px; }
      .section-header h2 { font-size: 14px; letter-spacing: 3px; text-transform: uppercase; color: #888; font-weight: 600; }
      .section-header .sub-header { margin-top: 12px; font-size: 18px; font-weight: 300; color: #ddd; }
      .carousel-container { display: flex; overflow-x: auto; scroll-snap-type: x mandatory; scroll-behavior: smooth; padding-bottom: 40px; align-items: center; -ms-overflow-style: none; scrollbar-width: none; }
      .carousel-container::-webkit-scrollbar { display: none; }
      .carousel-spacer { flex: 0 0 calc(50vw - 20vw); }
      .observer-card { scroll-snap-align: center; flex: 0 0 40vw; height: 60vh; margin: 0 1.5vw; position: relative; border-radius: 4px; overflow: hidden; transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1), opacity 0.6s ease; opacity: 0.4; transform: scale(0.85); display: block; }
      .observer-card.is-center { opacity: 1; transform: scale(1); box-shadow: 0 20px 50px rgba(0,0,0,0.5); z-index: 10; }
      .story-card .card-bg { position: absolute; inset: 0; background-size: cover; background-position: center; transition: transform 0.8s ease; }
      .story-card.is-center:hover .card-bg { transform: scale(1.05); }
      .story-card::after { content: ''; position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.2) 50%, rgba(0,0,0,0) 100%); }
      .card-content { position: absolute; bottom: 0; left: 0; width: 100%; padding: 40px; z-index: 2; display: flex; flex-direction: column; justify-content: flex-end; height: 100%; }
      .card-meta { display: flex; gap: 12px; margin-bottom: 16px; font-size: 12px; font-weight: 600; letter-spacing: 1px; text-transform: uppercase; }
      .card-meta .category { color: #fff; border-bottom: 1px solid rgba(255,255,255,0.4); padding-bottom: 4px; }
      .card-meta .country { color: #888; }
      .card-title { font-size: clamp(1.2rem, 2vw, 2rem); font-weight: 400; line-height: 1.3; margin-bottom: 16px; }
      .card-excerpt { font-size: 14px; color: #ccc; margin-bottom: 24px; display: none; line-height: 1.5; }
      .story-card.is-center .card-excerpt { display: block; }
      .cta-link { font-size: 12px; text-transform: uppercase; letter-spacing: 1px; color: #fff; display: flex; align-items: center; gap: 8px; opacity: 0; transform: translateY(10px); transition: all 0.4s ease; }
      .story-card.is-center .cta-link { opacity: 1; transform: translateY(0); }

      .lang-card { flex: 0 0 28vw; height: 50vh; display: flex; align-items: center; justify-content: center; border: 1px solid rgba(255,255,255,0.05); }
      .lang-bg { position: absolute; inset: 0; opacity: 0.15; transition: opacity 0.4s ease; }
      .lang-card.is-center .lang-bg { opacity: 0.8; }
      .map-pattern { position: absolute; inset: 0; background-image: radial-gradient(rgba(255,255,255,0.1) 1px, transparent 1px); background-size: 20px 20px; opacity: 0.5; }
      .lang-content { position: relative; z-index: 2; width: 100%; height: 100%; padding: 40px; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; }
      .lang-logo { position: absolute; bottom: 30px; left: 30px; font-size: 12px; letter-spacing: 2px; opacity: 0.5; }
      .lang-name { font-size: clamp(1.5rem, 3vw, 2.5rem); font-weight: 300; letter-spacing: 0.05em; transition: transform 0.4s ease; color: #fff; }
      .lang-border { width: 0; height: 1px; background: #fff; margin-top: 20px; transition: width 0.6s cubic-bezier(0.2, 0.8, 0.2, 1); opacity: 0.5; }
      .lang-card.is-center .lang-border { width: 40px; }
      .lang-card.is-center:hover .lang-name { transform: scale(1.05); }
    </style>

    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const mainScroll = document.getElementById('main-scroll');
        const header = document.getElementById('main-header');
        
        const l1 = document.querySelector('.left-track .p1');
        const l2 = document.querySelector('.left-track .p2');
        const l3 = document.querySelector('.left-track .p3');
        const r1 = document.querySelector('.right-track .p1');
        const r2 = document.querySelector('.right-track .p2');
        const r3 = document.querySelector('.right-track .p3');
        const allPanels = document.querySelectorAll('.desktop-split-wrapper .panel');

        // 最初は1組目の文字を表示
        if(l1 && r1) {
          l1.classList.add('is-active');
          r1.classList.add('is-active');
        }

        // スクロール時の処理
        mainScroll.addEventListener('scroll', () => {
          if (window.innerWidth <= 768) return;

          const scrollTop = mainScroll.scrollTop;
          const vh = window.innerHeight;
          const progress = scrollTop / vh; 

          // 2組目の画像をめくる
          let p2 = Math.max(0, Math.min(1, progress));
          if(l2) l2.style.clipPath = `inset(${100 - (p2 * 100)}% 0 0 0)`;
          if(r2) r2.style.clipPath = `inset(0 0 ${100 - (p2 * 100)}% 0)`;

          // 3組目の画像をめくる
          let p3 = Math.max(0, Math.min(1, progress - 1));
          if(l3) l3.style.clipPath = `inset(${100 - (p3 * 100)}% 0 0 0)`;
          if(r3) r3.style.clipPath = `inset(0 0 ${100 - (p3 * 100)}% 0)`;

          // ピタッと止まったら文字を出す
          allPanels.forEach(p => p.classList.remove('is-active'));
          
          if (progress < 0.15) {
            l1.classList.add('is-active'); r1.classList.add('is-active');
          } else if (progress > 0.85 && progress < 1.15) {
            l2.classList.add('is-active'); r2.classList.add('is-active');
          } else if (progress > 1.85 && progress < 2.15) {
            l3.classList.add('is-active'); r3.classList.add('is-active');
          }

          // 1組目から離れたらヘッダーを消す
          if (progress > 0.5) {
            header.style.opacity = '0';
            header.style.pointerEvents = 'none';
          } else {
            header.style.opacity = '1';
            header.style.pointerEvents = 'auto';
          }
        });

        // メニューの開閉
        const sideMenu = document.getElementById('side-menu');
        document.getElementById('menu-open').onclick = () => sideMenu.classList.add('is-open');
        document.getElementById('menu-close').onclick = () => sideMenu.classList.remove('is-open');

        // アニメーション用のセンサー
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(en => { if(en.isIntersecting) en.target.classList.add('is-visible'); });
        }, { threshold: 0.3 });
        document.querySelectorAll('.observer-mobile, .observer-target').forEach(el => observer.observe(el));

        const carouselObserver = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) entry.target.classList.add('is-center');
            else entry.target.classList.remove('is-center');
          });
        }, { root: null, rootMargin: "0px -40% 0px -40%", threshold: 0 });
        document.querySelectorAll('.observer-card').forEach(card => carouselObserver.observe(card));
      });
    </script>
  </body>
</html>
