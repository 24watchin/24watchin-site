---
import DesktopView from '../components/DesktopView.astro';
import MobileView from '../components/MobileView.astro';
import CookieBanner from '../components/CookieBanner.astro';
import { getBlogId } from '../lib/siteRoutes.ts';

const API_KEY = import.meta.env.API_KEY;
const BLOG_ID = getBlogId('en');

const cacheKey = 'bloggerPostsCache_top_en';
let englishPosts = [];

// ✅ API_KEYとBLOG_IDの確認を先に行い、その中でfetchします
// ✅ { cache: 'no-store' } と nocache を削除しました（Node.js 22で誤動作する原因）
if (API_KEY && BLOG_ID) {
  if (!globalThis[cacheKey]) {
    const url = `https://www.googleapis.com/blogger/v3/blogs/${BLOG_ID}/posts?key=${API_KEY}&maxResults=20`;
    globalThis[cacheKey] = fetch(url)
      .then(res => res.ok ? res.json() : null)
      .then(data => data && data.items ? data.items : [])
      .catch(() => []);
  }
  englishPosts = await globalThis[cacheKey];
}

const topStories = englishPosts;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>24watchin | Global Gateway</title>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@300;400;600&display=swap" rel="stylesheet" />
    <style is:global>
      :root { --bg-color: #0d0d0d; --text-main: #f0f0f0; --font-sans: 'Noto Sans', sans-serif; }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body { background-color: var(--bg-color); color: var(--text-main); font-family: var(--font-sans); margin: 0; }
      body.is-locked { overflow: hidden; }
      @media (max-width: 768px) { body.is-locked { overflow: auto; } }
    </style>
  </head>

  <body class="is-locked">
    <DesktopView latestStories={topStories} />
    <MobileView latestStories={topStories} />
    <CookieBanner />
  </body>
</html>
