---
// モックアップ用データ
const latestStories = [
  {
    id: 1,
    category: 'Politics',
    country: 'Japan',
    title: 'New Semiconductor Hub Opens in Hokkaido, Boosting Local Tech Industry',
    excerpt: 'The government aims to revitalize the regional economy with a multi-billion yen investment in chip manufacturing.',
    image: 'url("https://images.unsplash.com/photo-1518770660439-4636190af475?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80")'
  },
  {
    id: 2,
    category: 'Economy',
    country: 'United States',
    title: 'Federal Reserve Signals Potential Rate Cuts by Year-End',
    excerpt: 'Market rallies as inflation data shows signs of cooling off for the third consecutive month.',
    image: 'url("https://images.unsplash.com/photo-1611974789855-9c2a0a7236a3?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80")'
  },
  {
    id: 3,
    category: 'Society',
    country: 'France',
    title: 'Paris Sets New Standard for Eco-Friendly Urban Planning',
    excerpt: 'Historic districts are being transformed with green roofs and pedestrian-only zones.',
    image: 'url("https://images.unsplash.com/photo-1499856871958-5b9627545d1a?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80")'
  },
  {
    id: 4,
    category: 'Environment',
    country: 'Brazil',
    title: 'Amazon Conservation Efforts Show Promising Results This Quarter',
    excerpt: 'Deforestation rates drop significantly as new AI monitoring technologies are deployed across the rainforest.',
    image: 'url("https://images.unsplash.com/photo-1516026672322-bc52d61a55d5?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80")'
  },
  {
    id: 5,
    category: 'Technology',
    country: 'South Korea',
    title: 'Breakthrough in Solid-State Battery Tech Announced in Seoul',
    excerpt: 'Researchers unveil a new prototype that could double the range of current electric vehicles.',
    image: 'url("https://images.unsplash.com/photo-1526628953301-3e589a6a8b74?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80")'
  },
];

const languages = [
  { code: 'ja', name: '日本語', color: '#872732', url: '/ja/' },
  { code: 'en', name: 'English', color: '#1A365D', url: '/en/' },
  { code: 'zh-cn', name: '简体中文', color: '#C53030', url: '/zh-cn/' },
  { code: 'zh-tw', name: '繁體中文', color: '#2C5282', url: '/zh-tw/' },
  { code: 'es', name: 'Español', color: '#B7791F', url: '/es/' },
  { code: 'fr', name: 'Français', color: '#2B6CB0', url: '/fr/' },
  { code: 'de', name: 'Deutsch', color: '#276749', url: '/de/' },
  { code: 'ru', name: 'Русский', color: '#744210', url: '/ru/' },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>24watchin | Global Gateway</title>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@300;400;600&display=swap" rel="stylesheet" />
  </head>

  <body class="is-locked">
    <header class="global-header">
      <div class="header-band">
        <div class="logo-area">
          <a href="https://24watchin.com">
            <img src="/images/24Watchin-white.png" alt="24Watchin Logo" class="header-logo-img" />
          </a>
        </div>

        <button class="menu-trigger" id="menu-open" aria-label="Open menu">
          <span class="burger-line"></span>
          <span class="burger-line"></span>
          <span class="burger-line"></span>
        </button>
      </div>
    </header>

    <nav class="side-menu" id="side-menu">
      <button class="menu-close" id="menu-close" aria-label="Close menu">&times;</button>
      <div class="menu-inner">
        <h3>CHOOSE YOUR LANGUAGE</h3>
        <div class="menu-grid">
          {languages.map((lang) => (
            <a href={lang.url} class="menu-lang-card" style={`--accent: ${lang.color}`}>
              <span class="lang-name">{lang.name}</span>
            </a>
          ))}
        </div>
      </div>
    </nav>

    <div class="scroll-indicator" id="scroll-indicator">
      <div class="dot active"></div>
      <div class="dot"></div>
      <div class="dot"></div>
      <div class="dot"></div>
      <div class="dot"></div>
      <div class="dot"></div>
    </div>

    <!-- 4→5 / 5→4 用の幕 -->
    <div class="transition-mask" id="transition-mask" aria-hidden="true"></div>

    <!-- 5→6 用のライン -->
    <div class="line-wipe" id="line-wipe" aria-hidden="true"></div>

    <main class="gateway-main">
      <!-- 1〜4画面目は同じ固定ステージ -->
      <div class="desktop-sequence" id="desktop-sequence">
        <div class="split-stage">
          <div class="left-track">
            <div class="panel p1">
              <div class="bg-layer" style="background-image: url('/images/conflict.jpg');"></div>
              <div class="word-band-container">
                <div class="word-band"><h2>CONFLICT</h2></div>
              </div>
            </div>

            <div class="panel p2">
              <div class="bg-layer" style="background-image: url('/images/cities.webp');"></div>
              <div class="word-band-container">
                <div class="word-band"><h2>CITIES</h2></div>
              </div>
            </div>

            <div class="panel p3">
              <div class="bg-layer" style="background-image: url('/images/innovation.jpg');"></div>
              <div class="word-band-container">
                <div class="word-band"><h2>INNOVATION</h2></div>
              </div>
            </div>
          </div>

          <div class="right-track">
            <div class="panel p1">
              <div class="bg-layer" style="background-image: url('/images/crisis.png');"></div>
              <div class="word-band-container">
                <div class="word-band"><h2>CRISIS</h2></div>
              </div>
            </div>

            <div class="panel p2">
              <div class="bg-layer" style="background-image: url('/images/people.webp');"></div>
              <div class="word-band-container">
                <div class="word-band"><h2>PEOPLE</h2></div>
              </div>
            </div>

            <div class="panel p3">
              <div class="bg-layer" style="background-image: url('/images/frontier.jpg');"></div>
              <div class="word-band-container">
                <div class="word-band"><h2>FRONTIER</h2></div>
              </div>
            </div>
          </div>
        </div>

        <section class="brand-panel" id="brand-panel">
          <div class="brand-night"></div>
          <div class="brand-bg" style="background-image: url('/images/explanation.png');"></div>
          <div class="brand-bg-overlay"></div>

          <div class="brand-content text-anim-target" id="brand-text-target">
            <img src="/images/24Watchin-white.png" alt="24Watchin Logo" class="brand-logo-img fade-base fade-up anim-logo" />
            <h2 class="brand-catch fade-base fade-up anim-catch">Watch the world with clarity.</h2>

            <div class="brand-desc">
              <p class="fade-base fade-left anim-desc1">Global news.</p>
              <p class="fade-base fade-left anim-desc2">Explained clearly.</p>
              <p class="fade-base fade-left anim-desc3">In your language.</p>
            </div>
          </div>
        </section>
      </div>

      <!-- 固定ステージの下敷き -->
      <section class="hero-spacer" aria-hidden="true">
        <div class="hero-spacer-brand">
          <div class="hero-spacer-bg" style="background-image: url('/images/explanation.png');"></div>
          <div class="hero-spacer-bg-overlay"></div>
        </div>
      </section>

      <div class="mobile-only-area">
        <div class="mobile-placeholder">
          <p>スマホ版は準備中です</p>
        </div>
      </div>

      <section class="carousel-section section-observer" id="screen-5">
        <div class="section-fade-in">
          <div class="section-header">
            <h2>Latest Stories</h2>
          </div>

          <div class="carousel-wrapper">
            <button class="nav-arrow left-arrow" aria-label="Previous">&larr;</button>

            <div class="carousel-container" id="story-carousel">
              <div class="carousel-spacer"></div>

              {latestStories.map((story) => (
                <a href={`/en/story/${story.id}`} class="story-card observer-card">
                  <div class="card-bg" style={`background-image: ${story.image};`}></div>
                  <div class="card-content">
                    <div class="card-meta">
                      <span class="category">{story.category}</span>
                      <span class="country">{story.country}</span>
                    </div>
                    <h3 class="card-title">{story.title}</h3>
                    <p class="card-excerpt">{story.excerpt}</p>
                    <div class="cta-link">Read story <span>&rarr;</span></div>
                  </div>
                </a>
              ))}

              <div class="carousel-spacer"></div>
            </div>

            <button class="nav-arrow right-arrow" aria-label="Next">&rarr;</button>
          </div>
        </div>
      </section>

      <section class="carousel-section lang-section section-observer" id="screen-6">
        <div class="section-fade-in">
          <div class="section-header">
            <h2>CHOOSE YOUR LANGUAGE</h2>
          </div>

          <div class="carousel-wrapper">
            <button class="nav-arrow left-arrow" aria-label="Previous">&larr;</button>

            <div class="carousel-container" id="lang-carousel">
              <div class="carousel-spacer"></div>

              {languages.map((lang) => (
                <a href={lang.url} class="lang-card observer-card">
                  <div class="lang-bg" style={`background-color: ${lang.color};`}></div>
                  <div class="lang-content">
                    <div class="lang-logo">24watchin</div>
                    <h3 class="lang-name">{lang.name}</h3>
                    <div class="lang-border"></div>
                  </div>
                </a>
              ))}

              <div class="carousel-spacer"></div>
            </div>

            <button class="nav-arrow right-arrow" aria-label="Next">&rarr;</button>
          </div>
        </div>
      </section>

      <footer class="site-footer">
        <p>[ フッター領域 ]</p>
      </footer>
    </main>

    <style>
      :root {
        --bg-color: #0d0d0d;
        --text-main: #f0f0f0;
        --font-sans: 'Noto Sans', sans-serif;
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        background-color: var(--bg-color);
        color: var(--text-main);
        font-family: var(--font-sans);
        margin: 0;
      }

      body.is-locked {
        overflow: hidden;
      }

      .global-header {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        z-index: 300;
        pointer-events: none;
      }

      .header-band {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 30px 50px;
        background: linear-gradient(to bottom, rgba(0, 0, 0, 0.85) 0%, rgba(0, 0, 0, 0) 100%);
        pointer-events: auto;
      }

      .logo-area a {
        text-decoration: none;
        outline: none;
      }

      .header-logo-img {
        height: 48px;
        width: auto;
        transition: opacity 0.3s ease;
      }

      .header-logo-img:hover {
        opacity: 0.8;
      }

      .menu-trigger {
        background: none;
        border: none;
        cursor: pointer;
        display: flex;
        flex-direction: column;
        gap: 6px;
      }

      .burger-line {
        width: 30px;
        height: 2px;
        background: #fff;
        border-radius: 2px;
      }

      .side-menu {
        position: fixed;
        top: 0;
        right: -100%;
        width: 100%;
        height: 100%;
        background: rgba(10, 10, 10, 0.98);
        z-index: 400;
        transition: right 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
        padding: 80px 40px;
        display: flex;
        justify-content: center;
      }

      .side-menu.is-open {
        right: 0;
      }

      .menu-close {
        position: absolute;
        top: 30px;
        right: 40px;
        font-size: 40px;
        background: none;
        border: none;
        color: #fff;
        cursor: pointer;
      }

      .menu-inner {
        max-width: 1000px;
        width: 100%;
        text-align: center;
      }

      .menu-inner h3 {
        font-size: 14px;
        letter-spacing: 4px;
        margin-bottom: 50px;
        color: #888;
      }

      .menu-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
      }

      .menu-lang-card {
        padding: 40px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 4px;
        transition: 0.3s;
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.05) 0%, transparent 100%);
        text-decoration: none;
        color: white;
      }

      .menu-lang-card:hover {
        border-color: var(--accent);
        transform: translateY(-5px);
      }

      .scroll-indicator {
        position: fixed;
        top: 75%;
        right: 25px;
        transform: translateY(-50%);
        display: flex;
        flex-direction: column;
        gap: 12px;
        z-index: 500;
      }

      .scroll-indicator .dot {
        width: 6px;
        height: 6px;
        border-radius: 4px;
        background: rgba(255, 255, 255, 0.3);
        transition: all 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
      }

      .scroll-indicator .dot.active {
        height: 32px;
        background: rgba(255, 255, 255, 0.9);
      }

      .transition-mask {
        position: fixed;
        inset: 0;
        z-index: 220;
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
        background:
          radial-gradient(circle at 50% 38%, rgba(33, 76, 160, 0.14) 0%, rgba(17, 36, 82, 0.30) 26%, rgba(7, 15, 40, 0.70) 60%, rgba(4, 8, 24, 0.94) 100%),
          linear-gradient(to bottom, rgba(8, 18, 48, 0.34) 0%, rgba(5, 12, 32, 0.86) 100%);
        transition: opacity 0.34s cubic-bezier(0.2, 0.8, 0.2, 1), visibility 0s linear 0.34s;
      }

      .transition-mask.is-visible {
        opacity: 1;
        visibility: visible;
        transition: opacity 0.34s cubic-bezier(0.2, 0.8, 0.2, 1);
      }

      /* ===== 5→6 ライン演出 ===== */
      .line-wipe {
        position: fixed;
        top: 50%;
        left: 0;
        width: 0;
        height: 1px;
        background: rgba(255, 255, 255, 0.7);
        z-index: 230;
        transform: translateY(-50%);
        box-shadow: 0 0 8px rgba(255, 255, 255, 0.4);
        transition: none;
        pointer-events: none;
      }

      .line-wipe.is-running {
        width: 100vw;
        transition: width 0.65s cubic-bezier(0.4, 0, 0.2, 1);
      }

      .line-wipe.is-fading {
        opacity: 0;
        transition: opacity 0.3s ease;
      }

      .desktop-sequence {
        position: fixed;
        inset: 0;
        z-index: 120;
        opacity: 1;
        visibility: visible;
        transition: opacity 0.32s ease, visibility 0s linear 0s;
      }

      .desktop-sequence.is-hidden {
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
        transition: opacity 0.28s ease, visibility 0s linear 0.28s;
      }

      .hero-spacer {
        height: 100vh;
        position: relative;
        overflow: hidden;
        background: #050b18;
      }

      .hero-spacer-brand {
        position: absolute;
        inset: 0;
      }

      .hero-spacer-bg {
        position: absolute;
        inset: 0;
        background-size: cover;
        background-position: center;
        opacity: 0.96;
      }

      .hero-spacer-bg-overlay {
        position: absolute;
        inset: 0;
        background: radial-gradient(circle, rgba(0, 0, 0, 0.1) 0%, rgba(0, 0, 0, 0.62) 100%);
      }

      .split-stage {
        position: absolute;
        inset: 0;
        display: flex;
      }

      .left-track,
      .right-track {
        width: 50vw;
        height: 100vh;
        position: relative;
      }

      .panel {
        position: absolute;
        inset: 0;
        overflow: hidden;
      }

      .bg-layer {
        position: absolute;
        inset: 0;
        background-size: cover;
        background-position: center;
      }

      .left-track .p1 { z-index: 1; }
      .left-track .p2 {
        z-index: 2;
        clip-path: inset(100% 0 0 0);
        -webkit-clip-path: inset(100% 0 0 0);
        transition: clip-path 1.5s cubic-bezier(0.64, 0.04, 0.35, 1), -webkit-clip-path 1.5s cubic-bezier(0.64, 0.04, 0.35, 1);
      }
      .left-track .p3 {
        z-index: 3;
        clip-path: inset(100% 0 0 0);
        -webkit-clip-path: inset(100% 0 0 0);
        transition: clip-path 1.5s cubic-bezier(0.64, 0.04, 0.35, 1), -webkit-clip-path 1.5s cubic-bezier(0.64, 0.04, 0.35, 1);
      }

      .right-track .p1 { z-index: 1; }
      .right-track .p2 {
        z-index: 2;
        clip-path: inset(0 0 100% 0);
        -webkit-clip-path: inset(0 0 100% 0);
        transition: clip-path 1.5s cubic-bezier(0.64, 0.04, 0.35, 1), -webkit-clip-path 1.5s cubic-bezier(0.64, 0.04, 0.35, 1);
      }
      .right-track .p3 {
        z-index: 3;
        clip-path: inset(0 0 100% 0);
        -webkit-clip-path: inset(0 0 100% 0);
        transition: clip-path 1.5s cubic-bezier(0.64, 0.04, 0.35, 1), -webkit-clip-path 1.5s cubic-bezier(0.64, 0.04, 0.35, 1);
      }

      .panel.is-open {
        clip-path: inset(0 0 0 0) !important;
        -webkit-clip-path: inset(0 0 0 0) !important;
      }

      .word-band-container {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        z-index: 10;
        overflow: hidden;
      }

      .left-track .word-band-container {
        left: 0;
      }

      .right-track .word-band-container {
        right: 0;
      }

      .word-band {
        background: rgba(255, 255, 255, 0.35);
        backdrop-filter: blur(12px);
        padding: 15px 50px;
        display: flex;
        align-items: center;
        transition: transform 1.2s cubic-bezier(0.2, 0.8, 0.2, 1);
      }

      .left-track .word-band {
        transform: translateX(-105%);
        border-radius: 0 4px 4px 0;
      }

      .right-track .word-band {
        transform: translateX(105%);
        border-radius: 4px 0 0 4px;
      }

      .word-band h2 {
        color: #000;
        font-weight: 600;
        font-size: clamp(1.8rem, 3vw, 2.5rem);
        letter-spacing: 0.15em;
        margin: 0;
        opacity: 0;
        transition: opacity 1s ease 0.8s;
      }

      .panel.is-active .word-band {
        transform: translateX(0);
      }

      .panel.is-active .word-band h2 {
        opacity: 1;
      }

      .brand-panel {
        position: absolute;
        inset: 0;
        z-index: 30;
        visibility: hidden;
        pointer-events: none;
      }

      .brand-panel.is-visible {
        visibility: visible;
      }

      .brand-night {
        position: absolute;
        inset: 0;
        opacity: 0;
        background:
          radial-gradient(circle at 50% 35%, rgba(33, 76, 160, 0.18) 0%, rgba(17, 36, 82, 0.28) 22%, rgba(7, 15, 40, 0.62) 56%, rgba(4, 8, 24, 0.92) 100%),
          linear-gradient(to bottom, rgba(8, 18, 48, 0.55) 0%, rgba(5, 12, 32, 0.88) 75%, rgba(3, 7, 20, 0.96) 100%);
        transition: opacity 1.5s cubic-bezier(0.2, 0.8, 0.2, 1);
      }

      .brand-panel.is-night .brand-night {
        opacity: 1;
      }

      .brand-bg {
        position: absolute;
        inset: 0;
        background-size: cover;
        background-position: center;
        opacity: 0;
        transform: scale(1.04);
        transition: opacity 1.6s cubic-bezier(0.2, 0.8, 0.2, 1), transform 2.1s cubic-bezier(0.2, 0.8, 0.2, 1);
      }

      .brand-panel.is-bg .brand-bg {
        opacity: 0.96;
        transform: scale(1);
      }

      .brand-bg-overlay {
        position: absolute;
        inset: 0;
        background: radial-gradient(circle, rgba(0, 0, 0, 0.1) 0%, rgba(0, 0, 0, 0.62) 100%);
        opacity: 0;
        transition: opacity 1.3s ease;
      }

      .brand-panel.is-bg .brand-bg-overlay {
        opacity: 1;
      }

      .brand-content {
        position: relative;
        z-index: 3;
        height: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
      }

      .brand-logo-img {
        width: 250px;
        height: auto;
        margin-bottom: 30px;
      }

      .brand-catch {
        font-size: clamp(2rem, 4vw, 3.5rem);
        margin-bottom: 30px;
        font-weight: 300;
        letter-spacing: 0.05em;
        text-shadow: 0 4px 20px rgba(0, 0, 0, 0.8);
      }

      .brand-desc p {
        font-size: clamp(1.4rem, 2.5vw, 2.2rem);
        font-weight: 300;
        color: #eee;
        margin-bottom: 15px;
        letter-spacing: 0.05em;
        text-shadow: 0 2px 10px rgba(0, 0, 0, 0.8);
      }

      .fade-base {
        opacity: 0;
        transition: opacity 3.2s cubic-bezier(0.2, 0.8, 0.2, 1), transform 3.2s cubic-bezier(0.2, 0.8, 0.2, 1);
      }

      .fade-up {
        transform: translateY(40px);
      }

      .text-anim-target.is-visible .fade-up {
        transform: translateY(0);
        opacity: 1;
      }

      .fade-left {
        transform: translateX(-80px);
      }

      .text-anim-target.is-visible .fade-left {
        transform: translateX(0);
        opacity: 1;
      }

      .anim-logo { transition-delay: 0.2s; }
      .anim-catch { transition-delay: 0.9s; }
      .anim-desc1 { transition-delay: 1.8s; }
      .anim-desc2 { transition-delay: 2.6s; }
      .anim-desc3 { transition-delay: 3.4s; }

      .mobile-only-area {
        display: none;
      }

      .mobile-placeholder {
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #111;
      }

      .mobile-placeholder p {
        color: #666;
        font-size: 14px;
        letter-spacing: 2px;
      }

      .carousel-section {
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 100px 0;
        min-height: 100vh;
        background: linear-gradient(to bottom, #0d0d0d 0%, #1a1a24 50%, #0d0d0d 100%);
      }

      .section-fade-in {
        opacity: 0;
        transform: translateY(70px);
        transition: opacity 0.78s cubic-bezier(0.2, 0.8, 0.2, 1), transform 0.78s cubic-bezier(0.2, 0.8, 0.2, 1);
        width: 100%;
        will-change: opacity, transform;
      }

      .section-observer.is-visible .section-fade-in {
        opacity: 1;
        transform: translateY(0);
      }

      .section-header {
        text-align: center;
        margin-bottom: 60px;
        padding: 0 20px;
      }

      .section-header h2 {
        font-size: 14px;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: #888;
        font-weight: 600;
      }

      .carousel-wrapper {
        position: relative;
        width: 100%;
      }

      .nav-arrow {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.3);
        color: white;
        width: 60px;
        height: 60px;
        border-radius: 50%;
        cursor: pointer;
        z-index: 20;
        font-size: 24px;
        transition: background 0.3s ease, transform 0.2s ease;
        display: none;
      }

      .nav-arrow:hover {
        background: rgba(255, 255, 255, 0.3);
        transform: translateY(-50%) scale(1.05);
      }

      .left-arrow { left: 4vw; }
      .right-arrow { right: 4vw; }

      .carousel-container {
        display: flex;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        scroll-behavior: smooth;
        padding-bottom: 40px;
        align-items: center;
        -ms-overflow-style: none;
        scrollbar-width: none;
      }

      .carousel-container::-webkit-scrollbar {
        display: none;
      }

      .carousel-spacer {
        flex: 0 0 calc(50vw - 20vw);
      }

      .observer-card {
        scroll-snap-align: center;
        flex: 0 0 40vw;
        height: 60vh;
        margin: 0 1.5vw;
        position: relative;
        border-radius: 4px;
        overflow: hidden;
        transition: transform 0.6s ease, opacity 0.6s ease;
        opacity: 0.4;
        transform: scale(0.85);
        display: block;
        user-select: none;
        border: 1px solid rgba(255, 255, 255, 0.15);
        background-color: #111;
      }

      .observer-card.is-center {
        opacity: 1;
        transform: scale(1);
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.7);
        z-index: 10;
      }

      .story-card .card-bg {
        position: absolute;
        inset: 0;
        background-size: cover;
        background-position: center;
        transition: transform 0.8s ease;
      }

      .story-card.is-center:hover .card-bg {
        transform: scale(1.05);
      }

      .story-card::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(0, 0, 0, 0.9) 0%, rgba(0, 0, 0, 0.3) 50%, rgba(0, 0, 0, 0) 100%);
      }

      .card-content {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        padding: 40px;
        z-index: 2;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        height: 100%;
        pointer-events: none;
      }

      .card-meta {
        display: flex;
        gap: 12px;
        margin-bottom: 16px;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 1px;
        text-transform: uppercase;
      }

      .card-meta .category {
        color: #fff;
        border-bottom: 1px solid rgba(255, 255, 255, 0.4);
        padding-bottom: 4px;
      }

      .card-meta .country {
        color: #aaa;
      }

      .card-title {
        font-size: clamp(1.2rem, 2vw, 2rem);
        font-weight: 400;
        line-height: 1.3;
        margin-bottom: 16px;
        text-shadow: 0 2px 4px rgba(0, 0, 0, 0.5);
      }

      .card-excerpt {
        font-size: 14px;
        color: #ddd;
        margin-bottom: 24px;
        display: none;
        line-height: 1.5;
        text-shadow: 0 1px 2px rgba(0, 0, 0, 0.5);
      }

      .story-card.is-center .card-excerpt {
        display: block;
      }

      .cta-link {
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #fff;
        display: flex;
        align-items: center;
        gap: 8px;
        opacity: 0;
        transform: translateY(10px);
        transition: all 0.4s ease;
      }

      .story-card.is-center .cta-link {
        opacity: 1;
        transform: translateY(0);
      }

      .lang-card {
        flex: 0 0 28vw;
        height: 50vh;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid rgba(255, 255, 255, 0.05);
      }

      .lang-bg {
        position: absolute;
        inset: 0;
        opacity: 0.15;
        transition: opacity 0.4s ease;
      }

      .lang-card.is-center .lang-bg {
        opacity: 0.8;
      }

      .lang-content {
        position: relative;
        z-index: 2;
        width: 100%;
        height: 100%;
        padding: 40px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        pointer-events: none;
      }

      .lang-logo {
        position: absolute;
        bottom: 30px;
        left: 30px;
        font-size: 12px;
        letter-spacing: 2px;
        opacity: 0.5;
      }

      .lang-name {
        font-size: clamp(1.5rem, 3vw, 2.5rem);
        font-weight: 300;
        letter-spacing: 0.05em;
        transition: transform 0.4s ease;
        color: #fff;
      }

      .lang-border {
        width: 0;
        height: 1px;
        background: #fff;
        margin-top: 20px;
        transition: width 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
        opacity: 0.5;
      }

      .lang-card.is-center .lang-border {
        width: 40px;
      }

      .lang-card.is-center:hover .lang-name {
        transform: scale(1.05);
      }

      .site-footer {
        height: 300px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #0a0a0a;
        border-top: 1px solid #333;
      }

      .site-footer p {
        color: #666;
        font-size: 14px;
      }

      @media (min-width: 769px) {
        .nav-arrow {
          display: flex;
          align-items: center;
          justify-content: center;
        }
      }

      @media (max-width: 768px) {
        .scroll-indicator { display: none; }
        .desktop-sequence { display: none; }
        .transition-mask { display: none; }
        .hero-spacer { display: none; }
        .mobile-only-area { display: block; }
        body.is-locked { overflow: auto; }
        .header-band { padding: 15px 20px; }
      }
    </style>

    <script is:inline>
      if ('scrollRestoration' in history) {
        history.scrollRestoration = 'manual';
      }
      window.scrollTo(0, 0);

      document.addEventListener('DOMContentLoaded', () => {
        const DESKTOP_BREAKPOINT = 768;
        const HERO_ANIM_MS = 1500;
        const WHEEL_THRESHOLD = 24;

        const BRAND_BG_DELAY_MS = 700;
        const BRAND_TEXT_DELAY_MS = 1350;
        const BRAND_UNLOCK_MS = 2300;
        const BRAND_HIDE_MS = 500;

        // マスクCSS transition = 0.34s = 340ms に合わせる
        const MASK_IN_MS  = 360;   // マスクが完全に表示されるまで待つ
        const MASK_HOLD_MS = 60;   // 完全表示後に少し待つ
        const MASK_OUT_MS  = 340;  // マスクが消えるまで
        const MASK_UNLOCK_MS = 60;

        const SECTION_ANIM_MS = 240;
        const FOOTER_ANIM_MS = 900;

        let currentStep = 0;
        let isAnimating = false;
        let isFreeScroll = false;

        const body = document.body;
        const sideMenu = document.getElementById('side-menu');
        const footer = document.querySelector('.site-footer');

        const desktopSequence = document.getElementById('desktop-sequence');
        const brandPanel = document.getElementById('brand-panel');
        const brandTextTarget = document.getElementById('brand-text-target');
        const transitionMask = document.getElementById('transition-mask');

        const screen5 = document.getElementById('screen-5');
        const screen6 = document.getElementById('screen-6');
        const dots = document.querySelectorAll('.scroll-indicator .dot');

        const leftPanels = document.querySelectorAll('.left-track .panel');
        const rightPanels = document.querySelectorAll('.right-track .panel');

        const l2 = document.querySelector('.left-track .p2');
        const l3 = document.querySelector('.left-track .p3');
        const r2 = document.querySelector('.right-track .p2');
        const r3 = document.querySelector('.right-track .p3');

        function isDesktop() {
          return window.innerWidth > DESKTOP_BREAKPOINT;
        }

        function setBodyLocked(locked) {
          body.classList.toggle('is-locked', locked);
        }

        function updateIndicator(index) {
          dots.forEach((dot, i) => {
            dot.classList.toggle('active', i === index);
          });
        }

        function showMask() {
          transitionMask?.classList.add('is-visible');
        }

        function hideMask() {
          transitionMask?.classList.remove('is-visible');
        }

        function clearSectionVisibility() {
          screen5?.classList.remove('is-visible');
          screen6?.classList.remove('is-visible');
        }

        function showSection(step) {
          clearSectionVisibility();
          if (step === 4) screen5?.classList.add('is-visible');
          if (step === 5) screen6?.classList.add('is-visible');
        }

        function resetBrandPanel() {
          brandPanel?.classList.remove('is-visible', 'is-night', 'is-bg');
          brandTextTarget?.classList.remove('is-visible');
        }

        function revealBrandImmediate() {
          desktopSequence?.classList.remove('is-hidden');
          resetBrandPanel();
          brandPanel?.classList.add('is-visible', 'is-night', 'is-bg');

          requestAnimationFrame(() => {
            brandTextTarget?.classList.add('is-visible');
          });
        }

        function showBrandAnimated() {
          desktopSequence?.classList.remove('is-hidden');
          resetBrandPanel();
          brandPanel?.classList.add('is-visible', 'is-night');

          window.setTimeout(() => {
            brandPanel?.classList.add('is-bg');
          }, BRAND_BG_DELAY_MS);

          window.setTimeout(() => {
            brandTextTarget?.classList.add('is-visible');
          }, BRAND_TEXT_DELAY_MS);

          window.setTimeout(() => {
            isAnimating = false;
          }, BRAND_UNLOCK_MS);
        }

        function hideBrandAnimated() {
          brandTextTarget?.classList.remove('is-visible');
          brandPanel?.classList.remove('is-bg', 'is-night');

          window.setTimeout(() => {
            brandPanel?.classList.remove('is-visible');
            isAnimating = false;
          }, BRAND_HIDE_MS);
        }

        function activateHeroSlide(index) {
          leftPanels.forEach((panel) => panel.classList.remove('is-active'));
          rightPanels.forEach((panel) => panel.classList.remove('is-active'));

          if (index === 0) {
            l2?.classList.remove('is-open');
            r2?.classList.remove('is-open');
            l3?.classList.remove('is-open');
            r3?.classList.remove('is-open');
          } else if (index === 1) {
            l2?.classList.add('is-open');
            r2?.classList.add('is-open');
            l3?.classList.remove('is-open');
            r3?.classList.remove('is-open');
          } else if (index === 2) {
            l2?.classList.add('is-open');
            r2?.classList.add('is-open');
            l3?.classList.add('is-open');
            r3?.classList.add('is-open');
          }

          window.setTimeout(() => {
            leftPanels[index]?.classList.add('is-active');
            rightPanels[index]?.classList.add('is-active');
            isAnimating = false;
          }, HERO_ANIM_MS);
        }

        function transitionBrandToStories() {
          setBodyLocked(true);
          showMask();

          window.setTimeout(() => {
            desktopSequence?.classList.add('is-hidden');
            showSection(4);

            window.scrollTo({
              top: screen5?.offsetTop ?? window.innerHeight,
              left: 0,
              behavior: 'auto'
            });

            window.setTimeout(() => {
              setBodyLocked(false);
              hideMask();

              window.setTimeout(() => {
                isAnimating = false;
              }, MASK_UNLOCK_MS);
            }, MASK_HOLD_MS);
          }, MASK_IN_MS);
        }

        function transitionStoriesToBrand() {
          setBodyLocked(true);
          showMask();

          window.setTimeout(() => {
            clearSectionVisibility();

            window.scrollTo({
              top: 0,
              left: 0,
              behavior: 'auto'
            });

            revealBrandImmediate();
            desktopSequence?.classList.remove('is-hidden');

            window.setTimeout(() => {
              hideMask();

              window.setTimeout(() => {
                isAnimating = false;
              }, MASK_UNLOCK_MS);
            }, MASK_HOLD_MS);
          }, MASK_IN_MS);
        }

        function transitionBetweenSections(targetStep) {
          setBodyLocked(true);
          showMask();

          window.setTimeout(() => {
            // スクロール位置を先に移動（マスクで隠れているので見えない）
            const target = targetStep === 4 ? screen5 : screen6;
            const targetTop = target?.offsetTop ?? 0;
            window.scrollTo({ top: targetTop, left: 0, behavior: 'auto' });
            showSection(targetStep);

            window.setTimeout(() => {
              hideMask();
              setBodyLocked(false);
              window.setTimeout(() => {
                isAnimating = false;
              }, MASK_UNLOCK_MS);
            }, MASK_HOLD_MS);
          }, MASK_IN_MS);
        }

        function goToStep(step) {
          if (!isDesktop()) return;
          if (step < 0 || step > 5) return;
          if (isAnimating) return;

          const previousStep = currentStep;
          currentStep = step;
          isAnimating = true;
          updateIndicator(step);

          if (step <= 2) {
            isFreeScroll = false;
            setBodyLocked(true);
            desktopSequence?.classList.remove('is-hidden');
            hideMask();
            clearSectionVisibility();

            window.scrollTo({
              top: 0,
              left: 0,
              behavior: 'auto'
            });

            if (previousStep === 3 && step === 2) {
              hideBrandAnimated();
              return;
            }

            resetBrandPanel();
            activateHeroSlide(step);
            return;
          }

          if (step === 3) {
            isFreeScroll = false;
            setBodyLocked(true);
            desktopSequence?.classList.remove('is-hidden');
            hideMask();
            clearSectionVisibility();

            window.scrollTo({
              top: 0,
              left: 0,
              behavior: 'auto'
            });

            if (previousStep === 4) {
              transitionStoriesToBrand();
              return;
            }

            if (previousStep >= 5) {
              revealBrandImmediate();
              window.setTimeout(() => {
                isAnimating = false;
              }, 200);
            } else {
              showBrandAnimated();
            }
            return;
          }

          if (step === 4 && previousStep === 3) {
            transitionBrandToStories();
            return;
          }

          if (step === 5 && previousStep === 4) {
            transitionBetweenSections(5);
            return;
          }

          if (step === 4 && previousStep === 5) {
            transitionBetweenSections(4);
            return;
          }

          isFreeScroll = false;
          setBodyLocked(false);
          desktopSequence?.classList.add('is-hidden');
          hideMask();
          showSection(step);

          const target = step === 4 ? screen5 : screen6;
          target?.scrollIntoView({
            behavior: 'smooth',
            block: 'start'
          });

          window.setTimeout(() => {
            isAnimating = false;
          }, SECTION_ANIM_MS);
        }

        function enterFooterMode() {
          if (isAnimating) return;

          isAnimating = true;
          isFreeScroll = true;
          setBodyLocked(false);
          desktopSequence?.classList.add('is-hidden');
          hideMask();

          footer?.scrollIntoView({
            behavior: 'smooth',
            block: 'start'
          });

          window.setTimeout(() => {
            isAnimating = false;
          }, FOOTER_ANIM_MS);
        }

        function leaveFooterMode() {
          if (isAnimating) return;
          isFreeScroll = false;
          goToStep(5);
        }

        function moveNext() {
          if (currentStep < 5) {
            goToStep(currentStep + 1);
          } else {
            enterFooterMode();
          }
        }

        function movePrev() {
          if (currentStep > 0) {
            goToStep(currentStep - 1);
          }
        }

        window.addEventListener('wheel', (e) => {
          if (!isDesktop()) return;
          if (sideMenu?.classList.contains('is-open')) return;

          if (isFreeScroll) {
            if (e.deltaY < -WHEEL_THRESHOLD && window.scrollY <= (footer?.offsetTop ?? 0) + 10) {
              e.preventDefault();
              leaveFooterMode();
            }
            return;
          }

          e.preventDefault();

          if (isAnimating) return;

          if (e.deltaY > WHEEL_THRESHOLD) {
            moveNext();
          } else if (e.deltaY < -WHEEL_THRESHOLD) {
            movePrev();
          }
        }, { passive: false });

        window.addEventListener('keydown', (e) => {
          if (!isDesktop()) return;
          if (sideMenu?.classList.contains('is-open')) return;

          const downKeys = ['ArrowDown', 'PageDown', ' '];
          const upKeys = ['ArrowUp', 'PageUp'];

          if (isFreeScroll) {
            if (upKeys.includes(e.key) && window.scrollY <= (footer?.offsetTop ?? 0) + 10) {
              e.preventDefault();
              leaveFooterMode();
            }
            return;
          }

          if (downKeys.includes(e.key)) {
            e.preventDefault();
            if (!isAnimating) moveNext();
          }

          if (upKeys.includes(e.key)) {
            e.preventDefault();
            if (!isAnimating) movePrev();
          }

          if (e.key === 'Home') {
            e.preventDefault();
            goToStep(0);
          }
        });

        window.addEventListener('resize', () => {
          if (!isDesktop()) {
            isAnimating = false;
            isFreeScroll = false;
            setBodyLocked(false);
            desktopSequence?.classList.remove('is-hidden');
            hideMask();
            resetBrandPanel();
            clearSectionVisibility();
          }
        });

        setBodyLocked(true);
        desktopSequence?.classList.remove('is-hidden');
        hideMask();
        resetBrandPanel();
        clearSectionVisibility();
        updateIndicator(0);

        window.setTimeout(() => {
          leftPanels[0]?.classList.add('is-active');
          rightPanels[0]?.classList.add('is-active');
        }, 400);

        document.getElementById('menu-open').onclick = () => sideMenu?.classList.add('is-open');
        document.getElementById('menu-close').onclick = () => sideMenu?.classList.remove('is-open');

        const sectionObserver = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
            }
          });
        }, { threshold: 0.15 });

        document.querySelectorAll('.section-observer').forEach((el) => {
          sectionObserver.observe(el);
        });

        const carouselObserver = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) entry.target.classList.add('is-center');
            else entry.target.classList.remove('is-center');
          });
        }, {
          root: null,
          rootMargin: '0px -40% 0px -40%',
          threshold: 0
        });

        document.querySelectorAll('.observer-card').forEach((card) => {
          carouselObserver.observe(card);
        });

        document.querySelectorAll('.carousel-wrapper').forEach((wrapper) => {
          const container = wrapper.querySelector('.carousel-container');
          const leftBtn = wrapper.querySelector('.left-arrow');
          const rightBtn = wrapper.querySelector('.right-arrow');

          leftBtn?.addEventListener('click', () => {
            container?.scrollBy({
              left: -window.innerWidth * 0.4,
              behavior: 'smooth'
            });
          });

          rightBtn?.addEventListener('click', () => {
            container?.scrollBy({
              left: window.innerWidth * 0.4,
              behavior: 'smooth'
            });
          });
        });
      });
    </script>
  </body>
</html>
