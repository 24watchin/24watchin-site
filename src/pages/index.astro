---
import DesktopView from '../components/DesktopView.astro';
import MobileView from '../components/MobileView.astro';
// 各言語のブログIDを取得するツールを読み込みます
import { getBlogId } from '../lib/siteRoutes.ts';

// Blogger APIの鍵と、英語(en)のブログIDを準備します
const API_KEY = import.meta.env.API_KEY;
const BLOG_ID = getBlogId('en');

// 他のページと通信内容を共有する安全なキャッシュ機能
if (!globalThis.bloggerApiCache) {
  globalThis.bloggerApiCache = {};
}

let englishPosts = [];
if (API_KEY && BLOG_ID) {
  if (!globalThis.bloggerApiCache[BLOG_ID]) {
    // トップページ用なので、最新の5件だけ取得すれば十分です
    const url = `https://www.googleapis.com/blogger/v3/blogs/${BLOG_ID}/posts?key=${API_KEY}&maxResults=5`;
    globalThis.bloggerApiCache[BLOG_ID] = fetch(url)
      .then(res => res.ok ? res.json() : null)
      .then(data => data && data.items ? data.items : [])
      .catch(() => []); // エラー時は空箱を返す安全設計
  }
  // 取得完了を待って記事データを受け取ります
  englishPosts = await globalThis.bloggerApiCache[BLOG_ID];
}

// 念のため、確実な最新5件のデータとしてまとめます
const topStories = englishPosts.slice(0, 5);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>24watchin | Global Gateway</title>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@300;400;600&display=swap" rel="stylesheet" />
    <style is:global>
      :root {
        --bg-color: #0d0d0d;
        --text-main: #f0f0f0;
        --font-sans: 'Noto Sans', sans-serif;
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        background-color: var(--bg-color);
        color: var(--text-main);
        font-family: var(--font-sans);
        margin: 0;
      }
      body.is-locked { overflow: hidden; }
      @media (max-width: 768px) {
        body.is-locked { overflow: auto; }
      }
    </style>
  </head>

  <body class="is-locked">
    <DesktopView latestStories={topStories} />
    <MobileView latestStories={topStories} />
  </body>
</html>
