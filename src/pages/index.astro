---
// モックアップ用ダミーデータ

// 5画面目用：最新ニュースダミー
const latestStories = [
  { id: 1, category: 'Politics', country: 'United States', title: 'New Economic Policies Reshape the Global Market', excerpt: 'An in-depth look at the recent shifts in international trade agreements.', image: 'linear-gradient(135deg, #1a1c29 0%, #2a3b4c 100%)' },
  { id: 2, category: 'Economy', country: 'Taiwan', title: 'Tech Giants Announce Next-Generation Semiconductor', excerpt: 'Would you like to see what happened in Taiwan? The new chip architecture unveiled today.', image: 'linear-gradient(135deg, #2c2519 0%, #4a3f2c 100%)' },
  { id: 3, category: 'Society', country: 'France', title: 'Urban Renewal Projects Transform Historic Districts', excerpt: 'Paris sets a new standard for eco-friendly city planning.', image: 'linear-gradient(135deg, #1d2b22 0%, #2e4436 100%)' },
  { id: 4, category: 'Environment', country: 'Brazil', title: 'Amazon Conservation Efforts Show Promising Results', excerpt: 'Deforestation rates drop as new monitoring technologies are deployed.', image: 'linear-gradient(135deg, #2b1d1d 0%, #442e2e 100%)' },
];

// 6画面目用：言語ダミー
const languages = [
  { code: 'ja', name: '日本語', color: '#872732', url: '/ja/' },
  { code: 'en', name: 'English', color: '#1A365D', url: '/en/' },
  { code: 'zh-cn', name: '简体中文', color: '#C53030', url: '/zh-cn/' },
  { code: 'zh-tw', name: '繁體中文', color: '#2C5282', url: '/zh-tw/' },
  { code: 'es', name: 'Español', color: '#B7791F', url: '/es/' },
  { code: 'fr', name: 'Français', color: '#2B6CB0', url: '/fr/' },
  { code: 'de', name: 'Deutsch', color: '#276749', url: '/de/' },
  { code: 'ru', name: 'Русский', color: '#744210', url: '/ru/' },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>24watchin | Global Gateway</title>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@300;400;600&family=Playfair+Display:ital@0;1&display=swap" rel="stylesheet">
  </head>
  <body>

    <header class="global-header">
      <div class="logo">24watchin</div>
    </header>

    <main class="gateway-main">
      
      <section class="split-section" id="screen-1">
        <div class="split-pane left-pane dark-overlay">
          <div class="bg-layer" style="background: linear-gradient(to bottom, #2a2a2a, #111);"></div>
          <h2 class="split-word">Conflict</h2>
        </div>
        <div class="split-pane right-pane dark-overlay">
          <div class="bg-layer" style="background: linear-gradient(to bottom, #3a3a3a, #1a1a1a);"></div>
          <h2 class="split-word">People</h2>
        </div>
        <div class="scroll-indicator">
          <span class="line"></span>
        </div>
      </section>

      <section class="split-section" id="screen-2">
        <div class="split-pane left-pane dark-overlay">
          <div class="bg-layer" style="background: linear-gradient(to bottom, #1f1a1a, #0a0a0a);"></div>
          <h2 class="split-word">Crisis</h2>
        </div>
        <div class="split-pane right-pane dark-overlay">
          <div class="bg-layer" style="background: linear-gradient(to bottom, #1a1f2b, #0a0a11);"></div>
          <h2 class="split-word">Cities</h2>
        </div>
      </section>

      <section class="split-section" id="screen-3">
        <div class="split-pane left-pane dark-overlay">
          <div class="bg-layer" style="background: linear-gradient(to bottom, #1a2b2b, #0a1111);"></div>
          <h2 class="split-word">Innovation</h2>
        </div>
        <div class="split-pane right-pane dark-overlay">
          <div class="bg-layer" style="background: linear-gradient(to bottom, #2b2a1a, #11110a);"></div>
          <h2 class="split-word">Change</h2>
        </div>
      </section>

      <section class="brand-section" id="screen-4">
        <div class="brand-bg"></div>
        <div class="brand-content observer-target">
          <h1 class="brand-logo fade-item">24watchin</h1>
          <h2 class="brand-catch fade-item">Watch the world with clarity.</h2>
          <div class="brand-desc fade-item">
            <p>Global news.</p>
            <p>Explained clearly.</p>
            <p>In your language.</p>
          </div>
        </div>
      </section>

      <section class="carousel-section" id="screen-5">
        <div class="section-header">
          <h2>Latest Stories</h2>
        </div>
        <div class="carousel-container" id="story-carousel">
          <div class="carousel-spacer"></div>
          {latestStories.map((story) => (
            <a href={`/en/story/${story.id}`} class="story-card observer-card">
              <div class="card-bg" style={`background: ${story.image};`}></div>
              <div class="card-content">
                <div class="card-meta">
                  <span class="category">{story.category}</span>
                  <span class="country">{story.country}</span>
                </div>
                <h3 class="card-title">{story.title}</h3>
                <p class="card-excerpt">{story.excerpt}</p>
                <div class="cta-link">Read story <span>&rarr;</span></div>
              </div>
            </a>
          ))}
          <div class="carousel-spacer"></div>
        </div>
      </section>

      <section class="carousel-section lang-section" id="screen-6">
        <div class="section-header">
          <h2>CHOOSE YOUR LANGUAGE</h2>
          <p class="sub-header">Check the news in your own language.</p>
        </div>
        <div class="carousel-container" id="lang-carousel">
          <div class="carousel-spacer"></div>
          {languages.map((lang) => (
            <a href={lang.url} class="lang-card observer-card">
              <div class="lang-bg" style={`background-color: ${lang.color};`}>
                <div class="map-pattern"></div>
              </div>
              <div class="lang-content">
                <div class="lang-logo">24watchin</div>
                <h3 class="lang-name">{lang.name}</h3>
                <div class="lang-border"></div>
              </div>
            </a>
          ))}
          <div class="carousel-spacer"></div>
        </div>
      </section>

      <footer style="height: 300px; display: flex; align-items: center; justify-content: center; background: #0a0a0a; border-top: 1px solid #333; margin-top: 50px;">
        <p style="color: #666; font-size: 14px;">[ 既存のフッター領域（国リンクボタン等） ]</p>
      </footer>

    </main>

    <style>
      /* --- Global Reset & Variables --- */
      :root {
        --bg-color: #0d0d0d;
        --text-main: #f0f0f0;
        --text-muted: #a0a0a0;
        --font-sans: 'Noto Sans', 'Helvetica Neue', Arial, sans-serif;
        --font-serif: 'Playfair Display', serif;
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body { background-color: var(--bg-color); color: var(--text-main); font-family: var(--font-sans); -webkit-font-smoothing: antialiased; line-height: 1.6; overflow-x: hidden; }
      a { text-decoration: none; color: inherit; }

      /* --- Header --- */
      .global-header { position: fixed; top: 0; left: 0; width: 100%; padding: 40px 50px; z-index: 100; pointer-events: none; }
      .global-header .logo { font-weight: 600; font-size: 20px; letter-spacing: 1px; }

      /* --- 共通: Section Setup --- */
      section { position: relative; width: 100%; min-height: 100vh; overflow: hidden; }

      /* --- Screen 1-3: Split Screens --- */
      .split-section { display: flex; flex-direction: row; }
      .split-pane { position: relative; width: 50vw; height: 100vh; display: flex; align-items: center; justify-content: center; overflow: hidden; }
      .bg-layer { position: absolute; top: -5%; left: -5%; width: 110%; height: 110%; background-size: cover !important; background-position: center !important; transition: transform 0.1s ease-out; z-index: 1; }
      .dark-overlay::after { content: ''; position: absolute; inset: 0; background: rgba(0,0,0,0.4); z-index: 2; }
      .split-word { position: relative; z-index: 3; font-weight: 300; font-size: clamp(2rem, 4vw, 3.5rem); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 10vh; opacity: 0.9; text-shadow: 0 4px 15px rgba(0,0,0,0.5); }
      
      /* Scroll Indicator */
      .scroll-indicator { position: absolute; bottom: 40px; left: 50%; transform: translateX(-50%); z-index: 10; display: flex; flex-direction: column; align-items: center; opacity: 0.6; }
      .scroll-indicator .line { width: 1px; height: 60px; background: linear-gradient(to bottom, rgba(255,255,255,0.8), transparent); animation: scrollLine 2s infinite; transform-origin: top; }
      @keyframes scrollLine { 0% { transform: scaleY(0); } 50% { transform: scaleY(1); } 100% { transform: scaleY(0); transform-origin: bottom; } }

      /* --- Screen 4: Brand Core --- */
      .brand-section { display: flex; align-items: center; justify-content: center; text-align: center; }
      .brand-bg { position: absolute; inset: 0; background: linear-gradient(180deg, #111 0%, #1a1a24 50%, #111 100%); z-index: 1; opacity: 0.8; }
      .brand-content { position: relative; z-index: 2; max-width: 800px; padding: 0 20px; }
      .brand-logo { font-size: clamp(1.5rem, 3vw, 2.5rem); font-weight: 400; letter-spacing: 2px; margin-bottom: 24px; color: var(--text-muted); }
      .brand-catch { font-size: clamp(2rem, 5vw, 4.5rem); font-weight: 300; line-height: 1.2; margin-bottom: 40px; letter-spacing: 0.02em; }
      .brand-desc p { font-size: clamp(1.1rem, 2vw, 1.5rem); font-weight: 300; color: #ccc; margin-bottom: 8px; letter-spacing: 0.05em; }
      
      /* Fade Animations for Screen 4 */
      .fade-item { opacity: 0; transform: translateY(30px); transition: opacity 1.2s cubic-bezier(0.2, 0.8, 0.2, 1), transform 1.2s cubic-bezier(0.2, 0.8, 0.2, 1); }
      .fade-item:nth-child(1) { transition-delay: 0.2s; }
      .fade-item:nth-child(2) { transition-delay: 0.6s; }
      .fade-item:nth-child(3) { transition-delay: 1.0s; }
      .observer-target.is-visible .fade-item { opacity: 1; transform: translateY(0); }

      /* --- Screen 5 & 6: Carousel Common --- */
      .carousel-section { display: flex; flex-direction: column; justify-content: center; padding: 100px 0; min-height: 100vh; }
      .section-header { text-align: center; margin-bottom: 60px; padding: 0 20px; }
      .section-header h2 { font-size: 14px; letter-spacing: 3px; text-transform: uppercase; color: var(--text-muted); font-weight: 600; }
      .section-header .sub-header { margin-top: 12px; font-size: 18px; font-weight: 300; color: #ddd; }
      
      .carousel-container { display: flex; overflow-x: auto; scroll-snap-type: x mandatory; scroll-behavior: smooth; padding-bottom: 40px; align-items: center; /* 隠しスクロールバー */ -ms-overflow-style: none; scrollbar-width: none; }
      .carousel-container::-webkit-scrollbar { display: none; }
      
      /* Spacer to allow first/last items to center */
      .carousel-spacer { flex: 0 0 calc(50vw - 20vw); /* 中央カード(40vw)の半分の残りを計算 */ }
      
      .observer-card { scroll-snap-align: center; flex: 0 0 40vw; height: 60vh; margin: 0 1.5vw; position: relative; border-radius: 4px; overflow: hidden; text-decoration: none; transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1), opacity 0.6s ease; opacity: 0.4; transform: scale(0.85); cursor: pointer; }
      .observer-card.is-center { opacity: 1; transform: scale(1); box-shadow: 0 20px 50px rgba(0,0,0,0.5); z-index: 10; }

      /* --- Screen 5: Story Cards --- */
      .story-card .card-bg { position: absolute; inset: 0; background-size: cover !important; background-position: center !important; transition: transform 0.8s ease; }
      .story-card.is-center:hover .card-bg { transform: scale(1.05); }
      .story-card::after { content: ''; position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.2) 50%, rgba(0,0,0,0) 100%); pointer-events: none; }
      .card-content { position: absolute; bottom: 0; left: 0; width: 100%; padding: 40px; z-index: 2; display: flex; flex-direction: column; justify-content: flex-end; height: 100%; }
      .card-meta { display: flex; gap: 12px; margin-bottom: 16px; font-size: 12px; font-weight: 600; letter-spacing: 1px; text-transform: uppercase; }
      .card-meta .category { color: #fff; border-bottom: 1px solid rgba(255,255,255,0.4); padding-bottom: 4px; }
      .card-meta .country { color: var(--text-muted); }
      .card-title { font-size: clamp(1.2rem, 2vw, 2rem); font-weight: 400; line-height: 1.3; margin-bottom: 16px; }
      .card-excerpt { font-size: 14px; color: #ccc; margin-bottom: 24px; display: none; line-height: 1.5; }
      .story-card.is-center .card-excerpt { display: block; } /* 中央のみ補足表示 */
      .cta-link { font-size: 12px; text-transform: uppercase; letter-spacing: 1px; color: #fff; display: flex; align-items: center; gap: 8px; opacity: 0; transform: translateY(10px); transition: all 0.4s ease; }
      .story-card.is-center .cta-link { opacity: 1; transform: translateY(0); }

      /* --- Screen 6: Language Cards --- */
      .lang-card { flex: 0 0 28vw; height: 50vh; display: flex; align-items: center; justify-content: center; border: 1px solid rgba(255,255,255,0.05); }
      .lang-bg { position: absolute; inset: 0; opacity: 0.15; transition: opacity 0.4s ease; }
      .lang-card.is-center .lang-bg { opacity: 0.8; }
      .map-pattern { position: absolute; inset: 0; background-image: radial-gradient(rgba(255,255,255,0.1) 1px, transparent 1px); background-size: 20px 20px; opacity: 0.5; }
      .lang-content { position: relative; z-index: 2; width: 100%; height: 100%; padding: 40px; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; }
      .lang-logo { position: absolute; bottom: 30px; left: 30px; font-size: 12px; letter-spacing: 2px; opacity: 0.5; }
      .lang-name { font-size: clamp(1.5rem, 3vw, 2.5rem); font-weight: 300; letter-spacing: 0.05em; transition: transform 0.4s ease; }
      .lang-border { width: 0; height: 1px; background: #fff; margin-top: 20px; transition: width 0.6s cubic-bezier(0.2, 0.8, 0.2, 1); opacity: 0.5; }
      .lang-card.is-center .lang-border { width: 40px; }
      .lang-card.is-center:hover .lang-name { transform: scale(1.05); }

      /* --- Responsive (Mobile) --- */
      @media (max-width: 768px) {
        .global-header { padding: 20px; }
        .global-header .logo { font-size: 16px; }
        /* Mobile: Keep 50:50 side-by-side but tighten design */
        .split-word { font-size: 1.2rem; margin-bottom: 5vh; letter-spacing: 0.05em; }
        .brand-content { padding: 0 15px; }
        /* Carousel Mobile Adjustments */
        .carousel-spacer { flex: 0 0 calc(50vw - 37.5vw); } /* adjust for 75vw card */
        .observer-card { flex: 0 0 75vw; height: 55vh; margin: 0 2vw; }
        .lang-card { flex: 0 0 65vw; height: 45vh; }
        .card-content { padding: 25px 20px; }
        .lang-content { padding: 20px; }
        .lang-logo { bottom: 20px; left: 20px; }
      }
    </style>

    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        
        // 1. Mouse Parallax for Screen 1-3
        const bgLayers = document.querySelectorAll('.bg-layer');
        window.addEventListener('mousemove', (e) => {
          const mouseX = e.clientX / window.innerWidth - 0.5;
          const mouseY = e.clientY / window.innerHeight - 0.5;
          bgLayers.forEach(layer => {
            // 微小な動き（MAX 2% 程度）に抑えて上品さを保つ
            layer.style.transform = `translate(${mouseX * -2}%, ${mouseY * -2}%)`;
          });
        });

        // 2. Intersection Observer for Screen 4 (Fade In)
        const observerOptions = { root: null, threshold: 0.3 };
        const fadeObserver = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
            }
          });
        }, observerOptions);
        document.querySelectorAll('.observer-target').forEach(el => fadeObserver.observe(el));

        // 3. Intersection Observer for Carousels (Center Focus Effect)
        // 画面中央付近にあるカードを検知してクラスを付与する
        const carouselObserverOptions = {
          root: null, // viewportを基準
          rootMargin: "0px -40% 0px -40%", // 画面の中央20%の領域に入ったものを検知
          threshold: 0
        };
        const carouselObserver = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-center');
            } else {
              entry.target.classList.remove('is-center');
            }
          });
        }, carouselObserverOptions);
        
        document.querySelectorAll('.observer-card').forEach(card => {
          carouselObserver.observe(card);
        });

      });
    </script>
  </body>
</html>
