---
// モックアップ用データ
const latestStories = [
  { id: 1, category: 'Politics', country: 'United States', title: 'New Economic Policies Reshape the Global Market', excerpt: 'An in-depth look at the recent shifts in international trade agreements.', image: 'linear-gradient(135deg, #1a1c29 0%, #2a3b4c 100%)' },
  { id: 2, category: 'Economy', country: 'Taiwan', title: 'Tech Giants Announce Next-Generation Semiconductor', excerpt: 'Would you like to see what happened in Taiwan?', image: 'linear-gradient(135deg, #2c2519 0%, #4a3f2c 100%)' },
  { id: 3, category: 'Society', country: 'France', title: 'Urban Renewal Projects Transform Historic Districts', excerpt: 'Paris sets a new standard for eco-friendly city planning.', image: 'linear-gradient(135deg, #1d2b22 0%, #2e4436 100%)' },
  { id: 4, category: 'Environment', country: 'Brazil', title: 'Amazon Conservation Efforts Show Promising Results', excerpt: 'Deforestation rates drop as new monitoring technologies are deployed.', image: 'linear-gradient(135deg, #2b1d1d 0%, #442e2e 100%)' },
];

const languages = [
  { code: 'ja', name: '日本語', color: '#872732', url: '/ja/' },
  { code: 'en', name: 'English', color: '#1A365D', url: '/en/' },
  { code: 'zh-cn', name: '简体中文', color: '#C53030', url: '/zh-cn/' },
  { code: 'zh-tw', name: '繁體中文', color: '#2C5282', url: '/zh-tw/' },
  { code: 'es', name: 'Español', color: '#B7791F', url: '/es/' },
  { code: 'fr', name: 'Français', color: '#2B6CB0', url: '/fr/' },
  { code: 'de', name: 'Deutsch', color: '#276749', url: '/de/' },
  { code: 'ru', name: 'Русский', color: '#744210', url: '/ru/' },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>24watchin | Global Gateway</title>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@300;400;600&display=swap" rel="stylesheet">
  </head>
  <body class="is-locked">

    <header class="global-header" id="main-header">
      <div class="header-band">
        <div class="logo-area">
          <a href="https://24watchin.com">
            <img src="/images/24Watchin-white.png" alt="24Watchin Logo" class="header-logo-img" />
          </a>
        </div>
        <button class="menu-trigger" id="menu-open">
          <span class="burger-line"></span>
          <span class="burger-line"></span>
          <span class="burger-line"></span>
        </button>
      </div>
    </header>

    <nav class="side-menu" id="side-menu">
      <button class="menu-close" id="menu-close">&times;</button>
      <div class="menu-inner">
        <h3>CHOOSE YOUR LANGUAGE</h3>
        <div class="menu-grid">
          {languages.map(lang => (
            <a href={lang.url} class="menu-lang-card" style={`--accent: ${lang.color}`}>
              <span class="lang-name">{lang.name}</span>
            </a>
          ))}
        </div>
      </div>
    </nav>

    <div class="scroll-indicator" id="scroll-indicator">
      <div class="dot active"></div>
      <div class="dot"></div>
      <div class="dot"></div>
      <div class="dot"></div>
      <div class="dot"></div>
      <div class="dot"></div>
    </div>

    <main class="gateway-main">
      
      <div class="desktop-only-area" id="desktop-hero">
        <div class="left-track">
          <div class="panel p1">
            <div class="bg-layer" style="background-image: url('/images/conflict.jpg');"></div>
            <div class="word-band-container"><div class="word-band"><h2>CONFLICT</h2></div></div>
          </div>
          <div class="panel p2">
            <div class="bg-layer" style="background-image: url('/images/cities.webp');"></div>
            <div class="word-band-container"><div class="word-band"><h2>CITIES</h2></div></div>
          </div>
          <div class="panel p3">
            <div class="bg-layer" style="background-image: url('/images/innovation.jpg');"></div>
            <div class="word-band-container"><div class="word-band"><h2>INNOVATION</h2></div></div>
          </div>
        </div>
        
        <div class="right-track">
          <div class="panel p1">
            <div class="bg-layer" style="background-image: url('/images/crisis.png');"></div>
            <div class="word-band-container"><div class="word-band"><h2>CRISIS</h2></div></div>
          </div>
          <div class="panel p2">
            <div class="bg-layer" style="background-image: url('/images/people.webp');"></div>
            <div class="word-band-container"><div class="word-band"><h2>PEOPLE</h2></div></div>
          </div>
          <div class="panel p3">
            <div class="bg-layer" style="background-image: url('/images/frontier.jpg');"></div>
            <div class="word-band-container"><div class="word-band"><h2>FRONTIER</h2></div></div>
          </div>
        </div>
      </div>

      <div class="mobile-only-area">
        <div style="height: 100vh; display: flex; align-items: center; justify-content: center; background: #111;">
          <p style="color: #666; font-size: 14px; letter-spacing: 2px;">スマホ版は準備中です</p>
        </div>
      </div>

      <section class="brand-section section-observer" id="screen-4">
        <div class="brand-bg" style="background-image: url('/images/explanation.png');"></div>
        <div class="brand-bg-overlay"></div>
        
        <div class="brand-content text-anim-target">
          <img src="/images/24Watchin-white.png" alt="24Watchin Logo" class="brand-logo-img fade-base fade-up anim-logo" />
          <h2 class="brand-catch fade-base fade-up anim-catch">Watch the world with clarity.</h2>
          
          <div class="brand-desc">
            <p class="fade-base fade-left anim-desc1">Global news.</p>
            <p class="fade-base fade-left anim-desc2">Explained clearly.</p>
            <p class="fade-base fade-left anim-desc3">In your language.</p>
          </div>
        </div>
      </section>

      <section class="carousel-section section-observer" id="screen-5">
        <div class="section-fade-in">
          <div class="section-header"><h2>Latest Stories</h2></div>
          <div class="carousel-wrapper">
            <button class="nav-arrow left-arrow" aria-label="Previous">&larr;</button>
            <div class="carousel-container" id="story-carousel">
              <div class="carousel-spacer"></div>
              {latestStories.map((story) => (
                <a href={`/en/story/${story.id}`} class="story-card observer-card">
                  <div class="card-bg" style={`background: ${story.image};`}></div>
                  <div class="card-content">
                    <div class="card-meta"><span class="category">{story.category}</span><span class="country">{story.country}</span></div>
                    <h3 class="card-title">{story.title}</h3>
                    <p class="card-excerpt">{story.excerpt}</p>
                    <div class="cta-link">Read story <span>&rarr;</span></div>
                  </div>
                </a>
              ))}
              <div class="carousel-spacer"></div>
            </div>
            <button class="nav-arrow right-arrow" aria-label="Next">&rarr;</button>
          </div>
        </div>
      </section>

      <section class="carousel-section lang-section section-observer" id="screen-6">
        <div class="section-fade-in">
          <div class="section-header">
            <h2>CHOOSE YOUR LANGUAGE</h2>
          </div>
          <div class="carousel-wrapper">
            <button class="nav-arrow left-arrow" aria-label="Previous">&larr;</button>
            <div class="carousel-container" id="lang-carousel">
              <div class="carousel-spacer"></div>
              {languages.map((lang) => (
                <a href={lang.url} class="lang-card observer-card">
                  <div class="lang-bg" style={`background-color: ${lang.color};`}></div>
                  <div class="lang-content">
                    <div class="lang-logo">24watchin</div>
                    <h3 class="lang-name">{lang.name}</h3>
                    <div class="lang-border"></div>
                  </div>
                </a>
              ))}
              <div class="carousel-spacer"></div>
            </div>
            <button class="nav-arrow right-arrow" aria-label="Next">&rarr;</button>
          </div>
        </div>
      </section>

      <footer style="height: 300px; display: flex; align-items: center; justify-content: center; background: #0a0a0a; border-top: 1px solid #333;">
        <p style="color: #666; font-size: 14px;">[ フッター領域 ]</p>
      </footer>

    </main>

    <style>
      :root { --bg-color: #0d0d0d; --text-main: #f0f0f0; --font-sans: 'Noto Sans', sans-serif; }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      
      body { background-color: var(--bg-color); color: var(--text-main); font-family: var(--font-sans); margin: 0; }
      body.is-locked { overflow: hidden; }

      .global-header { position: fixed; top: 0; left: 0; width: 100%; z-index: 200; pointer-events: none; transition: opacity 0.8s ease; }
      .header-band { 
        display: flex; justify-content: space-between; align-items: center; 
        padding: 30px 50px; 
        background: linear-gradient(to bottom, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0) 100%); 
        pointer-events: auto; 
      }
      /* ▼ ロゴリンクの装飾を消すための設定 ▼ */
      .logo-area a { text-decoration: none; outline: none; }
      .header-logo-img { height: 48px; width: auto; transition: opacity 0.3s ease; } 
      .header-logo-img:hover { opacity: 0.8; } /* ホバー時に少し明るくします */
      
      .menu-trigger { background: none; border: none; cursor: pointer; display: flex; flex-direction: column; gap: 6px; }
      .burger-line { width: 30px; height: 2px; background: #fff; border-radius: 2px; }

      .side-menu { position: fixed; top: 0; right: -100%; width: 100%; height: 100%; background: rgba(10,10,10,0.98); z-index: 300; transition: right 0.6s cubic-bezier(0.2, 0.8, 0.2, 1); padding: 80px 40px; display: flex; justify-content: center; }
      .side-menu.is-open { right: 0; }
      .menu-close { position: absolute; top: 30px; right: 40px; font-size: 40px; background: none; border: none; color: #fff; cursor: pointer; }
      .menu-inner { max-width: 1000px; width: 100%; text-align: center; }
      .menu-inner h3 { font-size: 14px; letter-spacing: 4px; margin-bottom: 50px; color: #888; }
      .menu-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; }
      .menu-lang-card { padding: 40px; border: 1px solid rgba(255,255,255,0.1); border-radius: 4px; transition: 0.3s; background: linear-gradient(135deg, rgba(255,255,255,0.05) 0%, transparent 100%); text-decoration: none; color: white;}
      .menu-lang-card:hover { border-color: var(--accent); transform: translateY(-5px); }

      /* インジケーター（進行状況バー） */
      .scroll-indicator { position: fixed; top: 50%; right: 25px; transform: translateY(-50%); display: flex; flex-direction: column; gap: 12px; z-index: 500; }
      .scroll-indicator .dot { width: 6px; height: 6px; border-radius: 4px; background: rgba(255, 255, 255, 0.3); transition: all 0.4s cubic-bezier(0.2, 0.8, 0.2, 1); }
      .scroll-indicator .dot.active { height: 32px; background: rgba(255, 255, 255, 0.9); }
      @media (max-width: 768px) { .scroll-indicator { display: none; } }

      /* PC専用エリア */
      .desktop-only-area { width: 100vw; height: 100vh; display: flex; position: relative; overflow: hidden; }
      .left-track, .right-track { width: 50vw; height: 100vh; position: relative; }
      
      .panel { position: absolute; inset: 0; overflow: hidden; }
      .bg-layer { position: absolute; inset: 0; background-size: cover; background-position: center; }

      .left-track .p1 { z-index: 1; }
      .left-track .p2 { z-index: 2; clip-path: inset(100% 0 0 0); -webkit-clip-path: inset(100% 0 0 0); transition: clip-path 1.5s cubic-bezier(0.64, 0.04, 0.35, 1), -webkit-clip-path 1.5s cubic-bezier(0.64, 0.04, 0.35, 1); }
      .left-track .p3 { z-index: 3; clip-path: inset(100% 0 0 0); -webkit-clip-path: inset(100% 0 0 0); transition: clip-path 1.5s cubic-bezier(0.64, 0.04, 0.35, 1), -webkit-clip-path 1.5s cubic-bezier(0.64, 0.04, 0.35, 1); }

      .right-track .p1 { z-index: 1; }
      .right-track .p2 { z-index: 2; clip-path: inset(0 0 100% 0); -webkit-clip-path: inset(0 0 100% 0); transition: clip-path 1.5s cubic-bezier(0.64, 0.04, 0.35, 1), -webkit-clip-path 1.5s cubic-bezier(0.64, 0.04, 0.35, 1); }
      .right-track .p3 { z-index: 3; clip-path: inset(0 0 100% 0); -webkit-clip-path: inset(0 0 100% 0); transition: clip-path 1.5s cubic-bezier(0.64, 0.04, 0.35, 1), -webkit-clip-path 1.5s cubic-bezier(0.64, 0.04, 0.35, 1); }

      .panel.is-open { clip-path: inset(0 0 0 0) !important; -webkit-clip-path: inset(0 0 0 0) !important; }

      /* 白い帯と黒い文字 */
      .word-band-container { position: absolute; top: 50%; transform: translateY(-50%); z-index: 10; overflow: hidden; }
      .left-track .word-band-container { left: 0; }
      .right-track .word-band-container { right: 0; }

      .word-band { 
        background: rgba(255, 255, 255, 0.35); backdrop-filter: blur(12px); padding: 15px 50px; display: flex; align-items: center;
        transition: transform 1.2s cubic-bezier(0.2, 0.8, 0.2, 1);
      }
      .left-track .word-band { transform: translateX(-105%); border-radius: 0 4px 4px 0; }
      .right-track .word-band { transform: translateX(105%); border-radius: 4px 0 0 4px; }
      
      .word-band h2 { 
        color: #000; font-weight: 600; font-size: clamp(1.8rem, 3vw, 2.5rem); letter-spacing: 0.15em; margin: 0; opacity: 0; 
        transition: opacity 1s ease 0.8s; 
      }
      
      .panel.is-active .word-band { transform: translateX(0); }
      .panel.is-active .word-band h2 { opacity: 1; }

      .mobile-only-area { display: none; }
      @media (max-width: 768px) {
        .desktop-only-area { display: none; }
        .mobile-only-area { display: block; }
        body.is-locked { overflow: auto; } 
        .header-band { padding: 15px 20px; }
      }

      /* ==========================================
         4画面目：キャッチコピー画面
      ========================================== */
      .brand-section { height: 100vh; position: relative; display: flex; align-items: center; justify-content: center; text-align: center; overflow: hidden; }
      .brand-bg { position: absolute; inset: 0; background-size: cover; background-position: center; opacity: 0.6; transform: scale(1.15); transition: transform 3s cubic-bezier(0.2, 0.8, 0.2, 1); }
      .section-observer.is-visible .brand-bg { transform: scale(1); }
      .brand-bg-overlay { position: absolute; inset: 0; background: radial-gradient(circle, rgba(0,0,0,0.2) 0%, rgba(0,0,0,0.8) 100%); }
      
      .brand-content { position: relative; z-index: 3; display: flex; flex-direction: column; align-items: center; }
      .brand-logo-img { width: 250px; height: auto; margin-bottom: 30px; }
      .brand-catch { font-size: clamp(2rem, 4vw, 3.5rem); margin-bottom: 30px; font-weight: 300; letter-spacing: 0.05em; text-shadow: 0 4px 20px rgba(0,0,0,0.8); }
      
      .brand-desc p { font-size: clamp(1.4rem, 2.5vw, 2.2rem); font-weight: 300; color: #eee; margin-bottom: 15px; letter-spacing: 0.05em; text-shadow: 0 2px 10px rgba(0,0,0,0.8); }

      /* ▼ 修正：順番が狂わないアニメーション設定 ▼ */
      .fade-base { opacity: 0; transition: opacity 1.5s cubic-bezier(0.2, 0.8, 0.2, 1), transform 1.5s cubic-bezier(0.2, 0.8, 0.2, 1); }
      
      /* 下から上へ */
      .fade-up { transform: translateY(40px); }
      .text-anim-target.is-visible .fade-up { transform: translateY(0); opacity: 1; }
      
      /* 左から右へ */
      .fade-left { transform: translateX(-60px); }
      .text-anim-target.is-visible .fade-left { transform: translateX(0); opacity: 1; }

      /* ▼ 修正：一つ一つ順番に出るように秒数を細かく設定しました ▼ */
      .anim-logo { transition-delay: 0.2s; }    /* ロゴ：0.2秒後 */
      .anim-catch { transition-delay: 0.8s; }   /* キャッチコピー：0.8秒後 */
      .anim-desc1 { transition-delay: 1.4s; }   /* Global news.：1.4秒後 */
      .anim-desc2 { transition-delay: 2.0s; }   /* Explained clearly.：2.0秒後 */
      .anim-desc3 { transition-delay: 2.6s; }   /* In your language.：2.6秒後 */


      /* ==========================================
         5画面目以降：ヌルっと浮き出る設定
      ========================================== */
      /* ▼ 修正：コンテンツ全体がフワッと浮かび上がる魔法 ▼ */
      .section-fade-in {
        opacity: 0; transform: translateY(60px);
        transition: opacity 1.5s cubic-bezier(0.2, 0.8, 0.2, 1), transform 1.5s cubic-bezier(0.2, 0.8, 0.2, 1);
        width: 100%;
      }
      .section-observer.is-visible .section-fade-in {
        opacity: 1; transform: translateY(0);
      }

      .carousel-section { display: flex; flex-direction: column; justify-content: center; padding: 100px 0; min-height: 100vh; }
      .section-header { text-align: center; margin-bottom: 60px; padding: 0 20px; }
      .section-header h2 { font-size: 14px; letter-spacing: 3px; text-transform: uppercase; color: #888; font-weight: 600; }
      
      .carousel-wrapper { position: relative; width: 100%; }
      .nav-arrow {
        position: absolute; top: 50%; transform: translateY(-50%);
        background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.3);
        color: white; width: 60px; height: 60px; border-radius: 50%;
        cursor: pointer; z-index: 20; font-size: 24px;
        transition: background 0.3s ease, transform 0.2s ease;
        display: none; 
      }
      .nav-arrow:hover { background: rgba(255,255,255,0.3); transform: translateY(-50%) scale(1.05); }
      .left-arrow { left: 4vw; }
      .right-arrow { right: 4vw; }
      @media (min-width: 769px) { .nav-arrow { display: flex; align-items: center; justify-content: center; } }

      .carousel-container { display: flex; overflow-x: auto; scroll-snap-type: x mandatory; scroll-behavior: smooth; padding-bottom: 40px; align-items: center; -ms-overflow-style: none; scrollbar-width: none; }
      .carousel-container::-webkit-scrollbar { display: none; }
      .carousel-spacer { flex: 0 0 calc(50vw - 20vw); }
      
      .observer-card { scroll-snap-align: center; flex: 0 0 40vw; height: 60vh; margin: 0 1.5vw; position: relative; border-radius: 4px; overflow: hidden; transition: transform 0.6s ease, opacity 0.6s ease; opacity: 0.4; transform: scale(0.85); display: block; user-select: none; }
      .observer-card.is-center { opacity: 1; transform: scale(1); box-shadow: 0 20px 50px rgba(0,0,0,0.5); z-index: 10; }
      
      .story-card .card-bg { position: absolute; inset: 0; background-size: cover; background-position: center; transition: transform 0.8s ease; }
      .story-card.is-center:hover .card-bg { transform: scale(1.05); }
      .story-card::after { content: ''; position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.2) 50%, rgba(0,0,0,0) 100%); }
      .card-content { position: absolute; bottom: 0; left: 0; width: 100%; padding: 40px; z-index: 2; display: flex; flex-direction: column; justify-content: flex-end; height: 100%; pointer-events: none; }
      .card-meta { display: flex; gap: 12px; margin-bottom: 16px; font-size: 12px; font-weight: 600; letter-spacing: 1px; text-transform: uppercase; }
      .card-meta .category { color: #fff; border-bottom: 1px solid rgba(255,255,255,0.4); padding-bottom: 4px; }
      .card-meta .country { color: #888; }
      .card-title { font-size: clamp(1.2rem, 2vw, 2rem); font-weight: 400; line-height: 1.3; margin-bottom: 16px; }
      .card-excerpt { font-size: 14px; color: #ccc; margin-bottom: 24px; display: none; line-height: 1.5; }
      .story-card.is-center .card-excerpt { display: block; }
      .cta-link { font-size: 12px; text-transform: uppercase; letter-spacing: 1px; color: #fff; display: flex; align-items: center; gap: 8px; opacity: 0; transform: translateY(10px); transition: all 0.4s ease; }
      .story-card.is-center .cta-link { opacity: 1; transform: translateY(0); }
      
      .lang-card { flex: 0 0 28vw; height: 50vh; display: flex; align-items: center; justify-content: center; border: 1px solid rgba(255,255,255,0.05); }
      .lang-bg { position: absolute; inset: 0; opacity: 0.15; transition: opacity 0.4s ease; }
      .lang-card.is-center .lang-bg { opacity: 0.8; }
      .lang-content { position: relative; z-index: 2; width: 100%; height: 100%; padding: 40px; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; pointer-events: none; }
      .lang-logo { position: absolute; bottom: 30px; left: 30px; font-size: 12px; letter-spacing: 2px; opacity: 0.5; }
      .lang-name { font-size: clamp(1.5rem, 3vw, 2.5rem); font-weight: 300; letter-spacing: 0.05em; transition: transform 0.4s ease; color: #fff; }
      .lang-border { width: 0; height: 1px; background: #fff; margin-top: 20px; transition: width 0.6s cubic-bezier(0.2, 0.8, 0.2, 1); opacity: 0.5; }
      .lang-card.is-center .lang-border { width: 40px; }
      .lang-card.is-center:hover .lang-name { transform: scale(1.05); }
    </style>

    <script is:inline>
      // 更新ボタンを押した時に、必ず一番上からスタートさせる安全装置
      if ('scrollRestoration' in history) {
        history.scrollRestoration = 'manual';
      }
      window.scrollTo(0, 0);

      document.addEventListener('DOMContentLoaded', () => {
        let currentSlide = 0; 
        let isLocked = true;  
        let isAnimating = false; 

        const header = document.getElementById('main-header');
        
        // インジケーター（右の点々）を更新する機能
        const dots = document.querySelectorAll('.scroll-indicator .dot');
        function updateIndicator(index) {
          dots.forEach((dot, i) => {
            if (i === index) dot.classList.add('active');
            else dot.classList.remove('active');
          });
        }

        window.addEventListener('wheel', (e) => {
          if (window.innerWidth <= 768) return;

          if (isLocked) {
            e.preventDefault(); 
            if (isAnimating) return; 

            if (e.deltaY > 50) {
              if (currentSlide < 2) {
                goToSlide(currentSlide + 1);
              } else {
                unlockAndScrollDown();
              }
            } else if (e.deltaY < -50) {
              if (currentSlide > 0) {
                goToSlide(currentSlide - 1);
              }
            }
          } else {
            if (window.scrollY <= 0 && e.deltaY < -50 && !isAnimating) {
              e.preventDefault();
              lockAndScrollUp();
            }
          }
        }, { passive: false }); 

        function goToSlide(index) {
          isAnimating = true;
          currentSlide = index;
          updateIndicator(index);

          const l2 = document.querySelector('.left-track .p2');
          const l3 = document.querySelector('.left-track .p3');
          const r2 = document.querySelector('.right-track .p2');
          const r3 = document.querySelector('.right-track .p3');

          document.querySelectorAll('.desktop-only-area .panel').forEach(p => p.classList.remove('is-active'));

          if (index === 0) {
            l2.classList.remove('is-open'); r2.classList.remove('is-open');
            l3.classList.remove('is-open'); r3.classList.remove('is-open');
          } else if (index === 1) {
            l2.classList.add('is-open'); r2.classList.add('is-open');
            l3.classList.remove('is-open'); r3.classList.remove('is-open');
          } else if (index === 2) {
            l2.classList.add('is-open'); r2.classList.add('is-open');
            l3.classList.add('is-open'); r3.classList.add('is-open');
          }

          setTimeout(() => {
            const leftPanels = document.querySelectorAll('.left-track .panel');
            const rightPanels = document.querySelectorAll('.right-track .panel');
            leftPanels[index].classList.add('is-active');
            rightPanels[index].classList.add('is-active');
            isAnimating = false;
          }, 1500); 
        }

        function unlockAndScrollDown() {
          isAnimating = true;
          isLocked = false;
          document.body.classList.remove('is-locked'); 
          
          document.getElementById('screen-4').scrollIntoView({ behavior: 'smooth' });
          
          setTimeout(() => { isAnimating = false; }, 1000);
        }

        function lockAndScrollUp() {
          isAnimating = true;
          isLocked = true;
          document.body.classList.add('is-locked'); 
          window.scrollTo(0, 0); 
          goToSlide(2);
        }

        setTimeout(() => {
          document.querySelector('.left-track .p1').classList.add('is-active');
          document.querySelector('.right-track .p1').classList.add('is-active');
        }, 500);

        const sideMenu = document.getElementById('side-menu');
        document.getElementById('menu-open').onclick = () => sideMenu.classList.add('is-open');
        document.getElementById('menu-close').onclick = () => sideMenu.classList.remove('is-open');

        // ▼ 修正：全体のヌルっと効果とインジケーターの連動（早めに発動させるよう0.15に調整） ▼
        const sectionObserver = new IntersectionObserver((entries) => {
          entries.forEach(en => { 
            if(en.isIntersecting) {
              en.target.classList.add('is-visible'); 
              if (en.target.id === 'screen-4') updateIndicator(3);
              if (en.target.id === 'screen-5') updateIndicator(4);
              if (en.target.id === 'screen-6') updateIndicator(5);
            }
          });
        }, { threshold: 0.15 });
        document.querySelectorAll('.section-observer').forEach(el => sectionObserver.observe(el));

        // 文字の順番スライドイン
        const textObserver = new IntersectionObserver((entries) => {
          entries.forEach(en => { 
            if(en.isIntersecting) {
              en.target.classList.add('is-visible'); 
            } else {
              en.target.classList.remove('is-visible');
            }
          });
        }, { threshold: 0.2 }); 
        document.querySelectorAll('.text-anim-target').forEach(el => textObserver.observe(el));

        const carouselObserver = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) entry.target.classList.add('is-center');
            else entry.target.classList.remove('is-center');
          });
        }, { root: null, rootMargin: "0px -40% 0px -40%", threshold: 0 });
        document.querySelectorAll('.observer-card').forEach(card => carouselObserver.observe(card));

        // 矢印ボタンによる横スクロール
        document.querySelectorAll('.carousel-wrapper').forEach(wrapper => {
          const container = wrapper.querySelector('.carousel-container');
          const leftBtn = wrapper.querySelector('.left-arrow');
          const rightBtn = wrapper.querySelector('.right-arrow');

          leftBtn.addEventListener('click', () => {
            container.scrollBy({ left: -window.innerWidth * 0.4, behavior: 'smooth' });
          });
          rightBtn.addEventListener('click', () => {
            container.scrollBy({ left: window.innerWidth * 0.4, behavior: 'smooth' });
          });
        });

      });
    </script>
  </body>
</html>
