---
import Layout from '../layouts/Layout.astro';
import MainNewsLayout from '../components/MainNewsLayout.astro';
import TrendScroll from '../components/TrendScroll.astro';
import GoogleAdBanner from '../components/GoogleAdBanner.astro';
import CategoryNews from '../components/CategoryNews.astro';
import RegionNewsBlock from '../components/RegionNewsBlock.astro';

const API_KEY = import.meta.env.API_KEY;
const BLOG_ID = import.meta.env.BLOG_ID;
const url = `https://www.googleapis.com/blogger/v3/blogs/${BLOG_ID}/posts?key=${API_KEY}&maxResults=50`;
const response = await fetch(url).catch(() => null);
const data = response ? await response.json() : { items: [] };
const allPosts = data.items || [];

const filterByLabel = (labelName, count = 2) => {
  return allPosts.filter(post => post.labels && post.labels.includes(labelName)).slice(0, count);
};
---
<Layout title="TOP">
  <div slot="top-full">
    <MainNewsLayout />
    <TrendScroll />
  </div>

  {/* Layout側で2列にしてくれるので、ここでは純粋に記事だけを並べます */}
  <GoogleAdBanner position="上部" />
  <div class="genre-grid">
    <CategoryNews title="医療・健康" posts={filterByLabel("医療")} />
    <CategoryNews title="教育" posts={filterByLabel("教育")} />
    <CategoryNews title="文化" posts={filterByLabel("文化")} />
    <CategoryNews title="くらし" posts={filterByLabel("くらし")} />
    <CategoryNews title="社会" posts={filterByLabel("社会")} />
    <CategoryNews title="経済" posts={filterByLabel("経済")} />
    <CategoryNews title="テクノロジー" posts={filterByLabel("テクノロジー")} />
    <CategoryNews title="スポーツ" posts={filterByLabel("スポーツ")} />
    <CategoryNews title="エンタメ" posts={filterByLabel("エンタメ")} />
    <CategoryNews title="国際" posts={filterByLabel("国際")} />
  </div>
  <GoogleAdBanner position="下部" />

  <div slot="bottom-wide">
    <RegionNewsBlock title="北米" cityData={[]} />
    <RegionNewsBlock title="ヨーロッパ" cityData={[]} />
  </div>
</Layout>

<style>
  .genre-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  @media (max-width: 900px) { .genre-grid { grid-template-columns: 1fr; } }
</style>
