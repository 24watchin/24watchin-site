---
// src/pages/[lang]/[country]/info/index.astro
export function getStaticPaths() {
  // 運用している lang と country の組み合わせを記述します
  return [
    { params: { lang: 'en', country: 'us' } },
    { params: { lang: 'ja', country: 'jp' } },
    // 他の組み合わせも必要に応じて追加してください
  ];
}

const { lang, country } = Astro.params;
const target = `/${lang}/${country}/info/about/`;
---
<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <title>Redirecting...</title>
    <link rel="canonical" href={target} />
    <meta http-equiv="refresh" content={`0;url=${target}`} />
  </head>
  <body>
    <script is:inline define:vars={{ target }}>
      window.location.href = target;
    </script>
  </body>
</html>
