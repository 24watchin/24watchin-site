const descriptions: Record<string, string> = {
  ja: '24Watchinへのお問い合わせはこちらから。記事の訂正・転載・著作権などもお気軽にどうぞ。',
  en: 'Contact 24Watchin here. Feel free to reach out about article corrections, reprints, copyright, and more.',
  de: 'Kontaktieren Sie 24Watchin hier.',
  fr: 'Contactez 24Watchin ici.',
  es: 'Contacte a 24Watchin aquí.',
  ru: 'Свяжитесь с 24Watchin здесь.',
  'zh-cn': '在这里联系24Watchin。',
  'zh-tw': '在這裡聯絡24Watchin。',
