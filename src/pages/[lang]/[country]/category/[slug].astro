---
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import Layout from '../../../../layouts/Layout.astro';
import CategoryHero from '../../../../components/CategoryHero.astro';
import NewsList from '../../../../components/NewsList.astro';
import { categoryLabelMap, type SiteLanguageKey } from '../../../../lib/categoryLabels.ts';

export async function getStaticPaths() {
  const langCountryPairs = [
    { lang: 'ja',    country: 'jp' },
    { lang: 'en',    country: 'jp' },
    { lang: 'en',    country: 'us' },
    { lang: 'en',    country: 'ae' },
    { lang: 'en',    country: 'au' },
    { lang: 'en',    country: 'gb' },
    { lang: 'en',    country: 'sg' },
    { lang: 'en',    country: 'ca' },
    { lang: 'zh-cn', country: 'jp' },
    { lang: 'zh-cn', country: 'cn' },
    { lang: 'zh-tw', country: 'jp' },
    { lang: 'zh-tw', country: 'tw' },
    { lang: 'es',    country: 'jp' },
    { lang: 'es',    country: 'es' },
    { lang: 'fr',    country: 'jp' },
    { lang: 'fr',    country: 'fr' },
    { lang: 'de',    country: 'jp' },
    { lang: 'de',    country: 'de' },
    { lang: 'ru',    country: 'jp' },
  ];

  const localeKeyMap: Record<string, string> = {
    ja: 'jp', en: 'en', 'zh-cn': 'zh-cn', 'zh-tw': 'zh-tw',
    es: 'es', fr: 'fr', de: 'de', ru: 'ru',
  };

  const paths = [];
  for (const { lang, country } of langCountryPairs) {
    const localeKey = (localeKeyMap[lang] || 'jp') as SiteLanguageKey;
    const slugs = categoryLabelMap[localeKey].allCategories.map(cat => cat.slug);
    for (const slug of slugs) {
      paths.push({ params: { lang, country, slug } });
    }
  }
  return paths;
}

const { lang, country, slug } = Astro.params;

const localeKeyMap: Record<string, string> = {
  ja: 'jp', en: 'en', 'zh-cn': 'zh-cn', 'zh-tw': 'zh-tw',
  es: 'es', fr: 'fr', de: 'de', ru: 'ru',
};
const localeKey = (localeKeyMap[lang] || 'jp') as SiteLanguageKey;
const labels = categoryLabelMap[localeKey] || categoryLabelMap.jp;

// ▼ 言語別BLOG_ID
const blogIdMap: Record<string, string> = {
  ja:      import.meta.env.BLOG_ID_JA,
  en:      import.meta.env.BLOG_ID_EN,
  'zh-cn': import.meta.env.BLOG_ID_ZH_CN,
  'zh-tw': import.meta.env.BLOG_ID_ZH_TW,
  es:      import.meta.env.BLOG_ID_ES,
  fr:      import.meta.env.BLOG_ID_FR,
  de:      import.meta.env.BLOG_ID_DE,
  ru:      import.meta.env.BLOG_ID_RU,
};
const BLOG_ID = blogIdMap[lang] || import.meta.env.BLOG_ID_JA;
const API_KEY = import.meta.env.API_KEY;

// ▼ 言語別キャッシュ（API制限回避の最強版）
const cacheKey = 'bloggerPostsCache_' + lang;

if (!globalThis[cacheKey]) {
  const url = 'https://www.googleapis.com/blogger/v3/blogs/' + BLOG_ID + '/posts?key=' + API_KEY + '&maxResults=500';
  globalThis[cacheKey] = fetch(url)
    .then(res => res.ok ? res.json() : { items: [] })
    .then(data => data.items || [])
    .catch(err => {
      console.error("記事の取得に失敗しました", err);
      return [];
    });
}

const allPosts = await globalThis[cacheKey];

const catData = labels.allCategories.find(c => c.slug === slug);
const categoryName = catData ? catData.label : slug;
const keywords = catData ? catData.keywords : [slug];

const targetTag = lang + '-' + country;
const mainSitePosts = allPosts.filter(post => {
  if (!post.labels) return false;
  return post.labels.includes(targetTag);
});

const categoryPosts = mainSitePosts.filter(post => {
  if (!post.labels) return false;
  return post.labels.some(label => keywords.some(key => label.includes(key)));
});

const getImageUrl = (content) => {
  const match = (content || '').match(/<img[^>]+src="([^">]+)"/);
  return match ? match[1] : 'https://placehold.co/600x400/eeeeee/999999?text=No+Image';
};

const countryLabelMap: Record<string, Record<string, string>> = {
  jp: { ja: '日本', en: 'Japan', 'zh-cn': '日本', 'zh-tw': '日本', es: 'Japón', fr: 'Japon', de: 'Japan', ru: 'Япония' },
  us: { ja: 'アメリカ', en: 'USA', 'zh-cn': '美国', 'zh-tw': '美國', es: 'EE.UU.', fr: 'États-Unis', de: 'USA', ru: 'США' },
  ae: { ja: 'UAE', en: 'UAE', 'zh-cn': '阿联酋', 'zh-tw': '阿聯酋', es: 'EAU', fr: 'EAU', de: 'VAE', ru: 'ОАЭ' },
  au: { ja: 'オーストラリア', en: 'Australia', 'zh-cn': '澳大利亚', 'zh-tw': '澳洲', es: 'Australia', fr: 'Australie', de: 'Australien', ru: 'Австралия' },
  gb: { ja: 'イギリス', en: 'UK', 'zh-cn': '英国', 'zh-tw': '英國', es: 'Reino Unido', fr: 'Royaume-Uni', de: 'Großbritannien', ru: 'Великобритания' },
  sg: { ja: 'シンガポール', en: 'Singapore', 'zh-cn': '新加坡', 'zh-tw': '新加坡', es: 'Singapur', fr: 'Singapour', de: 'Singapur', ru: 'Сингапур' },
  ca: { ja: 'カナダ', en: 'Canada', 'zh-cn': '加拿大', 'zh-tw': '加拿大', es: 'Canadá', fr: 'Canada', de: 'Kanada', ru: 'Канада' },
  cn: { ja: '中国', en: 'China', 'zh-cn': '中国', 'zh-tw': '中國', es: 'China', fr: 'Chine', de: 'China', ru: 'Китай' },
  tw: { ja: '台湾', en: 'Taiwan', 'zh-cn': '台湾', 'zh-tw': '台灣', es: 'Taiwán', fr: 'Taïwan', de: 'Taiwan', ru: 'Тайвань' },
  es: { ja: 'スペイン', en: 'Spain', 'zh-cn': '西班牙', 'zh-tw': '西班牙', es: 'España', fr: 'Espagne', de: 'Spanien', ru: 'Испания' },
  fr: { ja: 'フランス', en: 'France', 'zh-cn': '法国', 'zh-tw': '法國', es: 'Francia', fr: 'France', de: 'Frankreich', ru: 'Франция' },
  de: { ja: 'ドイツ', en: 'Germany', 'zh-cn': '德国', 'zh-tw': '德國', es: 'Alemania', fr: 'Allemagne', de: 'Deutschland', ru: 'Германия' },
};
const countryLabel = countryLabelMap[country]?.[lang] || country.toUpperCase();
const countryHref = '/' + lang + '/' + country + '/';

const moreNewsMap: Record<string, string> = {
  ja:      'その他の' + categoryName + 'ニュース',
  en:      'More ' + categoryName + ' News',
  'zh-cn': '更多' + categoryName + '新闻',
  'zh-tw': '更多' + categoryName + '新聞',
  es:      'Más noticias de ' + categoryName,
  fr:      'Plus de nouvelles sur ' + categoryName,
  de:      'Weitere ' + categoryName + '-Nachrichten',
  ru:      'Больше новостей: ' + categoryName,
};
const moreNewsTitle = moreNewsMap[lang] || moreNewsMap['en'];

const emptyMessageMap: Record<string, string> = {
  ja:      'この記事は現在準備中です。',
  en:      'No articles available yet.',
  'zh-cn': '暂无文章。',
  'zh-tw': '暫無文章。',
  es:      'No hay artículos disponibles aún.',
  fr:      'Aucun article disponible pour le moment.',
  de:      'Noch keine Artikel verfügbar.',
  ru:      'Статьи пока недоступны.',
};
const emptyMessage = emptyMessageMap[lang] || emptyMessageMap['en'];
---

<Layout title={categoryName} sidebarType="category" allPosts={allPosts}>
  <Breadcrumb
    countryLabel={countryLabel}
    countryHref={countryHref}
    categoryLabel={categoryName}
    categoryHref={'/' + lang + '/' + country + '/category/' + slug + '/'}
  />

  {categoryPosts.length > 0 ?
    (
      <>
        <CategoryHero posts={categoryPosts} categoryName={categoryName} getImageUrl={getImageUrl} lang={lang} country={country} />
        <hr class="divider" />
        <h2 class="section-title">{moreNewsTitle}</h2>
        <NewsList posts={categoryPosts.slice(5)} getImageUrl={getImageUrl} lang={lang} country={country} />
      </>
    ) : (
      <p class="empty-message">{emptyMessage}</p>
    )}
</Layout>

<style>
  .divider { border: 0; border-top: 1px solid #eee; margin: 1rem 0 1.5rem; }
  .section-title { font-size: 1.5rem; border-left: 5px solid var(--theme-color, #872732); padding-left: 1rem; font-weight: bold; margin-bottom: 1.25rem; color: #1a1a1a; }
  .empty-message { color: #666; font-size: 16px; margin: 20px 0 0; }
</style>

