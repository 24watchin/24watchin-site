---
import Layout from '../../../layouts/Layout.astro';
import RelatedNews from '../../../components/RelatedNews.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import { getWeatherCondition, getUnitSystem, convertTemp, convertWind } from '../../../lib/weatherConditions';
import { countryCityMap } from '../../../lib/cityConfig';
import { langCountryPairs, getBlogId } from '../../../lib/siteRoutes.ts';

export async function getStaticPaths() {
  return langCountryPairs.map(({ lang, country }) => ({ params: { lang, country } }));
}

const { lang, country } = Astro.params;

const apiLangMap: Record<string, string> = {
  ja: 'ja', en: 'en', 'zh-cn': 'zh', 'zh-tw': 'zh',
  fr: 'fr', de: 'de', es: 'es', ru: 'ru',
};
const apiLang = apiLangMap[lang] || 'en';
const { isImperial, tempUnit, windUnit } = getUnitSystem(lang);

const API_KEY = import.meta.env.API_KEY;
const BLOG_ID = getBlogId(lang);
const WEATHER_API_KEY = import.meta.env.WEATHER_API_KEY;

let allPosts = globalThis.bloggerPostsCache || [];
if (allPosts.length === 0 && API_KEY && BLOG_ID) {
  const url = 'https://www.googleapis.com/blogger/v3/blogs/' + BLOG_ID + '/posts?key=' + API_KEY + '&maxResults=100';
  const response = await fetch(url).catch(() => null);
  if (response && response.ok) {
    const data = await response.json();
    allPosts = data.items || [];
    globalThis.bloggerPostsCache = allPosts;
  }
}

const targetTag = lang + '-' + country;
const relatedNews = allPosts.filter((post: any) =>
  post.labels &&
  post.labels.includes(targetTag) &&
  post.labels.some((label: string) => ['天気', '気象', '災害', 'weather', 'Weather'].includes(label))
).slice(0, 3);
const cities = countryCityMap[country] || countryCityMap['jp'];

const tzMap: Record<string, string> = {
  jp: 'Asia/Tokyo',          us: 'America/New_York',    de: 'Europe/Berlin',
  fr: 'Europe/Paris',        gb: 'Europe/London',       tw: 'Asia/Taipei',
  kr: 'Asia/Seoul',          cn: 'Asia/Shanghai',       sg: 'Asia/Singapore',
  au: 'Australia/Sydney',    ae: 'Asia/Dubai',          es: 'Europe/Madrid',
  ca: 'America/Toronto',     nz: 'Pacific/Auckland',    hk: 'Asia/Hong_Kong',
  in: 'Asia/Kolkata',        my: 'Asia/Kuala_Lumpur',   ph: 'Asia/Manila',
  th: 'Asia/Bangkok',        vn: 'Asia/Ho_Chi_Minh',    id: 'Asia/Jakarta',
  mx: 'America/Mexico_City', br: 'America/Sao_Paulo',   ar: 'America/Argentina/Buenos_Aires',
  co: 'America/Bogota',      za: 'Africa/Johannesburg', eg: 'Africa/Cairo',
  qa: 'Asia/Qatar',          om: 'Asia/Muscat',         sa: 'Asia/Riyadh',
  tr: 'Europe/Istanbul',     nl: 'Europe/Amsterdam',    ch: 'Europe/Zurich',
  se: 'Europe/Stockholm',    no: 'Europe/Oslo',         dk: 'Europe/Copenhagen',
  pt: 'Europe/Lisbon',       gr: 'Europe/Athens',       it: 'Europe/Rome',
  bd: 'Asia/Dhaka',          np: 'Asia/Kathmandu',
};
const allForecastData: Record<string, any> = {};
for (const city of cities) {
  if (!WEATHER_API_KEY) break;
  try {
    const weatherUrl = 'https://api.weatherapi.com/v1/forecast.json?key=' + WEATHER_API_KEY + '&q=' + city.key + '&days=5&aqi=no&alerts=yes&lang=' + apiLang;
    const wResponse = await fetch(weatherUrl);
    if (wResponse.ok) {
      const wData = await wResponse.json();
      allForecastData[city.key] = {
        alertText: (wData.alerts?.alert || []).map((a: any) => a.headline).join(' / '),
        timezone: tzMap[country] || 'Asia/Tokyo',
        forecastDays: wData.forecast.forecastday.map((day: any) => ({
          date: day.date,
          conditionText: getWeatherCondition(day.day.condition.code, lang),
          conditionIcon: day.day.condition.icon,
          maxtemp: convertTemp(day.day.maxtemp_c, isImperial),
          mintemp: convertTemp(day.day.mintemp_c, isImperial),
          rainChance: day.day.daily_chance_of_rain,
          hour: day.hour.map((h: any) => ({
            time: h.time.split(' ')[1],
            conditionText: getWeatherCondition(h.condition.code, lang),
            conditionIcon: h.condition.icon,
            temp: convertTemp(h.temp_c, isImperial),
            humidity: h.humidity,
            wind: convertWind(h.wind_kph, isImperial),
            rainChance: h.chance_of_rain,
          })),
        })),
      };
    }
  } catch (e) {}
}

const defaultCity = cities[0];
const defaultCityName = defaultCity.display[lang] || defaultCity.display['en'] || defaultCity.key;
const storageKey = 'watchin_weather_city_' + country;

const allLabels: Record<string, Record<string, string>> = {
  ja:      { title: '3日間の天気予報', alertTitle: '気象・災害情報', hourly: '1時間ごと', time: '時刻', weather: '天気', rain: '降水確率', humidity: '湿度', wind: '風速', max: '最高', min: '最低', temp: '気温' },
  en:      { title: '3-Day Forecast', alertTitle: 'Weather/Disaster Info', hourly: 'Hourly', time: 'Time', weather: 'Weather', rain: 'Rain', humidity: 'Humid', wind: 'Wind', max: 'Max', min: 'Min', temp: 'Temp' },
  'zh-cn': { title: '3天天气预报', alertTitle: '气象·灾害信息', hourly: '每小时', time: '时间', weather: '天气', rain: '降水概率', humidity: '湿度', wind: '风速', max: '最高', min: '最低', temp: '气温' },
  'zh-tw': { title: '3天天氣預報', alertTitle: '氣象・災害資訊', hourly: '每小時', time: '時間', weather: '天氣', rain: '降水概率', humidity: '濕度', wind: '風速', max: '最高', min: '最低', temp: '氣溫' },
  es:      { title: 'Pronóstico de 3 días', alertTitle: 'Info Meteorológica', hourly: 'Por hora', time: 'Hora', weather: 'Tiempo', rain: 'Lluvia', humidity: 'Humedad', wind: 'Viento', max: 'Máx', min: 'Mín', temp: 'Temp' },
  fr:      { title: 'Prévisions sur 3 jours', alertTitle: 'Infos Météo', hourly: 'Par heure', time: 'Heure', weather: 'Météo', rain: 'Pluie', humidity: 'Humidité', wind: 'Vent', max: 'Max', min: 'Min', temp: 'Temp' },
  de:      { title: '3-Tage-Vorhersage', alertTitle: 'Wetter-/Katastropheninfo', hourly: 'Stündlich', time: 'Zeit', weather: 'Wetter', rain: 'Regen', humidity: 'Feuchte', wind: 'Wind', max: 'Max', min: 'Min', temp: 'Temp' },
  ru:      { title: 'Прогноз на 3 дня', alertTitle: 'Погода/Катастрофы', hourly: 'По часам', time: 'Время', weather: 'Погода', rain: 'Дождь', humidity: 'Влажн.', wind: 'Ветер', max: 'Макс', min: 'Мин', temp: 'Темп.' },
};
const labels = allLabels[lang] || allLabels['en'];

const weatherPageLabels: Record<string, string> = {
  ja:      '天気予報・災害',
  en:      'Weather Forecast & Disasters',
  'zh-cn': '天气预报・灾害',
  'zh-tw': '天氣預報・災害',
  es:      'Pronóstico del Tiempo y Desastres',
  fr:      'Prévisions Météo et Catastrophes',
  de:      'Wettervorhersage & Katastrophen',
  ru:      'Прогноз погоды и катастрофы',
};
const weatherPageLabel = weatherPageLabels[lang] || weatherPageLabels['en'];

const countryLabelMap: Record<string, Record<string, string>> = {
  jp: { ja: '日本', en: 'Japan', 'zh-cn': '日本', 'zh-tw': '日本', es: 'Japón', fr: 'Japon', de: 'Japan', ru: 'Япония' },
  us: { ja: 'アメリカ', en: 'USA', 'zh-cn': '美国', 'zh-tw': '美國', es: 'EE.UU.', fr: 'États-Unis', de: 'USA', ru: 'США' },
  de: { ja: 'ドイツ', en: 'Germany', 'zh-cn': 'ドイツ', 'zh-tw': 'ドイツ', es: 'Alemania', fr: 'Allemagne', de: 'Deutschland', ru: 'ドイツ' },
  fr: { ja: 'フランス', en: 'France', 'zh-cn': 'フランス', 'zh-tw': 'フランス', es: 'Francia', fr: 'France', de: 'Frankreich', ru: 'フランス' },
  es: { ja: 'スペイン', en: 'Spain', 'zh-cn': 'スペイン', 'zh-tw': 'スペイン', es: 'España', fr: 'Espagne', de: 'Spanien', ru: 'スペイン' },
  gb: { ja: 'イギリス', en: 'UK', 'zh-cn': 'イギリス', 'zh-tw': 'イギリス', es: 'Reino Unido', fr: 'Royaume-Uni', de: 'UK', ru: 'イギリス' },
  cn: { ja: '中国', en: 'China', 'zh-cn': '中国', 'zh-tw': '中國', es: 'China', fr: 'Chine', de: 'China', ru: '中国' },
  tw: { ja: '台湾', en: 'Taiwan', 'zh-cn': '台湾', 'zh-tw': '台灣', es: 'Taiwán', fr: 'Taïwan', de: 'Taiwan', ru: 'タイワン' },
  ae: { ja: 'UAE（アラブ首長国連邦）', en: 'UAE', 'zh-cn': '阿联酋', 'zh-tw': '阿聯酋', es: 'EAU', fr: 'ÉAU', de: 'VAE', ru: 'ОАЭ' },
  au: { ja: 'オーストラリア', en: 'Australia', 'zh-cn': '澳大利亚', 'zh-tw': '澳大利亞', es: 'Australia', fr: 'Australie', de: 'Australien', ru: 'オーストラリア' },
  sg: { ja: 'シンガポール', en: 'Singapore', 'zh-cn': '新加坡', 'zh-tw': '新加坡', es: 'Singapur', fr: 'Singapour', de: 'Singapur', ru: 'シンガポール' },
  ca: { ja: 'カナダ', en: 'Canada', 'zh-cn': 'カナダ', 'zh-tw': 'カナダ', es: 'Canadá', fr: 'Canada', de: 'Kanada', ru: 'カナダ' },
  nz: { ja: 'ニュージーランド', en: 'New Zealand', 'zh-cn': 'ニュージーランド', 'zh-tw': '紐西蘭', es: 'Nueva Zelanda', fr: 'Nouvelle-Zélande', de: 'Neuseeland', ru: 'ニュージーランド' },
  hk: { ja: '香港', en: 'Hong Kong', 'zh-cn': '香港', 'zh-tw': '香港', es: 'Hong Kong', fr: 'Hong Kong', de: 'Hongkong', ru: 'ホンコン' },
  in: { ja: 'インド',   en: 'India',     'zh-cn': 'インド',   'zh-tw': 'インド',   es: 'India',     fr: 'Inde',     de: 'Indien',     ru: 'インド'      },
  my: { ja: 'マレーシア', en: 'Malaysia',  'zh-cn': 'マレーシア', 'zh-tw': '馬來西亞', es: 'Malasia',   fr: 'Malaisie',  de: 'Malaysia',   ru: 'マレーシア'     },
  ph: { ja: 'フィリピン', en: 'Philippines', 'zh-cn': 'フィリピン', 'zh-tw': 'フィリピン', es: 'Filipinas',  fr: 'Philippines', de: 'Philippinen', ru: 'フィリピン'   },
  th: { ja: 'タイ',     en: 'Thailand',    'zh-cn': 'タイ',     'zh-tw': '泰國',     es: 'Tailandia',  fr: 'Thaïlande',  de: 'Thailand',   ru: 'タイ'       },
  vn: { ja: 'ベトナム',   en: 'Vietnam',     'zh-cn': 'ベトナム',   'zh-tw': '越南',     es: 'Vietnam',    fr: 'Vietnam',    de: 'Vietnam',    ru: 'ベトナム'     },
  id: { ja: 'インドネシア', en: 'Indonesia',   'zh-cn': 'インドネシア', 'zh-tw': '印尼',     es: 'Indonesia',  fr: 'Indonésie',  de: 'Indonesien', ru: 'インドネシア'   },
  kr: { ja: '韓国',     en: 'South Korea', 'zh-cn': '韓国',     'zh-tw': '韓國',     es: 'Corea del Sur', fr: 'Corée du Sud', de: 'Südkorea',     ru: 'カンコク'      },
  mx: { ja: 'メキシコ',   en: 'Mexico',      'zh-cn': 'メキシコ',   'zh-tw': '墨西哥',   es: 'México',     fr: 'Mexique',    de: 'Mexiko',     ru: 'メキシコ'     },
  br: { ja: 'ブラジル',   en: 'Brazil',      'zh-cn': 'ブラジル',   'zh-tw': '巴西',     es: 'Brasil',     fr: 'Brésil',     de: 'Brasilien',  ru: 'ブラジル'     },
  za: { ja: '南アフリカ', en: 'South Africa', 'zh-cn': '南アフリカ', 'zh-tw': '南非',     es: 'Sudáfrica',  fr: 'Afrique du Sud', de: 'Südafrika',  ru: 'ミナミアフリカ'   },
  eg: { ja: 'エジプト',   en: 'Egypt',       'zh-cn': 'エジプト',   'zh-tw': '埃及',     es: 'Egipto',     fr: 'Égypte',     de: 'Ägypten',    ru: 'エジプト'     },
  qa: { ja: 'カタール',   en: 'Qatar',       'zh-cn': 'カタール',   'zh-tw': '卡達',     es: 'Catar',      fr: 'Qatar',      de: 'Katar',      ru: 'カタール'     },
  om: { ja: 'オマーン',   en: 'Oman',        'zh-cn': 'オマーン',   'zh-tw': '阿曼',     es: 'Omán',       fr: 'Oman',       de: 'Oman',       ru: 'オマーン'     },
  sa: { ja: 'サウジアラビア', en: 'Saudi Arabia', 'zh-cn': 'サウジアラビア', 'zh-tw': '沙烏地阿拉伯', es: 'Arabia Saudita', fr: 'Arabie Saoudite', de: 'Saudi-Arabien', ru: 'サウジアラビア' },
  tr: { ja: 'トルコ',     en: 'Turkey',      'zh-cn': 'トルコ',     'zh-tw': '土耳其',   es: 'Turquía',    fr: 'Turquie',    de: 'Türkei',     ru: 'トルコ'       },
  ar: { ja: 'アルゼンチン', en: 'Argentina',   'zh-cn': 'アルゼンチン', 'zh-tw': '阿根廷',   es: 'Argentina',  fr: 'Argentine',  de: 'Argentinien', ru: 'アルゼンチン'   },
  co: { ja: 'コロンビア', en: 'Colombia',    'zh-cn': 'コロンビア', 'zh-tw': '哥倫比亞', es: 'Colombia',   fr: 'Colombie',   de: 'Kolumbien',  ru: 'コロンビア'   },
};
const countryLabel = countryLabelMap[country]?.[lang] || country.toUpperCase();

const cityNameMap: Record<string, string> = {};
for (const city of cities) {
  cityNameMap[city.key] = city.display[lang] || city.display['en'] || city.key;
}
---

<Layout title={defaultCityName + ' | ' + labels.title} sidebarType="weather">
  <Breadcrumb
    countryLabel={countryLabel}
    countryHref={`/${lang}/${country}/`}
    categoryLabel={weatherPageLabel}
    categoryHref=""
  />

  <main class="weather-page"
    data-storage-key={storageKey}
    data-all-forecast={JSON.stringify(allForecastData)}
    data-city-names={JSON.stringify(cityNameMap)}
    data-labels={JSON.stringify(labels)}
    data-default-city={defaultCity.key}
    data-temp-unit={tempUnit}
    data-wind-unit={windUnit}
  >

    <div class="alert-ticker-container">
      <div class="alert-ticker-label">
        <span class="alert-ticker-icon">ℹ️</span>
        <span class="alert-ticker-name">{labels.alertTitle}（</span>
        <span id="alert-city-name">{defaultCityName}</span>
        <span>）：</span>
      </div>
      <div class="alert-ticker-window">
        <div id="alert-ticker-content" class="alert-ticker-empty"></div>
      </div>
    </div>

    <section class="forecast-section">
      <h2 class="section-title" id="forecast-title">{defaultCityName} {labels.title}</h2>
      <div class="forecast-container" id="forecast-container">
        </div>
    </section>

    {relatedNews.length > 0 && (
      <RelatedNews relatedPosts={relatedNews} lang={lang} country={country} />
    )}
  </main>
</Layout>

<script is:inline>
/* ▼ エラー修正：画面の準備が完全に終わるまで待ってからプログラムを動かします */
window.addEventListener('DOMContentLoaded', function() {
  var page = document.querySelector('.weather-page');
  if (!page) return;

  var storageKey      = page.getAttribute('data-storage-key') || '';
  var allForecast     = JSON.parse(page.getAttribute('data-all-forecast') || '{}');
  var cityNames       = JSON.parse(page.getAttribute('data-city-names') || '{}');
  var labels          = JSON.parse(page.getAttribute('data-labels') || '{}');
  var defaultCity     = page.getAttribute('data-default-city') || '';
  var tempUnit        = page.getAttribute('data-temp-unit') || '°C';
  var windUnit        = page.getAttribute('data-wind-unit') || 'km/h';
  
  var alertCityName     = document.getElementById('alert-city-name');
  var alertContent      = document.getElementById('alert-ticker-content');
  var forecastTitle     = document.getElementById('forecast-title');
  var forecastContainer = document.getElementById('forecast-container');

  function formatDate(dateStr) {
    var d = new Date(dateStr);
    return (d.getMonth() + 1) + '/' + d.getDate();
  }

  var dayLang = document.documentElement.lang || 'ja';
  var dayNamesMap = {
    ja: ['日','月','火','水','木','金','土'],
    en: ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'],
    'zh-cn': ['日','一','二','三','四','五','六'],
    'zh-tw': ['日','一','二','三','四','五','六'],
    es: ['Dom','Lun','Mar','Mié','Jue','Vie','Sáb'],
    fr: ['Dim','Lun','Mar','Mer','Jeu','Ven','Sam'],
    de: ['So','Mo','Di','Mi','Do','Fr','Sa'],
    ru: ['Вс','Пн','Вт','Ср','Чт','Пт','Сб'],
  };
  var dayNames = dayNamesMap[dayLang] || dayNamesMap['en'];
  function getDayName(dateStr) { return dayNames[new Date(dateStr).getDay()]; }

  /* ▼ 新デザイン：スマホ向けのカード形式で1時間予報を作るように変更しました */
  function buildForecastHTML(forecastDays) {
    if (!forecastDays || forecastDays.length === 0) return '<p style="padding:20px;color:#666">--</p>';
    var html = '';
    forecastDays.forEach(function(day, index) {
      var isMoonOnly = day.conditionIcon.includes('night/113.png');
      var iconClass = 'summary-icon' + (isMoonOnly ? ' moon-only' : '');
      
      html += '<div class="day-group" data-date="' + day.date + '">';
      html += '<button class="day-summary-btn" aria-expanded="false" data-target="hourly-' + index + '">';
      html += '<div class="date-info"><span class="date-text">' + formatDate(day.date) + '<br class="sp-only"><span class="day-name">(' + getDayName(day.date) + ')</span></span></div>';
      html += '<div class="weather-info">';
      html += '<img src="https:' + day.conditionIcon + '" alt="" class="' + iconClass + '" />';
      html += '<span class="condition-text">' + day.conditionText + '</span>';
      html += '</div>';
      html += '<div class="temp-info">';
      html += '<div class="temp-item"><span class="temp-label sp-hide">' + (labels.max||'Max') + '</span><span class="value-text temp-max">' + day.maxtemp + tempUnit + '</span></div>';
      html += '<span class="temp-sep">/</span>';
      html += '<div class="temp-item"><span class="temp-label sp-hide">' + (labels.min||'Min') + '</span><span class="value-text temp-min">' + day.mintemp + tempUnit + '</span></div>';
      html += '</div>';
      html += '<div class="rain-info"><span class="rain-label sp-only">' + (labels.rain||'Rain') + ': </span><span class="value-text rain-val">' + day.rainChance + '%</span></div>';
      html += '<div class="badge-wrapper"><span class="hourly-badge">' + (labels.hourly||'Hourly') + '<span class="sp-chevron"> ▼</span></span></div>';
      html += '</button>';

      // 時間ごとの詳細（横スクロール可能なカード形式）
      html += '<div id="hourly-' + index + '" class="hourly-details" hidden>';
      html += '<div class="hourly-scroll-wrapper"><div class="hourly-flex-container">';
      day.hour.forEach(function(h) {
        var hHour = parseInt(h.time.split(':')[0]);
        var hMoon = h.conditionIcon.includes('night/113.png');
        html += '<div class="hourly-card" data-hour="' + hHour + '">';
        html += '<div class="h-time">' + h.time + '</div>';
        html += '<div class="h-icon"><img src="https:' + h.conditionIcon + '" alt="" class="' + (hMoon ? 'moon-only' : '') + '" /></div>';
        html += '<div class="h-condition-text">' + h.conditionText + '</div>';
        html += '<div class="h-temp">' + h.temp + tempUnit + '</div>';
        html += '<div class="h-detail-item"><i class="fa-solid fa-droplet" style="color:#2196f3;"></i> ' + h.humidity + '%</div>';
        html += '<div class="h-detail-item"><i class="fa-solid fa-wind" style="color:#78909c;"></i> ' + h.wind + ' ' + windUnit + '</div>';
        html += '<div class="h-detail-item"><i class="fa-solid fa-umbrella" style="color:#0288d1;"></i> ' + h.rainChance + '%</div>';
        html += '</div>';
      });
      html += '</div></div></div></div>';
    });
    return html;
  }

  function applyCity(cityKey, saveStorage) {
    if (!cityKey) return;
    var data = allForecast[cityKey];
    if (!data) return;
    var cityName = cityNames[cityKey] || cityKey;

    if (alertCityName) alertCityName.textContent = cityName;
    if (alertContent) {
      if (data.alertText) {
        alertContent.className = 'alert-ticker-text';
        alertContent.innerHTML = '<span>' + data.alertText + '　　　' + data.alertText + '</span>';
      } else {
        alertContent.className = 'alert-ticker-empty';
        alertContent.innerHTML = '';
      }
    }
    if (forecastTitle) forecastTitle.textContent = cityName + ' ' + (labels.title || '');
    if (forecastContainer) {
      forecastContainer.innerHTML = buildForecastHTML(data.forecastDays);
      attachHourlyButtons();
      updateTimeFilter(data.timezone || 'Asia/Tokyo');
    }
    if (saveStorage && storageKey) {
      try { localStorage.setItem(storageKey, cityKey); } catch(e) {}
    }
  }

  function attachHourlyButtons() {
    document.querySelectorAll('.day-summary-btn').forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        var targetId = e.currentTarget.getAttribute('data-target');
        var targetEl = document.getElementById(targetId);
        var isExpanded = e.currentTarget.getAttribute('aria-expanded') === 'true';
        e.currentTarget.setAttribute('aria-expanded', String(!isExpanded));
        if (targetEl) targetEl.hidden = isExpanded;
      });
    });
  }

  function updateTimeFilter(timezone) {
    var nowInCity = new Intl.DateTimeFormat('en-US', {
      timeZone: timezone, year: 'numeric', month: '2-digit',
      day: '2-digit', hour: 'numeric', hourCycle: 'h23'
    }).formatToParts(new Date());
    var cityFullDate = nowInCity.find(function(p){return p.type==='year';}).value + '-'
      + nowInCity.find(function(p){return p.type==='month';}).value + '-'
      + nowInCity.find(function(p){return p.type==='day';}).value;
    var cityHour = parseInt(nowInCity.find(function(p){return p.type==='hour';}).value);
    
    var visibleCount = 0;
    document.querySelectorAll('.day-group').forEach(function(group) {
      var groupDate = group.getAttribute('data-date');
      if (groupDate < cityFullDate) {
        group.style.display = 'none';
      } else if (visibleCount < 3) {
        group.style.display = 'block';
        visibleCount++;
        if (groupDate === cityFullDate) {
          group.querySelectorAll('.hourly-card').forEach(function(card) {
            if (parseInt(card.getAttribute('data-hour')) < cityHour) card.style.display = 'none';
          });
        }
      } else {
        group.style.display = 'none';
      }
    });
  }

  window.updateWeatherMain = function(cityKey) { applyCity(cityKey, true); };

  function init() {
    var urlParams = new URLSearchParams(window.location.search);
    var savedKey = urlParams.get('city');
    if (!savedKey && storageKey) {
      try { savedKey = localStorage.getItem(storageKey); } catch(e) {}
    }
    applyCity(savedKey || defaultCity, false);
  }

  init();
});
</script>

