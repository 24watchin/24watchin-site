---
import Layout from '../../../layouts/Layout.astro';
import CategoryNews from '../../../components/CategoryNews.astro';
import MainNewsLayout from '../../../components/MainNewsLayout.astro';
import TrendScroll from '../../../components/TrendScroll.astro';
import GoogleAdBanner from '../../../components/GoogleAdBanner.astro';
import GlobalRegionNews from '../../../components/GlobalRegionNews.astro';
import { categoryLabelMap } from '../../../lib/categoryLabels.ts';
// ▼ カンペとマスターリストを読み込み
import { langCountryPairs, getBlogId } from '../../../lib/siteRoutes.ts';
import { getCountryLabel } from '../../../lib/countryData.ts';

export async function getStaticPaths() {
  // カンペから自動生成
  return langCountryPairs.map(({ lang, country }) => ({ params: { lang, country } }));
}

const { lang, country } = Astro.params;
const BLOG_ID = getBlogId(lang);
const API_KEY = import.meta.env.API_KEY;

const cacheKey = 'bloggerPostsCache_' + lang;
if (!globalThis[cacheKey]) {
  const url = `https://www.googleapis.com/blogger/v3/blogs/${BLOG_ID}/posts?key=${API_KEY}&maxResults=500&nocache=${Date.now()}`;
  globalThis[cacheKey] = fetch(url, { cache: 'no-store' })
    .then(res => res.ok ? res.json() : { items: [] })
    .then(data => data.items || [])
    .catch(() => []);
}

let allPosts = await globalThis[cacheKey];
const targetTag = lang + '-' + country;
const mainSitePosts = allPosts.filter(post => 
  post.labels?.some(label => label.toLowerCase().includes(targetTag.toLowerCase()))
);

const langKeyMap = { ja: 'jp', en: 'en', 'zh-cn': 'zh-cn', 'zh-tw': 'zh-tw', es: 'es', de: 'de', fr: 'fr', ru: 'ru' };
const langKey = langKeyMap[lang] || 'jp';
const categoryData = categoryLabelMap[langKey] || categoryLabelMap['jp'];

const displayCategories = ['politics', 'society', 'international', 'economy', 'environment-energy', 'business', 'technology-ai', 'entertainment', 'sports', 'health-life', 'weather', 'traffic'];

const categoryItems = displayCategories.map(slug => {
  const catData = categoryData.allCategories.find(c => c.slug === slug);
  const keywords = catData ? catData.keywords : [slug];
  return {
    slug,
    title: catData ? catData.label : slug,
    posts: mainSitePosts.filter(post => post.labels?.some(label => keywords.some(key => label.includes(key)))).slice(0, 3),
  };
});

// ▼ マスターリストから「〇〇のニュース」というタイトルを動的に作成
const countryLabel = getCountryLabel(country, lang);
const titleSuffixMap: Record<string, string> = {
  ja: 'のニュース', en: ' News', 'zh-cn': '新闻', 'zh-tw': '新聞', es: ' Noticias', fr: ' Actualités', de: ' Nachrichten', ru: ' Новости'
};
const pageTitle = countryLabel + (titleSuffixMap[lang] || titleSuffixMap['en']);
---

<Layout title={pageTitle} allPosts={allPosts}>
  <div slot="top-full">
    <MainNewsLayout posts={mainSitePosts} lang={lang} country={country} />
    <TrendScroll lang={lang} country={country} />
  </div>
  <GoogleAdBanner position="上部" />
  <div class="genre-grid">
    {categoryItems.map((cat) => (
      <CategoryNews title={cat.title} slug={cat.slug} posts={cat.posts} lang={lang} country={country} />
    ))}
  </div>
  <GoogleAdBanner position="下部" />
  <div slot="bottom-wide">
    <GlobalRegionNews lang={lang} country={country} allPosts={allPosts} />
  </div>
</Layout>

<style>
  .genre-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 30px; margin-top: 20px; }
  @media (max-width: 900px) { .genre-grid { grid-template-columns: 1fr; } }
</style>
