---
// src/pages/[lang]/info/index.astro
export function getStaticPaths() {
  return [
    { params: { lang: 'ja' } },
    { params: { lang: 'en' } },
    { params: { lang: 'ru' } },
    { params: { lang: 'fr' } },
    { params: { lang: 'de' } },
    { params: { lang: 'es' } },
    { params: { lang: 'zh-tw' } },
    { params: { lang: 'zh-cn' } },
  ];
}

const { lang } = Astro.params;
const target = `/${lang}/info/about/`;
---
<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <title>Redirecting...</title>
    <link rel="canonical" href={target} />
    <meta http-equiv="refresh" content={`0;url=${target}`} />
  </head>
  <body>
    <script is:inline define:vars={{ target }}>
      window.location.href = target;
    </script>
  </body>
</html>
