---
import Layout from '../../layouts/Layout.astro';

// ジャンルのURLと日本語名のリスト
export async function getStaticPaths() {
  const categories = [
    { slug: 'international', name: '国際' },
    { slug: 'business', name: 'ビジネス' },
    { slug: 'science', name: '科学' },
    { slug: 'local', name: '地域' },
    { slug: 'politics', name: '政治経済' },
    { slug: 'industry', name: '産業' },
    { slug: 'life', name: 'ライフ・教養' },
    { slug: 'special', name: '特集' },
  ];

  const API_KEY = import.meta.env.API_KEY;
  const BLOG_ID = import.meta.env.BLOG_ID;
  // ★ ここに「&maxResults=50」を足しました！これで隠れていた記事もたくさん持ってきます
  const url = `https://www.googleapis.com/blogger/v3/blogs/${BLOG_ID}/posts?key=${API_KEY}&maxResults=50`;
  const response = await fetch(url);
  const data = await response.json();
  const allPosts = data.items || [];

  return categories.map((category) => {
    const filteredPosts = allPosts.filter((post) => {
      return post.labels && post.labels.includes(category.name);
    });

    return {
      params: { slug: category.slug },
      props: { categoryName: category.name, posts: filteredPosts },
    };
  });
}

const { categoryName, posts } = Astro.props;

// ★ トップページと同じ「写真を見つけ出す魔法」を追加しました
const getImageUrl = (content) => {
  const match = content.match(/<img[^>]+src="([^">]+)"/);
  return match ? match[1] : 'https://placehold.co/600x400/eeeeee/999999?text=No+Image';
};
---

<Layout title={`${categoryName}ニュース`}>
  <div class="category-header">
    <h1>{categoryName}ニュース</h1>
    <a href="#" class="view-all">一覧へ →</a>
  </div>

  <div class="genre-top-grid">
    {posts.length > 0 && (
      <article class="main-article">
        <a href={`/news/${posts[0].id}/`}>
          <div class="image-wrapper main-image">
            <img src={getImageUrl(posts[0].content)} alt={posts[0].title} class="cover-image" />
          </div>
          <div class="article-content">
            <h2>{posts[0].title}</h2>
            <p class="date">{new Date(posts[0].published).toLocaleDateString('ja-JP')}</p>
          </div>
        </a>
      </article>
    )}

    <div class="sub-article-list">
      {posts.slice(1, 5).map((post) => (
        <article class="sub-article">
          <a href={`/news/${post.id}/`}>
            <div class="image-wrapper sub-image">
              <img src={getImageUrl(post.content)} alt={post.title} class="cover-image" />
            </div>
            <div class="sub-content">
              <h3>{post.title}</h3>
              <p class="date">{new Date(post.published).toLocaleDateString('ja-JP')}</p>
            </div>
          </a>
        </article>
      ))}
    </div>
  </div>

  <div class="ad-banner">広告スペース</div>

  <div class="more-news">
    <h3 class="more-news-title">More news</h3>
    <div class="more-news-list">
      {posts.slice(5, 9).map((post) => (
        <article class="list-item">
          <a href={`/news/${post.id}/`}>
            <div class="image-wrapper list-image-wrapper">
              <img src={getImageUrl(post.content)} alt={post.title} class="cover-image" />
            </div>
            <div class="list-content">
              <h4>{post.title}</h4>
              <p class="date">{new Date(post.published).toLocaleDateString('ja-JP')}</p>
            </div>
          </a>
        </article>
      ))}
    </div>
  </div>

  <style>
    /* デザイン設定（写真を綺麗に収める設定を追加しています） */
    .category-header { display: flex; justify-content: space-between; align-items: flex-end; border-bottom: 2px solid #1e3a8a; margin-bottom: 20px; padding-bottom: 10px; }
    .category-header h1 { font-size: 24px; margin: 0; color: #333; }
    .view-all { font-size: 14px; color: #1e3a8a; text-decoration: none; }
    .genre-top-grid { display: grid; grid-template-columns: 1.2fr 1fr; gap: 20px; margin-bottom: 30px; }
    @media (max-width: 768px) { .genre-top-grid { grid-template-columns: 1fr; } }
    .main-article a { text-decoration: none; color: #333; }
    
    /* 写真を枠にピッタリはめる魔法 */
    .image-wrapper { overflow: hidden; border-radius: 4px; background: #ddd; flex-shrink: 0; }
    .main-image { height: 250px; }
    .sub-image { width: 110px; height: 80px; }
    .list-image-wrapper { width: 140px; height: 90px; }
    .cover-image { width: 100%; height: 100%; object-fit: cover; display: block; }
    
    .article-content { padding: 15px 0; }
    .article-content h2 { font-size: 20px; margin: 0 0 10px; line-height: 1.4; }
    .date { font-size: 12px; color: #888; margin: 0; }
    .sub-article-list { display: flex; flex-direction: column; gap: 15px; }
    .sub-article a { display: flex; gap: 15px; text-decoration: none; color: #333; }
    .sub-content h3 { font-size: 14px; margin: 0 0 5px; line-height: 1.4; }
    .ad-banner { background: #eee; height: 120px; display: flex; align-items: center; justify-content: center; color: #999; margin: 40px 0; border: 1px solid #ddd; }
    .more-news-title { font-size: 18px; border-bottom: 2px solid #333; padding-bottom: 10px; margin-bottom: 20px; font-weight: bold; }
    .more-news-list { display: flex; flex-direction: column; gap: 20px; }
    .list-item a { display: flex; gap: 20px; text-decoration: none; color: #333; align-items: center; }
    .list-content h4 { font-size: 16px; margin: 0 0 8px; line-height: 1.4; }
  </style>
</Layout>
