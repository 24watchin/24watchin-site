---
import Layout from '../../layouts/Layout.astro';
import CategoryHero from '../../components/CategoryHero.astro';
import NewsList from '../../components/NewsList.astro';
import CategorySidebar from '../../components/CategorySidebar.astro'; // 新しいサイドバーを読み込み

export async function getStaticPaths() {
  const categories = [
    { slug: 'international', name: '国際' },
    { slug: 'business', name: 'ビジネス' },
    { slug: 'science', name: '科学' },
    { slug: 'local', name: '地域' },
    { slug: 'politics', name: '政治経済' },
    { slug: 'industry', name: '産業' },
    { slug: 'life', name: 'ライフ・教養' },
    { slug: 'special', name: '特集' },
  ];

  const API_KEY = import.meta.env.API_KEY;
  const BLOG_ID = import.meta.env.BLOG_ID;
  const url = `https://www.googleapis.com/blogger/v3/blogs/${BLOG_ID}/posts?key=${API_KEY}&maxResults=50`;
  
  const response = await fetch(url);
  const data = await response.json();
  const allPosts = data.items || [];

  return categories.map((category) => {
    const filteredPosts = allPosts.filter((post) => 
      post.labels && post.labels.includes(category.name)
    );
    return {
      params: { slug: category.slug },
      props: { categoryName: category.name, posts: filteredPosts },
    };
  });
}

const { categoryName, posts } = Astro.props;

const getImageUrl = (content) => {
  const match = content.match(/<img[^>]+src="([^">]+)"/);
  return match ? match[1] : 'https://placehold.co/600x400/eeeeee/999999?text=No+Image';
};
---

<Layout title={`${categoryName} | 24Watchin`}>
  <main class="container">
    <div class="page-layout">
      {/* 左側：メインコンテンツ */}
      <div class="main-content">
        {posts.length > 0 ? (
          <>
            <CategoryHero posts={posts} categoryName={categoryName} getImageUrl={getImageUrl} />
            <hr class="section-divider" />
            <section class="more-news">
              <h2 class="section-title">その他の{categoryName}ニュース</h2>
              <NewsList posts={posts.slice(5)} getImageUrl={getImageUrl} />
            </section>
          </>
        ) : (
          <p class="no-posts">現在、このジャンルの記事を準備中です。</p>
        )}
      </div>

      {/* 右側：ジャンル専用サイドバーエリア */}
      <div class="sidebar-area">
        <CategorySidebar />
      </div>
    </div>
  </main>
</Layout>

<style>
  .container { max-width: 1200px; margin: 0 auto; padding: 2rem 1rem; }
  
  .page-layout {
    display: grid;
    grid-template-columns: 1fr 300px; /* メイン記事とサイドバー(300px) */
    gap: 3rem;
  }

  .section-divider { border: 0; border-top: 1px solid #eee; margin: 3rem 0; }
  .section-title { 
    font-size: 1.5rem; margin-bottom: 2rem; 
    border-left: 5px solid #1e3a8a; padding-left: 1rem; 
    font-weight: bold;
  }

  /* スマホの時はサイドバーを下に回す */
  @media (max-width: 900px) {
    .page-layout { grid-template-columns: 1fr; }
    .sidebar-area { margin-top: 3rem; }
  }
</style>
