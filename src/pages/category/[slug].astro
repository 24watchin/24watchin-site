---
import Layout from '../../layouts/Layout.astro';
import CategoryHero from '../../components/CategoryHero.astro';
import NewsList from '../../components/NewsList.astro';
import CategorySidebar from '../../components/CategorySidebar.astro';

// (省略：getStaticPaths などのスクリプト部分はそのまま)
---

<Layout title={`${categoryName}`}>
  <div class="genre-container">
    <div class="main-column">
      {posts.length > 0 ? (
        <>
          <CategoryHero posts={posts} categoryName={categoryName} getImageUrl={getImageUrl} />
          <hr class="divider" />
          <h2 class="section-title">その他の{categoryName}ニュース</h2>
          <NewsList posts={posts.slice(5)} getImageUrl={getImageUrl} />
        </>
      ) : (
        <p>準備中です</p>
      )}
    </div>

    <aside class="sidebar-column">
      <CategorySidebar />
    </aside>
  </div>
</Layout>

<style>
  /* ここで「広々とした2列」を定義します */
  .genre-container {
    display: grid;
    grid-template-columns: 1fr 320px; /* サイドバーを少し広めの320pxに */
    gap: 50px; /* 記事とサイドバーの間隔をゆったりあける */
    margin-top: 30px;
  }
  .divider { border: 0; border-top: 1px solid #eee; margin: 40px 0; }
  .section-title { font-size: 1.5rem; border-left: 5px solid #1e3a8a; padding-left: 15px; margin-bottom: 30px; }

  @media (max-width: 1000px) {
    .genre-container { grid-template-columns: 1fr; }
  }
</style>
