---
import Layout from '../../layouts/Layout.astro';
import CategoryHero from '../../components/CategoryHero.astro';
import NewsList from '../../components/NewsList.astro';

// 1. ジャンルの設定
export async function getStaticPaths() {
  const categories = [
    { slug: 'international', name: '国際' },
    { slug: 'business', name: 'ビジネス' },
    { slug: 'science', name: '科学' },
    { slug: 'local', name: '地域' },
    { slug: 'politics', name: '政治経済' },
    { slug: 'industry', name: '産業' },
    { slug: 'life', name: 'ライフ・教養' },
    { slug: 'special', name: '特集' },
  ];

  const API_KEY = import.meta.env.API_KEY;
  const BLOG_ID = import.meta.env.BLOG_ID;
  const url = `https://www.googleapis.com/googleapis.com/blogger/v3/blogs/${BLOG_ID}/posts?key=${API_KEY}&maxResults=50`;
  
  const response = await fetch(url);
  const data = await response.json();
  const allPosts = data.items || [];

  return categories.map((category) => {
    const filteredPosts = allPosts.filter((post) => 
      post.labels && post.labels.includes(category.name)
    );

    return {
      params: { slug: category.slug },
      props: { categoryName: category.name, posts: filteredPosts },
    };
  });
}

const { categoryName, posts } = Astro.props;

// 2. 【脱Blogger・SEO対策】お掃除＆写真取得の魔法
const getImageUrl = (content) => {
  const match = content.match(/<img[^>]+src="([^">]+)"/);
  return match ? match[1] : 'https://placehold.co/600x400/eeeeee/999999?text=No+Image';
};

// Blogger特有の不要なタグやクラスを消し去る関数
const cleanContent = (content) => {
  return content
    .replace(/class="separator"/g, 'class="article-image-container"')
    .replace(/style="[^"]*"/g, '') // Bloggerのエディタが勝手に入れる装飾をリセット
    .replace(/<br\s*\/?>/gi, ''); // 不要な改行を整理
};
---

<Layout 
  title={`${categoryName}ニュース | 24Watchin`}
  description={`${categoryName}に関する最新のニュースをお届けします。24Watchinは独自ドメインで運営されるニュースメディアです。`}
>
  <main class="container">
    {/* ブロック1: ヒーローエリア（最新の5記事） */}
    {posts.length > 0 ? (
      <>
        <CategoryHero 
          posts={posts} 
          categoryName={categoryName} 
          getImageUrl={getImageUrl} 
        />

        {/* 広告や仕切りをここに入れることもできます */}
        <hr class="section-divider" />

        {/* ブロック2: 記事リストエリア（6記事目以降） */}
        <section class="more-news">
          <h2 class="section-title">その他の{categoryName}ニュース</h2>
          <NewsList 
            posts={posts.slice(5)} 
            getImageUrl={getImageUrl} 
          />
        </section>
      </>
    ) : (
      <p class="no-posts">現在、このジャンルの記事は準備中です。</p>
    )}
  </main>
</Layout>

<style>
  /* 全体のレイアウト設定 */
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .section-divider {
    border: 0;
    border-top: 1px solid #eee;
    margin: 3rem 0;
  }

  .section-title {
    font-size: 1.5rem;
    margin-bottom: 2rem;
    position: relative;
    padding-left: 1rem;
    border-left: 5px solid #1e3a8a;
  }

  .no-posts {
    text-align: center;
    padding: 5rem 0;
    color: #888;
  }

  /* 【スマホ対策】余白を調整 */
  @media (max-width: 600px) {
    .container { padding: 1rem; }
    .section-title { font-size: 1.2rem; }
  }
</style>