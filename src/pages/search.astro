---
import Layout from '../layouts/Layout.astro';

// GitHubのSecretsに登録したカギを読み込みます
const API_KEY = import.meta.env.API_KEY;
const BLOG_ID = import.meta.env.BLOG_ID;
---

<Layout title="検索結果">
  <section class="search-results-section">
    <h1 id="search-title">検索結果を読み込んでいます...</h1>
    
    <div class="results-grid" id="results-container">
      </div>

    <div id="loading" class="loading-status" style="display: none;">
      さらに読み込み中...
    </div>
  </section>
</Layout>

<script define:vars={{ API_KEY, BLOG_ID }}>
  // 1. URLから検索ワード（q=〇〇）を取り出す
  const urlParams = new URLSearchParams(window.location.search);
  const query = urlParams.get('q');
  
  const resultsContainer = document.getElementById('results-container');
  const searchTitle = document.getElementById('search-title');
  const loadingIndicator = document.getElementById('loading');

  let nextToken = '';
  let isFull = false;
  let isLoading = false;

  if (query) {
    searchTitle.textContent = `「${query}」の検索結果`;
    fetchResults();
  } else {
    searchTitle.textContent = 'キーワードを入力してください';
  }

  // 2. Blogger APIを使って記事を探す関数
  async function fetchResults() {
    if (isLoading || isFull) return;
    isLoading = true;
    loadingIndicator.style.display = 'block';

    // Bloggerの検索用URLを作成
    const url = `https://www.googleapis.com/blogger/v3/blogs/${BLOG_ID}/posts/search?q=${encodeURIComponent(query)}&key=${API_KEY}${nextToken ? `&pageToken=${nextToken}` : ''}`;

    try {
      const response = await fetch(url);
      const data = await response.json();
      const posts = data.items || [];

      if (posts.length === 0 && !nextToken) {
        resultsContainer.innerHTML = '<p>該当する記事が見つかりませんでした。</p>';
        isFull = true;
      } else {
        posts.forEach(post => {
          const card = createCard(post);
          resultsContainer.appendChild(card);
        });

        nextToken = data.nextPageToken || '';
        if (!nextToken) isFull = true;
      }
    } catch (error) {
      console.error('検索エラー:', error);
      resultsContainer.innerHTML = '<p>エラーが発生しました。時間を置いて再度お試しください。</p>';
    } finally {
      isLoading = false;
      loadingIndicator.style.display = 'none';
    }
  }

  // 3. 記事1つ分の「カード」を作る
  function createCard(post) {
    const div = document.createElement('div');
    div.className = 'result-item';
    
    // 画像を探す（なければプレースホルダーを表示）
    const imgMatch = (post.content || '').match(/<img[^>]+src="([^">]+)"/);
    const imgSrc = imgMatch ? imgMatch[1] : 'https://placehold.co/300x200/eeeeee/999999?text=No+Image';
    
    const date = new Date(post.published).toLocaleDateString('ja-JP');

    div.innerHTML = `
      <a href="/news/${post.id}/">
        <div class="img-wrapper">
          <img src="${imgSrc}" alt="" loading="lazy" />
        </div>
        <div class="text-content">
          <span class="post-date">${date}</span>
          <h2 class="post-title">${post.title}</h2>
        </div>
      </a>
    `;
    return div;
  }

  // 4. 無限スクロールの仕組み（一番下まで来たら次の記事を読み込む）
  window.addEventListener('scroll', () => {
    if (window.innerHeight + window.scrollY >= document.body.offsetHeight - 500) {
      fetchResults();
    }
  });
</script>

<style is:global>
  /* 検索結果ページの見た目 */
  .search-results-section {
    padding: 0 0 40px 0;
  }
  .search-results-section h1 {
    font-size: 20px;
    margin-bottom: 25px;
    padding-bottom: 10px;
    border-bottom: 1px solid #eee;
  }

  /* 4列グリッド（横に4枚並ぶ設定） */
  .results-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  .result-item a {
    text-decoration: none;
    color: #333;
    display: block;
    transition: opacity 0.2s;
  }
  .result-item a:hover {
    opacity: 0.8;
  }

  /* 画像の枠 */
  .img-wrapper {
    width: 100%;
    aspect-ratio: 16/10;
    overflow: hidden;
    background: #f0f0f0;
    margin-bottom: 8px;
  }
  .img-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* 日付とタイトルの装飾 */
  .post-date {
    display: block;
    font-size: 11px;
    color: #888;
    margin-bottom: 4px;
  }
  .post-title {
    font-size: 14px;
    font-weight: bold;
    line-height: 1.4;
    margin: 0;
    /* リンクの細い線（下線） */
    border-bottom: 1px solid transparent;
  }
  .result-item a:hover .post-title {
    border-bottom: 1px solid #ccc;
  }

  .loading-status {
    text-align: center;
    padding: 30px 0;
    color: #999;
    font-size: 14px;
  }

  /* スマホ・タブレットでは列の数を減らす */
  @media (max-width: 1000px) {
    .results-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 768px) {
    .results-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
