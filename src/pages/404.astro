---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 - Page Not Found">
  <div class="not-found-container">
    <div class="not-found-inner">
      <div class="error-code">404</div>
      <div class="domain-text">24watchin.com</div>
      
      <h1 class="error-title" id="error-title">Page Not Found</h1>
      <p class="error-sub" id="error-sub">The page you are looking for does not exist or has been moved.</p>
      <a href="/en/" class="back-btn" id="back-btn">Back to Top</a>
    </div>
  </div>
</Layout>

<script is:inline>
  // 各言語ごとのメッセージとURLプレフィックスの設定
  const messages = {
    ja: { title: 'ページが見つかりません', sub: 'お探しのページは存在しないか、移動した可能性があります。', btn: 'トップページに戻る', prefix: '/ja/' },
    en: { title: 'Page Not Found', sub: 'The page you are looking for does not exist or has been moved.', btn: 'Back to Top', prefix: '/en/' },
    'zh-cn': { title: '页面未找到', sub: '您查找的页面不存在或已被移动。', btn: '返回首页', prefix: '/zh-cn/' },
    'zh-tw': { title: '找不到頁面', sub: '您尋找的頁面不存在或已被移動。', btn: '返回首頁', prefix: '/zh-tw/' },
    es: { title: 'Página no encontrada', sub: 'La página que busca no existe o ha sido movida.', btn: 'Volver al inicio', prefix: '/es/' },
    fr: { title: 'Page introuvable', sub: "La page que vous recherchez n'existe pas ou a été déplacée.", btn: "Retour à l'accueil", prefix: '/fr/' },
    de: { title: 'Seite nicht gefunden', sub: 'Die gesuchte Seite existiert nicht oder wurde verschoben.', btn: 'Zurück zur Startseite', prefix: '/de/' },
    ru: { title: 'Страница не найдена', sub: 'Страница, которую вы ищете, не существует или была перемещена.', btn: 'На главную', prefix: '/ru/' },
  };

  const supportedLangs = Object.keys(messages);
  const pathParts = window.location.pathname.split('/').filter(Boolean);
  
  // ▼ 修正2：URLで言語が指定されていない場合は、強制的に「英語（en）」を基準にします
  let detectedLang = 'en';

  if (pathParts.length > 0 && supportedLangs.includes(pathParts[0])) {
    detectedLang = pathParts[0];
  }

  // 画面上のテキストとボタンの書き換え
  const msg = messages[detectedLang];

  document.getElementById('error-title').textContent = msg.title;
  document.getElementById('error-sub').textContent = msg.sub;
  const backBtn = document.getElementById('back-btn');
  backBtn.textContent = msg.btn;
  backBtn.href = msg.prefix;

  // ヘッダーのロゴリンクを現在の言語のトップページに書き換える
  const headerLinks = document.querySelectorAll('header a');
  headerLinks.forEach(link => {
    link.href = msg.prefix;
  });
</script>

<style>
  .not-found-container {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 60vh;
    padding: 40px 20px;
  }

  .not-found-inner {
    text-align: center;
    background: #fff;
    border-radius: 12px;
    padding: 60px 40px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    max-width: 500px;
    width: 100%;
  }

  .error-code {
    font-size: 96px;
    font-weight: 900;
    color: var(--theme-color, #872732);
    line-height: 1;
    margin-bottom: 8px;
    letter-spacing: -4px;
  }

  /* ▼ 修正1：新しく追加したドメインテキストのデザインです */
  .domain-text {
    font-size: 18px;
    font-weight: bold;
    color: #888;
    margin-bottom: 20px;
    letter-spacing: 1px;
  }

  .error-title {
    font-size: 24px;
    font-weight: bold;
    color: #1a1a1a;
    margin-bottom: 12px;
  }

  .error-sub {
    font-size: 15px;
    color: #666;
    margin-bottom: 32px;
    line-height: 1.6;
  }

  .back-btn {
    display: inline-block;
    background: var(--theme-color, #872732);
    color: #fff;
    padding: 14px 32px;
    border-radius: 6px;
    text-decoration: none;
    font-weight: bold;
    font-size: 15px;
    transition: opacity 0.2s;
  }

  .back-btn:hover {
    opacity: 0.85;
  }

  @media (max-width: 480px) {
    .not-found-inner { padding: 40px 20px; }
    .error-code { font-size: 72px; }
    .error-title { font-size: 20px; }
    .domain-text { font-size: 16px; } /* スマホ用の文字サイズ調整 */
  }
</style>

<style is:global>
  /* 1. サイドバー用の隙間をなくし、メインエリアを全画面に広げます */
  .main-layout { grid-template-columns: 1fr !important; }
  
  /* 2. サイドバーとフッターを完全に非表示にします */
  .sidebar-area, footer, .site-footer { display: none !important; }

  /* 3. ヘッダーの不要なパーツを正確な名前で狙い撃ちして非表示にします */
  .pc-top-gray-bar, .sp-top-gray-bar { display: none !important; }
  .pc-right-area, .sp-right-area, .sp-top-actions { display: none !important; }
  .category-bar, .sp-category-bar { display: none !important; }
  .header-word-bar { display: none !important; }
  .bottom-line { display: none !important; }
  .site-header > div[style*="height: 10px"] { display: none !important; }
  #rl-panel, #rl-overlay { display: none !important; }
</style>
