---
// 部品を呼び出すための道案内を「3つ戻る（../../../）」に変更しました
import Layout from '../../../layouts/Layout.astro';

const API_KEY = import.meta.env.API_KEY;
const BLOG_ID = import.meta.env.BLOG_ID;
---

<Layout title="検索結果">
  <section class="search-results-section">
    <h1 id="search-title">検索結果を読み込んでいます...</h1>
    
    <div class="results-grid" id="results-container">
      </div>

    <div id="loading" class="loading-status" style="display: none;">
      さらに読み込み中...
    </div>
  </section>
</Layout>

<script define:vars={{ API_KEY, BLOG_ID }}>
  const urlParams = new URLSearchParams(window.location.search);
  const query = urlParams.get('q');
  const resultsContainer = document.getElementById('results-container');
  const searchTitle = document.getElementById('search-title');
  const loadingIndicator = document.getElementById('loading');

  let nextToken = '';
  let isFull = false;
  let isLoading = false;

  if (query) {
    searchTitle.textContent = `「${query}」の検索結果`;
    fetchResults();
  } else {
    searchTitle.textContent = 'キーワードを入力してください';
  }

  async function fetchResults() {
    if (isLoading || isFull) return;
    isLoading = true;
    loadingIndicator.style.display = 'block';

    const url = `https://www.googleapis.com/blogger/v3/blogs/${BLOG_ID}/posts/search?q=${encodeURIComponent(query)}&key=${API_KEY}${nextToken ? `&pageToken=${nextToken}` : ''}`;

    try {
      const response = await fetch(url);
      const data = await response.json();

      if (data.items && data.items.length > 0) {
        data.items.forEach(post => {
          resultsContainer.appendChild(createResultCard(post));
        });
        nextToken = data.nextPageToken || '';
        if (!nextToken) {
          isFull = true;
          loadingIndicator.textContent = 'すべての結果を表示しました';
        } else {
          loadingIndicator.style.display = 'none';
        }
      } else {
        if (!resultsContainer.hasChildNodes()) {
          searchTitle.textContent = '記事が見つかりませんでした';
        }
        isFull = true;
        loadingIndicator.style.display = 'none';
      }
    } catch (error) {
      console.error('検索エラー:', error);
      searchTitle.textContent = 'エラーが発生しました';
      loadingIndicator.style.display = 'none';
    } finally {
      isLoading = false;
    }
  }

  function createResultCard(post) {
    const div = document.createElement('div');
    div.className = 'result-item';

    const match = (post.content || '').match(/<img[^>]+src="([^">]+)"/);
    const imgSrc = match ? match[1] : 'https://placehold.co/300x200/eeeeee/999999?text=No+Image';
    const date = new Date(post.published).toLocaleDateString('ja-JP');

    // ★ 検索結果のリンク先を日本版の住所（/jp/jp/）に修正しました！
    div.innerHTML = `
      <a href="/jp/jp/news/${post.id}/">
        <div class="img-wrapper">
          <img src="${imgSrc}" alt="${post.title}" loading="lazy" />
        </div>
        <div class="post-info">
          <span class="post-date">${date}</span>
          <h2 class="post-title">${post.title}</h2>
        </div>
      </a>
    `;
    return div;
  }

  window.addEventListener('scroll', () => {
    if (window.innerHeight + window.scrollY >= document.body.offsetHeight - 500) {
      fetchResults();
    }
  });
</script>

<style is:global>
  .search-results-section { padding: 0 0 40px 0; }
  .search-results-section h1 {
    font-size: 20px; margin-bottom: 25px; padding-bottom: 10px; border-bottom: 1px solid #eee;
  }
  .results-grid {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px;
  }
  .result-item a { text-decoration: none; color: #333; display: block; }
  .img-wrapper {
    width: 100%; aspect-ratio: 16/10; overflow: hidden; background: #f0f0f0; margin-bottom: 8px;
  }
  .img-wrapper img { width: 100%; height: 100%; object-fit: cover; }
  .post-date { display: block; font-size: 11px; color: #888; margin-bottom: 4px; }
  
  .post-title {
    font-size: 14px; font-weight: bold; line-height: 1.4; margin: 0;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .result-item a:hover .post-title { text-decoration: underline; text-decoration-thickness: 1px; text-underline-offset: 3px; }

  @media (max-width: 900px) {
    .results-grid { grid-template-columns: repeat(2, 1fr); gap: 15px; }
  }
  @media (max-width: 480px) {
    .results-grid { grid-template-columns: 1fr; }
    .search-results-section h1 { font-size: 18px; }
  }
  .loading-status { text-align: center; padding: 20px; color: #666; font-size: 14px; }
</style>
