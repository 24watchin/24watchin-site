---
import Layout from '../../../layouts/Layout.astro';

function extractImageSrc(html = '') {
  const match = html.match(/<img[^>]+src=["']([^"']+)["']/i);
  return match ? match[1] : '';
}

function stripHtml(html = '') {
  return html
    .replace(/<script[\s\S]*?<\/script>/gi, ' ')
    .replace(/<style[\s\S]*?<\/style>/gi, ' ')
    .replace(/<[^>]+>/g, ' ')
    .replace(/&nbsp;/gi, ' ')
    .replace(/&amp;/gi, '&')
    .replace(/&lt;/gi, '<')
    .replace(/&gt;/gi, '>')
    .replace(/&#39;/gi, "'")
    .replace(/&quot;/gi, '"')
    .replace(/\s+/g, ' ')
    .trim();
}

async function fetchAllPosts() {
  const API_KEY = import.meta.env.API_KEY;
  const BLOG_ID = import.meta.env.BLOG_ID;

  let allPosts = [];
  let pageToken = '';

  while (true) {
    const url = new URL(`https://www.googleapis.com/blogger/v3/blogs/${BLOG_ID}/posts`);
    url.searchParams.set('key', API_KEY);
    url.searchParams.set('maxResults', '100');

    if (pageToken) {
      url.searchParams.set('pageToken', pageToken);
    }

    const response = await fetch(url.toString());

    if (!response.ok) {
      throw new Error(`Blogger API error: ${response.status} ${response.statusText}`);
    }

    const data = await response.json();
    const items = data.items || [];

    allPosts.push(...items);

    if (!data.nextPageToken) {
      break;
    }

    pageToken = data.nextPageToken;
  }

  return allPosts;
}

const rawPosts = await fetchAllPosts();

const searchIndex = rawPosts.map((post) => ({
  id: post.id,
  title: post.title || '',
  published: post.published || '',
  imageUrl: extractImageSrc(post.content || ''),
  plainText: stripHtml(post.content || ''),
}));
---

<Layout title="検索結果">
  <div class="search-main-wrapper">
    <div class="search-header-area">
      <h1 class="search-title">
        「<span id="displayWord"></span>」の検索結果：<span id="resultCount">0</span>件
      </h1>
    </div>

    <div class="results-grid" id="resultsGrid"></div>

    <div id="noResults" class="no-results" style="display: none;">
      「<span id="displayWordNo"></span>」に一致する記事は見つかりませんでした。
    </div>

    <div id="loadMoreArea" class="load-more-area" style="display: none;">
      <button id="loadMoreBtn" class="load-more-btn">さらに表示</button>
    </div>
  </div>
</Layout>

<script is:inline define:vars={{ searchIndex }}>
  const params = new URLSearchParams(window.location.search);
  const q = (params.get('q') || '').trim();
  const searchWord = q.toLowerCase();
  const dateFormatter = new Intl.DateTimeFormat('ja-JP');
  const PLACEHOLDER_IMAGE = 'https://placehold.co/600x400/eeeeee/999999?text=No+Image';

  document.getElementById('displayWord').textContent = q;
  document.getElementById('displayWordNo').textContent = q;

  const filtered = searchIndex.filter((post) => {
    if (!searchWord) return false;

    const title = (post.title || '').toLowerCase();
    const content = (post.plainText || '').toLowerCase();

    return title.includes(searchWord) || content.includes(searchWord);
  });

  document.getElementById('resultCount').textContent = filtered.length;

  const grid = document.getElementById('resultsGrid');
  const loadMoreArea = document.getElementById('loadMoreArea');
  const noResults = document.getElementById('noResults');
  const loadMoreBtn = document.getElementById('loadMoreBtn');

  let currentCount = 0;
  const PAGE_SIZE = 20;

  function createCard(post) {
    const card = document.createElement('a');
    card.href = `/jp/jp/news/${post.id}`;
    card.className = 'grid-item';

    const imageBox = document.createElement('div');
    imageBox.className = 'post-image-box';

    const img = document.createElement('img');
    img.src = post.imageUrl || PLACEHOLDER_IMAGE;
    img.alt = post.title || '';

    imageBox.appendChild(img);

    const metaLine = document.createElement('div');
    metaLine.className = 'post-meta-line';

    const time = document.createElement('time');
    time.textContent = post.published
      ? dateFormatter.format(new Date(post.published))
      : '';

    metaLine.appendChild(time);

    const title = document.createElement('h2');
    title.className = 'post-title-text';
    title.textContent = post.title || '';

    card.appendChild(imageBox);
    card.appendChild(metaLine);
    card.appendChild(title);

    return card;
  }

  function displayItems(limit) {
    const nextItems = filtered.slice(currentCount, currentCount + limit);

    nextItems.forEach((post) => {
      grid.appendChild(createCard(post));
    });

    currentCount += nextItems.length;
    loadMoreArea.style.display = currentCount < filtered.length ? 'block' : 'none';
  }

  if (filtered.length > 0) {
    displayItems(PAGE_SIZE);
  } else {
    noResults.style.display = 'block';
  }

  loadMoreBtn?.addEventListener('click', () => {
    displayItems(PAGE_SIZE);
  });
</script>

<style is:global>
  .search-main-wrapper {
    width: 100%;
    min-width: 0;
    margin: 0;
    padding: 0;
  }

  .search-header-area {
    margin: 0 0 25px 0 !important;
    padding: 0 0 10px 0;
    border-bottom: 1px solid #ddd;
  }

  .search-title {
    margin: 0 !important;
    font-size: 1.25rem;
    font-weight: bold;
    color: #333;
    line-height: 1.5;
  }

  .results-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 20px;
    width: 100%;
    align-items: start;
  }

  .grid-item {
    display: block;
    width: 100%;
    min-width: 0;
    text-decoration: none !important;
    color: inherit !important;
  }

  .post-image-box {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: #f0f0f0;
    border-radius: 4px;
    margin: 0;
  }

  .post-image-box img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .post-meta-line {
    margin: 8px 0 4px 0;
    font-size: 13px;
    color: #999 !important;
  }

  .post-meta-line time {
    color: #999 !important;
    text-decoration: none !important;
  }

  .post-title-text {
    margin: 0;
    font-size: 16px !important;
    line-height: 1.4 !important;
    font-weight: bold !important;
    color: #333 !important;
    display: -webkit-box !important;
    -webkit-line-clamp: 3 !important;
    -webkit-box-orient: vertical !important;
    overflow: hidden !important;
  }

  .no-results {
    margin-top: 20px;
    font-size: 15px;
    color: #666;
  }

  .load-more-area {
    text-align: center;
    margin: 40px 0;
  }

  .load-more-btn {
    background: #fff;
    border: 1px solid #ccc;
    padding: 10px 30px;
    font-size: 14px;
    cursor: pointer;
    border-radius: 4px;
  }

  @media (max-width: 1024px) {
    .results-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 768px) {
    .results-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 480px) {
    .results-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
