---
import Layout from '../../../layouts/Layout.astro';
import MainNewsLayout from '../../../components/MainNewsLayout.astro';
import TrendScroll from '../../../components/TrendScroll.astro';
import GoogleAdBanner from '../../../components/GoogleAdBanner.astro';
import CategoryNews from '../../../components/CategoryNews.astro';
import RegionNewsBlock from '../../../components/RegionNewsBlock.astro';

const API_KEY = import.meta.env.API_KEY;
const BLOG_ID = import.meta.env.BLOG_ID;
const url = `https://www.googleapis.com/blogger/v3/blogs/${BLOG_ID}/posts?key=${API_KEY}&maxResults=100`;

const response = await fetch(url).catch(() => null);
const data = response ? await response.json() : { items: [] };
const allPosts = data.items || [];

const filterByLabel = (labelName, count = 2) => {
  return allPosts.filter(post => post.labels && post.labels.includes(labelName)).slice(0, count);
};
---

<Layout title="TOP">
  <div slot="top-full">
    <MainNewsLayout posts={allPosts} />
    <TrendScroll />
  </div>

  <GoogleAdBanner position="上部" />

  <div class="genre-grid">
    <CategoryNews title="政治" slug="politics" posts={filterByLabel("政治")} />
    <CategoryNews title="社会" slug="society" posts={filterByLabel("社会")} />
    
    <CategoryNews title="国際" slug="international" posts={filterByLabel("国際")} />
    <CategoryNews title="経済" slug="economy" posts={filterByLabel("経済")} />
    
    <CategoryNews title="環境・エネルギー" slug="environment-energy" posts={filterByLabel("環境・エネルギー")} />
    <CategoryNews title="ビジネス" slug="business" posts={filterByLabel("ビジネス")} />
    
    <CategoryNews title="テクノロジー・AI" slug="technology-ai" posts={filterByLabel("テクノロジー・AI")} />
    <CategoryNews title="文化・エンタメ" slug="entertainment" posts={filterByLabel("文化・エンタメ")} />
    
    <CategoryNews title="スポーツ" slug="sports" posts={filterByLabel("スポーツ")} />
    <CategoryNews title="健康・ライフ" slug="health-life" posts={filterByLabel("健康・ライフ")} />
    
    <CategoryNews title="天気" slug="weather" posts={filterByLabel("天気")} />
    <CategoryNews title="交通" slug="traffic" posts={filterByLabel("交通")} />
  </div>

  <GoogleAdBanner position="下部" />
</Layout>

<style>
  .genre-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 30px; margin-top: 20px; }
  @media (max-width: 900px) { .genre-grid { grid-template-columns: 1fr; } }
</style>
