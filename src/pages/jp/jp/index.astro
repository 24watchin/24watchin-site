---
import Layout from '../../../layouts/Layout.astro';
import CategoryNews from '../../../components/CategoryNews.astro';
// (他のインポートはそのまま)

// (API取得やfilterByLabelのロジックは既存のものを維持)
---

<Layout title="TOP">
  {/* (上部のニュースレイアウトなどはそのまま) */}

  <div class="genre-grid">
    {/* 政治・社会 */}
    <CategoryNews title="政治" slug="politics" posts={filterByLabel("政治")} />
    <CategoryNews title="社会" slug="society" posts={filterByLabel("社会")} />
    
    {/* 国際・経済 */}
    <CategoryNews title="国際" slug="international" posts={filterByLabel("国際")} />
    <CategoryNews title="経済" slug="economy" posts={filterByLabel("経済")} />
    
    {/* 環境・ビジネス */}
    <CategoryNews title="環境・エネルギー" slug="environment-energy" posts={filterByLabel("環境・エネルギー")} />
    <CategoryNews title="ビジネス" slug="business" posts={filterByLabel("ビジネス")} />
    
    {/* テクノロジー・文化 */}
    <CategoryNews title="テクノロジー・AI" slug="technology-ai" posts={filterByLabel("テクノロジー・AI")} />
    <CategoryNews title="文化・エンタメ" slug="entertainment" posts={filterByLabel("文化・エンタメ")} />
    
    {/* スポーツ・健康 */}
    <CategoryNews title="スポーツ" slug="sports" posts={filterByLabel("スポーツ")} />
    <CategoryNews title="健康・ライフ" slug="health-life" posts={filterByLabel("健康・ライフ")} />
    
    {/* 天気・交通 */}
    <CategoryNews title="天気" slug="weather" posts={filterByLabel("天気")} />
    <CategoryNews title="交通" slug="traffic" posts={filterByLabel("交通")} />
  </div>
</Layout>

<style>
  .genre-grid { 
    display: grid;
    grid-template-columns: 1fr 1fr; /* これで2列並びになります */
    gap: 30px; 
  }
  @media (max-width: 900px) { 
    .genre-grid { grid-template-columns: 1fr; } 
  }
</style>
