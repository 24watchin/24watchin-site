---
// (インポートなどは維持)
import { categoryLabelMap } from '../../../lib/categoryLabels';

// ▼ ここを賢く書き換えました ▼
const filterByCategory = (slug, count = 2) => {
  // 辞書から、そのカテゴリに紐づくキーワードを探します
  const catData = categoryLabelMap.jp.allCategories.find(c => c.slug === slug);
  const keywords = catData ? catData.keywords : [slug];

  return allPosts.filter(post => {
    if (!post.labels) return false;
    // Bloggerのラベルの中に、キーワードのどれか1つでも含まれていればOK！
    return post.labels.some(label => 
      keywords.some(key => label.includes(key))
    );
  }).slice(0, count);
};
---

<Layout title="TOP">
  <div class="genre-grid">
    {/* slug（英語名）で指定するようにしたので、ミスが減ります */}
    <CategoryNews title="政治" slug="politics" posts={filterByCategory("politics")} />
    <CategoryNews title="社会" slug="society" posts={filterByCategory("society")} />
    <CategoryNews title="国際" slug="international" posts={filterByCategory("international")} />
    <CategoryNews title="経済" slug="economy" posts={filterByCategory("economy")} />
    <CategoryNews title="環境・エネルギー" slug="environment-energy" posts={filterByCategory("environment-energy")} />
    <CategoryNews title="ビジネス" slug="business" posts={filterByCategory("business")} />
    <CategoryNews title="テクノロジー・AI" slug="technology-ai" posts={filterByCategory("technology-ai")} />
    <CategoryNews title="文化・エンタメ" slug="entertainment" posts={filterByCategory("entertainment")} />
    <CategoryNews title="スポーツ" slug="sports" posts={filterByCategory("sports")} />
    <CategoryNews title="健康・ライフ" slug="health-life" posts={filterByCategory("health-life")} />
    <CategoryNews title="天気" slug="weather" posts={filterByCategory("weather")} />
    <CategoryNews title="交通" slug="traffic" posts={filterByCategory("traffic")} />
  </div>
</Layout>
