---
import Layout from '../../../../layouts/Layout.astro';
import CategoryHero from '../../../../components/CategoryHero.astro';
import NewsList from '../../../../components/NewsList.astro';

export async function getStaticPaths() {
  const categories = [
    { slug: 'politics', name: '政治' },
    { slug: 'society', name: '社会' },
    { slug: 'international', name: '国際' },
    { slug: 'economy', name: '経済' },
    { slug: 'environment-energy', name: '環境・エネルギー' },
    { slug: 'business', name: 'ビジネス' },
    { slug: 'technology-ai', name: 'テクノロジー・AI' },
    { slug: 'entertainment', name: '文化・エンタメ' },
    { slug: 'sports', name: 'スポーツ' },
    { slug: 'traffic', name: '交通' },
    { slug: 'weather', name: '天気' },
  ];

  const API_KEY = import.meta.env.API_KEY;
  const BLOG_ID = import.meta.env.BLOG_ID;
  const url = `https://www.googleapis.com/blogger/v3/blogs/${BLOG_ID}/posts?key=${API_KEY}&maxResults=100`;

  const response = await fetch(url);
  const data = await response.json();
  const allPosts = data.items || [];

  return categories.map((category) => {
    const filteredPosts = allPosts.filter(
      (post) => post.labels && post.labels.includes(category.name)
    );

    return {
      params: { slug: category.slug },
      props: {
        categoryName: category.name,
        posts: filteredPosts,
      },
    };
  });
}

const { categoryName, posts } = Astro.props;

const getImageUrl = (content) => {
  const match = content?.match(/<img[^>]+src="([^">]+)"/);
  return match ? match[1] : 'https://placehold.co/600x400/eeeeee/999999?text=No+Image';
};
---

<Layout title={categoryName} sidebarType="category">
  {posts.length > 0 ? (
    <>
      <CategoryHero posts={posts} categoryName={categoryName} getImageUrl={getImageUrl} />
      <hr class="divider" />
      <h2 class="section-title">その他の{categoryName}ニュース</h2>
      <NewsList posts={posts.slice(5)} getImageUrl={getImageUrl} />
    </>
  ) : (
    <p>現在、この記事は準備中です。</p>
  )}
</Layout>

<style>
  .divider {
    border: 0;
    border-top: 1px solid #eee;
    margin: 3rem 0;
  }

  .section-title {
    font-size: 1.5rem;
    border-left: 5px solid #1e3a8a;
    padding-left: 1rem;
    font-weight: bold;
    margin-bottom: 2rem;
  }
</style>
