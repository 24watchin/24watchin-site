---
import Layout from '../../../../layouts/Layout.astro';
import CategoryHero from '../../../../components/CategoryHero.astro';
import CategoryNewsList from '../../../../components/CategoryNewsList.astro';
import { categoryLabelMap } from '../../../../lib/categoryLabels';

export async function getStaticPaths() {
  // 1. 辞書ファイル(categoryLabelMap)から全カテゴリのスラッグを取得します
  const slugs = categoryLabelMap.jp.allCategories.map(cat => cat.slug);
  
  return slugs.map((slug) => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;

// 2. Bloggerから記事を取得します
const API_KEY = import.meta.env.API_KEY;
const BLOG_ID = import.meta.env.BLOG_ID;
const url = `https://www.googleapis.com/blogger/v3/blogs/${BLOG_ID}/posts?key=${API_KEY}&maxResults=100`;

const response = await fetch(url).catch(() => null);
const data = response ? await response.json() : { items: [] };
const allPosts = data.items || [];

// 3. 辞書から、現在のカテゴリ名と「キーワード」を取り出します
const catData = categoryLabelMap.jp.allCategories.find(c => c.slug === slug);
const categoryName = catData ? catData.label : 'ニュース';
const keywords = catData ? catData.keywords : [slug];

// 4. キーワードを使って、この記事がこのカテゴリに属するか判定します.astro]
const categoryPosts = allPosts.filter(post => {
  if (!post.labels) return false;
  return post.labels.some(label => 
    keywords.some(key => label.includes(key))
  );
});

const getImageUrl = (content) => {
  const match = (content || '').match(/<img[^>]+src="([^">]+)"/);
  return match ? match[1] : 'https://placehold.co/600x400/eeeeee/999999?text=No+Image';
};

const pageDescription = `24Watchinの${categoryName}カテゴリ。世界中の最新の${categoryName}ニュースをお届けします。`;
---

<Layout title={categoryName} description={pageDescription} sidebarType="category">
  <div class="category-page">
    {/* 上部のメイン記事エリア */}
    <CategoryHero 
      posts={categoryPosts} 
      categoryName={categoryName} 
      getImageUrl={getImageUrl} 
    />

    {/* その下の記事リストエリア */}
    <div class="list-section">
      <CategoryNewsList 
        posts={categoryPosts.slice(5)} 
        getImageUrl={getImageUrl} 
      />
    </div>
  </div>
</Layout>

<style>
  .category-page {
    max-width: 1000px;
    margin: 0 auto;
    padding: 20px 0;
  }
  .list-section {
    margin-top: 3rem;
    border-top: 1px solid #ddd;
    padding-top: 2rem;
  }
</style>
