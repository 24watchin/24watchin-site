---
import Layout from '../../../layouts/Layout.astro';
import { getWeatherCondition } from '../../../lib/weatherConditions';

const currentPath = Astro.url.pathname;
const pathParts = currentPath.split('/').filter(Boolean);
const region = pathParts[0] || 'jp';
const lang = pathParts[1] || 'jp';
const apiLangMap = { jp: 'ja', en: 'en', cn: 'zh', fr: 'fr', de: 'de', es: 'es', ru: 'ru' };
const apiLang = apiLangMap[lang] || 'ja';
const isImperial = lang === 'en';

// --- Bloggerから関連記事を取得 ---
const API_KEY = import.meta.env.API_KEY;
const BLOG_ID = import.meta.env.BLOG_ID;
const WEATHER_API_KEY = import.meta.env.WEATHER_API_KEY;

let relatedNews = [];
if (API_KEY && BLOG_ID) {
  try {
    const bloggerUrl = `https://www.googleapis.com/blogger/v3/blogs/${BLOG_ID}/posts?key=${API_KEY}&maxResults=50`;
    const bResponse = await fetch(bloggerUrl);
    if (bResponse.ok) {
      const bData = await bResponse.json();
      const allPosts = bData.items || [];
      relatedNews = allPosts.filter(post => 
        post.labels && post.labels.some(label => ['天気', '気象', '災害', 'weather'].includes(label))
      ).slice(0, 5);
    }
  } catch (e) {}
}

const getImageUrl = (content) => {
  const match = content?.match(/<img[^>]+src="([^">]+)"/);
  return match ? match[1] : 'https://placehold.co/600x400/eeeeee/999999?text=No+Image';
};

// --- 天気データの取得 ---
const cityMap = {
  jp: { name: 'Tokyo', tz: 'Asia/Tokyo', display: { jp: '東京', en: 'Tokyo' } },
  us: { name: 'New_York', tz: 'America/New_York', display: { jp: 'ニューヨーク', en: 'New York' } },
  de: { name: 'Berlin', tz: 'Europe/Berlin', display: { jp: 'ベルリン', en: 'Berlin' } },
};

const targetCity = cityMap[region] || cityMap.jp;
const cityDisplayName = targetCity.display[lang] || targetCity.display.en;

let forecastDays = [];
let alertFullText = "";

if (WEATHER_API_KEY) {
  try {
    const weatherUrl = `https://api.weatherapi.com/v1/forecast.json?key=${WEATHER_API_KEY}&q=${targetCity.name}&days=3&aqi=no&alerts=yes&lang=${apiLang}`;
    const wResponse = await fetch(weatherUrl);
    if (wResponse.ok) {
      const wData = await wResponse.json();
      forecastDays = wData.forecast.forecastday;
      const alerts = wData.alerts.alert || [];
      alertFullText = alerts.map(a => a.headline).join(' / ');
    }
  } catch (e) {}
}

const allLabels = {
  jp: { title: '3日間の天気予報', alertTitle: '気象・災害情報', relatedTitle: '関連記事', hourly: '1時間ごと', time: '時刻', weather: '天気', rain: '降水', humidity: '湿度', wind: '風速', max: '最高', min: '最低', temp: '気温' },
  en: { title: '3-Day Forecast', alertTitle: 'Weather/Disaster Info', relatedTitle: 'Related News', hourly: 'Hourly', time: 'Time', weather: 'Weather', rain: 'Rain', humidity: 'Humid', wind: 'Wind', max: 'Max', min: 'Min', temp: 'Temp' }
};
const labels = allLabels[lang] || allLabels.en;
const tempUnit = isImperial ? '℉' : '℃';
const windUnit = isImperial ? 'mph' : 'km/h';

const formatDate = (dateStr) => {
  const date = new Date(dateStr);
  return `${date.getMonth() + 1}/${date.getDate()}`;
};
const getDayName = (dateStr) => {
  const dayIndex = new Date(dateStr).getDay();
  const dayNames = { jp: ['日', '月', '火', '水', '木', '金', '土'], en: ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'] };
  return (dayNames[lang] || dayNames.en)[dayIndex];
};
---

<Layout title={`${cityDisplayName} | ${labels.title}`} sidebarType="weather">
  <main class="weather-page" data-timezone={targetCity.tz}>
    
    <div class="alert-ticker-container">
      <div class="alert-ticker-label">
        <span class="alert-ticker-icon">ℹ️</span>
        <span class="alert-ticker-name">{labels.alertTitle} ({cityDisplayName})：</span>
      </div>
      <div class="alert-ticker-window">
        {alertFullText ? (
          <div class="alert-ticker-text">
            <span>{alertFullText}　　　{alertFullText}</span>
          </div>
        ) : (
          <div class="alert-ticker-empty"></div>
        )}
      </div>
    </div>

    <section class="forecast-section">
      <h2 class="section-title">{cityDisplayName} {labels.title}</h2>
      
      <div class="forecast-container">
        {forecastDays.map((day, index) => (
          <div class="day-group" data-date={day.date}>
            <button class="day-summary-btn" aria-expanded="false" data-target={`hourly-${index}`}>
              <div class="date-info">
                <span class="date-text">{formatDate(day.date)}({getDayName(day.date)})</span>
              </div>
              <div class="weather-info">
                <img src={`https:${day.day.condition.icon}`} alt="" class="summary-icon" />
                <span class="condition-text">{getWeatherCondition(day.day.condition.code, lang)}</span>
              </div>
              <div class="temp-info">
                <div class="temp-item">
                  <span class="temp-label">{labels.max}</span>
                  <span class="value-text temp-max">{isImperial ? Math.round(day.day.maxtemp_f) : Math.round(day.day.maxtemp_c)}°</span>
                </div>
                <span class="temp-sep">/</span>
                <div class="temp-item">
                  <span class="temp-label">{labels.min}</span>
                  <span class="value-text temp-min">{isImperial ? Math.round(day.day.mintemp_f) : Math.round(day.day.mintemp_c)}°</span>
                </div>
              </div>
              <div class="rain-info">
                <span class="value-text rain-val">{day.day.daily_chance_of_rain}%</span>
              </div>
              <div class="badge-wrapper">
                <span class="hourly-badge">{labels.hourly}</span>
              </div>
            </button>

            <div id={`hourly-${index}`} class="hourly-details" hidden>
              <div class="hourly-scroll-wrapper">
                <table class="hourly-table">
                  <thead>
                    <tr>
                      <th>{labels.time}</th>
                      <th>{labels.weather}</th>
                      <th>{labels.temp}({tempUnit})</th>
                      <th>{labels.humidity}</th>
                      <th>{labels.wind}({windUnit})</th>
                      <th>{labels.rain}</th>
                    </tr>
                  </thead>
                  <tbody>
                    {day.hour.map((h) => (
                      <tr class="hourly-row" data-hour={parseInt(h.time.split(' ')[1].split(':')[0])}>
                        <td class="h-time value-text">{h.time.split(' ')[1]}</td>
                        <td class="h-icon"><img src={`https:${h.condition.icon}`} alt="" /></td>
                        <td class="h-temp value-text">{isImperial ? Math.round(h.temp_f) : Math.round(h.temp_c)}°</td>
                        <td class="h-humidity value-text">{h.humidity}%</td>
                        <td class="h-wind value-text">{isImperial ? Math.round(h.wind_mph) : Math.round(h.wind_kph)}</td>
                        <td class="h-rain value-text">{h.chance_of_rain}%</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    {relatedNews.length > 0 && (
      <section class="related-news-section">
        <h2 class="section-title">{labels.relatedTitle}</h2>
        <div class="news-list-one-column">
          {relatedNews.map((post) => (
            <a href={`/jp/jp/news/${post.id}/`} class="news-item">
              <div class="news-image">
                <img src={getImageUrl(post.content)} alt={post.title} />
              </div>
              <div class="news-content">
                <h3 class="news-title">{post.title}</h3>
                <time class="news-date">{new Date(post.published).toLocaleDateString('ja-JP')}</time>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}
  </main>
</Layout>

{/* ▼ ここが修正されたスクリプトです ▼ */}
<script>
  function updateWeatherDisplay() {
    const page = document.querySelector('.weather-page');
    if (!page) return;

    const timezone = page.getAttribute('data-timezone') || 'Asia/Tokyo';
    // 時間の形式を確実に24時間表記（0〜23）にするために hourCycle を追加しました
    const nowInCity = new Intl.DateTimeFormat('en-US', {
      timeZone: timezone,
      year: 'numeric', month: '2-digit', day: '2-digit', hour: 'numeric', hourCycle: 'h23'
    }).formatToParts(new Date());

    const cityFullDate = `${nowInCity.find(p => p.type === 'year').value}-${nowInCity.find(p => p.type === 'month').value}-${nowInCity.find(p => p.type === 'day').value}`;
    const cityHour = parseInt(nowInCity.find(p => p.type === 'hour').value);

    document.querySelectorAll('.day-group').forEach(group => {
      const groupDate = group.getAttribute('data-date');

      // 1. 今日より「過去」の日付は、丸ごと非表示にする
      if (groupDate < cityFullDate) {
        group.style.display = 'none';
      }
      // 2. 「今日」の場合は、過去の時間を非表示にする
      else if (groupDate === cityFullDate) {
        group.style.display = 'block';
        group.querySelectorAll('.hourly-row').forEach(row => {
          if (parseInt(row.getAttribute('data-hour')) < cityHour) {
            row.style.display = 'none';
          }
        });
      }
      // 3. 「未来」の日付はそのまま表示する
      else {
        group.style.display = 'block';
      }
    });

    document.querySelectorAll('.day-summary-btn').forEach(button => {
      button.addEventListener('click', (e) => {
        const targetId = e.currentTarget.getAttribute('data-target');
        const targetEl = document.getElementById(targetId);
        const isExpanded = e.currentTarget.getAttribute('aria-expanded') === 'true';
        e.currentTarget.setAttribute('aria-expanded', String(!isExpanded));
        targetEl.hidden = isExpanded;
      });
    });
  }
  updateWeatherDisplay();
</script>

<style>
  :root { --weather-value-size: 1.15rem; }
  .weather-page { max-width: 850px; margin: 0 auto; padding: 20px; font-family: sans-serif; }
  .weather-page .section-title { font-size: 1.4rem; margin: 40px 0 20px 0; border-left: 6px solid #872732; padding-left: 12px; }

  .alert-ticker-container { background: #f0f7ff; border: 1.5px solid #1fa7db; border-radius: 8px; padding: 6px 12px; margin-bottom: 24px; display: flex; align-items: center; gap: 12px; overflow: hidden; }
  .alert-ticker-label { display: flex; align-items: center; gap: 6px; white-space: nowrap; color: #0068b7; font-weight: bold; font-size: 0.95rem; }
  .alert-ticker-window { flex-grow: 1; background: #fff; border: 1px solid #1fa7db; border-radius: 4px; height: 32px; display: flex; align-items: center; overflow: hidden; position: relative; }
  .alert-ticker-text { white-space: nowrap; position: absolute; padding-left: 100%; animation: ticker 30s linear infinite; font-size: 0.9rem; color: #c53030; font-weight: bold; }
  @keyframes ticker { 0% { transform: translate(0, 0); } 100% { transform: translate(-100%, 0); } }

  .weather-page .forecast-container { background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 6px rgba(0,0,0,0.05); }
  .weather-page .day-group { border-bottom: 1px solid #e5e7eb; }
  .weather-page .day-summary-btn { width: 100%; display: grid; grid-template-columns: 0.9fr 1.6fr 1.6fr 0.6fr 0.9fr; align-items: center; padding: 6px 16px; background: none; border: none; cursor: pointer; }
  .weather-page .day-summary-btn:hover { background: #f9fafb; }
  .weather-page .summary-icon { width: 72px; height: 72px; } 
  .weather-page .temp-max { color: #d32f2f !important; }
  .weather-page .temp-min { color: #1976d2 !important; }
  .weather-page .hourly-badge { background-color: #4141e0; color: white; padding: 6px 10px; border-radius: 4px; font-size: 0.8rem; font-weight: bold; }

  .weather-page .hourly-details { background: #f8f9fa; padding: 0 16px 4px 16px; border-top: 1px solid #eee; }
  .weather-page .hourly-table { width: 100%; min-width: 550px; border-collapse: collapse; }
  .weather-page .hourly-table th { padding: 8px 4px; font-size: 0.8rem; color: #888; border-bottom: 1px solid #ddd; text-align: center; }
  .weather-page .hourly-table td { padding: 4px 4px; text-align: center; border-bottom: 1px solid #eee; }

  .news-list-one-column { display: flex; flex-direction: column; gap: 15px; }
  .news-item { display: flex; gap: 20px; text-decoration: none; color: inherit; padding: 12px; border: 1px solid #eee; border-radius: 12px; transition: background 0.2s; }
  .news-item:hover { background: #f8f9fa; }
  .news-image { width: 200px; flex-shrink: 0; }
  .news-image img { width: 100%; height: 120px; object-fit: cover; border-radius: 8px; }
  .news-content { flex-grow: 1; display: flex; flex-direction: column; justify-content: center; }
  .news-title { font-size: 1.1rem; font-weight: bold; margin: 0 0 10px 0; }
  .news-date { font-size: 0.85rem; color: #999; }

  @media (max-width: 600px) {
    .news-item { flex-direction: column; }
    .news-image { width: 100%; }
    .weather-page .day-summary-btn { grid-template-columns: 1fr 1fr; gap: 10px; padding: 12px; }
  }
</style>
