---
import Layout from '../../../layouts/Layout.astro';
import { getWeatherCondition } from '../../../lib/weatherConditions';

const currentPath = Astro.url.pathname;
const pathParts = currentPath.split('/').filter(Boolean);
const region = pathParts[0] || 'jp';
const lang = pathParts[1] || 'jp';

const cityMap = {
  jp: { name: 'Tokyo', display: lang === 'en' ? 'Tokyo' : '東京' },
  us: { name: 'New_York', display: lang === 'en' ? 'New York' : 'ニューヨーク' },
  de: { name: 'Berlin', display: lang === 'en' ? 'Berlin' : 'ベルリン' },
};

const targetCity = cityMap[region] || cityMap.jp;
const API_KEY = import.meta.env.WEATHER_API_KEY;

let forecastDays = [];
let alerts = [];

if (API_KEY) {
  try {
    const url = `https://api.weatherapi.com/v1/forecast.json?key=${API_KEY}&q=${targetCity.name}&days=3&aqi=no&alerts=yes&lang=ja`;
    const response = await fetch(url);
    if (response.ok) {
      const data = await response.json();
      forecastDays = data.forecast.forecastday;
      alerts = data.alerts.alert;
    }
  } catch (e) {}
}

const formatDate = (dateStr) => {
  const date = new Date(dateStr);
  return `${date.getMonth() + 1}/${date.getDate()}`;
};

const getDayName = (dateStr) => {
  const days = lang === 'en' ? ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'] : ['日', '月', '火', '水', '木', '金', '土'];
  return days[new Date(dateStr).getDay()];
};
---

<Layout title={`${targetCity.display}${lang === 'en' ? ' Weather' : 'の天気'}`}>
  <main class="weather-page">
    <section class="forecast-section">
      <h2 class="section-title">{targetCity.display} 3日間の天気予報</h2>
      
      <table class="forecast-table">
        <thead>
          <tr>
            <th>日付</th>
            <th>天気</th>
            <th>最高 / 最低</th>
            <th>降水確率</th>
          </tr>
        </thead>
        <tbody>
          {forecastDays.map((day) => (
            <tr>
              <td class="date-col">
                <span class="date-num">{formatDate(day.date)}</span>
                <span class="date-day">({getDayName(day.date)})</span>
              </td>
              <td class="icon-col">
                <img src={`https:${day.day.condition.icon}`} alt={day.day.condition.text} />
                <span class="condition-text">{getWeatherCondition(day.day.condition.code, lang)}</span>
              </td>
              <td class="temp-col">
                <span class="temp-max">{Math.round(day.day.maxtemp_c)}°</span>
                <span class="temp-sep">/</span>
                <span class="temp-min">{Math.round(day.day.mintemp_c)}°</span>
              </td>
              <td class="rain-col">
                {day.day.daily_chance_of_rain}%
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>

    {alerts.length > 0 && (
      <section class="alert-section">
        <h3 class="alert-title">気象注意報・警報</h3>
        <div class="alert-list">
          {alerts.map((alert) => (
            <div class="alert-item">
              <span class="alert-headline">{alert.headline}</span>
            </div>
          ))}
        </div>
      </section>
    )}
  </main>
</Layout>

<style>
  .weather-page {
    max-width: 800px;
    margin: 0 auto;
    padding: 20px;
    font-family: sans-serif;
  }
  .section-title {
    font-size: 1.5rem;
    margin-bottom: 20px;
    border-left: 6px solid #872732;
    padding-left: 12px;
  }
  .forecast-table {
    width: 100%;
    border-collapse: collapse;
    background: #fff;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  }
  .forecast-table th {
    background: #f8f9fa;
    padding: 12px;
    text-align: center;
    border-bottom: 2px solid #eee;
    font-size: 0.9rem;
    color: #666;
  }
  .forecast-table td {
    padding: 16px 12px;
    text-align: center;
    border-bottom: 1px solid #eee;
    vertical-align: middle;
  }
  .date-col {
    font-weight: bold;
  }
  .date-day {
    font-size: 0.85rem;
    margin-left: 4px;
  }
  .icon-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }
  .icon-col img {
    width: 48px;
    height: 48px;
  }
  .condition-text {
    font-size: 0.8rem;
    color: #333;
  }
  .temp-max {
    color: #d32f2f;
    font-weight: bold;
    font-size: 1.1rem;
  }
  .temp-min {
    color: #1976d2;
    font-weight: bold;
    font-size: 1.1rem;
  }
  .temp-sep {
    color: #ccc;
    margin: 0 4px;
  }
  .rain-col {
    font-weight: bold;
    color: #007bb5;
  }
  .alert-section {
    margin-top: 30px;
    background: #fff5f5;
    border: 1px solid #feb2b2;
    border-radius: 8px;
    padding: 16px;
  }
  .alert-title {
    color: #c53030;
    margin: 0 0 10px 0;
    font-size: 1.1rem;
  }
  .alert-item {
    font-size: 0.9rem;
    color: #4a5568;
    line-height: 1.5;
  }
</style>
