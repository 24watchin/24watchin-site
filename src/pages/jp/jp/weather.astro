---
import Layout from '../../../layouts/Layout.astro';
import { getWeatherCondition } from '../../../lib/weatherConditions';

const currentPath = Astro.url.pathname;
const pathParts = currentPath.split('/').filter(Boolean);
const region = pathParts[0] || 'jp';
const lang = pathParts[1] || 'jp';

const apiLangMap = { jp: 'ja', en: 'en', cn: 'zh', fr: 'fr', de: 'de', es: 'es', ru: 'ru' };
const apiLang = apiLangMap[lang] || 'ja';

// 単位の判定：言語が英語（en）なら華氏、それ以外は摂氏
const isImperial = lang === 'en';

const cityMap = {
  jp: { name: 'Tokyo', display: { jp: '東京', en: 'Tokyo', cn: '东京', fr: 'Tokyo', de: 'Tokio', es: 'Tokio', ru: 'Токио' } },
  us: { name: 'New_York', display: { jp: 'ニューヨーク', en: 'New York', cn: '纽约', fr: 'New York', de: 'New York', es: 'Nueva York', ru: 'Нью-Йорк' } },
  de: { name: 'Berlin', display: { jp: 'ベルリン', en: 'Berlin', cn: '柏林', fr: 'Berlin', de: 'Berlin', es: 'Berlín', ru: 'Берлин' } },
};

const targetCity = cityMap[region] || cityMap.jp;
const cityDisplayName = targetCity.display[lang] || targetCity.display.en;

const API_KEY = import.meta.env.WEATHER_API_KEY;
let forecastDays = [];
let alerts = [];
let localHour = 0;
let localDateStr = '';

if (API_KEY) {
  try {
    const url = `https://api.weatherapi.com/v1/forecast.json?key=${API_KEY}&q=${targetCity.name}&days=3&aqi=no&alerts=yes&lang=${apiLang}`;
    const response = await fetch(url);
    if (response.ok) {
      const data = await response.json();
      forecastDays = data.forecast.forecastday;
      alerts = data.alerts.alert;
      const localTimeStr = data.location.localtime;
      localDateStr = localTimeStr.split(' ')[0];
      localHour = parseInt(localTimeStr.split(' ')[1].split(':')[0]);
    }
  } catch (e) {}
}

const allLabels = {
  jp: { title: '3日間の天気予報', hourly: '1時間ごと', alert: '気象警報', time: '時刻', weather: '天気', rain: '降水', humidity: '湿度', wind: '風', max: '最高', min: '最低' },
  en: { title: '3-Day Forecast', hourly: 'Hourly', alert: 'Alerts', time: 'Time', weather: 'Weather', rain: 'Rain', humidity: 'Humid', wind: 'Wind', max: 'Max', min: 'Min' },
  cn: { title: '3日天气预报', hourly: '1小时预报', alert: '气象预警', time: '时间', weather: '天气', rain: '降水', humidity: '湿度', wind: '风', max: '最高', min: '最低' },
  fr: { title: 'Prévisions', hourly: 'Par heure', alert: 'Alertes', time: 'Heure', weather: 'Météo', rain: 'Pluie', humidity: 'Humid', wind: 'Vent', max: 'Max', min: 'Min' },
  de: { title: '3-Tage-Vorhersage', hourly: 'Stündlich', alert: 'Warnungen', time: 'Zeit', weather: 'Wetter', rain: 'Regen', humidity: 'Luftf', wind: 'Wind', max: 'Max', min: 'Min' },
  es: { title: 'Pronóstico', hourly: 'Por hora', alert: 'Alertas', time: 'Hora', weather: 'Clima', rain: 'Lluvia', humidity: 'Humed', wind: 'Viento', max: 'Máx', min: 'Mín' },
  ru: { title: 'Прогноз', hourly: 'По часам', alert: 'Оповещения', time: 'Время', weather: 'Погода', rain: 'Осадки', humidity: 'Влаж', wind: 'Ветер', max: 'Макс', min: 'Мин' }
};

const labels = allLabels[lang] || allLabels.en;

const formatDate = (dateStr) => {
  const date = new Date(dateStr);
  return `${date.getMonth() + 1}/${date.getDate()}`;
};

const getDayName = (dateStr) => {
  const dayIndex = new Date(dateStr).getDay();
  const dayNames = {
    jp: ['日', '月', '火', '水', '木', '金', '土'],
    en: ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'],
    cn: ['日', '一', '二', '三', '四', '五', '六'],
    fr: ['Dim', 'Lun', 'Mar', 'Mer', 'Jeu', 'Ven', 'Sam'],
    de: ['So', 'Mo', 'Di', 'Mi', 'Do', 'Fr', 'Sa'],
    es: ['Dom', 'Lun', 'Mar', 'Mié', 'Jue', 'Vie', 'Sáb'],
    ru: ['Вс', 'Пн', 'Вт', 'Ср', 'Чт', 'Пт', 'Сб']
  };
  return (dayNames[lang] || dayNames.en)[dayIndex];
};
---

<Layout title={`${cityDisplayName} | ${labels.title}`}>
  <main class="weather-page">
    <section class="forecast-section">
      <h2 class="section-title">{cityDisplayName} {labels.title}</h2>
      
      <div class="forecast-container">
        {forecastDays.map((day, index) => {
          const isTodayInCity = day.date === localDateStr;
          const filteredHours = isTodayInCity 
            ? day.hour.filter(h => parseInt(h.time.split(' ')[1].split(':')[0]) >= localHour)
            : day.hour;

          return (
            <div class="day-group">
              <button class="day-summary-btn" aria-expanded="false" data-target={`hourly-${index}`}>
                <div class="date-info">
                  <span class="date-text">{formatDate(day.date)}({getDayName(day.date)})</span>
                </div>
                <div class="weather-info">
                  <img src={`https:${day.day.condition.icon}`} alt="" class="summary-icon icon-filter" />
                  <span class="condition-text">{getWeatherCondition(day.day.condition.code, lang)}</span>
                </div>
                <div class="temp-info">
                  <div class="temp-item">
                    <span class="temp-label">{labels.max}</span>
                    <span class="value-text temp-max">
                      {isImperial ? Math.round(day.day.maxtemp_f) : Math.round(day.day.maxtemp_c)}°
                    </span>
                  </div>
                  <span class="temp-sep">/</span>
                  <div class="temp-item">
                    <span class="temp-label">{labels.min}</span>
                    <span class="value-text temp-min">
                      {isImperial ? Math.round(day.day.mintemp_f) : Math.round(day.day.mintemp_c)}°
                    </span>
                  </div>
                </div>
                <div class="rain-info">
                  <span class="value-text rain-val">{day.day.daily_chance_of_rain}%</span>
                </div>
                <div class="badge-wrapper">
                  <span class="hourly-badge">{labels.hourly}</span>
                </div>
              </button>

              <div id={`hourly-${index}`} class="hourly-details" hidden>
                <div class="hourly-scroll-wrapper">
                  <table class="hourly-table">
                    <thead>
                      <tr>
                        <th>{labels.time}</th>
                        <th>{labels.weather}</th>
                        <th>{isImperial ? '℉' : '℃'}</th>
                        <th>{labels.humidity}</th>
                        <th>{labels.wind}</th>
                        <th>{labels.rain}</th>
                      </tr>
                    </thead>
                    <tbody>
                      {filteredHours.map((h) => (
                        <tr>
                          <td class="h-time value-text">{h.time.split(' ')[1]}</td>
                          <td class="h-icon">
                            <img src={`https:${h.condition.icon}`} alt="" class="icon-filter" />
                          </td>
                          <td class="h-temp value-text">
                            {isImperial ? Math.round(h.temp_f) : Math.round(h.temp_c)}°
                          </td>
                          <td class="h-humidity value-text">{h.humidity}%</td>
                          <td class="h-wind value-text">
                            {isImperial ? Math.round(h.wind_mph) : Math.round(h.wind_kph)}
                            <small>{isImperial ? 'mph' : 'k/h'}</small>
                          </td>
                          <td class="h-rain value-text">{h.chance_of_rain}%</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </section>

    {alerts.length > 0 && (
      <section class="alert-section">
        <h3 class="alert-title">{labels.alert}</h3>
        <div class="alert-list">
          {alerts.map((alert) => (
            <div class="alert-item">
              <span class="alert-headline">{alert.headline}</span>
            </div>
          ))}
        </div>
      </section>
    )}
  </main>
</Layout>

<script>
  // Astroのページ読み込み完了後に確実に実行されるようにします
  function initWeatherAccordion() {
    const buttons = document.querySelectorAll('.day-summary-btn');
    buttons.forEach(button => {
      // 既存のリスナーを一度リセットしてから貼り直します
      button.removeEventListener('click', toggleAccordion);
      button.addEventListener('click', toggleAccordion);
    });
  }

  function toggleAccordion(event) {
    const button = event.currentTarget;
    const targetId = button.getAttribute('data-target');
    const targetEl = document.getElementById(targetId);
    if (!targetEl) return;

    const isExpanded = button.getAttribute('aria-expanded') === 'true';
    button.setAttribute('aria-expanded', !isExpanded);
    targetEl.hidden = isExpanded;
  }

  // 最初の読み込み時
  initWeatherAccordion();
</script>

<style>
  :root { --weather-value-size: 1.15rem; }
  .weather-page { max-width: 850px; margin: 0 auto; padding: 20px; font-family: sans-serif; }
  .section-title { font-size: 1.4rem; margin-bottom: 24px; border-left: 6px solid #872732; padding-left: 12px; }
  .forecast-container { background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 6px rgba(0,0,0,0.05); }
  .day-group { border-bottom: 1px solid #e5e7eb; }
  .day-summary-btn { width: 100%; display: grid; grid-template-columns: 0.9fr 1.6fr 1.6fr 0.6fr 0.9fr; align-items: center; padding: 6px 16px; background: none; border: none; cursor: pointer; }
  .day-summary-btn:hover { background: #f9fafb; }
  .date-text { font-weight: bold; font-size: 1.15rem; white-space: nowrap; }
  .weather-info { display: flex; align-items: center; gap: 8px; }
  .summary-icon { width: 76px; height: 76px; } 
  .icon-filter[src*="day"] { filter: saturate(3) hue-rotate(-10deg) brightness(1.1) drop-shadow(0 0 1px #ff4500); }
  .icon-filter[src*="night"] { filter: brightness(1.2) sepia(1) saturate(20) hue-rotate(-35deg) drop-shadow(0 0 1px gold); }
  .temp-info { display: flex; align-items: center; justify-content: center; gap: 6px; }
  .temp-item { display: flex; flex-direction: column; align-items: center; }
  .temp-label { font-size: 0.75rem; color: #666; font-weight: bold; margin-bottom: -2px; }
  .temp-sep { color: #ccc; font-size: 1.3rem; margin-top: 8px; }
  .value-text { font-size: var(--weather-value-size); font-weight: 800; }
  .temp-max { color: #d32f2f !important; }
  .temp-min { color: #1976d2 !important; }
  .rain-info { text-align: center; color: #007bb5; }
  .badge-wrapper { text-align: right; }
  .hourly-badge { background-color: #4141e0; color: white; padding: 6px 10px; border-radius: 4px; font-size: 0.8rem; font-weight: bold; display: inline-block; }
  .hourly-details { background: #f8f9fa; padding: 0 16px 4px 16px; border-top: 1px solid #eee; }
  .hourly-scroll-wrapper { overflow-x: auto; }
  .hourly-table { width: 100%; min-width: 550px; border-collapse: collapse; }
  .hourly-table th { padding: 8px 4px; font-size: 0.75rem; color: #888; border-bottom: 1px solid #ddd; }
  .hourly-table td { padding: 0px 4px; text-align: center; border-bottom: 1px solid #eee; }
  .h-time { color: #333; font-weight: bold; }
  .h-icon img { width: 64px; height: 64px; vertical-align: middle; object-fit: contain; transform: scale(1.25); }
  .h-temp { color: #1a1a1a !important; font-size: 1.25rem !important; }
  .h-humidity { color: #555; }
  .h-rain { color: #007bb5; }
  .h-wind small { font-size: 0.6rem; margin-left: 1px; }
  .alert-section { margin-top: 30px; background: #fff5f5; border: 1px solid #feb2b2; border-radius: 12px; padding: 20px; }
  .alert-title { color: #c53030; margin: 0 0 10px 0; font-weight: bold; }
  .alert-item { font-size: 0.9rem; line-height: 1.6; }
</style>
