---
import Layout from '../../../layouts/Layout.astro';
import { getWeatherCondition } from '../../../lib/weatherConditions';

const currentPath = Astro.url.pathname;
const pathParts = currentPath.split('/').filter(Boolean);
const region = pathParts[0] || 'jp';
const lang = pathParts[1] || 'jp';

const apiLangMap = { jp: 'ja', en: 'en', cn: 'zh', fr: 'fr', de: 'de', es: 'es', ru: 'ru' };
const apiLang = apiLangMap[lang] || 'ja';
const isImperial = lang === 'en';

const cityMap = {
  jp: { name: 'Tokyo', tz: 'Asia/Tokyo', display: { jp: '東京', en: 'Tokyo', cn: '东京', fr: 'Tokyo', de: 'Tokio', es: 'Tokio', ru: 'Токио' } },
  us: { name: 'New_York', tz: 'America/New_York', display: { jp: 'ニューヨーク', en: 'New York', cn: '纽约', fr: 'New York', de: 'New York', es: 'Nueva York', ru: 'Нью-Йорк' } },
  de: { name: 'Berlin', tz: 'Europe/Berlin', display: { jp: 'ベルリン', en: 'Berlin', cn: '柏林', fr: 'Berlin', de: 'Berlin', es: 'Berlín', ru: 'Берлин' } },
};

const targetCity = cityMap[region] || cityMap.jp;
const cityDisplayName = targetCity.display[lang] || targetCity.display.en;

const API_KEY = import.meta.env.WEATHER_API_KEY;
let forecastDays = [];
let alerts = [];

if (API_KEY) {
  try {
    const url = `https://api.weatherapi.com/v1/forecast.json?key=${API_KEY}&q=${targetCity.name}&days=3&aqi=no&alerts=yes&lang=${apiLang}`;
    const response = await fetch(url);
    if (response.ok) {
      const data = await response.json();
      forecastDays = data.forecast.forecastday;
      alerts = data.alerts.alert;
    }
  } catch (e) {}
}

const allLabels = {
  jp: { title: '3日間の天気予報', hourly: '1時間ごと', alertTitle: '気象警報・注意報', time: '時刻', weather: '天気', rain: '降水', humidity: '湿度', wind: '風速', max: '最高', min: '最低', temp: '気温' },
  en: { title: '3-Day Forecast', hourly: 'Hourly', alertTitle: 'Weather Alerts', time: 'Time', weather: 'Weather', rain: 'Rain', humidity: 'Humid', wind: 'Wind', max: 'Max', min: 'Min', temp: 'Temp' },
  // ...他言語も同様に設定
};

const labels = allLabels[lang] || allLabels.en;
const tempUnit = isImperial ? '℉' : '℃';
const windUnit = isImperial ? 'mph' : 'km/h';

const formatDate = (dateStr) => {
  const date = new Date(dateStr);
  return `${date.getMonth() + 1}/${date.getDate()}`;
};

const getDayName = (dateStr) => {
  const dayIndex = new Date(dateStr).getDay();
  const dayNames = {
    jp: ['日', '月', '火', '水', '木', '金', '土'],
    en: ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat']
  };
  return (dayNames[lang] || dayNames.en)[dayIndex];
};
---

<Layout title={`${cityDisplayName} | ${labels.title}`}>
  <main class="weather-page" data-timezone={targetCity.tz}>
    
    {/* ▼ 【新規】災害アラートセクション（最上部） ▼ */}
    {alerts.length > 0 && (
      <div class="alert-banner-container">
        <div class="alert-banner-header">
          <span class="alert-icon">⚠️</span>
          <h2 class="alert-main-title">{labels.alertTitle}</h2>
        </div>
        <div class="alert-scroll-area">
          {alerts.map((alert) => (
            <div class="alert-card">
              <h3 class="alert-headline">{alert.headline}</h3>
              <p class="alert-desc">{alert.desc}</p>
              {alert.instruction && (
                <div class="alert-instruction">
                  <strong>Instruction:</strong> {alert.instruction}
                </div>
              )}
            </div>
          ))}
        </div>
      </div>
    )}

    <section class="forecast-section">
      <h2 class="section-title">{cityDisplayName} {labels.title}</h2>
      <div class="forecast-container">
        {/* ...（以前と同じ予報部分）... */}
        {forecastDays.map((day, index) => (
          <div class="day-group" data-date={day.date}>
            <button class="day-summary-btn" aria-expanded="false" data-target={`hourly-${index}`}>
              <div class="date-info">
                <span class="date-text">{formatDate(day.date)}({getDayName(day.date)})</span>
              </div>
              <div class="weather-info">
                <img src={`https:${day.day.condition.icon}`} alt="" class="summary-icon" />
                <span class="condition-text">{getWeatherCondition(day.day.condition.code, lang)}</span>
              </div>
              <div class="temp-info">
                <div class="temp-item">
                  <span class="temp-label">{labels.max}</span>
                  <span class="value-text temp-max">{isImperial ? Math.round(day.day.maxtemp_f) : Math.round(day.day.maxtemp_c)}°</span>
                </div>
                <span class="temp-sep">/</span>
                <div class="temp-item">
                  <span class="temp-label">{labels.min}</span>
                  <span class="value-text temp-min">{isImperial ? Math.round(day.day.mintemp_f) : Math.round(day.day.mintemp_c)}°</span>
                </div>
              </div>
              <div class="rain-info">
                <span class="value-text rain-val">{day.day.daily_chance_of_rain}%</span>
              </div>
              <div class="badge-wrapper">
                <span class="hourly-badge">{labels.hourly}</span>
              </div>
            </button>
            {/* 1時間予報のテーブル部分は省略せずに維持してください */}
          </div>
        ))}
      </div>
    </section>
  </main>
</Layout>

<script>
  // ...（以前と同じJavaScript部分）...
</script>

<style>
  /* ▼ 災害アラートのスタイル ▼ */
  .alert-banner-container {
    background: #fff5f5;
    border: 2px solid #f56565;
    border-radius: 12px;
    padding: 16px;
    margin-bottom: 24px;
    box-shadow: 0 4px 6px rgba(245, 101, 101, 0.1);
  }
  .alert-banner-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 12px;
    color: #c53030;
  }
  .alert-icon { font-size: 1.5rem; }
  .alert-main-title { font-size: 1.2rem; font-weight: bold; margin: 0; }
  .alert-card {
    background: #fff;
    border-left: 4px solid #f56565;
    padding: 12px;
    margin-bottom: 10px;
    border-radius: 4px;
  }
  .alert-headline { font-size: 1rem; color: #c53030; margin: 0 0 8px 0; }
  .alert-desc { font-size: 0.9rem; line-height: 1.5; color: #4a5568; margin-bottom: 8px; }
  .alert-instruction {
    font-size: 0.85rem;
    background: #edf2f7;
    padding: 8px;
    border-radius: 4px;
    color: #2d3748;
  }

  /* 既存のスタイル */
  :root { --weather-value-size: 1.15rem; }
  .weather-page { max-width: 850px; margin: 0 auto; padding: 20px; font-family: sans-serif; }
  /* ...（その他のスタイルは維持）... */
</style>
