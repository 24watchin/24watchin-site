---
import Layout from '../../../layouts/Layout.astro';
import { getWeatherCondition } from '../../../lib/weatherConditions';

const currentPath = Astro.url.pathname;
const pathParts = currentPath.split('/').filter(Boolean);
const region = pathParts[0] || 'jp';
const lang = pathParts[1] || 'jp';

const cityMap = {
  jp: { name: 'Tokyo', display: lang === 'en' ? 'Tokyo' : '東京' },
  us: { name: 'New_York', display: lang === 'en' ? 'New York' : 'ニューヨーク' },
  de: { name: 'Berlin', display: lang === 'en' ? 'Berlin' : 'ベルリン' },
};

const targetCity = cityMap[region] || cityMap.jp;
const API_KEY = import.meta.env.WEATHER_API_KEY;

let forecastDays = [];
let alerts = [];

if (API_KEY) {
  try {
    const url = `https://api.weatherapi.com/v1/forecast.json?key=${API_KEY}&q=${targetCity.name}&days=3&aqi=no&alerts=yes&lang=ja`;
    const response = await fetch(url);
    if (response.ok) {
      const data = await response.json();
      forecastDays = data.forecast.forecastday;
      alerts = data.alerts.alert;
    }
  } catch (e) {}
}

const formatDate = (dateStr) => {
  const date = new Date(dateStr);
  return `${date.getMonth() + 1}/${date.getDate()}`;
};

const getDayName = (dateStr) => {
  const days = lang === 'en' ? ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'] : ['日', '月', '火', '水', '木', '金', '土'];
  return days[new Date(dateStr).getDay()];
};

const labels = {
  title: lang === 'en' ? `${targetCity.display} 3-Day Forecast` : `${targetCity.display} 3日間の天気予報`,
  hourlyBadge: lang === 'en' ? 'Hourly' : '1時間ごと',
  alertTitle: lang === 'en' ? 'Weather Alerts' : '気象注意報・警報',
  tableTime: lang === 'en' ? 'Time' : '時刻',
  tableWeather: lang === 'en' ? 'Weather' : '天気',
  tableTemp: lang === 'en' ? 'Temp' : '気温',
  tableRain: lang === 'en' ? 'Rain' : '降水',
};
---

<Layout title={`${targetCity.display}${lang === 'en' ? ' Weather' : 'の天気'}`}>
  <main class="weather-page">
    <section class="forecast-section">
      <h2 class="section-title">{labels.title}</h2>
      
      <div class="forecast-container">
        {forecastDays.map((day, index) => (
          <div class="day-group">
            <button class="day-summary-btn" aria-expanded="false" data-target={`hourly-${index}`}>
              <div class="date-info">
                <span class="date-num">{formatDate(day.date)}</span>
                <span class="date-day">({getDayName(day.date)})</span>
              </div>
              <div class="weather-info">
                <img src={`https:${day.day.condition.icon}`} alt="" />
                <span class="condition-text">{getWeatherCondition(day.day.condition.code, lang)}</span>
              </div>
              <div class="temp-info">
                <span class="temp-max">{Math.round(day.day.maxtemp_c)}°</span>
                <span class="temp-sep">/</span>
                <span class="temp-min">{Math.round(day.day.mintemp_c)}°</span>
              </div>
              <div class="rain-info">
                <span class="rain-val">{day.day.daily_chance_of_rain}%</span>
              </div>
              <div class="badge-wrapper">
                <span class="hourly-badge">{labels.hourlyBadge}</span>
              </div>
            </button>

            <div id={`hourly-${index}`} class="hourly-details" hidden>
              <div class="hourly-scroll-wrapper">
                <table class="hourly-table">
                  <thead>
                    <tr>
                      <th>{labels.tableTime}</th>
                      <th>{labels.tableWeather}</th>
                      <th>{labels.tableTemp}</th>
                      <th>{labels.tableRain}</th>
                    </tr>
                  </thead>
                  <tbody>
                    {day.hour.map((h) => (
                      <tr>
                        <td class="h-time">{h.time.split(' ')[1]}</td>
                        <td class="h-icon">
                          <img src={`https:${h.condition.icon}`} alt="" />
                        </td>
                        <td class="h-temp">{Math.round(h.temp_c)}°</td>
                        <td class="h-rain">{h.chance_of_rain}%</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    {alerts.length > 0 && (
      <section class="alert-section">
        <h3 class="alert-title">{labels.alertTitle}</h3>
        <div class="alert-list">
          {alerts.map((alert) => (
            <div class="alert-item">
              <span class="alert-headline">{alert.headline}</span>
            </div>
          ))}
        </div>
      </section>
    )}
  </main>
</Layout>

<script>
  const buttons = document.querySelectorAll('.day-summary-btn');
  buttons.forEach(button => {
    button.addEventListener('click', () => {
      const targetId = button.getAttribute('data-target');
      const targetEl = document.getElementById(targetId);
      const isExpanded = button.getAttribute('aria-expanded') === 'true';

      button.setAttribute('aria-expanded', !isExpanded);
      targetEl.hidden = isExpanded;
    });
  });
</script>

<style>
  .weather-page {
    max-width: 800px;
    margin: 0 auto;
    padding: 20px;
    font-family: sans-serif;
  }
  .section-title {
    font-size: 1.4rem;
    margin-bottom: 24px;
    border-left: 6px solid #872732;
    padding-left: 12px;
  }
  .forecast-container {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 6px rgba(0,0,0,0.05);
  }
  .day-group {
    border-bottom: 1px solid #e5e7eb;
  }
  .day-group:last-child {
    border-bottom: none;
  }
  .day-summary-btn {
    width: 100%;
    display: grid;
    /* バッジの幅に合わせて列の比率を調整しました */
    grid-template-columns: 0.8fr 1.4fr 1.1fr 0.7fr 1.2fr;
    align-items: center;
    padding: 16px;
    background: none;
    border: none;
    cursor: pointer;
    transition: background 0.2s;
  }
  .day-summary-btn:hover {
    background: #f9fafb;
  }
  .date-info {
    font-weight: bold;
    text-align: left;
  }
  .date-day {
    font-size: 0.85rem;
    color: #666;
    display: block;
  }
  .weather-info {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .weather-info img {
    width: 44px;
    height: 44px;
  }
  .condition-text {
    font-size: 0.9rem;
  }
  .temp-info {
    text-align: center;
  }
  .temp-max {
    color: #d32f2f;
    font-weight: bold;
    font-size: 1.2rem;
  }
  .temp-min {
    color: #1976d2;
    font-weight: bold;
    font-size: 1.2rem;
  }
  .temp-sep {
    color: #ccc;
    margin: 0 4px;
  }
  .rain-info {
    text-align: center;
    color: #007bb5;
    font-weight: bold;
  }
  
  /* 1時間ごとバッジのデザイン */
  .badge-wrapper {
    text-align: right;
  }
  .hourly-badge {
    background-color: #4141e0;
    color: white;
    padding: 6px 10px;
    border-radius: 4px;
    font-size: 0.8rem;
    font-weight: bold;
    display: inline-block;
  }

  .hourly-details {
    background: #f8f9fa;
    padding: 0 16px 16px 16px;
  }
  .hourly-scroll-wrapper {
    overflow-x: auto;
  }
  .hourly-table {
    width: 100%;
    min-width: 450px;
    border-collapse: collapse;
  }
  .hourly-table th {
    padding: 12px 4px;
    font-size: 0.75rem;
    color: #888;
    border-bottom: 1px solid #ddd;
  }
  .hourly-table td {
    padding: 10px 4px;
    text-align: center;
    border-bottom: 1px solid #eee;
  }
  .h-time { color: #666; }
  .h-icon img { width: 32px; height: 32px; }
  .h-temp { font-weight: bold; }
  .h-rain { color: #007bb5; }

  .alert-section {
    margin-top: 30px;
    background: #fff5f5;
    border: 1px solid #feb2b2;
    border-radius: 12px;
    padding: 20px;
  }
  .alert-title {
    color: #c53030;
    margin: 0 0 10px 0;
  }
  .alert-item {
    font-size: 0.9rem;
    line-height: 1.6;
  }
</style>
