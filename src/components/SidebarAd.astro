---
// サイドバーに表示する広告（300x250サイズ）の部品です
---
<div class="sidebar-ad">
  {/* ここに将来、Googleアドセンスなどの広告コードが入ります */}
  {/* 今は分かりやすい300x250のダミー画像を表示します */}
  <img 
    src="https://placehold.co/300x250/dddddd/999999?text=広告スペース+(300x250)" 
    alt="広告ダミー画像"
    class="ad-image"
  />
</div>

<style>
  /* 広告エリアの枠の設定 */
  .sidebar-ad {
    width: 100%;
    /* 念のため、最大幅を300pxに制限して、絶対にはみ出さないようにします */
    max-width: 300px;
    margin: 0 auto; /* 中央揃え */
    border: 1px solid #eee; /* 薄い枠線をつけて分かりやすくします */
    background: #f9f9f9; /* 背景色 */
  }

  /* ダミー画像の設定 */
  .ad-image {
    width: 100%; /* 親の枠（300px）に合わせて横幅いっぱいに広げます */
    height: auto; /* 高さは自動で調整して比率を保ちます */
    display: block; /* 画像の下に変な隙間ができるのを防ぎます */
  }
</style>
