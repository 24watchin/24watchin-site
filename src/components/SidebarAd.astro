---
// サイドバー用の300x250広告部品です。
// 現在はダミー表示になっています。
---

<div class="sidebar-ad-wrapper">
  {/* 上部の「広告スペース」という文字です */}
  <div class="ad-label">広告スペース</div>
  
  {/* 白い四角い枠（300x250）の部分です */}
  <div class="ad-box">
    <span class="ad-size">300 x 250</span>
  </div>
</div>

<style>
  /* 外側の薄いグレーの枠の設定です */
  .sidebar-ad-wrapper {
    background-color: #f1f3f6; /* 薄いグレーの背景 */
    padding: 15px; /* 内側に少し余白をとります */
    border-radius: 5px; /* 角を少しだけ丸くします */
    text-align: center; /* 文字を真ん中に寄せます */
    font-family: sans-serif;
  }
  
  /* 「広告スペース」という文字の設定です */
  .ad-label {
    font-size: 13px;
    color: #666;
    margin-bottom: 10px; /* 下に少し隙間を空けます */
  }
  
  /* 白い広告枠本体の設定です */
  .ad-box {
    background-color: #ffffff;
    width: 300px;
    height: 250px;
    margin: 0 auto; /* 真ん中に配置します */
    display: flex;
    justify-content: center; /* 中の文字を左右の真ん中にします */
    align-items: center; /* 中の文字を上下の真ん中にします */
  }
  
  /* 「300 x 250」という文字の設定です */
  .ad-size {
    font-size: 18px;
    color: #99aab5;
  }
</style>
