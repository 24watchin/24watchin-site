---
// 「あわせて読みたい」枠（Google AdSense マルチプレックス広告）
const { lang = 'ja' } = Astro.props;

// ▼ 多言語タイトル
const titleMap: Record<string, string> = {
  ja:      'あわせて読みたい',
  en:      'You May Also Like',
  'zh-cn': '猜你喜欢',
  'zh-tw': '猜你喜歡',
  es:      'También te puede interesar',
  fr:      'Vous aimerez aussi',
  de:      'Das könnte Sie auch interessieren',
  ru:      'Вам также может понравиться',
};
const sectionTitle = titleMap[lang] || titleMap['en'];
---

<div class="bottom-section">
  <div class="sponsored-header">
    <h3 class="section-title">{sectionTitle}</h3>
    <span class="sponsor-credit">PR</span>
  </div>
  
  <div class="adsense-container">
    {/* ▼ Google AdSenseコード ▼ */}
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-2614349930540151" crossorigin="anonymous"></script>
    <ins class="adsbygoogle"
         style="display:block"
         data-ad-format="autorelaxed"
         data-ad-client="ca-pub-2614349930540151"
         data-ad-slot="6685789540"></ins>
    <script>
         (adsbygoogle = window.adsbygoogle || []).push({});
    </script>
    {/* ▲ ここまで ▲ */}
  </div>
</div>

<style>
  .bottom-section { margin-bottom: 50px; }

  /* ▼ sponsored-headerのborder-bottomは削除、下線はsection-titleに移動 */
  .sponsored-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 20px; }

  /* ▼ EditorPicksと同じスタイル！テーマカラーの下線 */
  .section-title { font-size: 19px; color: #333; margin-bottom: 0; border-bottom: 3px solid var(--theme-color, #872732); padding-bottom: 5px; display: inline-block; font-weight: bold; }

  /* PRの文字：控えめなグレー */
  .sponsor-credit { font-size: 13px; color: #888888; font-weight: bold; margin-bottom: 5px; }

  .adsense-container { width: 100%; overflow: hidden; }
</style>
