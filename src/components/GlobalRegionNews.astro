---
import RegionNewsBlock from './RegionNewsBlock.astro';

// lang: 現在の言語（ja, enなど）を受け取ります
const { lang = 'ja', allPosts = [] } = Astro.props;

// 国ごとの記事を抽出する補助関数
const filterByCountryTag = (countryCode, count = 3) => {
  const tag = `${countryCode}-${lang}`; // 例: "us-ja" や "us-en" を自動生成
  return allPosts.filter(post => post.labels?.includes(tag)).slice(0, count);
};

// 地域と国の定義（ここ一箇所を直せば全サイトが変わります！）
const regions = [
  {
    title: lang === 'ja' ? 'アジア' : 'Asia',
    cities: [
      { name: lang === 'ja' ? '日本' : 'Japan', code: 'jp' },
      { name: lang === 'ja' ? '台湾' : 'Taiwan', code: 'tw' },
    ]
  },
  {
    title: lang === 'ja' ? 'ヨーロッパ' : 'Europe',
    cities: [
      { name: lang === 'ja' ? 'ドイツ' : 'Germany', code: 'de' },
      { name: lang === 'ja' ? 'フランス' : 'France', code: 'fr' },
    ]
  },
  {
    title: lang === 'ja' ? 'アメリカ大陸' : 'Americas',
    cities: [
      { name: lang === 'ja' ? 'アメリカ' : 'USA', code: 'us' },
    ]
  }
];
---

<div class="region-section-container">
  {regions.map(region => (
    <RegionNewsBlock 
      lang={lang}
      title={region.title}
      cityData={region.cities.map(city => ({
        name: city.name,
        code: city.code,
        posts: filterByCountryTag(city.code)
      }))}
    />
  ))}
</div>

<style>
  .region-section-container { margin-top: 40px; width: 100%; }
</style>
