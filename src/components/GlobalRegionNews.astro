---
import RegionNewsBlock from './RegionNewsBlock.astro';

const { lang = 'ja', country = '', allPosts = [] } = Astro.props;

// 言語-国 の形式でフィルタリング（例: ja-tw）
const filterByCountryTag = (countryCode, count = 3) => {
  const tag = `${lang}-${countryCode}`;
  return allPosts.filter(post => post.labels?.includes(tag)).slice(0, count);
};

const regionsTemplate = [
  {
    title: lang === 'ja' ? 'アジア' : 'Asia',
    cities: [
      { name: lang === 'ja' ? '日本' : 'Japan', code: 'jp' },
      { name: lang === 'ja' ? '台湾' : 'Taiwan', code: 'tw' },
    ]
  },
  {
    title: lang === 'ja' ? 'ヨーロッパ' : 'Europe',
    cities: [
      { name: lang === 'ja' ? 'ドイツ' : 'Germany', code: 'de' },
      { name: lang === 'ja' ? 'フランス' : 'France', code: 'fr' },
    ]
  },
  {
    title: lang === 'ja' ? 'アメリカ大陸' : 'Americas',
    cities: [
      { name: lang === 'ja' ? 'アメリカ' : 'USA', code: 'us' },
    ]
  }
];

// 現在の国(jp)を除外し、かつ記事が存在する国・地域だけを抽出
const activeRegions = regionsTemplate.map(region => {
  const activeCities = region.cities
    .filter(city => city.code !== country) // 現在の国を表示しない
    .map(city => ({
      ...city,
      posts: filterByCountryTag(city.code)
    }))
    .filter(city => city.posts.length > 0);

  return { ...region, cities: activeCities };
}).filter(region => region.cities.length > 0);
---

<div class="region-section-container">
  {activeRegions.map(region => (
    <RegionNewsBlock 
      lang={lang}
      title={region.title}
      cityData={region.cities}
    />
  ))}
</div>

<style>
  .region-section-container { margin-top: 30px; width: 100%; }
</style>
