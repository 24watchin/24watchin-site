---
// 編集部のおすすめ（横スクロール）を表示する専用の部品です
const { recentPosts } = Astro.props; // 記事データを受け取ります

const getImageUrl = (content) => {
  const match = content.match(/<img[^>]+src="([^">]+)"/);
  return match ? match[1] : 'https://placehold.co/400x300/eeeeee/999999?text=No+Image';
};
---

<div class="editor-picks-section">
  <h3 class="section-title">編集部のおすすめ</h3>
  <div class="scroll-wrapper">
    <div class="scroll-container">
      {recentPosts.map((rp) => (
        <a href={`/news/${rp.id}/`} class="scroll-item">
          <div class="scroll-img-wrapper">
            <img src={getImageUrl(rp.content)} alt={rp.title} />
          </div>
          <div class="scroll-text">
            <h4>{rp.title}</h4>
            <span class="tag-link"># おすすめ</span>
          </div>
        </a>
      ))}
    </div>
    <div class="scroll-arrow"><i class="fas fa-chevron-right"></i></div>
  </div>
</div>

<style>
  /* 見出しの共通デザイン */
  .section-title { font-size: 22px; color: #333; margin-bottom: 20px; border-bottom: 3px solid #1e3a8a; padding-bottom: 10px; display: inline-block; }
  .tag-link { font-size: 12px; color: #d97706; font-weight: bold; margin-top: 10px; display: block; }

  /* 編集部のおすすめ専用の横スクロールデザイン */
  .editor-picks-section { background: #e5e7eb; padding: 40px; margin: 0 0 50px; border-radius: 8px; }
  .scroll-wrapper { position: relative; }
  .scroll-container { display: flex; gap: 20px; overflow-x: auto; padding-bottom: 15px; scroll-snap-type: x mandatory; }
  .scroll-container::-webkit-scrollbar { display: none; } 
  .scroll-item { min-width: 280px; flex-shrink: 0; background: #fff; scroll-snap-align: start; text-decoration: none; color: #333; display: flex; flex-direction: column; border-radius: 4px; overflow: hidden; }
  .scroll-img-wrapper { height: 180px; overflow: hidden; background: #ddd; }
  .scroll-img-wrapper img { width: 100%; height: 100%; object-fit: cover; }
  .scroll-text { padding: 15px; }
  .scroll-text h4 { font-size: 16px; margin: 0; line-height: 1.4; }
  
  .scroll-arrow { position: absolute; right: -15px; top: 40%; transform: translateY(-50%); background: rgba(0,0,0,0.7); color: #fff; width: 45px; height: 45px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 20px; cursor: pointer; box-shadow: 0 4px 6px rgba(0,0,0,0.3); z-index: 10; }

  /* スマホ画面の調整 */
  @media (max-width: 768px) {
    .editor-picks-section { padding: 20px 15px; }
  }
</style>
