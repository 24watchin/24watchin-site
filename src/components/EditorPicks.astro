---
// 編集部のおすすめ（横スクロール）部品
const { recentPosts = [] } = Astro.props;

const getImageUrl = (content) => {
  if (!content) return 'https://placehold.co/400x300/eeeeee/999999?text=No+Image';
  const match = content.match(/<img[^>]+src="([^">]+)"/);
  return match ? match[1] : 'https://placehold.co/400x300/eeeeee/999999?text=No+Image';
};
---

<div class="editor-picks-section">
  <h3 class="section-title">編集部のおすすめ</h3>
  
  <div class="scroll-wrapper">
    <button class="nav-btn prev-btn" id="prev-btn" aria-label="前へ">
      <span>&#10094;</span>
    </button>

    <div class="scroll-container" id="editor-picks-scroller">
      {recentPosts.map((rp) => (
        <a href={`/jp/jp/news/${rp.id}/`} class="scroll-item">
          <div class="scroll-img-wrapper">
            <img src={getImageUrl(rp.content)} alt={rp.title} />
          </div>
          <div class="scroll-text">
            <h4>{rp.title}</h4>
            <span class="tag-link"># おすすめ</span>
          </div>
        </a>
      ))}
    </div>

    <button class="nav-btn next-btn" id="next-btn" aria-label="次へ">
      <span>&#10095;</span>
    </button>
  </div>
</div>

<script>
  // ボタンをクリックしたときに動かす命令です
  const scroller = document.getElementById('editor-picks-scroller');
  const prevBtn = document.getElementById('prev-btn');
  const nextBtn = document.getElementById('next-btn');

  if (scroller && prevBtn && nextBtn) {
    // 右へボタンを押した時
    nextBtn.addEventListener('click', () => {
      scroller.scrollBy({ left: 320, behavior: 'smooth' });
    });

    // 左へボタンを押した時
    prevBtn.addEventListener('click', () => {
      scroller.scrollBy({ left: -320, behavior: 'smooth' });
    });
  }
</script>

<style>
  .editor-picks-section { 
    background: #e5e7eb; 
    padding: 30px 20px; 
    margin: 40px 0; 
    border-radius: 12px; 
  }
  
  .section-title { 
    font-size: 20px; 
    color: #333; 
    margin-bottom: 20px; 
    border-bottom: 3px solid #1e3a8a; 
    padding-bottom: 8px; 
    display: inline-block; 
  }

  .scroll-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .scroll-container { 
    display: flex; 
    gap: 20px; 
    overflow-x: auto; 
    padding: 10px 0 20px; 
    scroll-snap-type: x mandatory; 
    -webkit-overflow-scrolling: touch;
    scroll-behavior: smooth;
  }
  .scroll-container::-webkit-scrollbar { display: none; } 

  .scroll-item { 
    width: 300px; 
    flex: 0 0 300px; 
    background: #fff; 
    scroll-snap-align: start; 
    text-decoration: none; 
    color: #333; 
    border-radius: 8px; 
    overflow: hidden; 
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
  }

  .scroll-img-wrapper { height: 180px; overflow: hidden; background: #ddd; }
  .scroll-img-wrapper img { width: 100%; height: 100%; object-fit: cover; }
  .scroll-text { padding: 15px; }
  .scroll-text h4 { font-size: 15px; line-height: 1.5; margin: 0; font-weight: bold; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  .tag-link { font-size: 12px; color: #d97706; font-weight: bold; margin-top: 10px; display: block; }

  /* ナビゲーションボタン（矢印）の見た目 */
  .nav-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.6);
    color: white;
    border: none;
    cursor: pointer;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    transition: background 0.2s;
  }
  .nav-btn:hover { background: rgba(0, 0, 0, 0.8); }
  .prev-btn { left: -10px; }
  .next-btn { right: -10px; }

  /* スマホなどではボタンを隠して指でスワイプできるようにします */
  @media (max-width: 768px) {
    .nav-btn { display: none; }
    .scroll-container { padding: 10px 0; }
  }
</style>
