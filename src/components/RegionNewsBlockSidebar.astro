---
const { lang = 'ja', title = '', cityData = [] } = Astro.props;

const getImageUrl = (content) => {
  const match = (content || '').match(/<img[^>]+src="([^">]+)"/);
  return match ? match[1] : 'https://placehold.co/80x60/eeeeee/999999?text=No+Image';
};
---

{cityData.map((city) => (
  <div class="gnews-city-block">
    <p class="gnews-region-name">{title}</p>
    {city.posts.slice(0, 1).map((post) => (
      <a href={`/${lang}/${city.code}/news/${post.id}/`} class="gnews-item">
        <div class="gnews-thumbnail">
          <img src={getImageUrl(post.content)} alt={post.title} />
        </div>
        <div class="gnews-info">
          <p class="gnews-title">{post.title}</p>
          <span class="gnews-country-badge">{city.name}</span>
        </div>
      </a>
    ))}
  </div>
))}

<style>
  .gnews-city-block {
    padding: 8px 0;
    border-bottom: 1px dashed #ccc;
  }

  .gnews-city-block:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .gnews-region-name {
    font-size: 13px;
    font-weight: 700;
    color: #872732;
    margin: 0 0 6px 0;
    padding-left: 8px;
    border-left: 3px solid #872732;
    line-height: 1.3;
  }

  .gnews-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    text-decoration: none;
    color: #111;
  }

  .gnews-item:hover .gnews-title {
    text-decoration: underline;
  }

  .gnews-thumbnail {
    width: 80px;
    flex-shrink: 0;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: 4px;
    background: #eee;
  }

  .gnews-thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .gnews-info {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .gnews-title {
    margin: 0;
    font-size: 13px;
    font-weight: 700;
    line-height: 1.4;
    color: #000;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .gnews-country-badge {
    display: inline-block;
    padding: 1px 6px;
    background: #e5e5e5;
    color: #444;
    font-size: 11px;
    border-radius: 3px;
    font-weight: 600;
    align-self: flex-start;
  }
</style>
