---
const { articleUrl, articleTitle } = Astro.props;

const encodedUrl = encodeURIComponent(articleUrl || '');
const encodedTitle = encodeURIComponent(articleTitle || '');

const xUrl = `https://x.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`;
const facebookUrl = `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`;
const hatenaUrl = `https://b.hatena.ne.jp/entry/panel/?url=${encodedUrl}`;
const lineUrl = `https://social-plugins.line.me/lineit/share?url=${encodedUrl}`;
const blueskyUrl = `https://bsky.app/intent/compose?text=${encodedTitle}%20${encodedUrl}`;
const mailUrl = `mailto:?subject=${encodedTitle}&body=${encodedTitle}%0A${encodedUrl}`;
---

<div class="share-wrap">
  <div class="share-main">
    <a href={xUrl} class="share-icon-btn x-btn" target="_blank" rel="noopener noreferrer" aria-label="Share on X" title="Share on X">
      <svg viewBox="0 0 24 24" aria-hidden="true" class="share-icon">
        <path fill="currentColor" d="M18.244 2H21l-6.56 7.497L22.16 22h-6.045l-4.734-6.185L5.97 22H3.21l7.016-8.018L1.84 2h6.198l4.28 5.65L18.244 2Zm-1.06 18h1.676L7.13 3.895H5.332L17.184 20Z"/>
      </svg>
    </a>

    <a href={facebookUrl} class="share-icon-btn facebook-btn" target="_blank" rel="noopener noreferrer" aria-label="Share on Facebook" title="Share on Facebook">
  <svg viewBox="0 0 24 24" aria-hidden="true" class="share-icon facebook-icon">
    <path fill="currentColor" d="M14 8.5V6.8c0-.6.4-.8.9-.8H17V2.5h-3c-3 0-4.5 1.8-4.5 4.4v1.6H7v3.8h2.5V22H14v-9.7h2.8l.4-3.8H14Z"/>
  </svg>
</a>

    <a href={mailUrl} class="share-icon-btn mail-btn" aria-label="Share by email" title="Share by email">
      <svg viewBox="0 0 24 24" aria-hidden="true" class="share-icon">
        <path fill="currentColor" d="M3 6h18a1 1 0 0 1 1 1v10a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V7a1 1 0 0 1 1-1Zm0 2v.5l9 5.6 9-5.6V8l-9 5.6L3 8Z"/>
      </svg>
    </a>

    <details class="share-more-details">
      <summary class="share-icon-btn more-btn" aria-label="More share options" title="More share options">
        <span class="dots">・・・</span>
      </summary>

      <div class="share-more-menu">
        <div class="share-more-header">
          <button type="button" class="close-menu-btn" aria-label="Close share menu" title="Close">
            ×
          </button>
        </div>

        <a href={hatenaUrl} class="share-menu-btn hatena-btn" target="_blank" rel="noopener noreferrer" aria-label="Share on Hatena">
          <span class="hatena-mark">B!</span>
          <span class="menu-text">Hatena</span>
        </a>

        <a href={lineUrl} class="share-menu-btn line-btn" target="_blank" rel="noopener noreferrer" aria-label="Share on LINE">
          <svg viewBox="0 0 24 24" aria-hidden="true" class="menu-icon">
            <path fill="currentColor" d="M12 3C6.48 3 2 6.79 2 11.47c0 4.2 3.6 7.72 8.47 8.38l-.36 2.16c-.06.33.29.58.58.4l2.48-1.72c5.07-.26 9.13-3.72 9.13-8.43C22.3 6.79 17.52 3 12 3Zm-4.2 10.2H6.4V9.5h1.4v3.7Zm2.8 0H9.2V9.5h1.4v3.7Zm3.6 0h-3V9.5h1.4v2.5h1.6v1.2Zm3.4-2.6h-1.6v.6h1.6v1h-1.6v.6h1.6v1h-3V9.5h3v1.1Z"/>
          </svg>
          <span class="menu-text">LINE</span>
        </a>

        <a href={blueskyUrl} class="share-menu-btn bluesky-btn" target="_blank" rel="noopener noreferrer" aria-label="Share on Bluesky">
          <svg viewBox="0 0 24 24" aria-hidden="true" class="menu-icon">
            <path fill="currentColor" d="M12 11.3c1.3-2.5 4.8-6.3 7.1-7.9 1.7-1.2 2.9-.9 2.9.5 0 .3-.2 2.8-.4 3.2-.7 2.5-3.1 3.2-5.2 2.8 3.7.6 4.6 2.5 2.6 4.4-3.9 3.7-5.6-.9-6-2.1-.1-.2-.2-.2-.3 0-.4 1.2-2.1 5.8-6 2.1-2-1.9-1.1-3.8 2.6-4.4-2.1.4-4.5-.3-5.2-2.8C4 6.7 3.8 4.2 3.8 3.9c0-1.4 1.2-1.7 2.9-.5 2.3 1.6 5.8 5.4 7.1 7.9Z"/>
          </svg>
          <span class="menu-text">Bluesky</span>
        </a>

        <button
          type="button"
          class="share-menu-btn copy-btn"
          data-copy-url={articleUrl}
          data-copy-title={articleTitle}
          aria-label="Copy link"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true" class="menu-icon copy-color">
            <path fill="currentColor" d="M8 7a3 3 0 0 1 3-3h7a3 3 0 0 1 3 3v7a3 3 0 0 1-3 3h-1v-2h1a1 1 0 0 0 1-1V7a1 1 0 0 0-1-1h-7a1 1 0 0 0-1 1v1H8V7Zm-5 4a3 3 0 0 1 3-3h7a3 3 0 0 1 3 3v7a3 3 0 0 1-3 3H6a3 3 0 0 1-3-3v-7Zm3-1a1 1 0 0 0-1 1v7a1 1 0 0 0 1 1h7a1 1 0 0 0 1-1v-7a1 1 0 0 0-1-1H6Z"/>
          </svg>
          <span class="menu-text">Copy Link</span>
        </button>
      </div>
    </details>
  </div>
</div>

<script>
  const shareDetails = document.querySelector('.share-more-details');
  const closeBtn = document.querySelector('.close-menu-btn');
  const copyBtn = document.querySelector('.copy-btn');

  closeBtn?.addEventListener('click', () => {
    if (shareDetails) {
      shareDetails.removeAttribute('open');
    }
  });

  copyBtn?.addEventListener('click', async () => {
    const url = copyBtn.getAttribute('data-copy-url') || '';
    const title = copyBtn.getAttribute('data-copy-title') || '';
    const text = `${title}\n${url}`.trim();

    try {
      await navigator.clipboard.writeText(text);
      const textNode = copyBtn.querySelector('.menu-text');
      if (textNode) {
        textNode.textContent = 'Copied';
        setTimeout(() => {
          textNode.textContent = 'Copy Link';
        }, 1500);
      }
    } catch {
      const textNode = copyBtn.querySelector('.menu-text');
      if (textNode) {
        textNode.textContent = 'Failed';
        setTimeout(() => {
          textNode.textContent = 'Copy Link';
        }, 1500);
      }
    }
  });

  document.addEventListener('click', (event) => {
    if (!shareDetails) return;
    if (shareDetails.contains(event.target)) return;
    shareDetails.removeAttribute('open');
  });
</script>

<style>
  .share-wrap {
    display: flex;
    justify-content: flex-end;
    width: 100%;
  }

  .share-main {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 10px;
    flex-wrap: wrap;
  }

  .share-icon-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: none;
    border-radius: 999px;
    text-decoration: none;
    cursor: pointer;
    box-sizing: border-box;
    transition: transform 0.15s ease, opacity 0.15s ease;
    color: #fff;
  }

  .share-icon-btn:hover,
  .share-icon-btn:focus-visible {
    text-decoration: none;
    transform: translateY(-1px);
    opacity: 0.9;
  }

  .share-icon {
    width: 22px;
    height: 22px;
    display: block;
  }

  .facebook-icon {
    width: 24px;
    height: 24px;
  }

  .x-btn {
    background: #111111;
  }

  .facebook-btn {
    background: #1877f2;
  }

  .mail-btn {
    background: #d44638;
  }

  .more-btn {
    background: #666666;
    font-size: 16px;
    font-weight: 700;
    line-height: 1;
  }

  .dots {
  color: #fff;
  line-height: 1;
  letter-spacing: -2px;
  transform: translateY(-1px);
  display: inline-block;
  font-weight: 700;
}

  .share-more-details {
    position: relative;
  }

  .share-more-details summary {
    list-style: none;
  }

  .share-more-details summary::-webkit-details-marker {
    display: none;
  }

  .share-more-menu {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-width: 152px;
    padding: 10px;
    border: 1px solid #e2e2e2;
    border-radius: 12px;
    background: #fff;
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
    z-index: 20;
  }

  .share-more-header {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 2px;
  }

  .close-menu-btn {
    width: 26px;
    height: 26px;
    border: none;
    border-radius: 999px;
    background: #f3f3f3;
    color: #666666;
    font-size: 18px;
    line-height: 1;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }

  .close-menu-btn:hover,
  .close-menu-btn:focus-visible {
    background: #e8e8e8;
  }

  .share-menu-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    width: 100%;
    min-height: 38px;
    padding: 0 10px;
    border: 1px solid #e0e0e0;
    border-radius: 10px;
    background: #fff;
    color: #1a1a1a;
    text-decoration: none;
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
    box-sizing: border-box;
    font-family: inherit;
  }

  .share-menu-btn:hover,
  .share-menu-btn:focus-visible {
    background: #f7f7f7;
    text-decoration: none;
    color: #1a1a1a;
  }

  .menu-icon {
    width: 20px;
    height: 20px;
    display: block;
    flex-shrink: 0;
  }

  .hatena-mark {
    width: 20px;
    text-align: center;
    font-size: 16px;
    font-weight: 800;
    line-height: 1;
    color: #00a4de;
    flex-shrink: 0;
  }

  .line-btn .menu-icon {
    color: #06c755;
  }

  .bluesky-btn .menu-icon {
    color: #1185fe;
  }

  .copy-color {
    color: #666666;
  }

  .menu-text {
    line-height: 1;
  }

  .copy-btn {
    font-family: inherit;
  }

  @media (max-width: 768px) {
    .share-wrap {
      justify-content: flex-start;
    }

    .share-main {
      justify-content: flex-start;
    }

    .share-icon-btn {
      width: 38px;
      height: 38px;
    }

    .share-icon {
      width: 21px;
      height: 21px;
    }

    .facebook-icon {
      width: 23px;
      height: 23px;
    }

    .share-more-menu {
      right: auto;
      left: 0;
      min-width: 148px;
    }
  }
</style>
