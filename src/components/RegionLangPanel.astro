---
// RegionLangPanel.astro
import { langCountryPairs } from '../lib/siteRoutes.ts';
import { getCountryLabel } from '../lib/countryData.ts';

export interface Props {
  currentLang?: string;
  currentCountry?: string;
  themeColor?: string;
}
const { currentLang = 'ja', currentCountry = 'jp', themeColor = '#872732' } = Astro.props;

// フッターと同じ「地域グループ」のルールを定義します
const globalRegionsRaw = [
  { key: 'asia',     countries: ['jp','tw','kr','cn','th','sg','in','hk','vn','my'] },
  { key: 'europe',   countries: ['de','fr','gb','it','es','nl'] },
  { key: 'americas', countries: ['us','ca','br','mx','ar'] },
  { key: 'mideast',  countries: ['ae','sa','za','eg'] },
  { key: 'oceania',  countries: ['au','nz'] },
];

const regionNamesMap: Record<string, Record<string, string>> = {
  asia:     { ja: 'アジア', en: 'Asia', 'zh-cn': '亚洲', 'zh-tw': '亞洲', es: 'Asia', fr: 'Asie', de: 'Asien', ru: 'Азия' },
  europe:   { ja: 'ヨーロッパ', en: 'Europe', 'zh-cn': '欧洲', 'zh-tw': '歐洲', es: 'Europa', fr: 'Europe', de: 'Europa', ru: 'Европа' },
  americas: { ja: '南北アメリカ', en: 'Americas', 'zh-cn': '美洲', 'zh-tw': '美洲', es: 'Américas', fr: 'Amériques', de: 'Amerika', ru: 'Америка' },
  mideast:  { ja: '中東・アフリカ', en: 'Middle East & Africa', 'zh-cn': '中东与非洲', 'zh-tw': '中東與非洲', es: 'Oriente Medio y África', fr: 'Moyen-Orient & Afrique', de: 'Nahost & Afrika', ru: 'Ближний Восток и Африка' },
  oceania:  { ja: 'オセアニア', en: 'Oceania', 'zh-cn': '大洋洲', 'zh-tw': '大洋洲', es: 'Oceanía', fr: 'Océanie', de: 'Ozeanien', ru: 'Океания' },
};

// 1. マスターデータ（siteRoutes.ts）から、各国が「どの言語に対応しているか」を自動で整理します
const countrySupportedLangs: Record<string, string[]> = {};
langCountryPairs.forEach(pair => {
  if (!countrySupportedLangs[pair.country]) {
    countrySupportedLangs[pair.country] = [];
  }
  if (!countrySupportedLangs[pair.country].includes(pair.lang)) {
    countrySupportedLangs[pair.country].push(pair.lang);
  }
});

// 2. パネルに表示する「地域」と「国」のデータを自動で組み立てます
const panelRegions = globalRegionsRaw.map(region => {
  // True設定されている（langCountryPairsに存在する）国だけを抽出します
  const activeCountries = region.countries
    .filter(code => countrySupportedLangs[code] && countrySupportedLangs[code].length > 0)
    .map(code => {
      return {
        code: code,
        supportedLangs: countrySupportedLangs[code].join(',') // 例: "ja,en,zh-tw"
      };
    });

  return {
    key: region.key,
    countries: activeCountries
  };
}).filter(region => region.countries.length > 0);

// 3. クリックした時に一瞬で翻訳できるよう、すべての国の翻訳辞書を裏側で生成しておきます
const allLangs = ['ja', 'en', 'zh-cn', 'zh-tw', 'es', 'fr', 'de', 'ru'];
const countryTranslations: Record<string, Record<string, string>> = {};

globalRegionsRaw.forEach(region => {
  region.countries.forEach(code => {
    countryTranslations[code] = {};
    allLangs.forEach(l => {
      let label = getCountryLabel(code, l);
      if (l === 'ja' && code === 'jp') label = '日本'; // フッターの特別ルールを適用
      countryTranslations[code][l] = label;
    });
  });
});
---

<div id="rl-overlay" class="rl-overlay"></div>
<div id="rl-panel" class="rl-panel" data-current-country={currentCountry}>
  
  <button id="rl-close-btn" class="rl-close" type="button">&#10005;</button>
  <div class="rl-header-text">地域 / 言語</div>

  <div class="rl-current-box">
    <span id="rl-current-display">読み込み中...</span>
  </div>

  <div class="rl-section">
    <div class="rl-section-title">言語</div>
    <div class="rl-lang-grid">
      <button class="rl-lang-btn" data-lang="ja" lang="ja" style={currentLang === 'ja' ? `background-color: ${themeColor}; color: white; border-color: ${themeColor};` : ''}>日本語</button>
      <button class="rl-lang-btn" data-lang="en" lang="en" style={currentLang === 'en' ? `background-color: ${themeColor}; color: white; border-color: ${themeColor};` : ''}>English</button>
      <button class="rl-lang-btn" data-lang="zh-cn" lang="zh-cn" style={currentLang === 'zh-cn' ? `background-color: ${themeColor}; color: white; border-color: ${themeColor};` : ''}>简体中文</button>
      <button class="rl-lang-btn" data-lang="zh-tw" lang="zh-tw" style={currentLang === 'zh-tw' ? `background-color: ${themeColor}; color: white; border-color: ${themeColor};` : ''}>繁體中文</button>
      <button class="rl-lang-btn" data-lang="es" lang="es" style={currentLang === 'es' ? `background-color: ${themeColor}; color: white; border-color: ${themeColor};` : ''}>Español</button>
      <button class="rl-lang-btn" data-lang="fr" lang="fr" style={currentLang === 'fr' ? `background-color: ${themeColor}; color: white; border-color: ${themeColor};` : ''}>Français</button>
      <button class="rl-lang-btn" data-lang="de" lang="de" style={currentLang === 'de' ? `background-color: ${themeColor}; color: white; border-color: ${themeColor};` : ''}>Deutsch</button>
      <button class="rl-lang-btn" data-lang="ru" lang="ru" style={currentLang === 'ru' ? `background-color: ${themeColor}; color: white; border-color: ${themeColor};` : ''}>Русский</button>
    </div>
  </div>

  <div class="rl-country-area">
    {panelRegions.map((region) => (
      <div class="rl-region-group">
        <div class="rl-region-title" data-region-key={region.key}>
          {regionNamesMap[region.key]?.[currentLang] || regionNamesMap[region.key]?.['ja']}
        </div>
        <div class="rl-country-grid">
          {region.countries.map((c) => (
            <a href={`/${currentLang}/${c.code}/`} 
               class="rl-country-btn" 
               data-country={c.code} 
               data-langs={c.supportedLangs} 
               style={currentCountry === c.code ? `background-color: ${themeColor}; color: white;` : ''}>
              {countryTranslations[c.code]?.[currentLang] || c.code}
            </a>
          ))}
        </div>
      </div>
    ))}
  </div>
</div>

<style>
  .rl-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.6); z-index: 9998; }
  .rl-overlay.open { display: block; }
  .rl-panel { position: fixed; top: 0; right: -400px; width: 100%; max-width: 380px; height: 100%; background: #403e3e; color: #ffffff; z-index: 9999; transition: right 0.4s ease; overflow-y: auto; padding: 20px 24px; box-sizing: border-box; box-shadow: -4px 0 15px rgba(0,0,0,0.3); }
  .rl-panel.open { right: 0; }
  .rl-close { background: none; border: none; color: #ffffff; font-size: 28px; cursor: pointer; position: absolute; top: 15px; left: 15px; }
  .rl-header-text { margin-top: 50px; font-size: 14px; color: #e0e0e0; margin-bottom: 8px; }
  .rl-current-box { background: #e8e8e8; color: #000; padding: 12px 16px; border-radius: 6px; font-size: 20px; font-weight: bold; margin-bottom: 24px; }
  .rl-section { background: #e8e8e8; border-radius: 6px; overflow: hidden; margin-bottom: 20px; }
  .rl-section-title { background: #d0d0d0; color: #000; padding: 8px 12px; font-size: 14px; font-weight: bold; }
  .rl-lang-grid { display: flex; flex-wrap: wrap; gap: 10px; padding: 16px; background: #f5f5f5; }
  .rl-lang-btn { background: none; border: none; color: #333; font-size: 15px; text-decoration: underline; cursor: pointer; padding: 4px 8px; border-radius: 4px; }
  .rl-region-group { background: #e8e8e8; border-radius: 6px; overflow: hidden; margin-bottom: 16px; }
  .rl-region-title { background: #9e9e9e; color: #000; padding: 8px 12px; font-size: 14px; font-weight: bold; }
  .rl-country-grid { display: flex; flex-wrap: wrap; gap: 12px; padding: 16px; background: #e8e8e8; }
  .rl-country-btn { background: #b0b0b0; color: #000; text-decoration: none; padding: 6px 16px; border-radius: 20px; font-size: 14px; transition: background 0.2s; }
</style>

<script is:inline define:vars={{ themeColor, countryTranslations, regionNamesMap }}>
  window.addEventListener('load', function() {
    var overlay = document.getElementById('rl-overlay');
    var panel = document.getElementById('rl-panel');
    var closeBtn = document.getElementById('rl-close-btn');
    var langBtns = document.querySelectorAll('.rl-lang-btn');
    var countryBtns = document.querySelectorAll('.rl-country-btn');
    var regionGroups = document.querySelectorAll('.rl-region-group');
    var currentDisplay = document.getElementById('rl-current-display');
    var currentCountryCode = panel.getAttribute('data-current-country');

    var langNames = { ja: '日本語', en: 'English', 'zh-cn': '简体中文', 'zh-tw': '繁體中文', es: 'Español', fr: 'Français', de: 'Deutsch', ru: 'Русский' };

    function closePanel() { panel.classList.remove('open'); overlay.classList.remove('open'); }
    if (closeBtn) closeBtn.addEventListener('click', closePanel);
    if (overlay) overlay.addEventListener('click', closePanel);

    langBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        var selectedLang = this.getAttribute('data-lang');

        // 言語ボタンの色を変える
        langBtns.forEach(function(b) { b.style.backgroundColor = ''; b.style.color = '#333'; });
        this.style.backgroundColor = themeColor;
        this.style.color = 'white';

        // 上部の表示を書き換える
        var currentCountryName = countryTranslations[currentCountryCode] ? (countryTranslations[currentCountryCode][selectedLang] || countryTranslations[currentCountryCode]['ja']) : '';
        var selectedLangName = langNames[selectedLang] || '';
        if (currentDisplay) currentDisplay.textContent = currentCountryName + ' / ' + selectedLangName;

        // 地域の名前（アジアなど）を言語に合わせて書き換える
        var regionTitles = document.querySelectorAll('.rl-region-title');
        regionTitles.forEach(function(titleEl) {
          var rKey = titleEl.getAttribute('data-region-key');
          if (rKey && regionNamesMap[rKey]) {
            titleEl.textContent = regionNamesMap[rKey][selectedLang] || regionNamesMap[rKey]['ja'];
          }
        });

        // 国ボタンのリンクと名前を書き換える
        countryBtns.forEach(function(cBtn) {
          var countryCode = cBtn.getAttribute('data-country');
          var supportedLangs = cBtn.getAttribute('data-langs');
          
          if (supportedLangs && supportedLangs.includes(selectedLang)) {
            cBtn.style.display = 'inline-block';
            cBtn.href = '/' + selectedLang + '/' + countryCode + '/';
            if (countryTranslations[countryCode] && countryTranslations[countryCode][selectedLang]) {
              cBtn.textContent = countryTranslations[countryCode][selectedLang];
            }
          } else {
            cBtn.style.display = 'none';
          }
        });

        // 国が一つもない地域枠を隠す
        regionGroups.forEach(function(group) {
          var visibleCountries = group.querySelectorAll('.rl-country-btn[style*="display: inline-block"]');
          if (visibleCountries.length === 0) { group.style.display = 'none'; } else { group.style.display = 'block'; }
        });
      });
    });
  });
</script>
