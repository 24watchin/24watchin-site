---
// 1. GoogleAdBannerとAccessRankingだけを読み込みます
import GoogleAdBanner from './GoogleAdBanner.astro';
import AccessRanking from './AccessRanking.astro';
---

<div class="sidebar-wrapper">
  {/* 上部に本物の広告を表示します */}
  <GoogleAdBanner />

  {/* その下にランキングを表示します */}
  <AccessRanking />
</div>

<style>
  .sidebar-wrapper {
    display: flex;
    flex-direction: column;
    gap: 40px;
    width: 100%;
    margin: 0;
    padding: 0;
  }
  .sidebar-wrapper > :global(*) {
    width: 100% !important;
    max-width: 100% !important;
    margin-left: 0 !important;
    margin-right: 0 !important;
    box-sizing: border-box !important;
  }
</style>
