---
// サイドバー用の広告部品を読み込みます
import SidebarAd from './SidebarAd.astro';
// ★新しく作った「編集部のおすすめ」部品を読み込みます
import EditorsPick from './EditorsPick.astro';
---

<div class="sidebar-wrapper">
  {/* 1. 上部に広告を配置します（ランキングを削除しました） */}
  <SidebarAd />

  {/* 2. 広告の下に「編集部のおすすめ」を配置します */}
  <EditorsPick />
</div>

<style>
  /* サイドバー全体をピシッと整列させるための設定です */
  .sidebar-wrapper {
    display: flex;
    flex-direction: column;
    gap: 40px; /* パーツの間の隙間を40pxに設定 */
    width: 100%;
    margin: 0;
    padding: 0;
  }

  /* 中に入るパーツを枠いっぱいに揃える設定 */
  .sidebar-wrapper > :global(*) {
    width: 100% !important;
    max-width: 100% !important;
    margin-left: 0 !important;
    margin-right: 0 !important;
    box-sizing: border-box !important;
  }
</style>
