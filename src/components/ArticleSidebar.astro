---
// 1. 広告部品を読み込みます
import SidebarAd from './SidebarAd.astro';
// 2. 「編集部のおすすめ」部品を読み込みます（ファイル名を修正しました）
import EditorsPick from './EditorsPick.astro';
---

<div class="sidebar-wrapper">
  {/* 1. 広告を上に配置します */}
  <SidebarAd />

  {/* 2. 「編集部のおすすめ」を配置します（アクセスランキングは完全に削除しました） */}
  <EditorsPick />
</div>

<style>
  /* サイドバー全体の見た目を整える設定です */
  .sidebar-wrapper {
    display: flex;
    flex-direction: column;
    gap: 40px; /* パーツの間の隙間を40pxに設定 */
    width: 100%;
    margin: 0;
    padding: 0;
  }

  /* 中に入るパーツの横幅を100%に揃える設定 */
  .sidebar-wrapper > :global(*) {
    width: 100% !important;
    max-width: 100% !important;
    box-sizing: border-box !important;
  }
</style>
