---
const API_KEY = import.meta.env.API_KEY;
const BLOG_ID = import.meta.env.BLOG_ID;
const url = `https://www.googleapis.com/blogger/v3/blogs/${BLOG_ID}/posts?key=${API_KEY}&maxResults=20`;

const response = await fetch(url);
const data = await response.json();
const posts = data.items || [];

const getImageUrl = (content) => {
  const match = (content || '').match(/<img[^>]+src="([^">]+)"/);
  return match ? match[1] : 'https://placehold.co/600x400/eeeeee/999999?text=No+Image';
};
---

<div class="top-news-container">
  <div class="main-column">
    {posts.length > 0 && (
      <article class="hero-post">
        <a href={`/news/${posts[0].id}/`}>
          <div class="hero-image">
            <img src={getImageUrl(posts[0].content)} alt={posts[0].title} />
          </div>
          <div class="hero-text">
            <h2>{posts[0].title}</h2>
          </div>
        </a>
      </article>
    )}

    <div class="sub-grid">
      {posts.slice(1, 5).map((post) => (
        <article class="grid-item">
          <a href={`/news/${post.id}/`}>
            <div class="grid-image">
              <img src={getImageUrl(post.content)} alt={post.title} />
            </div>
            <div class="grid-text">
              <h3>{post.title}</h3>
            </div>
          </a>
        </article>
      ))}
    </div>
  </div>

  <div class="side-list-column">
    {posts.slice(5, 13).map((post) => (
      <article class="list-item">
        <a href={`/news/${post.id}/`}>
          <h4>{post.title}</h4>
        </a>
      </article>
    ))}
  </div>
</div>

<style>
  .top-news-container { display: grid; grid-template-columns: 1fr 400px; gap: 30px; margin-bottom: 40px; }
  @media (max-width: 900px) { .top-news-container { grid-template-columns: 1fr; } }
  
  .hero-post a { display: grid; grid-template-columns: 1fr 1.2fr; gap: 20px; text-decoration: none; color: #333; margin-bottom: 15px; }
  .hero-image { aspect-ratio: 16/10; overflow: hidden; border-radius: 4px; }
  .hero-image img { width: 100%; height: 100%; object-fit: cover; }
  .hero-text { display: flex; align-items: center; } 
  .hero-text h2 { font-size: 24px; margin: 0; line-height: 1.4; } 
  
  /* 線の色を#cccに変更 */
  .sub-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; border-top: 1px solid #ccc; padding-top: 15px; }
  .grid-item a { display: flex; gap: 15px; text-decoration: none; color: #333; }
  .grid-image { width: 120px; height: 80px; flex-shrink: 0; overflow: hidden; border-radius: 4px; }
  .grid-image img { width: 100%; height: 100%; object-fit: cover; }
  /* 文字サイズを16pxに変更 */
  .grid-text h3 { font-size: 16px; margin: 0; line-height: 1.4; }
  
  /* 線の色を#cccに変更 */
  .side-list-column { border-left: 1px solid #ccc; padding-left: 20px; }
  /* 線の色を#cccに変更 */
  .list-item { border-bottom: 1px solid #ccc; padding: 10px 0; }
  .list-item:first-child { padding-top: 0; }
  .list-item a { text-decoration: none; color: #333; }
  
  /* 文字サイズを16pxに変更 */
  .list-item h4 { display: inline; font-size: 16px; line-height: 1.25; font-weight: bold; margin: 0; display: block; }
  
  .hero-post a:hover h2,
  .grid-item a:hover h3,
  .list-item a:hover h4 {
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-decoration-color: #333;
    text-underline-offset: 3px;
  }
  
  @media (max-width: 600px) { 
    .hero-post a { grid-template-columns: 1fr; } 
    .sub-grid { grid-template-columns: 1fr; } 
    /* 線の色を#cccに変更 */
    .side-list-column { border-left: none; padding-left: 0; border-top: 1px solid #ccc; margin-top: 20px; } 
  }
</style>
