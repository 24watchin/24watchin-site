---
// Bloggerから最新の記事を多めに（100件）取得します
const API_KEY = import.meta.env.API_KEY;
const BLOG_ID = import.meta.env.BLOG_ID;
const url = `https://www.googleapis.com/blogger/v3/blogs/${BLOG_ID}/posts?key=${API_KEY}&maxResults=100`;

const response = await fetch(url).catch(() => null);
const data = response ? await response.json() : { items: [] };
const allPosts = data.items || [];

// --- 記事の自動配置ロジック ---

// 1. 「TOP①」〜「TOP⑩」のラベルがついた記事を抽出して整理します
const topPostsMap = new Map();
const topLabelRegex = /^TOP([①②③④⑤⑥⑦⑧⑨⑩])$/;
const numMap = { '①':1, '②':2, '③':3, '④':4, '⑤':5, '⑥':6, '⑦':7, '⑧':8, '⑨':9, '⑩':10 };

allPosts.forEach(post => {
  if (!post.labels) return;
  post.labels.forEach(label => {
    const match = label.match(topLabelRegex);
    if (match) {
      const num = numMap[match[1]];
      // 同じ番号なら、日付が新しい方を優先（交代）
      if (!topPostsMap.has(num)) {
        topPostsMap.set(num, post);
      }
    }
  });
});

// 2. 抽出したTOP記事を番号順（1, 2, 3...）に並べたリストを作ります（空席詰め）
let finalPosts = Array.from(topPostsMap.entries())
  .sort((a, b) => a[0] - b[0])
  .map(entry => entry[1]);

// 3. 10件に足りない場合、TOPラベルがついていない最新記事で埋めます
const usedIds = new Set(finalPosts.map(p => p.id));
const normalPosts = allPosts.filter(p => !usedIds.has(p.id));

while (finalPosts.length < 10 && normalPosts.length > 0) {
  finalPosts.push(normalPosts.shift());
}

// 最終的に表示する10件を切り出します
const displayPosts = finalPosts.slice(0, 10);

// --- 補助関数 ---
const getImageUrl = (content) => {
  const match = (content || '').match(/<img[^>]+src="([^">]+)"/);
  return match ? match[1] : 'https://placehold.co/600x400/eeeeee/999999?text=No+Image';
};

const formatPostTime = (dateString) => {
  if (!dateString) return '';
  return new Date(dateString).toLocaleString('ja-JP', {
    month: 'numeric', day: 'numeric', hour: '2-digit', minute: '2-digit'
  });
};
---

<div class="top-news-container">
  <div class="main-column">
    {/* ①番の席：メインの大枠 */}
    {displayPosts[0] && (
      <article class="hero-post">
        <a href={`/jp/jp/news/${displayPosts[0].id}/`}>
          <div class="hero-image">
            <img src={getImageUrl(displayPosts[0].content)} alt={displayPosts[0].title} />
          </div>
          <div class="hero-text">
            <h2 class="hero-title">{displayPosts[0].title}</h2>
            <p class="hero-time">{formatPostTime(displayPosts[0].published)}</p>
          </div>
        </a>
      </article>
    )}

    {/* ②〜⑤番の席：中央下の4つの枠 */}
    <div class="news-grid">
      {displayPosts.slice(1, 5).map((post) => (
        <article class="grid-item">
          <a href={`/jp/jp/news/${post.id}/`}>
            <div class="grid-image">
              <img src={getImageUrl(post.content)} alt={post.title} />
            </div>
            <h3 class="grid-title">{post.title}</h3>
            <p class="grid-time">{formatPostTime(post.published)}</p>
          </a>
        </article>
      ))}
    </div>
  </div>

  {/* ⑥〜⑩番の席：右側のリスト枠 */}
  <aside class="side-list-column">
    {displayPosts.slice(5, 10).map((post) => (
      <div class="list-item">
        <a href={`/jp/jp/news/${post.id}/`}>
          <h3 class="list-title">{post.title}</h3>
          <p class="list-time">{formatPostTime(post.published)}</p>
        </a>
      </div>
    ))}
  </aside>
</div>

<style>
  .top-news-container { display: flex; gap: 20px; margin-bottom: 30px; }
  .main-column { flex: 2; min-width: 0; }
  .side-list-column { flex: 1; border-left: 1px solid #e5e5e5; padding-left: 20px; }

  .hero-post { margin-bottom: 20px; }
  .hero-post a { text-decoration: none; color: inherit; }
  .hero-image { width: 100%; aspect-ratio: 16 / 9; overflow: hidden; border-radius: 4px; }
  .hero-image img { width: 100%; height: 100%; object-fit: cover; }
  .hero-title { font-size: 24px; margin: 12px 0 5px; font-weight: bold; line-height: 1.3; }
  .hero-time { font-size: 14px; color: #888; }

  .news-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; }
  .grid-item a { text-decoration: none; color: inherit; }
  .grid-image { width: 100%; aspect-ratio: 16 / 10; overflow: hidden; border-radius: 4px; }
  .grid-image img { width: 100%; height: 100%; object-fit: cover; }
  .grid-title { font-size: 15px; margin: 8px 0 4px; font-weight: bold; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .grid-time { font-size: 13px; color: #888; }

  .list-item { padding: 10px 0; border-bottom: 1px solid #eee; }
  .list-item:first-child { padding-top: 0; }
  .list-item:last-child { border-bottom: none; }
  .list-item a { text-decoration: none; color: inherit; }
  .list-title { font-size: 15px; font-weight: bold; line-height: 1.4; margin-bottom: 4px; }
  .list-time { font-size: 13px; color: #888; }

  @media (max-width: 900px) {
    .top-news-container { flex-direction: column; }
    .side-list-column { border-left: none; padding-left: 0; border-top: 1px solid #eee; padding-top: 20px; }
  }
</style>
