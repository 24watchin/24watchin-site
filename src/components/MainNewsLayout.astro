---
const API_KEY = import.meta.env.API_KEY;
const BLOG_ID = import.meta.env.BLOG_ID;
const url = `https://www.googleapis.com/blogger/v3/blogs/${BLOG_ID}/posts?key=${API_KEY}&maxResults=20`;

const response = await fetch(url);
const data = await response.json();
const posts = data.items || [];

const getImageUrl = (content) => {
  const match = (content || '').match(/<img[^>]+src="([^">]+)"/);
  return match ? match[1] : 'https://placehold.co/600x400/eeeeee/999999?text=No+Image';
};

const getExcerpt = (content) => {
  if (!content) return '';
  return content.replace(/<[^>]*>/g, '').substring(0, 70) + '...';
};
---

<div class="top-news-container">
  <div class="main-column">
    {posts.length > 0 && (
      <article class="hero-post">
        <a href={`/jp/jp/news/${posts[0].id}/`}>
          <div class="hero-image">
            <img src={getImageUrl(posts[0].content)} alt={posts[0].title} />
          </div>
          <div class="hero-text">
            <h2>{posts[0].title}</h2>
            <p>{getExcerpt(posts[0].content)}</p>
          </div>
        </a>
      </article>
    )}

    <div class="sub-grid">
      {posts.slice(1, 5).map((post) => (
        <article class="grid-item">
          <a href={`/jp/jp/news/${post.id}/`}>
            <div class="grid-image">
              <img src={getImageUrl(post.content)} alt={post.title} />
            </div>
            <div class="grid-text">
              <h3>{post.title}</h3>
            </div>
          </a>
        </article>
      ))}
    </div>
  </div>

  <div class="side-list-column">
    {posts.slice(5, 15).map((post) => (
      <article class="list-item">
        <a href={`/jp/jp/news/${post.id}/`}>
          <h4>{post.title}</h4>
        </a>
      </article>
    ))}
  </div>
</div>

<style>
  .top-news-container {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 360px;
    gap: 24px;
    margin-bottom: 40px;
    align-items: start;
  }

  .main-column {
    min-width: 0;
  }

  .hero-post a {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 18px;
    text-decoration: none;
    color: #111111;
    margin-bottom: 24px;
    align-items: start;
  }

  .hero-image {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border-radius: 4px;
  }

  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero-text h2 {
    font-size: 16px;
    line-height: 1.45;
    font-weight: 700;
    margin: 0 0 10px;
    color: #111111;
  }

  .hero-text p {
    font-size: 16px;
    line-height: 1.5;
    font-weight: 700;
    margin: 0;
    color: #111111;
  }

  .sub-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px 22px;
    border-top: 1px solid #e5e5e5;
    padding-top: 18px;
  }

  .grid-item a {
    display: flex;
    gap: 12px;
    text-decoration: none;
    color: #111111;
    align-items: flex-start;
  }

  .grid-image {
    width: 108px;
    height: 72px;
    flex-shrink: 0;
    overflow: hidden;
    border-radius: 4px;
  }

  .grid-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .grid-text h3 {
    font-size: 16px;
    line-height: 1.45;
    font-weight: 700;
    margin: 0;
    color: #111111;
  }

  .side-list-column {
    border-left: 1px solid #e5e5e5;
    padding-left: 18px;
    min-width: 0;
  }

  .list-item {
    border-bottom: 1px solid #e5e5e5;
    padding: 8px 0;
  }

  .list-item:first-child {
    padding-top: 0;
  }

  .list-item a {
    text-decoration: none;
    color: #111111;
    display: block;
  }

  .list-item h4 {
    font-size: 16px;
    line-height: 1.45;
    font-weight: 700;
    margin: 0;
    color: #111111;
  }

  .hero-post a:hover .hero-text h2,
  .grid-item a:hover .grid-text h3,
  .list-item a:hover h4 {
    text-decoration-line: underline;
    text-decoration-color: #000000;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  @media (max-width: 900px) {
    .top-news-container {
      grid-template-columns: 1fr;
      gap: 22px;
    }

    .side-list-column {
      border-left: none;
      padding-left: 0;
      border-top: 1px solid #e5e5e5;
      padding-top: 14px;
    }
  }

  @media (max-width: 600px) {
    .hero-post a {
      grid-template-columns: 1fr;
    }

    .sub-grid {
      grid-template-columns: 1fr;
    }

    .grid-image {
      width: 96px;
      height: 64px;
    }
  }
</style>
