---
import { categoryLabelMap, type SiteLanguageKey } from '../lib/categoryLabels';
import { langCountryPairs } from '../lib/siteRoutes.ts';
import { getCountryLabel } from '../lib/countryData.ts';
import RegionLangPanel from './RegionLangPanel.astro';

import { getWeatherCondition, getUnitSystem, convertTemp } from '../lib/weatherConditions';
import { countryCityMap } from '../lib/cityConfig';

const SPACE_ID = import.meta.env.CONTENTFUL_SPACE_ID;
const DELIVERY_TOKEN = import.meta.env.CONTENTFUL_DELIVERY_TOKEN;
const WEATHER_API_KEY = import.meta.env.WEATHER_API_KEY;

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const pathParts = currentPath.split('/').filter(Boolean);
const lang = pathParts[0] || 'ja';

const langNameMap: Record<string, string> = {
  ja: '日本語', en: 'English', 'zh-cn': '简体中文', 'zh-tw': '繁體中文',
  es: 'Español', fr: 'Français', de: 'Deutsch', ru: 'Русский'
};
const topLangLabel = langNameMap[lang] || 'English';

const SITE_ID = 'jp-ja'; 
const SLOT = 'header_words';

type HeaderWord = { label: string; url: string; displayOrder: number; };
let headerWords: HeaderWord[] = [];

if (SPACE_ID && DELIVERY_TOKEN) {
  try {
    const params = new URLSearchParams({ content_type: 'headerWord', 'fields.siteId': SITE_ID, 'fields.slot': SLOT, 'fields.enabled': 'true', order: 'fields.displayOrder', limit: '20' });
    const res = await fetch(`https://cdn.contentful.com/spaces/${SPACE_ID}/environments/master/entries?${params.toString()}`, { headers: { Authorization: `Bearer ${DELIVERY_TOKEN}` } });
    if (res.ok) {
      const data = await res.json();
      headerWords = (data.items ?? []).map((item: any) => ({ label: item?.fields?.label ?? '', url: item?.fields?.url ?? '#', displayOrder: Number(item?.fields?.displayOrder ?? 9999), enabled: item?.fields?.enabled ?? false, siteId: item?.fields?.siteId ?? '', slot: item?.fields?.slot ?? '' }))
        .filter((item: any) => item.enabled === true && item.siteId === SITE_ID && item.slot === SLOT && item.label)
        .sort((a: any, b: any) => a.displayOrder - b.displayOrder)
        .map((item: any) => ({ label: item.label, url: item.url, displayOrder: item.displayOrder }));
    }
  } catch (e) { headerWords = []; }
}

const localeKeyMap: Record<string, string> = { ja: 'jp', en: 'en', 'zh-cn': 'zh-cn', 'zh-tw': 'zh-tw', es: 'es', de: 'de', fr: 'fr', ru: 'ru' };
const localeKey = (localeKeyMap[lang] || 'jp') as SiteLanguageKey;
const labels = categoryLabelMap[localeKey] || categoryLabelMap.jp;

const searchAction = '/' + lang + '/search/';

const availableCountries = langCountryPairs
  .filter(pair => pair.lang === lang)
  .map(pair => ({
    code: pair.country,
    name: getCountryLabel(pair.country, lang)
  }));

const categoryItems = (labels.headerCategories || []).map((item) => {
  return { label: item.label, slug: item.slug };
});

const moreSlugsMap: Record<string, string[]> = { jp: ['health-life', 'weather', 'traffic'], en: ['environment-energy', 'sports', 'health-life', 'weather', 'traffic'], es: ['environment-energy', 'sports', 'health-life', 'weather', 'traffic'], fr: ['environment-energy', 'sports', 'health-life', 'weather', 'traffic'], de: ['environment-energy', 'sports', 'health-life', 'weather', 'traffic'], ru: ['environment-energy', 'sports', 'health-life', 'weather', 'traffic'], 'zh-cn': [], 'zh-tw': [] };
const moreSlugs = moreSlugsMap[localeKey] || [];
const mainItems = categoryItems.filter(item => !moreSlugs.includes(item.slug));
const moreItems = categoryItems.filter(item => moreSlugs.includes(item.slug));

const defaultCountryForWeather = availableCountries.length > 0 ? availableCountries[0].code : 'jp';
const cities = countryCityMap[defaultCountryForWeather] || countryCityMap['jp'];
const { isImperial, tempUnit } = getUnitSystem(lang);

if (!globalThis.weatherCache) globalThis.weatherCache = {};
const allCityWeather: Record<string, any> = {};
for (const city of cities) {
  const cityKey = city.key;
  const now = Date.now();
  const CACHE = 30 * 60 * 1000;
  if (globalThis.weatherCache[cityKey] && (now - globalThis.weatherCache[cityKey].time < CACHE)) {
    allCityWeather[cityKey] = globalThis.weatherCache[cityKey].data;
  } else if (WEATHER_API_KEY) {
    try {
      const url = 'https://api.weatherapi.com/v1/current.json?key=' + WEATHER_API_KEY + '&q=' + cityKey + '&aqi=no';
      const res = await fetch(url);
      if (res.ok) {
        const data = await res.json();
        allCityWeather[cityKey] = data;
        globalThis.weatherCache[cityKey] = { data, time: now };
      }
    } catch (e) {}
  }
}

const cityDataForJs = cities.map((city: any) => {
  const wd = allCityWeather[city.key];
  const current = wd?.current;
  const conditionCode = current?.condition?.code;
  const iconUrl = current?.condition?.icon ? 'https:' + current.condition.icon : '';
  return {
    key: city.key,
    displayName: city.display[lang] || city.display['en'] || city.key,
    temp: current ? convertTemp(current.temp_c, isImperial) : null,
    feelsLike: current ? convertTemp(current.feelslike_c, isImperial) : null,
    iconUrl,
    conditionText: conditionCode ? getWeatherCondition(conditionCode, lang) : '',
  };
});
const defaultWeatherData = cityDataForJs[0] || null;
---

<div class="header-pc-wrapper">
  <div class="pc-top-gray-bar">
    <div class="pc-top-gray-inner">
      <span class="pc-top-country">{topLangLabel}</span>
    </div>
  </div>

  <header class="site-header">
    <div class="header-top pc-header-top">
      <div class="brand-area">
        <a href={`/${lang}/`} class="logo-link"><img src="/images/logo-24watchin.png" alt="24Watchin" class="logo-image" /></a>
      </div>
      <div class="right-area pc-right-area">
        <form action={searchAction} method="get" class="search-form-animated" id="pc-search-form">
          <input type="text" name="q" class="search-input-animated" placeholder={labels.searchPlaceholder} id="pc-search-input" />
          <button type="button" class="search-icon-btn" id="pc-search-icon-btn">
            <svg class="search-icon" viewBox="0 0 24 24"><circle cx="11" cy="11" r="6.5"></circle><line x1="16" y1="16" x2="21" y2="21"></line></svg>
          </button>
        </form>

        <button type="button" class="region-lang-open-btn" id="pc-region-lang-btn" data-current-lang={lang}>
          地域 / 言語 <span class="hamburger-icon">&#8803;</span>
        </button>
      </div>
    </div>

    <nav class="category-bar">
      <div class="category-nav-inner">
        <button class="scroll-arrow arrow-left" id="pc-arrow-left" type="button">&#8249;</button>
        <div class="pc-category-group">
          <div class="category-scroll pc-scroll" id="pc-scroll">
            {mainItems.map((item) => (
              <button class="category-link cat-dropdown-trigger" data-slug={item.slug}>
                <span class="category-link-text">{item.label}</span>
              </button>
            ))}
          </div>
          {moreItems.length > 0 && (
            <div class="more-wrapper">
              <div class="more-btn">
                {lang === 'ja' ? 'さらに見る' : 'More'}
                <svg class="more-chevron" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"></polyline></svg>
              </div>
              <div class="more-dropdown">
                {moreItems.map((item) => (
                  <button class="more-link cat-dropdown-trigger" data-slug={item.slug}>
                    <span class="more-link-text">{item.label}</span>
                  </button>
                ))}
              </div>
            </div>
          )}
        </div>
        <button class="scroll-arrow arrow-right" id="pc-arrow-right" type="button">&#8250;</button>
      </div>
    </nav>

    <div class="header-word-bar">
      <div class="header-word-inner">
        {headerWords.map((item) => (
          <a href={item.url} class="header-word-link">{item.label}</a>
        ))}
      </div>
    </div>
    <div class="bottom-line" style={`background: ${labels.themeColor || '#872732'}`}></div>
  </header>
</div>


<div class="header-sp-wrapper">
  <div class="sp-top-gray-bar">
    <div class="sp-top-country">{topLangLabel}</div>
    
    <div class="sp-top-actions">
      <form action={searchAction} method="get" class="search-form-animated sp-search-form" id="sp-search-form">
        <input type="text" name="q" class="search-input-animated sp-search-input" placeholder={labels.searchPlaceholder} id="sp-search-input" />
        <button type="button" class="search-icon-btn sp-search-btn" id="sp-search-icon-btn" aria-label="検索">
          <svg class="search-icon" viewBox="0 0 24 24"><circle cx="11" cy="11" r="6.5"></circle><line x1="16" y1="16" x2="21" y2="21"></line></svg>
        </button>
      </form>

      <button type="button" class="sp-reload-btn" onclick="window.location.reload();" aria-label="ページを更新">
        <svg viewBox="0 0 24 24" class="reload-icon"><path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.32-9.83l5.67 5.67" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      
      <button type="button" class="region-lang-open-btn sp-region-lang-btn" id="sp-region-lang-btn" data-current-lang={lang}>
        地域 / 言語 <span class="hamburger-icon">&#8803;</span>
      </button>
    </div>
  </div>

  <header class="site-header">
    <div class="header-top sp-header-top">
      <div class="brand-area sp-brand-area">
        <a href={`/${lang}/`} class="logo-link"><img src="/images/logo-24watchin.png" alt="24Watchin" class="logo-image sp-logo-image" /></a>
      </div>
      
      <div class="right-area sp-right-area">
        <a href={`/${lang}/${defaultCountryForWeather}/weather/`} class="sp-weather-widget">
          {defaultWeatherData && defaultWeatherData.temp !== null ? (
            <>
              <div class="sp-weather-icon">
                <img src={defaultWeatherData.iconUrl} alt={defaultWeatherData.conditionText} style="width: 28px; height: 28px; object-fit: contain;" />
              </div>
              <div class="sp-weather-info">
                <span class="sp-weather-loc no-wrap-text">{defaultWeatherData.displayName} &gt;</span>
                <span class="sp-weather-temp">{defaultWeatherData.temp}{tempUnit} / {defaultWeatherData.feelsLike}{tempUnit}</span>
              </div>
            </>
          ) : (
            <>
              <div class="sp-weather-icon">
                <i class="fa-solid fa-cloud-sun" style="color: #6b7280; font-size: 20px; margin-top: 4px;"></i>
              </div>
              <div class="sp-weather-info">
                <span class="sp-weather-loc">読込中... &gt;</span>
                <span class="sp-weather-temp">-- / --</span>
              </div>
            </>
          )}
        </a>
      </div>
    </div>

    <nav class="category-bar sp-category-bar">
      <div class="category-scroll sp-scroll" id="sp-scroll">
        {categoryItems.map((item) => (
          <button class="category-link cat-dropdown-trigger" data-slug={item.slug}>
            <span class="category-link-text">{item.label}</span>
          </button>
        ))}
        <div class="sp-scroll-padding"></div>
      </div>
    </nav>

    <div style="height: 10px; background-color: #ffffff; width: 100%;"></div>

    <div class="bottom-line" style={`background: ${labels.themeColor || '#872732'}`}></div>
  </header>
</div>

{/* ▼ 通常の「地域 / 言語」パネル */}
<RegionLangPanel currentLang={lang} currentCountry={defaultCountryForWeather} themeColor={labels.themeColor || '#872732'} />

{/* ▼ 国名ドロップダウン */}
<div id="cat-country-panel" class="cat-country-panel">
  <div class="cat-country-header">
    <span id="cat-country-title" class="cat-country-title">カテゴリ名</span>
    <button id="cat-country-close" class="cat-country-close" aria-label="閉じる">&times;</button>
  </div>
  <div class="cat-country-panel-inner" id="cat-country-panel-inner"></div>
</div>

<script type="application/json" id="lang-top-countries-data" set:html={JSON.stringify(availableCountries)}></script>

<style>
