  .sp-search-input { position: absolute; right: 34px; top: 50%; transform: translateY(-50%); width: 0; height: 30px !important; padding: 0 !important; background: #fff; border: 1px solid transparent; border-radius: 8px; opacity: 0; transition: all 0.3s ease; box-sizing: border-box; z-index: 10; }
  .sp-search-input.active { width: calc(100vw - 195px) !important; padding: 0 10px !important; border: 1px solid #ccc; opacity: 1; }
  .sp-search-btn { width: 28px !important; height: 28px !important; border-radius: 50%; box-sizing: border-box; flex-shrink: 0; background: #fff; border: 1px solid #ccc; padding: 0; display: flex; align-items: center; justify-content: center; z-index: 11; }
