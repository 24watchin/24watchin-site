  .sp-header-top { padding: 6px 14px; align-items: center; overflow: hidden; }
  .sp-logo-image { width: 150px; }
  .sp-right-area { gap: 8px; position: relative; flex: 1; min-width: 0; align-items: flex-end !important; }
  .sp-weather-widget { display: flex; align-items: center; justify-content: flex-end; gap: 4px; text-decoration: none; margin-top: 0; overflow: hidden; max-width: 140px; }
