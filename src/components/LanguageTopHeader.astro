  .no-wrap-text { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; width: 100%; text-align: right; }
  .sp-weather-loc { font-size: 10px; color: #0044cc; font-weight: bold; }
  .sp-weather-temp { font-size: 11px; color: #d9534f; font-weight: bold; white-space: nowrap; }

  .sp-category-bar { width: 100%; overflow: hidden; position: relative; }
  .sp-category-bar::after { content: ''; position: absolute; top: 0; right: 0; width: 35px; height: 100%; background: linear-gradient(to right, rgba(57,55,55,0) 0%, rgba(57,55,55,1) 100%); pointer-events: none; }
  .sp-scroll { padding-left: 6px; scrollbar-width: none; }
  .sp-scroll::-webkit-scrollbar { display: none; }
  .sp-scroll-padding { width: 45px; flex-shrink: 0; }

  @media (max-width: 768px) { .category-link { font-size: 14px; padding: 0 10px; height: 46px; } }
</style>

{/* ▼▼▼ 追加：ドロップダウンのデザインをJSで作った要素にも効かせるための「is:global」設定 ▼▼▼ */}
<style is:global>
