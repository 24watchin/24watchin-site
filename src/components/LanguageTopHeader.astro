  .sp-top-gray-bar { background-color: #e6e6e6; width: 100%; height: 38px; display: flex; align-items: center; justify-content: space-between; padding: 0 14px; box-sizing: border-box; position: relative; }
  .sp-top-country { font-size: 15px; font-weight: bold; color: #000; }
  .sp-top-actions { display: flex; align-items: center; gap: 10px; } 
