{/* ▲▲▲ 追加ここまで ▲▲▲ */}

<script is:inline>
  window.addEventListener('load', function() {
    function setupSearch(btnId, inputId, formId) {
      var btn = document.getElementById(btnId);
      var input = document.getElementById(inputId);
      var form = document.getElementById(formId);
      if (btn && input && form) {
        btn.addEventListener('click', function(e) {
          if (!input.classList.contains('active')) {
            e.preventDefault();
            input.classList.add('active');
            input.focus();
          } else {
            if (input.value.trim() === '') {
              e.preventDefault();
              input.classList.remove('active');
            } else {
              form.submit();
            }
          }
        });
      }
    }
    setupSearch('pc-search-icon-btn', 'pc-search-input', 'pc-search-form');
    setupSearch('sp-search-icon-btn', 'sp-search-input', 'sp-search-form');

    function setupRegionPanel(btnId) {
      var btn = document.getElementById(btnId);
      var rlPanel = document.getElementById('rl-panel');
      var rlOverlay = document.getElementById('rl-overlay');
      if (btn && rlPanel && rlOverlay) {
        btn.addEventListener('click', function() {
          rlPanel.classList.add('open');
          rlOverlay.classList.add('open');
          var currentLang = btn.getAttribute('data-current-lang');
          var activeLangBtn = document.querySelector('.rl-lang-btn[data-lang="' + currentLang + '"]');
          if (activeLangBtn) { activeLangBtn.click(); }
        });
      }
    }
    setupRegionPanel('pc-region-lang-btn');
    setupRegionPanel('sp-region-lang-btn');

    var pcScroll = document.getElementById('pc-scroll');
    var pcBtnLeft = document.getElementById('pc-arrow-left');
    var pcBtnRight = document.getElementById('pc-arrow-right');
    function updateArrows() {
      var width = window.innerWidth;
      if (pcScroll && pcBtnLeft && pcBtnRight) {
        if (width > 1000 || width <= 768) {
          pcBtnLeft.classList.remove('active');
          pcBtnRight.classList.remove('active');
        } else {
          var atLeftPC = pcScroll.scrollLeft <= 5;
          var atRightPC = pcScroll.scrollLeft >= (pcScroll.scrollWidth - pcScroll.clientWidth - 5);
          if (!atLeftPC) { pcBtnLeft.classList.add('active'); } else { pcBtnLeft.classList.remove('active'); }
          if (!atRightPC) { pcBtnRight.classList.add('active'); } else { pcBtnRight.classList.remove('active'); }
        }
      }
    }
    if(pcBtnLeft) pcBtnLeft.addEventListener('click', function() { pcScroll.scrollBy({ left: -200, behavior: 'smooth' }); });
    if(pcBtnRight) pcBtnRight.addEventListener('click', function() { pcScroll.scrollBy({ left: 200, behavior: 'smooth' }); });
    if (pcScroll) pcScroll.addEventListener('scroll', updateArrows);
    window.addEventListener('resize', updateArrows);
    updateArrows();

    // ドロップダウンの動き
    var catCountryPanel = document.getElementById('cat-country-panel');
    var catCountryInner = document.getElementById('cat-country-panel-inner');
    var catCountryTitle = document.getElementById('cat-country-title');
    var catCountryClose = document.getElementById('cat-country-close');
    var countriesDataEl = document.getElementById('lang-top-countries-data');
    var currentPanelSlug = null;
    
    if (catCountryPanel && countriesDataEl) {
      var availableCountries = JSON.parse(countriesDataEl.textContent);
      var currentLang = document.documentElement.lang || 'ja';

      document.querySelectorAll('.cat-dropdown-trigger').forEach(function(btn) {
        btn.addEventListener('click', function(e) {
          e.preventDefault();
          e.stopPropagation();
          var slug = btn.getAttribute('data-slug');
          var catName = btn.textContent.trim();

          if (catCountryPanel.classList.contains('show') && currentPanelSlug === slug) {
              catCountryPanel.classList.remove('show');
              currentPanelSlug = null;
              return;
          }
          currentPanelSlug = slug;

          if (catCountryTitle) {
            catCountryTitle.textContent = catName;
          }

          var rect = btn.getBoundingClientRect();
          catCountryInner.innerHTML = ''; 

          availableCountries.forEach(function(c) {
            var a = document.createElement('a');
            a.className = 'cat-country-link';
            a.href = '/' + currentLang + '/' + c.code + '/category/' + slug + '/';
            a.innerHTML = '<span class="cat-country-icon">▶</span>' + c.name;
            catCountryInner.appendChild(a);
          });

          var top = rect.bottom + window.scrollY + 8;
          var left = rect.left + window.scrollX;

          if (window.innerWidth <= 600) {
             left = (window.innerWidth - 220) / 2;
          } else if (left + 220 > window.innerWidth) {
             left = window.innerWidth - 240;
          }

          catCountryPanel.style.top = top + 'px';
          catCountryPanel.style.left = left + 'px';
          catCountryPanel.classList.add('show');
        });
      });

      if (catCountryClose) {
        catCountryClose.addEventListener('click', function(e) {
          e.stopPropagation();
          catCountryPanel.classList.remove('show');
          currentPanelSlug = null;
        });
      }

      document.addEventListener('click', function(e) {
        if (!e.target.closest('.cat-country-panel') && !e.target.closest('.cat-dropdown-trigger')) {
           catCountryPanel.classList.remove('show');
           currentPanelSlug = null;
        }
      });
    }
  });
</script>
