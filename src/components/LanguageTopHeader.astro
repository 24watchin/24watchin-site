  .pc-top-country { font-size: 16px; font-weight: bold; color: #000; }
  .pc-header-top { display: flex; justify-content: space-between; align-items: flex-end; padding: 20px 14px 15px; }
  .pc-right-area { display: flex; flex-direction: column; align-items: flex-end; gap: 15px; }

  .search-form-animated { display: flex; align-items: center; justify-content: flex-end; }
