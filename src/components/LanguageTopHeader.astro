  .search-icon-btn { width: 34px; height: 34px; border: 1px solid #d8d8d8; border-radius: 8px; background: #ffffff; cursor: pointer; display: flex; align-items: center; justify-content: center; z-index: 2; flex-shrink: 0; box-sizing: border-box; }

  .region-lang-open-btn { background: none; border: none; color: #000; font-size: 15px; font-weight: bold; cursor: pointer; display: flex; align-items: center; gap: 8px; padding: 0; }
  .hamburger-icon { font-size: 22px; font-weight: bold; }

