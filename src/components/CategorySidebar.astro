---
// ジャンルページ専用サイドバー：ランキングと広告を統合
const API_KEY = import.meta.env.API_KEY;
const BLOG_ID = import.meta.env.BLOG_ID;

// 1. ランキング用のデータを取得（最新10件）
const url = `https://www.googleapis.com/blogger/v3/blogs/${BLOG_ID}/posts?key=${API_KEY}&maxResults=10`;
const response = await fetch(url).catch(() => null);
const data = response ? await response.json() : { items: [] };
const fetchedPosts = data.items || [];

const rankingList = [];
for (let i = 0; i < 10; i++) {
  if (fetchedPosts[i]) {
    rankingList.push(fetchedPosts[i]);
  } else {
    rankingList.push({ title: "（記事準備中）", url: "#", dummy: true });
  }
}
---

<aside class="category-sidebar">
  
  {/* 1. アクセスランキング ブロック */}
  <section class="sidebar-widget">
    <div class="ranking-container">
      <div class="ranking-header">
        <h2><span class="ranking-label">RANKING</span> アクセスランキング</h2>
      </div>

      <div class="tabs">
        <div class="tab active">最新</div>
        <div class="tab">24時間</div>
        <div class="tab">週間</div>
      </div>

      <ul class="ranking-list">
        {rankingList.map((post, index) => (
          <li class="ranking-item">
            <div class="rank-number">{index + 1}</div>
            <div class="post-info">
              {/* ★ ここを日本版の住所（/jp/jp/）に修正しました！ */}
              <a href={post.dummy ? "#" : `/jp/jp/news/${post.id}/`} class="post-title">{post.title}</a>
            </div>
            <div class="post-thumbnail">
              <img src="https://placehold.co/80x60?text=No+Image" alt="サムネイル" />
            </div>
          </li>
        ))}
      </ul>
      
      <div class="ranking-footer">
        <a href="#">ランキング一覧へ ＞</a>
      </div>
    </div>
  </section>

  {/* 2. 広告エリア ブロック */}
  <section class="sidebar-widget ad-section">
    <div class="ad-container">
      <p class="ad-label">ADVERTISEMENT</p>
      <div class="ad-box">
        {/* ここに将来的にGoogle AdSenseなどのコードを貼り付けます */}
        <p>広告エリア</p>
      </div>
    </div>
  </section>

</aside>

<style>
  .category-sidebar { display: flex; flex-direction: column; gap: 2.5rem; }

  /* ランキングのデザイン（ご提供いただいたものを調整） */
  .ranking-container { background-color: #fff; font-family: sans-serif; }
  .ranking-header h2 { font-size: 16px; font-weight: bold; margin: 0 0 10px 0; display: flex; align-items: center; gap: 8px; }
  .ranking-label { font-size: 10px; border-top: 1px solid #000; border-bottom: 1px solid #000; padding: 2px 0; }
  .tabs { display: flex; margin-bottom: 15px; }
  .tab { flex: 1; text-align: center; padding: 8px 0; font-size: 13px; background-color: #eee; color: #333; border: 1px solid #ccc; cursor: pointer; }
  .tab.active { background-color: #333; color: #fff; font-weight: bold; border-color: #333; }
  .ranking-list { list-style: none; padding: 0; margin: 0; }
  .ranking-item { display: flex; align-items: center; padding: 10px 0; border-bottom: 1px dashed #ccc; gap: 10px; }
  .ranking-item:last-child { border-bottom: none; }
  .rank-number { font-size: 22px; font-weight: bold; font-style: italic; width: 25px; text-align: center; color: #1e3a8a; }
  .post-info { flex: 1; }
  .post-title { font-size: 13px; color: #000; text-decoration: none; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.4; }
  .post-thumbnail img { width: 70px; height: 50px; object-fit: cover; border-radius: 4px; }
  .ranking-footer { text-align: right; margin-top: 15px; font-size: 12px; }
  .ranking-footer a { color: #666; text-decoration: none; }

  /* 広告エリアのデザイン */
  .ad-container { text-align: center; }
  .ad-label { font-size: 10px; color: #999; margin-bottom: 5px; }
  .ad-box { background: #f4f4f4; height: 250px; display: flex; align-items: center; justify-content: center; border: 1px solid #eee; color: #bbb; font-weight: bold; }
</style>
