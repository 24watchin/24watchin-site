---
import GoogleAdBanner from './GoogleAdBanner.astro';
import GlobalRegionNewsSidebar from './GlobalRegionNewsSidebar.astro';
import AccessRanking from './AccessRanking.astro';
// ▼ ここを「EditorsPick」（sなし）の縦並び部品に戻します
import EditorsPick from './EditorsPick.astro';

// ▼ GPS機能は残しておきます
const { lang: propLang, country: propCountry, allPosts = [] } = Astro.props;
const { lang: paramLang, country: paramCountry } = Astro.params;

const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const urlLang = pathSegments[0];
const urlCountry = pathSegments[1];

const lang = propLang || paramLang || urlLang || 'ja';
const country = propCountry || paramCountry || urlCountry || 'jp';
---

<aside class="category-sidebar">

  <AccessRanking lang={lang} country={country} />

  {/* ▼ 呼び出すコンポーネントも EditorsPick に戻します */}
  <EditorsPick lang={lang} country={country} />

  <GlobalRegionNewsSidebar
    lang={lang}
    country={country}
    allPosts={allPosts}
  />

  <GoogleAdBanner />
</aside>

<style>
  .category-sidebar { display: flex; flex-direction: column; gap: 24px; }
</style>
