---
import GoogleAdBanner from './GoogleAdBanner.astro';
import GlobalRegionNewsSidebar from './GlobalRegionNewsSidebar.astro';
import AccessRanking from './AccessRanking.astro';
import EditorsPick from './EditorsPick.astro';

const { lang = 'ja', country = 'jp', allPosts = [] } = Astro.props;
---

<aside class="category-sidebar">

  <AccessRanking lang={lang} country={country} />

  <EditorsPick lang={lang} country={country} />

  <GlobalRegionNewsSidebar
    lang={lang}
    country={country}
    allPosts={allPosts}
  />

  <GoogleAdBanner />
</aside>

<style>
  .category-sidebar { display: flex; flex-direction: column; gap: 24px; }
</style>

