---
const { lang = 'ja', title, cityData = [] } = Astro.props;

const getImageUrl = (content) => {
  const match = (content || '').match(/<img[^>]+src="([^">]+)"/);
  return match ? match[1] : 'https://placehold.co/124x83/eeeeee/999999?text=No+Image';
};

const formatPostTime = (dateString) => {
  if (!dateString) return '';
  try {
    return new Date(dateString).toLocaleString('ja-JP', {
      month: 'numeric', day: 'numeric', hour: '2-digit', minute: '2-digit',
    });
  } catch { return ''; }
};

const getDisplayCategory = (post) => {
  const labels = post?.labels || [];
  const visibleLabel = labels.find((label) => {
    if (!label) return false;
    if (/^[a-z]{2}-[a-z]{2}$/i.test(label)) return false; // タグを非表示
    return true;
  });
  return visibleLabel || 'ニュース';
};
---

<section class="region-section">
  <div class="region-header">
    <h2 class="region-title">{title}</h2>
    <div class="region-line"></div>
  </div>

  <div class="city-groups">
    {cityData.map((city) => (
      <div class="city-block">
        <h3 class="city-name">{city.name}</h3>
        <div class="article-3-grid">
          {city.posts.slice(0, 3).map((post) => (
            <a href={`/${lang}/${city.code}/news/${post.id}/`} class="news-item">
              <div class="media-column">
                <div class="thumbnail">
                  <img src={getImageUrl(post.content)} alt={post.title} />
                </div>
                <div class="image-date-row">
                  {post.published && (
                    <span class="post-time">{formatPostTime(post.published)}</span>
                  )}
                </div>
              </div>
              <div class="info">
                <h4 class="news-title">{post.title}</h4>
                <div class="category-row">
                  <span class="category-badge">{getDisplayCategory(post)}</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .region-section { 
    width: 100%; 
    margin-bottom: 5px; /* 地域セクション同士の間隔を最小限に */
  }
  .region-header { margin-bottom: 12px; }
  .region-title { margin: 0 0 6px; font-size: 19px; font-weight: 700; color: #111111; }
  .region-line { width: 100%; height: 3px; background: #872732; }
  
  .city-groups { 
    display: flex; 
    flex-direction: column; 
    gap: 10px; /* 日本・台湾などの行の間隔 */
  }
  .city-block { 
    width: 100%; 
    padding: 4px 0; /* 各国の上下の余白を最小限に */
  }
  
  .city-name { 
    font-size: 15px; font-weight: bold; color: #333; 
    margin: 0 0 8px 0; padding-left: 8px; 
    border-left: 4px solid #d9d9d9; 
  }

  .article-3-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 12px 20px; }
  .news-item { display: flex; align-items: flex-start; gap: 12px; text-decoration: none; color: #111111; }
  .media-column { width: 116px; flex-shrink: 0; }
  .thumbnail { width: 116px; aspect-ratio: 3 / 2; overflow: hidden; border-radius: 4px; background: #eeeeee; }
  .thumbnail img { width: 100%; height: 100%; object-fit: cover; }
  .image-date-row { margin-top: 2px; text-align: right; }
  .info { min-width: 0; flex: 1; }
  .news-title { margin: 0; font-size: 15px; line-height: 1.4; font-weight: 700; -webkit-line-clamp: 2; display: -webkit-box; -webkit-box-orient: vertical; overflow: hidden; min-height: 2.8em; }
  .category-row { margin-top: 4px; text-align: right; }
  .category-badge { padding: 1px 6px; background: #4d4d4d; color: #fff; font-size: 13px; border-radius: 2px; }
  .post-time { font-size: 13px; color: #8a8a8a; }

  @media (max-width: 1024px) { .article-3-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 700px) { .article-3-grid { grid-template-columns: 1fr; } .media-column, .thumbnail, .image-date-row { width: 112px; } }
</style>
