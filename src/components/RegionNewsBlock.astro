---
// 画像デザインに基づいた「地域別・都市別」ブロック
// title: 地域名 (北米 など)
// cityData: [{ cityName: "シカゴ", posts: [...] }, { cityName: "アトランタ", posts: [...] }] のようなデータ
const { title, cityData = [] } = Astro.props;

const getImageUrl = (content) => {
  const match = (content || '').match(/<img[^>]+src="([^">]+)"/);
  return match ? match[1] : 'https://placehold.co/120x80/eeeeee/999999?text=No+Image';
};
---

<section class="region-section">
  <div class="region-main-header">
    <div class="region-badge">{title}</div>
    <div class="region-line"></div>
  </div>

  <div class="city-groups">
    {cityData.map((city) => (
      <div class="city-block">
        <h3 class="city-name">{city.cityName}</h3>
        
        <div class="article-3-grid">
          {city.posts.slice(0, 3).map((post) => (
            <a href={`/news/${post.id}/`} class="news-item">
              <div class="thumbnail">
                <img src={getImageUrl(post.content)} alt={post.title} />
              </div>
              <div class="info">
                <h4>{post.title}</h4>
                <p class="summary">{post.title.substring(0, 30)}...</p>
                <div class="meta">
                  <span class="time"><i class="far fa-clock"></i> 15:00</span>
                  <span class="badge-new">NEW</span>
                  <span class="tag">国際</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .region-section { margin-bottom: 60px; width: 100%; }

  /* 赤い大見出しのデザイン */
  .region-main-header { display: flex; align-items: center; margin-bottom: 30px; }
  .region-badge { background: #e11d48; color: #fff; padding: 6px 20px; font-weight: bold; font-size: 18px; border-radius: 2px; }
  .region-line { flex-grow: 1; height: 2px; background: #e11d48; margin-left: -2px; }

  /* 都市名 */
  .city-name { font-size: 20px; font-weight: bold; margin: 0 0 15px 10px; color: #111; }
  .city-block { margin-bottom: 40px; }

  /* 3枚横並びのグリッド */
  .article-3-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  /* 個別の記事パーツ（横型） */
  .news-item { display: flex; gap: 12px; text-decoration: none; color: #333; }
  .thumbnail { width: 120px; height: 80px; flex-shrink: 0; border-radius: 4px; overflow: hidden; background: #eee; }
  .thumbnail img { width: 100%; height: 100%; object-fit: cover; }
  
  .info h4 { font-size: 14px; margin: 0 0 4px; line-height: 1.4; font-weight: bold; }
  .summary { font-size: 12px; color: #666; margin: 0 0 8px; line-height: 1.4; }
  .meta { display: flex; align-items: center; gap: 8px; font-size: 11px; color: #888; }
  .badge-new { background: #e11d48; color: #fff; padding: 0 4px; border-radius: 2px; font-weight: bold; }

  /* レスポンシブ：画面が狭くなったら1列にする */
  @media (max-width: 1024px) {
    .article-3-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 700px) {
    .article-3-grid { grid-template-columns: 1fr; }
  }
</style>
