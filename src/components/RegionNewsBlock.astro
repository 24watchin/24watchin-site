---
const { lang = 'ja', title, cityData = [] } = Astro.props;

const getImageUrl = (content) => {
  const match = (content || '').match(/<img[^>]+src="([^">]+)"/);
  return match ? match[1] : 'https://placehold.co/124x83/eeeeee/999999?text=No+Image';
};

const formatPostTime = (dateString) => {
  if (!dateString) return '';
  try {
    return new Date(dateString).toLocaleString(lang === 'ja' ? 'ja-JP' : 'en-US', {
      month: 'numeric', day: 'numeric', hour: '2-digit', minute: '2-digit',
    });
  } catch { return ''; }
};

const getDisplayCategory = (post) => {
  const labels = post?.labels || [];
  const visibleLabel = labels.find((label) => {
    if (!label) return false;
    if (/^[a-z]{2}-[a-z]{2}$/i.test(label)) return false;
    return true;
  });
  return visibleLabel || (lang === 'ja' ? 'ニュース' : 'News');
};
---

<section class="region-section">
  <div class="region-header">
    <h2 class="region-title">{title}</h2>
    <div class="region-line"></div>
  </div>

  <div class="city-groups">
    {cityData.map((city) => (
      <div class="city-block">
        <h3 class="city-name">{city.name}</h3>
        <div class="article-3-grid">
          {city.posts.slice(0, 3).map((post) => (
            <a href={`/${lang}/${city.code}/news/${post.id}/`} class="news-item">
              <div class="media-column">
                <div class="thumbnail">
                  <img src={getImageUrl(post.content)} alt={post.title} />
                </div>
                <div class="image-date-row">
                  {post.published && (
                    <span class="post-time">{formatPostTime(post.published)}</span>
                  )}
                </div>
              </div>
              <div class="info">
                <h4 class="news-title">{post.title}</h4>
                <div class="category-row">
                  <span class="category-badge">{getDisplayCategory(post)}</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .region-section { width: 100%; margin-bottom: 56px; }
  .region-header { margin-bottom: 18px; }
  .region-title { margin: 0 0 10px; font-size: 20px; font-weight: 700; color: #111111; }
  .region-line { width: 100%; height: 4px; background: #872732; }
  .city-groups { display: flex; flex-direction: column; gap: 24px; }
  .city-block { width: 100%; padding: 10px 0; }
  .city-name { font-size: 16px; font-weight: bold; color: #333; margin: 0 0 12px 0; padding-left: 8px; border-left: 4px solid #d9d9d9; }
  .article-3-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 16px 24px; }
  .news-item { display: flex; align-items: flex-start; gap: 14px; text-decoration: none; color: #111111; }
  .media-column { width: 124px; flex-shrink: 0; }
  .thumbnail { width: 124px; aspect-ratio: 3 / 2; overflow: hidden; border-radius: 4px; background: #eeeeee; }
  .thumbnail img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .image-date-row { margin-top: 3px; width: 124px; text-align: right; }
  .info { min-width: 0; flex: 1; }
  .news-title { margin: 0; font-size: 16px; line-height: 1.45; font-weight: 700; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; min-height: 2.9em; }
  .category-row { margin-top: 6px; text-align: right; }
  .category-badge { display: inline-block; padding: 2px 8px; border-radius: 2px; background: #4d4d4d; color: #ffffff; font-size: 14px; }
  .post-time { font-size: 14px; color: #8a8a8a; }
  .news-item:hover .news-title { text-decoration: underline; }

  @media (max-width: 1024px) { .article-3-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 700px) { .article-3-grid { grid-template-columns: 1fr; } .media-column, .thumbnail, .image-date-row { width: 116px; } }
</style>
