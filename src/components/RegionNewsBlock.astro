---
// index.astro から送られてくるデータ（地域名と都市ごとの記事）を受け取ります
const { title, cityData } = Astro.props;
---

<section class="region-block">
  <h2 class="region-title">{title}</h2>

  <div class="cities-container">
    {cityData.map((city) => (
      <div class="city-section">
        <h3 class="city-name">{city.cityName}</h3>
        
        <div class="posts-grid">
          {city.posts.map((post) => {
            // 記事の中から最初の画像を探します
            const imgMatch = (post.content || '').match(/<img[^>]+src="([^">]+)"/);
            const imgSrc = imgMatch ? imgMatch[1] : 'https://placehold.co/300x200/eeeeee/999999?text=No+Image';
            const date = new Date(post.published).toLocaleTimeString('ja-JP', { hour: '2-digit', minute: '2-digit' });

            return (
              <article class="post-card">
                {/* ★ ここを日本版の住所（/jp/jp/）に修正しました！ */}
                <a href={`/jp/jp/news/${post.id}/`} class="post-link">
                  <div class="img-wrapper">
                    <img src={imgSrc} alt="" loading="lazy" />
                  </div>
                  <div class="post-info">
                    <h4 class="post-title">{post.title}</h4>
                    <div class="post-meta">
                      <span class="time"><i class="far fa-clock"></i> {date}</span>
                      <span class="badge-new">NEW</span>
                      <span class="category">国際</span>
                    </div>
                  </div>
                </a>
              </article>
            );
          })}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .region-block { margin-bottom: 40px; }
  .region-title { font-size: 24px; font-weight: bold; color: #333; margin-bottom: 20px; padding-bottom: 8px; border-bottom: 4px solid #b11d2c; }
  .city-section { margin-bottom: 25px; }
  .city-name { font-size: 18px; font-weight: bold; margin-bottom: 12px; color: #333; }
  .posts-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .post-link { text-decoration: none; color: inherit; display: flex; gap: 12px; }
  .img-wrapper { flex-shrink: 0; width: 100px; height: 65px; overflow: hidden; border-radius: 4px; background: #eee; }
  .img-wrapper img { width: 100%; height: 100%; object-fit: cover; }
  .post-info { flex-grow: 1; }
  .post-title { font-size: 14px; font-weight: bold; line-height: 1.4; margin: 0 0 6px 0; color: #333; border-bottom: 1px solid transparent; }
  .post-link:hover .post-title { border-bottom: 1px solid #333; }
  .post-meta { font-size: 11px; color: #888; display: flex; align-items: center; gap: 8px; }
  .badge-new { background: #e11d48; color: white; padding: 1px 4px; border-radius: 2px; font-weight: bold; font-size: 10px; }
  .category { color: #888; }
  @media (max-width: 768px) {
    .posts-grid { grid-template-columns: 1fr; gap: 15px; }
    .region-title { font-size: 20px; }
  }
</style>
