---
import { categoryLabelMap } from '../lib/categoryLabels.ts';

// 司令塔から記事データを受け取ります
const { latestStories = [] } = Astro.props;

// 英語のカテゴリ翻訳ルールを読み込みます
const enCategories = categoryLabelMap?.['en']?.allCategories || [];

// 英語の国名辞書
const countryNameMap = {
  jp: 'Japan', us: 'USA', ae: 'UAE', au: 'Australia',
  gb: 'UK', sg: 'Singapore', ca: 'Canada', cn: 'China',
  tw: 'Taiwan', es: 'Spain', fr: 'France', de: 'Germany',
  br: 'Brazil', kr: 'South Korea'
};

const backupStories = [
  { id: 1, category: 'Politics', countryCode: 'jp', country: 'Japan', title: 'New Semiconductor Hub Opens in Hokkaido, Boosting Local Tech Industry', excerpt: 'The government aims to revitalize the regional economy with a multi-billion yen investment in chip manufacturing.', image: 'url("https://images.unsplash.com/photo-1518770660439-4636190af475?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80")' },
  { id: 2, category: 'Economy', countryCode: 'us', country: 'USA', title: 'Federal Reserve Signals Potential Rate Cuts by Year-End', excerpt: 'Market rallies as inflation data shows signs of cooling off for the third consecutive month.', image: 'url("https://images.unsplash.com/photo-1611974789855-9c2a0a7236a3?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80")' },
  { id: 3, category: 'Society', countryCode: 'fr', country: 'France', title: 'Paris Sets New Standard for Eco-Friendly Urban Planning', excerpt: 'Historic districts are being transformed with green roofs and pedestrian-only zones.', image: 'url("https://images.unsplash.com/photo-1499856871958-5b9627545d1a?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80")' },
  { id: 4, category: 'Environment', countryCode: 'br', country: 'Brazil', title: 'Amazon Conservation Efforts Show Promising Results This Quarter', excerpt: 'Deforestation rates drop significantly as new AI monitoring technologies are deployed across the rainforest.', image: 'url("https://images.unsplash.com/photo-1516026672322-bc52d61a55d5?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80")' },
  { id: 5, category: 'Technology', countryCode: 'kr', country: 'South Korea', title: 'Breakthrough in Solid-State Battery Tech Announced in Seoul', excerpt: 'Researchers unveil a new prototype that could double the range of current electric vehicles.', image: 'url("https://images.unsplash.com/photo-1526628953301-3e589a6a8b74?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80")' },
];

const displayStories = latestStories.length > 0 ? latestStories : backupStories;

const languages = [
  { code: 'en', name: 'English', color: '#1A365D', url: '/en/' },
  { code: 'ja', name: '日本語', color: '#872732', url: '/ja/' },
  { code: 'zh-cn', name: '简体中文', color: '#C53030', url: '/zh-cn/' },
  { code: 'zh-tw', name: '繁體中文', color: '#2C5282', url: '/zh-tw/' },
  { code: 'es', name: 'Español', color: '#B7791F', url: '/es/' },
  { code: 'fr', name: 'Français', color: '#2B6CB0', url: '/fr/' },
  { code: 'de', name: 'Deutsch', color: '#276749', url: '/de/' },
  { code: 'ru', name: 'Русский', color: '#744210', url: '/ru/' },
];

function stripHtml(html) {
  if (!html) return '';
  const text = html.replace(/<[^>]*>?/gm, '');
  return text.length > 100 ? text.substring(0, 100) + '...' : text;
}

function getThumbnail(content) {
  if (!content) return 'linear-gradient(135deg, #1a1c29 0%, #2a3b4c 100%)';
  const match = content.match(/<img[^>]+src="([^">]+)"/);
  return match ? `url("${match[1]}")` : 'linear-gradient(135deg, #1a1c29 0%, #2a3b4c 100%)';
}
---

<header class="global-header">
  <div class="header-band">
    <div class="logo-area">
      <a href="https://24watchin.com">
        <img src="/images/24Watchin-white.png" alt="24Watchin Logo" class="header-logo-img" />
      </a>
    </div>
    <button class="menu-trigger" id="menu-open" aria-label="Open menu">
      <span class="burger-line"></span>
      <span class="burger-line"></span>
      <span class="burger-line"></span>
    </button>
  </div>
</header>

<nav class="side-menu" id="side-menu">
  <button class="menu-close" id="menu-close" aria-label="Close menu">&times;</button>
  <div class="menu-inner">
    <h3>CHOOSE YOUR LANGUAGE</h3>
    <div class="menu-grid">
      {languages.map((lang) => (
        <a href={lang.url} class="menu-lang-card" style={`--accent: ${lang.color}`}>
          <span class="lang-name" lang={lang.code}>{lang.name}</span>
        </a>
      ))}
    </div>
  </div>
</nav>

<div class="scroll-indicator" id="scroll-indicator">
  <div class="dot active"></div>
  <div class="dot"></div>
  <div class="dot"></div>
  <div class="dot"></div>
  <div class="dot"></div>
  <div class="dot"></div>
</div>

<div class="transition-mask" id="transition-mask" aria-hidden="true"></div>

<div class="desktop-only-wrapper">
  <div class="desktop-sequence" id="desktop-sequence">
    <div class="split-stage">
      <div class="left-track">
        <div class="panel p1">
          <div class="bg-layer" style="background-image: url('/images/conflict.jpg');"></div>
          <div class="word-band-container"><div class="word-band"><h2>CONFLICT</h2></div></div>
        </div>
        <div class="panel p2">
          <div class="bg-layer" style="background-image: url('/images/cities.webp');"></div>
          <div class="word-band-container"><div class="word-band"><h2>CITIES</h2></div></div>
        </div>
        <div class="panel p3">
          <div class="bg-layer" style="background-image: url('/images/innovation.jpg');"></div>
          <div class="word-band-container"><div class="word-band"><h2>INNOVATION</h2></div></div>
        </div>
      </div>
      <div class="right-track">
        <div class="panel p1">
          <div class="bg-layer" style="background-image: url('/images/crisis.png');"></div>
          <div class="word-band-container"><div class="word-band"><h2>CRISIS</h2></div></div>
        </div>
        <div class="panel p2">
          <div class="bg-layer" style="background-image: url('/images/people.webp');"></div>
          <div class="word-band-container"><div class="word-band"><h2>PEOPLE</h2></div></div>
        </div>
        <div class="panel p3">
          <div class="bg-layer" style="background-image: url('/images/frontier.jpg');"></div>
          <div class="word-band-container"><div class="word-band"><h2>FRONTIER</h2></div></div>
        </div>
      </div>
    </div>

    <section class="brand-panel" id="brand-panel">
      <div class="brand-night"></div>
      <div class="brand-bg" style="background-image: url('/images/explanation.png');"></div>
      <div class="brand-bg-overlay"></div>
      <div class="brand-content text-anim-target" id="brand-text-target">
        <img src="/images/24Watchin-white.png" alt="24Watchin Logo" class="brand-logo-img fade-base fade-up anim-logo" />
        <h2 class="brand-catch fade-base fade-up anim-catch">Watch the world with clarity.</h2>
        <div class="brand-desc">
          <p class="fade-base fade-left anim-desc1">Global news.</p>
          <p class="fade-base fade-left anim-desc2">Explained clearly.</p>
          <p class="fade-base fade-left anim-desc3">In your language.</p>
        </div>
      </div>
    </section>

    <section class="seq-panel" id="screen-5">
      <div class="seq-inner">
        <div class="section-header"><h2>Latest Stories</h2></div>
        
        <div class="carousel-wrapper">
          <div class="carousel-container" id="story-carousel">
            <div class="carousel-spacer"></div>
            
            {displayStories.map((post) => {
              let bgImage = '';
              let categoryName = 'News';
              let countryCode = 'world';
              let countryName = '';
              let dateText = '';
              if (post.labels && Array.isArray(post.labels)) {
                bgImage = getThumbnail(post.content);
                const countryTag = post.labels.find(l => l.startsWith('en-'));
                if (countryTag) {
                  countryCode = countryTag.replace('en-', '');
                  if (countryNameMap[countryCode]) {
                    countryName = countryNameMap[countryCode];
                  }
                }
                
                const foundCat = enCategories.find(cat => 
                  post.labels.some(label => cat.keywords?.some(key => label.toLowerCase().includes(key.toLowerCase())))
                );
                if (foundCat) categoryName = foundCat.label;

                dateText = post.published ? new Date(post.published).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '';
              } 
              else {
                bgImage = post.image;
                categoryName = post.category;
                countryCode = post.countryCode;
                countryName = post.country;
                dateText = new Date().toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
              }

              return (
                <a href={`/en/${countryCode}/news/${post.id}`} class="story-card observer-card no-link-color">
                  <div class="card-img-box">
                    <div class="card-bg" style={`background-image: ${bgImage};`}></div>
                  </div>
                  <div class="card-text-box">
                    <div class="card-meta">
                      <span class="category">{categoryName}</span>
                      {countryName && <span class="country-name">from {countryName}</span>}
                    </div>
                    <div class="card-date">{dateText}</div>
                    <h3 class="card-title">{post.title}</h3>
                  </div>
                </a>
              );
            })}

            <div class="carousel-spacer"></div>
          </div>
          
          <div class="carousel-bottom-nav">
            <button class="carousel-nav-arrow" id="story-carousel-prev" aria-label="Previous">&lt;</button>
            <div class="carousel-dots-wrapper" id="story-carousel-dots">
              {displayStories.map((_, i) => (
                <div class={`c-dot ${i === 0 ? 'active' : ''}`}></div>
              ))}
            </div>
            <button class="carousel-nav-arrow" id="story-carousel-next" aria-label="Next">&gt;</button>
          </div>
        </div>

      </div>
    </section>

    <section class="seq-panel" id="screen-6">
      <div class="seq-inner">
        <div class="section-header"><h2>CHOOSE YOUR LANGUAGE</h2></div>
        <div class="carousel-wrapper">
          <div class="carousel-container" id="lang-carousel">
            <div class="carousel-spacer"></div>
            {languages.map((lang) => (
              <a href={lang.url} class="lang-card observer-card no-link-color">
                <div class="lang-bg" style={`background-color: ${lang.color};`}></div>
                <div class="lang-content">
                  <h3 class="lang-name" lang={lang.code}>{lang.name}</h3>
                  <div class="lang-border"></div>
                </div>
              </a>
            ))}
            <div class="carousel-spacer"></div>
          </div>
          
          <div class="carousel-bottom-nav">
            <button class="carousel-nav-arrow" id="lang-carousel-prev" aria-label="Previous">&lt;</button>
            <div class="carousel-dots-wrapper" id="lang-carousel-dots">
              {languages.map((_, i) => (
                <div class={`c-dot ${i === 0 ? 'active' : ''}`}></div>
              ))}
            </div>
            <button class="carousel-nav-arrow" id="lang-carousel-next" aria-label="Next">&gt;</button>
          </div>
        </div>
      </div>

      <footer class="top-footer">
        <div class="top-footer-inner">
          <div class="top-footer-logo">
            <img src="/images/24Watchin-white.png" alt="24Watchin Logo" />
          </div>
          <div class="top-footer-right">
            <div class="top-footer-links">
              <a href="/info/about/">ABOUT 24WATCHIN</a>
              <a href="/info/privacy/">PRIVACY POLICY</a>
              <a href="/info/terms/">TERMS OF USE</a>
              <a href="/info/contact/">CONTACT</a>
            </div>
            <div class="top-footer-copy">
              &copy; 2026 The Dexent Media Enterprises. All Rights Reserved.
            </div>
          </div>
        </div>
      </footer>
    </section>

  </div>

  <section class="hero-spacer" aria-hidden="true">
    <div class="hero-spacer-brand">
      <div class="hero-spacer-bg" style="background-image: url('/images/explanation.png');"></div>
      <div class="hero-spacer-bg-overlay"></div>
    </div>
  </section>

</div>

<style>
  body {
    -webkit-user-select: none;
    user-select: none;
  }
  
  .global-header { position: fixed; top: 0; left: 0; width: 100%; z-index: 300; pointer-events: none; }
  .header-band { display: flex; justify-content: space-between; align-items: center; padding: 30px 50px; background: linear-gradient(to bottom, rgba(0, 0, 0, 0.85) 0%, rgba(0, 0, 0, 0) 100%); pointer-events: auto; }
  .logo-area a { text-decoration: none; outline: none; }
  
  /* ▼ ヘッダーロゴを白く反転させるフィルター ▼ */
  .header-logo-img { height: 48px; width: auto; transition: opacity 0.3s ease; filter: brightness(0) invert(1); } 
  .header-logo-img:hover { opacity: 0.8; }
  
  .menu-trigger { background: none; border: none; cursor: pointer; display: flex; flex-direction: column; gap: 6px; }
  .burger-line { width: 30px; height: 2px; background: #fff; border-radius: 2px; }
  .side-menu { position: fixed; top: 0; right: -100%; width: 100%; height: 100%; background: rgba(10, 10, 10, 0.98); z-index: 400; transition: right 0.6s cubic-bezier(0.2, 0.8, 0.2, 1); padding: 80px 40px; display: flex; justify-content: center; }
  .side-menu.is-open { right: 0; }
  .menu-close { position: absolute; top: 30px; right: 40px; font-size: 40px; background: none; border: none; color: #fff; cursor: pointer; }
  .menu-inner { max-width: 1000px; width: 100%; text-align: center; }
  .menu-inner h3 { font-size: 14px; letter-spacing: 4px; margin-bottom: 50px; color: #888; }
  .menu-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; }
  .menu-lang-card { padding: 40px; border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 4px; transition: 0.3s; background: linear-gradient(135deg, rgba(255, 255, 255, 0.05) 0%, transparent 100%); text-decoration: none; color: white; }
  .menu-lang-card:hover { border-color: var(--accent); transform: translateY(-5px); }
  .scroll-indicator { position: fixed; top: 75%; right: 25px; transform: translateY(-50%); display: flex; flex-direction: column; gap: 12px; z-index: 500; }
  .scroll-indicator .dot { width: 6px; height: 6px; border-radius: 4px; background: rgba(255, 255, 255, 0.3); transition: all 0.4s cubic-bezier(0.2, 0.8, 0.2, 1); }
  .scroll-indicator .dot.active { height: 32px; background: rgba(255, 255, 255, 0.9); }
  .transition-mask { position: fixed; inset: 0; z-index: 220; opacity: 0; visibility: hidden; pointer-events: none; background: #010411; transition: opacity 0.8s ease, visibility 0s linear 0.8s; }
  .transition-mask.is-visible { opacity: 1; visibility: visible; transition: opacity 0.8s ease; }
  .desktop-sequence { position: fixed; inset: 0; z-index: 120; opacity: 1; visibility: visible; transition: opacity 0.32s ease, visibility 0s linear 0s; }
  .desktop-sequence.is-hidden { opacity: 0; visibility: hidden; pointer-events: none; transition: opacity 0.28s ease, visibility 0s linear 0.28s; }
  .hero-spacer { height: 100vh; position: relative; overflow: hidden; background: #050b18; }
  .hero-spacer-brand { position: absolute; inset: 0; }
  .hero-spacer-bg { position: absolute; inset: 0; background-size: cover; background-position: center; opacity: 0.96; }
  .hero-spacer-bg-overlay { position: absolute; inset: 0; background: radial-gradient(circle, rgba(0, 0, 0, 0.1) 0%, rgba(0, 0, 0, 0.62) 100%); }
  .split-stage { position: absolute; inset: 0; display: flex; }
  .left-track, .right-track { width: 50vw; height: 100vh; position: relative; }
  .panel { position: absolute; inset: 0; overflow: hidden; }
  .bg-layer { position: absolute; inset: 0; background-size: cover; background-position: center; }
  .left-track .p1 { z-index: 1; }
  .left-track .p2 { z-index: 2; clip-path: inset(100% 0 0 0); -webkit-clip-path: inset(100% 0 0 0); transition: clip-path 1.5s cubic-bezier(0.64, 0.04, 0.35, 1), -webkit-clip-path 1.5s cubic-bezier(0.64, 0.04, 0.35, 1); }
  .left-track .p3 { z-index: 3; clip-path: inset(100% 0 0 0); -webkit-clip-path: inset(100% 0 0 0); transition: clip-path 1.5s cubic-bezier(0.64, 0.04, 0.35, 1), -webkit-clip-path 1.5s cubic-bezier(0.64, 0.04, 0.35, 1); }
  .right-track .p1 { z-index: 1; }
  .right-track .p2 { z-index: 2; clip-path: inset(0 0 100% 0); -webkit-clip-path: inset(0 0 100% 0); transition: clip-path 1.5s cubic-bezier(0.64, 0.04, 0.35, 1), -webkit-clip-path 1.5s cubic-bezier(0.64, 0.04, 0.35, 1); }
  .right-track .p3 { z-index: 3; clip-path: inset(0 0 100% 0); -webkit-clip-path: inset(0 0 100% 0); transition: clip-path 1.5s cubic-bezier(0.64, 0.04, 0.35, 1), -webkit-clip-path 1.5s cubic-bezier(0.64, 0.04, 0.35, 1); }
  .panel.is-open { clip-path: inset(0 0 0 0) !important; -webkit-clip-path: inset(0 0 0 0) !important; }
  .word-band-container { position: absolute; top: 50%; transform: translateY(-50%); z-index: 10; overflow: hidden; }
  .left-track .word-band-container { left: 0; }
  .right-track .word-band-container { right: 0; }
  .word-band { background: rgba(255, 255, 255, 0.35); backdrop-filter: blur(12px); padding: 15px 50px; display: flex; align-items: center; transition: transform 1.2s cubic-bezier(0.2, 0.8, 0.2, 1); }
  .left-track .word-band { transform: translateX(-105%); border-radius: 0 4px 4px 0; }
  .right-track .word-band { transform: translateX(105%); border-radius: 4px 0 0 4px; }
  .word-band h2 { color: #000; font-weight: 600; font-size: clamp(1.8rem, 3vw, 2.5rem); letter-spacing: 0.15em; margin: 0; opacity: 0; transition: opacity 0.3s ease; }
  .panel.is-active .word-band { transform: translateX(0); }
  .panel.is-active .word-band h2 { opacity: 1; transition: opacity 1s ease 0.8s; }
  .brand-panel { position: absolute; inset: 0; z-index: 30; visibility: hidden; pointer-events: none; }
  .brand-panel.is-visible { visibility: visible; }
  .seq-panel { position: absolute; inset: 0; z-index: 40; visibility: hidden; pointer-events: none; background: linear-gradient(to bottom, #0d0d0d 0%, #1a1a24 50%, #0d0d0d 100%); display: flex; flex-direction: column; align-items: center; justify-content: center; overflow: hidden; }
  #screen-6 { z-index: 41; padding-bottom: 110px; }
  .seq-panel.is-visible { visibility: visible; pointer-events: auto; }
  .seq-inner { width: 100%; opacity: 0; transform: translateY(40px); transition: opacity 0.6s cubic-bezier(0.2, 0.8, 0.2, 1) 0.1s, transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1) 0.1s; }
  .seq-panel.is-visible .seq-inner { opacity: 1; transform: translateY(0); }
  .brand-night { position: absolute; inset: 0; opacity: 0; background: radial-gradient(circle at 50% 35%, rgba(33, 76, 160, 0.18) 0%, rgba(17, 36, 82, 0.28) 22%, rgba(7, 15, 40, 0.62) 56%, rgba(4, 8, 24, 0.92) 100%), linear-gradient(to bottom, rgba(8, 18, 48, 0.55) 0%, rgba(5, 12, 32, 0.88) 75%, rgba(3, 7, 20, 0.96) 100%); transition: opacity 0.6s ease; }
  .brand-panel.is-night .brand-night { opacity: 1; transition: opacity 1.5s cubic-bezier(0.2, 0.8, 0.2, 1); }
  .brand-bg { position: absolute; inset: 0; background-size: cover; background-position: center; opacity: 0; transform: scale(1.04); transition: opacity 0.6s ease, transform 0.6s ease; }
  .brand-panel.is-bg .brand-bg { opacity: 0.96; transform: scale(1); transition: opacity 1.6s cubic-bezier(0.2, 0.8, 0.2, 1), transform 2.1s cubic-bezier(0.2, 0.8, 0.2, 1); }
  .brand-bg-overlay { position: absolute; inset: 0; background: radial-gradient(circle, rgba(0, 0, 0, 0.1) 0%, rgba(0, 0, 0, 0.62) 100%); opacity: 0; transition: opacity 1.3s ease; }
  .brand-panel.is-bg .brand-bg-overlay { opacity: 1; }
  .brand-content { position: relative; z-index: 3; height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; }
  
  /* ▼ 画面中央のロゴを白く反転させるフィルター ▼ */
  .brand-logo-img { width: 250px; height: auto; margin-bottom: 30px; filter: brightness(0) invert(1); }
  
  .brand-catch { font-size: clamp(2rem, 4vw, 3.5rem); margin-bottom: 30px; font-weight: 300; letter-spacing: 0.05em; text-shadow: 0 4px 20px rgba(0, 0, 0, 0.8); }
  .brand-desc p { font-size: clamp(1.4rem, 2.5vw, 2.2rem); font-weight: 300; color: #eee; margin-bottom: 15px; letter-spacing: 0.05em; text-shadow: 0 2px 10px rgba(0, 0, 0, 0.8); }
  .fade-base { opacity: 0; transition: opacity 0.3s ease, transform 0.3s ease; }
  .fade-up { transform: translateY(40px); }
  .fade-left { transform: translateX(-80px); }
  .text-anim-target.is-visible .fade-up, .text-anim-target.is-visible .fade-left { transform: translate(0); opacity: 1; transition: opacity 2.5s cubic-bezier(0.2, 0.8, 0.2, 1), transform 2.5s cubic-bezier(0.2, 0.8, 0.2, 1); }
  .text-anim-target.is-visible .anim-logo { transition-delay: 0.2s; }
  .text-anim-target.is-visible .anim-catch { transition-delay: 0.9s; }
  .text-anim-target.is-visible .anim-desc1 { transition-delay: 1.8s; }
  .text-anim-target.is-visible .anim-desc2 { transition-delay: 2.6s; }
  .text-anim-target.is-visible .anim-desc3 { transition-delay: 3.4s; }
  .section-header { text-align: center; margin-bottom: 60px; padding: 0 20px; }
  .section-header h2 { font-size: 14px; letter-spacing: 3px; text-transform: uppercase; color: #888; font-weight: 600; }
  
  .carousel-wrapper { position: relative; width: 100%; }
  .no-link-color { color: inherit !important; text-decoration: none !important; }
  .no-link-color:visited, .no-link-color:hover, .no-link-color:active { color: inherit !important; text-decoration: none !important; }

  .observer-card { 
    scroll-snap-align: center; flex: 0 0 40vw; height: 60vh; margin: 0 1.5vw;
    position: relative; border-radius: 8px; overflow: hidden; 
    transition: transform 0.6s ease, opacity 0.6s ease, box-shadow 0.6s ease; 
    opacity: 0.4; transform: scale(0.85);
    display: flex; flex-direction: column; 
    border: 1px solid rgba(255, 255, 255, 0.15); background-color: #111;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
  }
  .observer-card.is-center { opacity: 1; transform: scale(1); box-shadow: 0 20px 50px rgba(0, 0, 0, 0.8); z-index: 10; }

  .card-img-box { width: 100%; height: 66.66%; position: relative; overflow: hidden; }
  .card-bg { position: absolute; inset: 0; background-size: cover; background-position: center; transition: transform 0.8s ease; }
  .story-card.is-center:hover .card-bg { transform: scale(1.05); }

  .card-text-box { 
    width: 100%; height: 33.33%; padding: 20px 30px; 
    background: linear-gradient(to bottom, #050b1e, #02040a); 
    display: flex; flex-direction: column; justify-content: center;
    border-top: 1px solid rgba(255, 255, 255, 0.05); 
  }
  
  .card-meta { display: flex; align-items: center; gap: 10px; margin-bottom: 6px; font-size: 11px; font-weight: 600; letter-spacing: 1px; text-transform: uppercase; }
  .card-meta .category { color: #fff; border-bottom: 1px solid rgba(255, 255, 255, 0.4); padding-bottom: 4px; }
  .card-meta .country-name { color: #aaa; font-size: 10px; }
  .card-date { color: #888; font-size: 12px; margin-bottom: 10px; letter-spacing: 0.5px; }
  .card-title { font-size: clamp(1.1rem, 1.8vw, 1.6rem); font-weight: 400; line-height: 1.4; margin-bottom: 0; color: #fff; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

  .carousel-bottom-nav { display: flex; align-items: center; justify-content: center; gap: 30px; margin-top: 40px; }
  .carousel-dots-wrapper { display: flex; gap: 10px; }
  .c-dot { width: 6px; height: 6px; border-radius: 50%; background: rgba(255, 255, 255, 0.3); transition: transform 0.3s ease, background 0.3s ease; }
  .c-dot.active { background: #fff; transform: scale(1.5); }
  .carousel-nav-arrow { background: none; border: 1px solid rgba(255, 255, 255, 0.3); color: #fff; width: 44px; height: 44px; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 18px; transition: background 0.3s ease, transform 0.2s ease; }
  .carousel-nav-arrow:hover { background: rgba(255, 255, 255, 0.15); transform: scale(1.05); }

  .carousel-container { display: flex; overflow-x: auto; scroll-snap-type: x mandatory; scroll-behavior: smooth; padding-bottom: 20px; align-items: center; -ms-overflow-style: none; scrollbar-width: none; }
  .carousel-container::-webkit-scrollbar { display: none; }
  .carousel-spacer { flex: 0 0 calc(50vw - 20vw); }
  
  .lang-card { flex: 0 0 28vw; height: 50vh; display: flex; align-items: center; justify-content: center; border: 1px solid rgba(255, 255, 255, 0.05); }
  
  .lang-card::before {
    content: '';
    position: absolute;
    top: 15px; left: 15px; right: 15px; bottom: 15px;
    border: 1px solid rgba(255, 255, 255, 0.3);
    z-index: 5;
    pointer-events: none;
    transition: top 0.6s ease, left 0.6s ease, right 0.6s ease, bottom 0.6s ease, border-color 0.6s ease;
  }
  .lang-card.is-center::before {
    top: 25px; left: 25px; right: 25px; bottom: 25px;
    border-color: rgba(255, 255, 255, 0.6);
  }

  .lang-bg { position: absolute; inset: 0; opacity: 0.15; transition: opacity 0.4s ease; }
  .lang-card.is-center .lang-bg { opacity: 0.8; }
  .lang-content { position: relative; z-index: 2; width: 100%; height: 100%; padding: 40px; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; pointer-events: none; }
  .lang-name { font-size: clamp(1.5rem, 3vw, 2.5rem); font-weight: 300; letter-spacing: 0.05em; transition: transform 0.4s ease; color: #fff; }
  .lang-border { width: 0; height: 1px; background: #fff; margin-top: 20px; transition: width 0.6s cubic-bezier(0.2, 0.8, 0.2, 1); opacity: 0.5; }
  .lang-card.is-center .lang-border { width: 40px; }
  .lang-card.is-center:hover .lang-name { transform: scale(1.05); }
  
  .desktop-only-wrapper { display: block; }
  @media (max-width: 768px) { .desktop-only-wrapper { display: none; } }

  .top-footer { 
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    background: #393737; 
    border-top: 1px solid rgba(255, 255, 255, 0.05); 
    padding: 30px 50px; 
    box-sizing: border-box;
    z-index: 100;
  }
  .top-footer-inner { 
    display: flex; 
    align-items: center; 
    justify-content: space-between; 
    width: 100%; 
  }
  
  /* ▼ フッターのロゴを白く反転させるフィルター ▼ */
  .top-footer-logo img { 
    height: 48px; 
    width: auto; 
    opacity: 0.8; 
    transition: opacity 0.3s ease; 
    filter: brightness(0) invert(1);
  }
  .top-footer-logo img:hover { 
    opacity: 1; 
  }
  
  .top-footer-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end; 
    gap: 8px;
  }
  .top-footer-links { 
    display: flex; 
    gap: 24px; 
  }
  .top-footer-links a { 
    color: #a0aec0; 
    font-size: 11px; 
    text-decoration: none; 
    letter-spacing: 2px; 
    transition: color 0.3s ease; 
  }
  .top-footer-links a:hover { 
    color: #fff; 
  }
  .top-footer-copy { 
    color: #cbd5e1; 
    font-size: 10px; 
    letter-spacing: 1px; 
  }
</style>

<script is:inline>
  if ('scrollRestoration' in history) { history.scrollRestoration = 'manual'; }
  
  document.addEventListener('DOMContentLoaded', () => {
    document.addEventListener('contextmenu', event => event.preventDefault());

    const DESKTOP_BREAKPOINT = 768;
    const HERO_ANIM_MS = 1500;
    const WHEEL_THRESHOLD = 24;
    const BRAND_BG_DELAY_MS = 700;
    const BRAND_TEXT_DELAY_MS = 1350;
    const BRAND_UNLOCK_MS = 2300;
    const BRAND_HIDE_MS = 600; 

    const MASK_IN_MS  = 800;   
    const MASK_HOLD_MS = 50;
    const MASK_OUT_MS  = 800;
    const MASK_UNLOCK_MS = 100;

    let currentStep = 0;
    let isAnimating = false;

    const body = document.body;
    const desktopSequence = document.getElementById('desktop-sequence');
    const brandPanel = document.getElementById('brand-panel');
    const brandTextTarget = document.getElementById('brand-text-target');
    const transitionMask = document.getElementById('transition-mask');
    const screen5 = document.getElementById('screen-5');
    const screen6 = document.getElementById('screen-6');
    const dots = document.querySelectorAll('.scroll-indicator .dot');
    const leftPanels = document.querySelectorAll('.left-track .panel');
    const rightPanels = document.querySelectorAll('.right-track .panel');
    const l2 = document.querySelector('.left-track .p2');
    const l3 = document.querySelector('.left-track .p3');
    const r2 = document.querySelector('.right-track .p2');
    const r3 = document.querySelector('.right-track .p3');

    const menuOpenBtn = document.getElementById('menu-open');
    const menuCloseBtn = document.getElementById('menu-close');
    const sideMenu = document.getElementById('side-menu');

    menuOpenBtn?.addEventListener('click', () => {
      sideMenu?.classList.add('is-open');
    });

    menuCloseBtn?.addEventListener('click', () => {
      sideMenu?.classList.remove('is-open');
    });

    function isDesktop() { return window.innerWidth > DESKTOP_BREAKPOINT; }
    
    function setBodyLocked(locked) { 
      body.classList.toggle('is-locked', locked); 
    }
    
    function updateIndicator(index) { dots.forEach((dot, i) => { dot.classList.toggle('active', i === index); }); }
    function showMask() { transitionMask?.classList.add('is-visible'); }
    function hideMask() { transitionMask?.classList.remove('is-visible'); }
    function clearSectionVisibility() { screen5?.classList.remove('is-visible'); screen6?.classList.remove('is-visible'); }
    function showSection(step) { clearSectionVisibility(); if (step === 4) screen5?.classList.add('is-visible'); if (step === 5) screen6?.classList.add('is-visible'); }
    function resetBrandPanel() { brandPanel?.classList.remove('is-visible', 'is-night', 'is-bg'); brandTextTarget?.classList.remove('is-visible'); }
    
    function revealBrandImmediate() {
      desktopSequence?.classList.remove('is-hidden');
      resetBrandPanel();
      brandPanel?.classList.add('is-visible', 'is-night', 'is-bg');
      requestAnimationFrame(() => { brandTextTarget?.classList.add('is-visible'); });
    }

    function showBrandAnimated() {
      desktopSequence?.classList.remove('is-hidden');
      resetBrandPanel();
      brandPanel?.classList.add('is-visible', 'is-night');
      window.setTimeout(() => { brandPanel?.classList.add('is-bg'); }, BRAND_BG_DELAY_MS);
      window.setTimeout(() => { brandTextTarget?.classList.add('is-visible'); }, BRAND_TEXT_DELAY_MS);
      window.setTimeout(() => { isAnimating = false; }, BRAND_UNLOCK_MS);
    }

    function hideBrandAnimated() {
      brandTextTarget?.classList.remove('is-visible');
      brandPanel?.classList.remove('is-bg', 'is-night');
      window.setTimeout(() => { brandPanel?.classList.remove('is-visible'); isAnimating = false; }, BRAND_HIDE_MS);
    }

    function activateHeroSlide(index) {
      leftPanels.forEach((panel) => panel.classList.remove('is-active'));
      rightPanels.forEach((panel) => panel.classList.remove('is-active'));
      if (index === 0) { l2?.classList.remove('is-open'); r2?.classList.remove('is-open'); l3?.classList.remove('is-open'); r3?.classList.remove('is-open'); }
      else if (index === 1) { l2?.classList.add('is-open'); r2?.classList.add('is-open'); l3?.classList.remove('is-open'); r3?.classList.remove('is-open'); }
      else if (index === 2) { l2?.classList.add('is-open'); r2?.classList.add('is-open'); l3?.classList.add('is-open'); r3?.classList.add('is-open'); }
      window.setTimeout(() => { leftPanels[index]?.classList.add('is-active'); rightPanels[index]?.classList.add('is-active'); isAnimating = false; }, HERO_ANIM_MS);
    }

    function transitionBrandToStories() {
      showMask();
      window.setTimeout(() => { showSection(4); hideMask(); window.setTimeout(() => { isAnimating = false; }, MASK_UNLOCK_MS); }, MASK_IN_MS);
    }

    function transitionStoriesToBrand() {
      showMask();
      window.setTimeout(() => { clearSectionVisibility(); revealBrandImmediate(); hideMask(); window.setTimeout(() => { isAnimating = false; }, MASK_UNLOCK_MS); }, MASK_IN_MS);
    }

    function transitionBetweenSections(targetStep) {
      showMask();
      window.setTimeout(() => { showSection(targetStep); hideMask(); window.setTimeout(() => { isAnimating = false; }, MASK_UNLOCK_MS); }, MASK_IN_MS);
    }

    function transitionBrandToHero() {
      showMask();
      window.setTimeout(() => {
        resetBrandPanel(); 
        clearSectionVisibility();
        activateHeroSlide(2); 
        hideMask();
      }, MASK_IN_MS);
    }

    function goToStep(step) {
      if (!isDesktop()) return;
      if (step < 0 || step > 5) return;
      if (isAnimating) return;

      const previousStep = currentStep;
      currentStep = step;
      isAnimating = true;
      updateIndicator(step);

      if (step <= 2) {
        setBodyLocked(true);
        desktopSequence?.classList.remove('is-hidden');
        window.scrollTo({ top: 0, left: 0, behavior: 'auto' });
        if (previousStep === 3 && step === 2) { transitionBrandToHero(); return; }
        hideMask(); clearSectionVisibility(); resetBrandPanel(); activateHeroSlide(step); return;
      }

      if (step === 3) {
        setBodyLocked(true);
        window.scrollTo({ top: 0, left: 0, behavior: 'auto' });
        if (previousStep === 4) { transitionStoriesToBrand(); return; }
        hideMask(); clearSectionVisibility(); desktopSequence?.classList.remove('is-hidden');
        if (previousStep >= 5) { revealBrandImmediate(); window.setTimeout(() => { isAnimating = false; }, 200); } 
        else { showBrandAnimated(); }
        return;
      }

      if (step === 4 && previousStep === 3) { transitionBrandToStories(); return; }
      if (step === 5 && previousStep === 4) { transitionBetweenSections(5); return; }
      if (step === 4 && previousStep === 5) { transitionBetweenSections(4); return; }

      showSection(step);
      window.setTimeout(() => { isAnimating = false; }, 300);
    }

    function moveNext() { if (currentStep < 5) { goToStep(currentStep + 1); } }
    function movePrev() { if (currentStep > 0) { goToStep(currentStep - 1); } }

    window.addEventListener('wheel', (e) => {
      if (!isDesktop() || document.getElementById('side-menu')?.classList.contains('is-open')) return;
      e.preventDefault();
      if (isAnimating) return;
      if (e.deltaY > WHEEL_THRESHOLD) moveNext(); 
      else if (e.deltaY < -WHEEL_THRESHOLD) movePrev();
    }, { passive: false });

    function scrollCarouselByOneCard(container, direction) {
      const cards = container.querySelectorAll('.observer-card');
      if (cards.length === 0) return;
      const cardWidth = cards[0].offsetWidth;
      const style = window.getComputedStyle(cards[0]);
      const margin = parseFloat(style.marginLeft) + parseFloat(style.marginRight);
      const distance = (cardWidth + margin) * direction;
      container.scrollBy({ left: distance, behavior: 'smooth' });
    }

    const storyCards = document.querySelectorAll('#story-carousel .observer-card');
    const storyDots = document.querySelectorAll('#story-carousel-dots .c-dot');
    const storyPrevBtn = document.getElementById('story-carousel-prev');
    const storyNextBtn = document.getElementById('story-carousel-next');
    const storyContainer = document.getElementById('story-carousel');

    storyPrevBtn?.addEventListener('click', () => scrollCarouselByOneCard(storyContainer, -1));
    storyNextBtn?.addEventListener('click', () => scrollCarouselByOneCard(storyContainer, 1));

    const storyObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-center');
          const index = Array.from(storyCards).indexOf(entry.target);
          if(index !== -1 && storyDots[index]) {
            storyDots.forEach(d => d.classList.remove('active'));
            storyDots[index].classList.add('active');
          }
        } else {
          entry.target.classList.remove('is-center');
        }
      });
    }, { root: storyContainer, rootMargin: '0px -45% 0px -45%', threshold: 0 });
    storyCards.forEach(card => storyObserver.observe(card));

    const langCards = document.querySelectorAll('#lang-carousel .observer-card');
    const langDots = document.querySelectorAll('#lang-carousel-dots .c-dot');
    const langPrevBtn = document.getElementById('lang-carousel-prev');
    const langNextBtn = document.getElementById('lang-carousel-next');
    const langContainer = document.getElementById('lang-carousel');

    langPrevBtn?.addEventListener('click', () => scrollCarouselByOneCard(langContainer, -1));
    langNextBtn?.addEventListener('click', () => scrollCarouselByOneCard(langContainer, 1));

    const langObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-center');
          const index = Array.from(langCards).indexOf(entry.target);
          if(index !== -1 && langDots[index]) {
            langDots.forEach(d => d.classList.remove('active'));
            langDots[index].classList.add('active');
          }
        } else {
          entry.target.classList.remove('is-center');
        }
      });
    }, { root: langContainer, rootMargin: '0px -45% 0px -45%', threshold: 0 });
    langCards.forEach(card => langObserver.observe(card));

    setBodyLocked(true); desktopSequence?.classList.remove('is-hidden'); hideMask(); resetBrandPanel(); clearSectionVisibility(); updateIndicator(0);
    window.setTimeout(() => { leftPanels[0]?.classList.add('is-active'); rightPanels[0]?.classList.add('is-active'); }, 400);
  });
</script>
