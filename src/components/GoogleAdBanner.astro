---
// 1. 各言語ごとの「広告」という文字の翻訳辞書です
const adLabels = {
  ja: '広告',
  en: 'Advertisement',
  fr: 'Publicité',
  de: 'Anzeige',
  es: 'Anuncio',
  ru: 'Реклама',
  'zh-cn': '广告',
  'zh-tw': '廣告',
};

// 2. 今見ているページのURLから「何語のサイトか」を自動で読み取ります
const currentPath = Astro.url.pathname;
const pathParts = currentPath.split('/').filter(Boolean);
const lang = pathParts[0] || 'ja';

// 3. 読み取った言語に合わせて、表示する文字を決定します
const adText = adLabels[lang] || adLabels['en'];
---

<div class="ad-container">
  {/* 広告の上に小さく「広告」というラベルを表示します */}
  <span class="ad-label">{adText}</span>
  
  <div class="ad-wrapper">
    {/* ▼ 公開するまでは、このダミーの文字が表示されます */}
    <span class="dummy-text">Advertisement Space</span>

    {/* ▼▼▼ ここが、なるさん専用のIDが入った本物のGoogle AdSenseコードです ▼▼▼ 
      ※現在は、画面から見えなくなってしまうのを防ぐため、一時的に「コメントアウト」して動作を止めています。
      いざ審査が通って本番公開する時は、上のダミー文字を消し、
      以下のコードを囲んでいる {/* と */} を消すだけで、一瞬で本物の広告が出ます！
    */}
    {/*
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-2614349930540151" crossorigin="anonymous"></script>
    <ins class="adsbygoogle"
         style="display:block"
         data-ad-client="ca-pub-2614349930540151"
         data-ad-format="auto"
         data-full-width-responsive="true"></ins>
    <script is:inline>
         (adsbygoogle = window.adsbygoogle || []).push({});
    </script>
    */}
  </div>
</div>

<style>
  /* 広告枠のデザインとレイアウトのルールです */
  .ad-container {
    width: 100%;
    margin: 30px 0; /* 上下に30pxの余白を空けて、記事とくっつかないようにします */
    text-align: center; /* 広告を真ん中に配置します */
  }
  .ad-label {
    display: block;
    font-size: 11px;
    color: #999999;
    margin-bottom: 4px;
    letter-spacing: 0.5px;
  }
  
  /* ▼ サイドバーと同じ、グレーの点線の枠を表示する設定に書き換えました */
  .ad-wrapper {
    width: 100%;
    min-height: 120px; 
    background-color: #f0f0f0;
    border: 1px dashed #ccc;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .dummy-text {
    color: #999;
    font-size: 14px;
  }
</style>
