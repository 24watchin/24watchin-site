---
// 何語のサイトか自動で読み取ります
const currentPath = Astro.url.pathname;
const pathParts = currentPath.split('/').filter(Boolean);
const lang = pathParts[0] || 'ja';

// 各言語ごとの「広告」という文字の翻訳辞書です
const labels = {
  ja: '広告',
  en: 'Advertisement',
  fr: 'Publicité',
  de: 'Anzeige',
  es: 'Anuncio',
  ru: 'Реклама',
  'zh-cn': '广告',
  'zh-tw': '廣告',
};
const text = labels[lang] || labels['en'];
---

{/* ▼ 絶対にブロックされないように、クラス名（裏側の名前）を使わず、直接デザインを指定しました */}
<div style="width: 100%; margin: 30px 0; text-align: center;">
  
  <span style="display: block; font-size: 11px; color: #999999; margin-bottom: 4px; letter-spacing: 0.5px;">
    {text}
  </span>
  
  <div style="width: 100%; min-height: 120px; background-color: #f0f0f0; border: 1px dashed #ccc; border-radius: 8px; display: flex; align-items: center; justify-content: center;">
    
    {/* ▼ ダミーの文字も Advertisement（広告） という単語を避けて Placeholder（場所取り） に変更しました */}
    <span style="color: #999; font-size: 14px;">Placeholder Space</span>

    </div>
</div>
