---
// ランキング部品を読み込みます
import AccessRanking from './AccessRanking.astro';
// サイドバー用の広告部品を読み込みます
import SidebarAd from './SidebarAd.astro';
---

<aside class="sidebar-wrapper">
  {/* ランキング部品を一番上に配置します */}
  <AccessRanking />

  {/* 1つ目の広告（上部広告）をランキングの下に配置します */}
  <SidebarAd />

  {/* 2つ目の広告（中部の広告予定・今は隠しています） */}
  {/* <SidebarAd /> */}

  {/* 3つ目の広告（下部の広告予定・今は隠しています） */}
  {/* <SidebarAd /> */}
</aside>

<style>
  /* サイドバー全体の簡単なデザイン設定です */
  .sidebar-wrapper {
    display: flex;
    flex-direction: column;
    gap: 20px; /* 部品と部品の間に20pxの隙間を空けます */
  }
</style>
