---
// ランキング部品を読み込みます
import AccessRanking from './AccessRanking.astro';
// サイドバー用の広告部品を読み込みます
import SidebarAd from './SidebarAd.astro';
// ★新しく作った「編集部のおすすめ」部品を読み込みます
import EditorsPick from './EditorsPick.astro';
---

<aside class="sidebar-wrapper">
  {/* 1. 一番上にランキング部品を配置します */}
  <AccessRanking />

  {/* 2. ランキングの下に上部広告を配置します */}
  <SidebarAd />

  {/* 3. ★上部広告の下に「編集部のおすすめ」を配置します */}
  <EditorsPick />

  {/* 中部の広告（今は隠しています） */}
  {/* <SidebarAd /> */}

  {/* 下部の広告（今は隠しています） */}
  {/* <SidebarAd /> */}
</aside>

<style>
  /* サイドバー全体の簡単なデザイン設定です */
  .sidebar-wrapper {
    display: flex;
    flex-direction: column;
    gap: 20px; /* 部品と部品の間に20pxの隙間を空けます */
  }
</style>
