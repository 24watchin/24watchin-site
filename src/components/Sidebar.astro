---
// ランキング部品を読み込みます
import AccessRanking from './AccessRanking.astro';
// サイドバー用の広告部品を読み込みます
import SidebarAd from './SidebarAd.astro';
// 「編集部のおすすめ」部品を読み込みます
import EditorsPick from './EditorsPick.astro';
// ★今回新しく作った「天気パーツ」を読み込みます
import WeatherWidget from './WeatherWidget.astro';
---

<div class="sidebar-wrapper">
  {/* 1. 一番上に天気パーツを配置します */}
  <WeatherWidget />

  {/* 2. 天気の下にランキング部品を配置します */}
  <AccessRanking />

  {/* 3. ランキングの下に上部広告を配置します */}
  <SidebarAd />

  {/* 4. 上部広告の下に「編集部のおすすめ」を配置します */}
  <EditorsPick />
</div>

<style>
  /* サイドバー全体をピシッと整列させるための設定です */
  .sidebar-wrapper {
    display: flex;
    flex-direction: column;
    gap: 40px; /* パーツとパーツの間の隙間を均等に「40px」空けて、窮屈さをなくしました */
    width: 100%; /* サイドバーの枠（300px）いっぱいに広げます */
    margin: 0;
    padding: 0;
  }

  /* 中に入るパーツに対して、「自分勝手な幅やズレをなくして、強制的に100%に揃えなさい」と指示します */
  .sidebar-wrapper > :global(*) {
    width: 100% !important;
    max-width: 100% !important;
    margin-left: 0 !important;
    margin-right: 0 !important;
    box-sizing: border-box !important;
  }
</style>
