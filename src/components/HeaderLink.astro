---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'a'> & {
  activeMatch?: string;
};

const {
  href = '#',
  class: className,
  activeMatch,
  ...props
} = Astro.props;

const pathname = Astro.url.pathname;
const normalizedHref = typeof href === 'string' ? href.replace(/\/$/, '') || '/' : '/';
const normalizedPath = pathname.replace(/\/$/, '') || '/';
const matchBase = activeMatch ?? normalizedHref;

const isActive =
  normalizedPath === normalizedHref ||
  (matchBase !== '/' && normalizedPath.startsWith(matchBase));
---

<a href={href} class:list={['header-link', className, { active: isActive }]} {...props}>
  <slot />
</a>

<style>
  .header-link {
    display: inline-flex;
    align-items: center;
    height: 54px;
    padding: 0 18px;
    color: #fff;
    text-decoration: none;
    font-size: 15px;
    font-weight: 700;
    line-height: 1;
    border-bottom: 4px solid transparent;
    transition: border-color 0.2s ease;
    box-sizing: border-box;
    white-space: nowrap;
  }

  .header-link:hover,
  .header-link.active {
    border-bottom-color: #e8383d;
  }

  @media (max-width: 640px) {
    .header-link {
      height: 48px;
      padding: 0 14px;
      font-size: 14px;
    }
  }
</style>
