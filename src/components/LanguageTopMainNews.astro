---
const { posts = [], lang = 'ja' } = Astro.props;

// ▼ 言語ごとのトップ固定用タグの「頭文字」を設定します
const langPrefixMap: Record<string, string> = {
  ja: '日本語',
  en: '英語',
  'zh-cn': '簡体字',
  'zh-tw': '繁体字',
  es: 'スペイン語',
  fr: 'フランス語',
  de: 'ドイツ語',
  ru: 'ロシア語'
};
const prefix = langPrefixMap[lang] || '';

// 例：「日本語①」のようなタグを探すための条件を作成
const langTopRegex = new RegExp(`^${prefix}([①②③④⑤⑥⑦⑧⑨⑩])$`);

const topPostsMap = new Map();
const numMap: Record<string, number> = { '①':1, '②':2, '③':3, '④':4, '⑤':5, '⑥':6, '⑦':7, '⑧':8, '⑨':9, '⑩':10 };

// ▼ 1. まずは「言語トップ専用の固定タグ」がついている記事を抽出して配置します
posts.forEach((post: any) => {
  if (!post.labels) return;
  post.labels.forEach((label: string) => {
    const match = label.match(langTopRegex);
    if (match) {
      const num = numMap[match[1]];
      if (!topPostsMap.has(num)) {
        topPostsMap.set(num, post);
      }
    }
  });
});

// 番号順に並べて「空席詰め」を行う
let finalPosts = Array.from(topPostsMap.entries())
  .sort((a, b) => a[0] - b[0])
  .map(entry => entry[1]);

// ▼ 2. 足りない枠（10枠に満たない部分）は、固定タグがない最新記事で埋めます
const usedIds = new Set(finalPosts.map(p => p.id));
const normalPosts = posts.filter((p: any) => !usedIds.has(p.id));

while (finalPosts.length < 10 && normalPosts.length > 0) {
  finalPosts.push(normalPosts.shift());
}

const displayPosts = finalPosts.slice(0, 10);

// --- 補助関数 ---
const getImageUrl = (content: string) => {
  const match = (content || '').match(/<img[^>]+src="([^">]+)"/);
  return match ? match[1] : 'https://placehold.co/600x400/eeeeee/999999?text=No+Image';
};

const localeMap: Record<string, string> = {
  ja: 'ja-JP', en: 'en-US', 'zh-cn': 'zh-CN', 'zh-tw': 'zh-TW',
  es: 'es-ES', fr: 'fr-FR', de: 'de-DE', ru: 'ru-RU',
};
const formatPostTime = (dateString: string) => {
  if (!dateString) return '';
  try {
    return new Date(dateString).toLocaleString(localeMap[lang] || 'en-US', {
      month: 'numeric', day: 'numeric', hour: '2-digit', minute: '2-digit',
    });
  } catch { return ''; }
};

// ▼ 【重要】記事のタグから「その記事がどの国のものか」を推測し、正しいリンクを作る関数
const getCountryFromLabels = (labels: string[], currentLang: string) => {
  if (!labels) return 'jp'; // デフォルトはjp
  const searchPrefix = currentLang + '-';
  const targetLabel = labels.find((label: string) => label.startsWith(searchPrefix));
  if (targetLabel) {
    return targetLabel.replace(searchPrefix, ''); // 例：「ja-tw」から「tw」を取り出す
  }
  return 'jp'; 
};
---

<div class="top-news-container">
  <div class="main-column">
    {displayPosts.length > 0 && (
      <article class="hero-post">
        {/* ▼ 推測した「国コード」を使って、正しいURLに飛ばします */}
        <a href={`/${lang}/${getCountryFromLabels(displayPosts[0].labels, lang)}/news/${displayPosts[0].id}/`}>
          <div class="hero-image">
            <img src={getImageUrl(displayPosts[0].content)} alt={displayPosts[0].title} />
          </div>
          <div class="hero-text">
            <h2 class="hero-title">{displayPosts[0].title}</h2>
            {displayPosts[0].published && (
              <div class="hero-time">{formatPostTime(displayPosts[0].published)}</div>
            )}
          </div>
        </a>
      </article>
    )}

    <div class="sub-grid">
      {displayPosts.slice(1, 5).map((post) => (
        <article class="grid-item">
          <a href={`/${lang}/${getCountryFromLabels(post.labels, lang)}/news/${post.id}/`}>
            <div class="grid-image">
              <img src={getImageUrl(post.content)} alt={post.title} />
            </div>
            <div class="grid-text">
              <h3 class="grid-title">{post.title}</h3>
              {post.published && (
                <div class="grid-time">{formatPostTime(post.published)}</div>
              )}
            </div>
          </a>
        </article>
      ))}
    </div>
  </div>

  <div class="side-list-column">
    {displayPosts.slice(5, 10).map((post) => (
      <article class="list-item">
        <a href={`/${lang}/${getCountryFromLabels(post.labels, lang)}/news/${post.id}/`}>
          <h4 class="list-title">{post.title}</h4>
          {post.published && (
            <div class="list-time">{formatPostTime(post.published)}</div>
          )}
        </a>
      </article>
    ))}
  </div>
</div>

<style>
  /* 見た目は各国のメインニュース（MainNewsLayout）と完全に同じにしています */
  .top-news-container { display: grid; grid-template-columns: minmax(0, 1fr) 410px; gap: 24px; margin-bottom: 28px; align-items: start; }
  .main-column { min-width: 0; }
  .hero-post a { display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, 1.03fr); gap: 18px; text-decoration: none; color: #111111; margin-bottom: 24px; align-items: start; }
  .hero-image { aspect-ratio: 16 / 10; overflow: hidden; border-radius: 4px; }
  .hero-image img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .hero-title { font-size: 24px; line-height: 1.45; font-weight: 700; margin: 0; color: #111111; display: -webkit-box; -webkit-line-clamp: 5; -webkit-box-orient: vertical; overflow: hidden; }
  .hero-time { margin-top: 6px; font-size: 16px; line-height: 1.45; font-weight: 400; color: #8a8a8a; }
  .sub-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 18px 22px; border-top: 1px solid #e5e5e5; padding-top: 18px; }
  .grid-item a { display: flex; gap: 12px; text-decoration: none; color: #111111; align-items: flex-start; }
  .grid-image { width: 108px; height: 72px; flex-shrink: 0; overflow: hidden; border-radius: 4px; }
  .grid-image img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .grid-text { min-width: 0; display: flex; flex-direction: column; align-items: flex-start; }
  .grid-title { font-size: 16px; line-height: 1.45; font-weight: 700; margin: 0; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  .grid-time { margin-top: 4px; font-size: 16px; color: #8a8a8a; }
  .side-list-column { border-left: 1px solid #e5e5e5; padding-left: 18px; min-width: 0; }
  .list-item { border-bottom: 1px solid #e5e5e5; padding: 8px 0; }
  .list-item:first-child { padding-top: 0; }
  .list-item a { text-decoration: none; color: #111111; display: block; }
  .list-title { font-size: 16px; line-height: 1.45; font-weight: 700; margin: 0; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .list-time { margin-top: 4px; font-size: 16px; color: #8a8a8a; }
  .hero-post a:hover .hero-title, .grid-item a:hover .grid-title, .list-item a:hover .list-title { text-decoration: underline; text-decoration-color: #000000; text-underline-offset: 3px; }

  @media (max-width: 900px) {
    .top-news-container { grid-template-columns: 1fr; gap: 22px; }
    .side-list-column { border-left: none; padding-left: 0; border-top: 1px solid #e5e5e5; padding-top: 14px; }
  }
  @media (max-width: 600px) {
    .hero-post a { grid-template-columns: 1fr; }
    .sub-grid { grid-template-columns: 1fr; }
    .grid-image { width: 96px; height: 64px; }
  }
</style>
