---
// 関連記事：タイル形式（3列）＆ 多言語対応版
const { relatedPosts = [], lang = 'ja', country = 'jp' } = Astro.props;

const getImageUrl = (content) => {
  if (!content) return 'https://placehold.co/400x300/eeeeee/999999?text=No+Image';
  const match = (content || '').match(/<img[^>]+src="([^">]+)"/);
  return match ? match[1] : 'https://placehold.co/400x300/eeeeee/999999?text=No+Image';
};

// ▼ 多言語タイトル
const titleMap: Record<string, string> = {
  ja:      '関連記事',
  en:      'Related Articles',
  'zh-cn': '相关文章',
  'zh-tw': '相關文章',
  es:      'Artículos relacionados',
  fr:      'Articles connexes',
  de:      'Verwandte Artikel',
  ru:      'Похожие статьи',
};
const sectionTitle = titleMap[lang] || titleMap['en'];

// ▼ 「関連記事なし」メッセージも多言語化
const emptyMap: Record<string, string> = {
  ja:      '関連記事はまだありません。',
  en:      'No related articles yet.',
  'zh-cn': '暂无相关文章。',
  'zh-tw': '暫無相關文章。',
  es:      'No hay artículos relacionados aún.',
  fr:      'Aucun article connexe pour le moment.',
  de:      'Noch keine verwandten Artikel.',
  ru:      'Похожих статей пока нет.',
};
const emptyText = emptyMap[lang] || emptyMap['en'];
---

<div class="bottom-section">
  <h3 class="section-title">{sectionTitle}</h3>

  {relatedPosts.length > 0 ? (
    <div class="related-grid">
      {relatedPosts.map((rp) => (
        <a href={`/${lang}/${country}/news/${rp.id}/`} class="related-card">
          <div class="related-img-wrapper">
            <img src={getImageUrl(rp.content)} alt={rp.title} />
          </div>

          <div class="related-text">
            <h4>{rp.title}</h4>
            {rp.matchedKeywordLabels && rp.matchedKeywordLabels.length > 0 && (
              <div class="tag-row" aria-label="関連キーワード">
                {rp.matchedKeywordLabels.slice(0, 3).map((tag) => (
                  <span class="tag-chip">#{tag}</span>
                ))}
              </div>
            )}
          </div>
        </a>
      ))}
    </div>
  ) : (
    <p class="empty-text">{emptyText}</p>
  )}
</div>

<style>
  .bottom-section { margin-bottom: 50px; }
  /* ▼ EditorPicksと同じスタイル！テーマカラーの下線 */
  .section-title { font-size: 19px; color: #333; margin-bottom: 20px; border-bottom: 3px solid var(--theme-color, #872732); padding-bottom: 5px; display: inline-block; font-weight: bold; }
  .related-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 20px; }
  .related-card { text-decoration: none; color: #1a1a1a; display: block; }
  .related-card:hover .related-text h4 { text-decoration: underline; }
  .related-img-wrapper { aspect-ratio: 16 / 9; overflow: hidden; background: #eee; margin-bottom: 10px; border-radius: 6px; }
  .related-img-wrapper img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .related-text h4 { font-size: 14px; margin: 0; line-height: 1.5; color: #1a1a1a; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; font-weight: bold; }
  .tag-row { margin-top: 10px; display: flex; gap: 6px; flex-wrap: nowrap; overflow: hidden; }
  .tag-chip { display: inline-flex; align-items: center; padding: 2px 6px; background: #666; color: #fff; font-size: 10px; border-radius: 4px; }
  .empty-text { color: #666; font-size: 14px; }
  @media (max-width: 900px) { .related-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media (max-width: 640px) { .related-grid { grid-template-columns: 1fr; } }
</style>
