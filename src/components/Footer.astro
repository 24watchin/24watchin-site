---
// フッター（サイトの一番下の部分）の部品です。
---

<footer class="site-footer">
  <div class="footer-content">
    {/* 1列目：サイト情報とSNS */}
    <div class="footer-column">
      <div class="footer-logo">
        <span class="logo-icon">📰</span> NEWS
      </div>
      <p class="footer-desc">
        最新のニュースと情報をお届けする総合ニュースサイトです。
      </p>
      <div class="footer-sns">
        <span class="sns-label">公式SNS</span>
        <a href="#" class="sns-icon">X</a>
        <a href="#" class="sns-icon">f</a>
        <a href="#" class="sns-icon" style="font-size: 10px;">LINE</a>
        <a href="#" class="sns-icon">▶</a>
        <a href="#" class="sns-icon">📷</a>
      </div>
    </div>

    {/* 2列目：カテゴリー */}
    <div class="footer-column">
      <h3 class="footer-heading">カテゴリー</h3>
      <ul class="footer-links">
        {/* ★ トップページへのリンクを日本版（/jp/jp/）に修正しました！ */}
        <li><a href="/jp/jp/">トップ</a></li>
        <li><a href="#">テクノロジー</a></li>
        <li><a href="#">ビジネス</a></li>
        <li><a href="#">スポーツ</a></li>
      </ul>
    </div>

    {/* 3列目：情報 */}
    <div class="footer-column">
      <h3 class="footer-heading">情報</h3>
      <ul class="footer-links">
        <li><a href="#">会社概要</a></li>
        <li><a href="#">利用規約</a></li>
        <li><a href="#">プライバシーポリシー</a></li>
        <li><a href="#">お問い合わせ</a></li>
      </ul>
    </div>

    {/* 4列目：フォロー */}
    <div class="footer-column">
      <h3 class="footer-heading">フォロー</h3>
      <ul class="footer-links">
        <li><a href="#">Twitter</a></li>
        <li><a href="#">Facebook</a></li>
        <li><a href="#">Instagram</a></li>
        <li><a href="#">YouTube</a></li>
      </ul>
    </div>
  </div>

  {/* 一番下のコピーライト部分 */}
  <div class="footer-bottom">
    {/* ★ コピーライトを W-Studio Global Media Enterprises に更新しました！ */}
    <p>&copy; 2026 W-Studio Global Media Enterprises. All rights reserved.</p>
  </div>
</footer>

<style>
  /* フッター全体の背景色と文字色 */
  .site-footer { background-color: #111827; color: #ffffff; font-family: sans-serif; padding-top: 40px; }
  .footer-content { display: flex; justify-content: space-between; margin: 0 auto; padding: 0 20px 40px 20px; gap: 20px; }
  .footer-column { flex: 1; }
  .footer-logo { font-size: 20px; font-weight: bold; margin-bottom: 15px; display: flex; align-items: center; gap: 8px; }
  .logo-icon { color: #ef3332; }
  .footer-desc { font-size: 13px; color: #9ca3af; line-height: 1.6; margin-bottom: 20px; }
  .footer-sns { display: flex; align-items: center; gap: 10px; }
  .sns-label { font-size: 12px; font-weight: bold; margin-right: 5px; }
  .sns-icon { display: inline-flex; justify-content: center; align-items: center; width: 30px; height: 30px; border: 1px solid #ffffff; border-radius: 50%; color: #ffffff; text-decoration: none; font-size: 14px; font-weight: bold; }
  .footer-heading { font-size: 16px; font-weight: bold; margin-bottom: 15px; }
  .footer-links { list-style: none; padding: 0; margin: 0; }
  .footer-links li { margin-bottom: 10px; }
  .footer-links a { color: #9ca3af; text-decoration: none; font-size: 13px; }
  .footer-bottom { text-align: center; border-top: 1px solid #1f2937; padding: 20px 0; font-size: 12px; color: #6b7280; }
</style>
