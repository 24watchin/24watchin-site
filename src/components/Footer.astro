---
const currentPath = Astro.url.pathname;
const pathParts = currentPath.split('/').filter(Boolean);
const lang = pathParts[0] || 'ja';
const country = pathParts[1] || 'jp';

// SNSリンク（show: true で表示・false で非表示）
const snsLinks = [
  { label: 'X',         href: 'https://x.com/24watchin',       icon: 'x',         show: true  },
  { label: 'Facebook',  href: 'https://facebook.com/24watchin', icon: 'facebook',  show: true  },
  { label: 'LINE',      href: '#',                              icon: 'line',       show: false },
  { label: 'YouTube',   href: '#',                              icon: 'youtube',    show: false },
  { label: 'Instagram', href: '#',                              icon: 'instagram',  show: false },
];

// Informationリンク（言語で自動切り替え）
const infoMenus: Record<string, { label: string; href: string }[]> = {
  ja: [
    { label: 'About 24Watchin',          href: `/${lang}/about/` },
    { label: 'プライバシーポリシー',      href: `/${lang}/privacy/` },
    { label: '利用規約',                  href: `/${lang}/terms/` },
    { label: 'お問い合わせ',              href: `/${lang}/contact/` },
    { label: '訂正・修正ポリシー',        href: `/${lang}/corrections/` },
    { label: '著作権・転載・引用について', href: `/${lang}/copyright/` },
  ],
  en: [
    { label: 'About 24Watchin',    href: `/${lang}/about/` },
    { label: 'Privacy Policy',     href: `/${lang}/privacy/` },
    { label: 'Terms of Use',       href: `/${lang}/terms/` },
    { label: 'Contact',            href: `/${lang}/contact/` },
    { label: 'Corrections Policy', href: `/${lang}/corrections/` },
    { label: 'Copyright / Reuse',  href: `/${lang}/copyright/` },
  ],
  de: [
    { label: 'Über 24Watchin',        href: `/${lang}/about/` },
    { label: 'Datenschutzrichtlinie', href: `/${lang}/privacy/` },
    { label: 'Nutzungsbedingungen',   href: `/${lang}/terms/` },
    { label: 'Kontakt',               href: `/${lang}/contact/` },
    { label: 'Korrekturen',           href: `/${lang}/corrections/` },
    { label: 'Urheberrecht',          href: `/${lang}/copyright/` },
  ],
  fr: [
    { label: 'À propos de 24Watchin',        href: `/${lang}/about/` },
    { label: 'Politique de confidentialité', href: `/${lang}/privacy/` },
    { label: "Conditions d'utilisation",     href: `/${lang}/terms/` },
    { label: 'Contact',                      href: `/${lang}/contact/` },
    { label: 'Politique de corrections',     href: `/${lang}/corrections/` },
    { label: "Droits d'auteur",              href: `/${lang}/copyright/` },
  ],
  es: [
    { label: 'Acerca de 24Watchin',      href: `/${lang}/about/` },
    { label: 'Política de privacidad',   href: `/${lang}/privacy/` },
    { label: 'Términos de uso',          href: `/${lang}/terms/` },
    { label: 'Contacto',                 href: `/${lang}/contact/` },
    { label: 'Política de correcciones', href: `/${lang}/corrections/` },
    { label: 'Derechos de autor',        href: `/${lang}/copyright/` },
  ],
  ru: [
    { label: 'О 24Watchin',                 href: `/${lang}/about/` },
    { label: 'Политика конфиденциальности', href: `/${lang}/privacy/` },
    { label: 'Условия использования',       href: `/${lang}/terms/` },
    { label: 'Контакты',                    href: `/${lang}/contact/` },
    { label: 'Политика исправлений',        href: `/${lang}/corrections/` },
    { label: 'Авторские права',             href: `/${lang}/copyright/` },
  ],
  'zh-cn': [
    { label: '关于 24Watchin', href: `/${lang}/about/` },
    { label: '隐私政策',       href: `/${lang}/privacy/` },
    { label: '使用条款',       href: `/${lang}/terms/` },
    { label: '联系我们',       href: `/${lang}/contact/` },
    { label: '更正政策',       href: `/${lang}/corrections/` },
    { label: '版权声明',       href: `/${lang}/copyright/` },
  ],
  'zh-tw': [
    { label: '關於 24Watchin', href: `/${lang}/about/` },
    { label: '隱私政策',       href: `/${lang}/privacy/` },
    { label: '使用條款',       href: `/${lang}/terms/` },
    { label: '聯絡我們',       href: `/${lang}/contact/` },
    { label: '更正政策',       href: `/${lang}/corrections/` },
    { label: '版權聲明',       href: `/${lang}/copyright/` },
  ],
};

const currentMenu = infoMenus[lang] ?? infoMenus['en'];
const infoTitle = lang === 'ja' ? 'インフォメーション' : 'Information';

// Global Sites（地域別・現在の言語で自動リンク）
const globalRegions = [
  {
    name: lang === 'ja' ? 'アジア' : 'Asia',
    countries: [
      { label: lang === 'ja' ? '日本'         : 'Japan',       code: 'jp' },
      { label: lang === 'ja' ? '韓国'         : 'South Korea', code: 'kr' },
      { label: lang === 'ja' ? '中国'         : 'China',       code: 'cn' },
      { label: lang === 'ja' ? '台湾'         : 'Taiwan',      code: 'tw' },
      { label: lang === 'ja' ? 'タイ'         : 'Thailand',    code: 'th' },
      { label: lang === 'ja' ? 'シンガポール' : 'Singapore',   code: 'sg' },
      { label: lang === 'ja' ? 'インド'       : 'India',       code: 'in' },
    ],
  },
  {
    name: lang === 'ja' ? 'ヨーロッパ' : 'Europe',
    countries: [
      { label: lang === 'ja' ? 'ドイツ'   : 'Germany', code: 'de' },
      { label: lang === 'ja' ? 'フランス' : 'France',  code: 'fr' },
      { label: lang === 'ja' ? 'イギリス' : 'UK',      code: 'gb' },
      { label: lang === 'ja' ? 'イタリア' : 'Italy',   code: 'it' },
      { label: lang === 'ja' ? 'スペイン' : 'Spain',   code: 'es' },
    ],
  },
  {
    name: lang === 'ja' ? 'アメリカ大陸' : 'Americas',
    countries: [
      { label: lang === 'ja' ? 'アメリカ' : 'USA',    code: 'us' },
      { label: lang === 'ja' ? 'カナダ'   : 'Canada', code: 'ca' },
      { label: lang === 'ja' ? 'ブラジル' : 'Brazil', code: 'br' },
      { label: lang === 'ja' ? 'メキシコ' : 'Mexico', code: 'mx' },
    ],
  },
  {
    name: lang === 'ja' ? '中東・アフリカ' : 'Middle East & Africa',
    countries: [
      { label: 'UAE',                                              code: 'ae' },
      { label: lang === 'ja' ? 'サウジアラビア' : 'Saudi Arabia', code: 'sa' },
      { label: lang === 'ja' ? '南アフリカ'     : 'South Africa', code: 'za' },
    ],
  },
  {
    name: lang === 'ja' ? 'オセアニア' : 'Oceania',
    countries: [
      { label: lang === 'ja' ? 'オーストラリア'   : 'Australia',   code: 'au' },
      { label: lang === 'ja' ? 'ニュージーランド' : 'New Zealand', code: 'nz' },
    ],
  },
];

const globalTitle = lang === 'ja' ? 'グローバルサイト' : 'Global Sites';
const seeAllLabel = lang === 'ja' ? '全サイトを見る →' : 'See all sites →';
const seeAllHref  = `/${lang}/`;
---

<footer class="site-footer">
  <div class="footer-inner">

    <!-- ロゴ＋SNS -->
    <div class="top-row">
      <a href={`/${lang}/${country}/`} class="footer-logo">
        <img src="/images/logo-24watchin-white.png" alt="24Watchin" height="36" />
      </a>
      <div class="sns-row">
        {snsLinks.filter(s => s.show).map(s => (
          <a href={s.href} class="sns-btn" aria-label={s.label} target="_blank" rel="noopener noreferrer">
            {s.icon === 'x'         && <span>𝕏</span>}
            {s.icon === 'facebook'  && <span>f</span>}
            {s.icon === 'line'      && <span>L</span>}
            {s.icon === 'youtube'   && <span>▶</span>}
            {s.icon === 'instagram' && <span>ig</span>}
          </a>
        ))}
      </div>
    </div>

    <hr class="divider" />

    <!-- Global Sites -->
    <p class="footer-heading">{globalTitle}</p>
    <div class="accordion-list">
      {globalRegions.map((region, i) => (
        <div class="region-group">
          <button class="region-header" aria-expanded="false" data-index={i}>
            <span class="region-name">{region.name}</span>
            <span class="region-arrow">▼</span>
          </button>
          <div class="region-body" id={`region-${i}`}>
            {region.countries.map(c => (
              <a href={`/${lang}/${c.code}/`} class="country-link">{c.label}</a>
            ))}
          </div>
        </div>
      ))}
    </div>
    <a href={seeAllHref} class="see-all">{seeAllLabel}</a>

    <!-- Information -->
    <div class="info-section">
      <p class="footer-heading">{infoTitle}</p>
      <div class="info-links">
        {currentMenu.map(item => (
          <a href={item.href} class="info-link">{item.label}</a>
        ))}
      </div>
    </div>

  </div>

  <!-- コピーライト -->
  <div class="footer-bottom">
    <p>24Watchin.com に掲載している記事、写真、画像、図表、その他のコンテンツの無断転載・無断利用を禁止します。</p>
    <p>著作権は The Dexent Media Enterprises または正当な権利者に帰属します。</p>
    <p class="copyright-year">&copy; 2026 The Dexent Media Enterprises. All Rights Reserved.</p>
  </div>
</footer>

<script>
  document.querySelectorAll('.region-header').forEach(btn => {
    btn.addEventListener('click', () => {
      const index = btn.getAttribute('data-index');
      const body  = document.getElementById(`region-${index}`);
      const arrow = btn.querySelector('.region-arrow') as HTMLElement;
      const isOpen = body!.classList.contains('open');
      body!.classList.toggle('open', !isOpen);
      btn.setAttribute('aria-expanded', String(!isOpen));
      arrow.style.transform = isOpen ? '' : 'rotate(180deg)';
      btn.classList.toggle('open', !isOpen);
    });
  });
</script>

<style>
  .site-footer {
    background-color: #393737;
    color: #f3f4f6;
    font-family: sans-serif;
    margin-top: 60px;
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 36px 24px 32px;
  }

  /* ロゴ＋SNS */
  .top-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 24px;
  }
  .footer-logo img { height: 36px; width: auto; display: block; filter: brightness(0) invert(1); }
  .sns-row { display: flex; gap: 10px; }
  .sns-btn {
    width: 34px; height: 34px;
    border-radius: 50%;
    background: rgba(255,255,255,0.1);
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-size: 13px; text-decoration: none;
    transition: background 0.2s;
  }
  .sns-btn:hover { background: #872732; }

  .divider { border: none; border-top: 1px solid rgba(255,255,255,0.1); margin: 0 0 24px; }

  /* 見出し */
  .footer-heading {
    font-size: 13px; font-weight: bold; color: #fff;
    margin: 0 0 14px;
    padding-bottom: 8px;
    border-bottom: 2px solid #872732;
    display: inline-block;
  }

  /* アコーディオン */
  .accordion-list { display: flex; flex-direction: column; gap: 4px; }
  .region-group { border-radius: 8px; overflow: hidden; }
  .region-header {
    width: 100%;
    display: flex; justify-content: space-between; align-items: center;
    padding: 9px 13px;
    background: rgba(255,255,255,0.07);
    border: none; border-radius: 8px;
    color: #f3f4f6; cursor: pointer;
    transition: background 0.2s;
  }
  .region-header:hover { background: rgba(255,255,255,0.13); }
  .region-header.open  { border-radius: 8px 8px 0 0; background: rgba(135,39,50,0.35); }
  .region-name  { font-size: 12px; font-weight: bold; }
  .region-arrow { font-size: 9px; color: #9ca3af; transition: transform 0.25s; }

  /* ← 修正ポイント！ */
  .region-body {
    display: none;
    flex-wrap: wrap;
    gap: 6px;
    background: rgba(255,255,255,0.04);
    border-radius: 0 0 8px 8px;
    padding: 10px 13px;
  }
  .region-body.open {
    display: flex;
  }

  .country-link {
    font-size: 11px; color: #d1d5db; text-decoration: none;
    padding: 3px 10px; border-radius: 20px;
    background: rgba(255,255,255,0.08);
    transition: all 0.2s; white-space: nowrap;
  }
  .country-link:hover { background: #872732; color: #fff; }

  .see-all {
    display: inline-block; margin-top: 10px;
    font-size: 11px; color: #9ca3af; text-decoration: none;
    border-bottom: 1px dashed #9ca3af;
    transition: color 0.2s;
  }
  .see-all:hover { color: #fff; }

  /* Information */
  .info-section { margin-top: 28px; padding-top: 24px; border-top: 1px solid rgba(255,255,255,0.1); }
  .info-links { display: flex; flex-wrap: wrap; gap: 8px 24px; }
  .info-link {
    font-size: 12px; color: #d1d5db; text-decoration: none;
    white-space: nowrap; transition: color 0.2s;
  }
  .info-link:hover { color: #fff; text-decoration: underline; }

  /* コピーライト */
  .footer-bottom {
    background-color: #2b2a2a;
    padding: 24px 20px;
    text-align: center;
  }
  .footer-bottom p { margin: 0 0 6px; font-size: 12px; color: #9ca3af; line-height: 1.6; }
  .copyright-year { margin-top: 12px !important; font-size: 13px !important; color: #d1d5db !important; }

  /* スマホ対応 */
  @media (max-width: 600px) {
    .top-row { flex-direction: column; align-items: flex-start; }
    .info-links { gap: 10px 16px; }
  }
</style>
