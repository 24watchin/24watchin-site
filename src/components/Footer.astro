---
import { categoryLabelMap } from '../lib/categoryLabels.ts';
import { langCountryPairs } from '../lib/siteRoutes.ts';
// マスターリストを読み込み
import { getCountryLabel } from '../lib/countryData.ts';

const currentPath = Astro.url.pathname;
const pathParts = currentPath.split('/').filter(Boolean);

// 1. 言語の判定（404などのエラー対策）
const supportedLangs = ['ja', 'en', 'zh-cn', 'zh-tw', 'es', 'fr', 'de', 'ru'];
const lang = supportedLangs.includes(pathParts[0]) ? pathParts[0] : 'ja';

// 2. 国コードの判定（'info'を国として誤認するのを防ぐ）
const country = (pathParts.length > 1 && pathParts[1] !== 'info') ? pathParts[1] : '';

// 3. リンク用のベースURLを組み立てる
const infoBasePath = country ? `/${lang}/${country}/info` : `/${lang}/info`;
const homePath = country ? `/${lang}/${country}/` : `/${lang}/`;

let { allPosts = [] } = Astro.props;
const cacheKey = 'bloggerPostsCache_' + lang;

if ((!allPosts || allPosts.length === 0) && globalThis[cacheKey]) {
  allPosts = await globalThis[cacheKey];
}
if (!Array.isArray(allPosts)) { allPosts = []; }

const localeKeyMap: Record<string, string> = { ja: 'jp', en: 'en', 'zh-cn': 'zh-cn', 'zh-tw': 'zh-tw', es: 'es', de: 'de', fr: 'fr', ru: 'ru' };
const themeColor = categoryLabelMap[localeKeyMap[lang] || 'jp']?.themeColor || '#872732';

// SNSアイコン用のホバー色（丸い背景の色になります）
const snsColorMap: Record<string, string> = {
  ja: '#872732',
  en: '#001580',
  'zh-cn': '#0e7c7b',
  'zh-tw': '#b33224',
  es: '#b38000',
  fr: '#3d3d99',
  de: '#006600',
  ru: '#500d80',
};
const snsHoverColor = snsColorMap[lang] || '#872732';

// 各言語用のアカウントの末尾の文字を定義（ロシア語と簡体字は除外）
const snsSuffixMap: Record<string, string> = {
  ja: 'ja',
  en: 'en',
  'zh-tw': 'tw',
  es: 'es',
  fr: 'fr',
  de: 'de',
};
const snsSuffix = snsSuffixMap[lang];

const globalRegionsRaw = [
  { key: 'asia',     countries: ['jp','tw','kr','cn','th','sg','in','hk','vn','my'] },
  { key: 'europe',   countries: ['de','fr','gb','it','es','nl'] },
  { key: 'americas', countries: ['us','ca','br','mx','ar'] },
  { key: 'mideast',  countries: ['ae','sa','za','eg'] },
  { key: 'oceania',  countries: ['au','nz'] },
];

const regionNames: Record<string, Record<string, string>> = {
  asia:     { ja: 'アジア', en: 'Asia', 'zh-cn': '亚洲', 'zh-tw': '亞洲', es: 'Asia', fr: 'Asie', de: 'Asien', ru: 'Азия' },
  europe:   { ja: 'ヨーロッパ', en: 'Europe', 'zh-cn': '欧洲', 'zh-tw': '歐洲', es: 'Europa', fr: 'Europe', de: 'Europa', ru: 'Европа' },
  americas: { ja: '南北アメリカ', en: 'Americas', 'zh-cn': '美洲', 'zh-tw': '美洲', es: 'Américas', fr: 'Amériques', de: 'Amerika', ru: 'Америка' },
  mideast:  { ja: '中東・アフリカ', en: 'Middle East & Africa', 'zh-cn': '中东与非洲', 'zh-tw': '中東與非洲', es: 'Oriente Medio y África', fr: 'Moyen-Orient & Afrique', de: 'Nahost & Afrika', ru: 'Ближний Восток и Африка' },
  oceania:  { ja: 'オセアニア', en: 'Oceania', 'zh-cn': '大洋洲', 'zh-tw': '大洋洲', es: 'Oceanía', fr: 'Océanie', de: 'Ozeanien', ru: 'Океания' },
};

const globalRegions = globalRegionsRaw.map(region => {
  const activeCountries = region.countries
    .filter(code => allPosts.some(p => p.labels?.includes(lang + '-' + code)))
    .map(code => {
      let label = getCountryLabel(code, lang);
      if (lang === 'ja' && code === 'jp') { label = '日本'; }
      return { code, label };
    });
  return {
    name: regionNames[region.key]?.[lang] || regionNames[region.key]?.['en'] || region.key,
    countries: activeCountries,
  };
}).filter(region => region.countries.length > 0);

// フランス語などの記号(')がエラーにならないように整理・修正済み
const infoMenus: Record<string, { label: string; href: string }[]> = {
  ja: [ { label: 'About 24Watchin', href: `${infoBasePath}/about/` }, { label: 'プライバシーポリシー', href: `${infoBasePath}/privacy/` }, { label: '利用規約', href: `${infoBasePath}/terms/` }, { label: 'お問い合わせ', href: `${infoBasePath}/contact/` }, { label: '訂正・修正ポリシー', href: `${infoBasePath}/corrections/` }, { label: '著作権・転載・引用について', href: `${infoBasePath}/copyright/` }, ],
  en: [ { label: 'About 24Watchin', href: `${infoBasePath}/about/` }, { label: 'Privacy Policy', href: `${infoBasePath}/privacy/` }, { label: 'Terms of Use', href: `${infoBasePath}/terms/` }, { label: 'Contact', href: `${infoBasePath}/contact/` }, { label: 'Corrections Policy', href: `${infoBasePath}/corrections/` }, { label: 'Copyright / Reuse', href: `${infoBasePath}/copyright/` }, ],
  'zh-cn': [ { label: '关于 24Watchin', href: `${infoBasePath}/about/` }, { label: '隐私政策', href: `${infoBasePath}/privacy/` }, { label: '使用条款', href: `${infoBasePath}/terms/` }, { label: '联系我们', href: `${infoBasePath}/contact/` }, { label: '更正政策', href: `${infoBasePath}/corrections/` }, { label: '版权声明', href: `${infoBasePath}/copyright/` } ],
  'zh-tw': [ { label: '關於 24Watchin', href: `${infoBasePath}/about/` }, { label: '隱私政策', href: `${infoBasePath}/privacy/` }, { label: '使用條款', href: `${infoBasePath}/terms/` }, { label: '聯絡我們', href: `${infoBasePath}/contact/` }, { label: '更正政策', href: `${infoBasePath}/corrections/` }, { label: '版權聲明', href: `${infoBasePath}/copyright/` } ],
  es: [ { label: 'Acerca de 24Watchin', href: `${infoBasePath}/about/` }, { label: 'Política de privacidad', href: `${infoBasePath}/privacy/` }, { label: 'Términos de uso', href: `${infoBasePath}/terms/` }, { label: 'Contacto', href: `${infoBasePath}/contact/` }, { label: 'Política de correcciones', href: `${infoBasePath}/corrections/` }, { label: 'Derechos de autor', href: `${infoBasePath}/copyright/` } ],
  fr: [ { label: 'À propos de 24Watchin', href: `${infoBasePath}/about/` }, { label: 'Politique de confidentialité', href: `${infoBasePath}/privacy/` }, { label: "Conditions d'utilisation", href: `${infoBasePath}/terms/` }, { label: 'Contact', href: `${infoBasePath}/contact/` }, { label: 'Politique de corrections', href: `${infoBasePath}/corrections/` }, { label: "Droits d'auteur", href: `${infoBasePath}/copyright/` } ],
  de: [ { label: 'Über 24Watchin', href: `${infoBasePath}/about/` }, { label: 'Datenschutzrichtlinie', href: `${infoBasePath}/privacy/` }, { label: 'Nutzungsbedingungen', href: `${infoBasePath}/terms/` }, { label: 'Kontakt', href: `${infoBasePath}/contact/` }, { label: 'Korrekturrichtlinie', href: `${infoBasePath}/corrections/` }, { label: 'Urheberrecht', href: `${infoBasePath}/copyright/` } ],
  ru: [ { label: 'О 24Watchin', href: `${infoBasePath}/about/` }, { label: 'Политика конфиденциальности', href: `${infoBasePath}/privacy/` }, { label: 'Условия использования', href: `${infoBasePath}/terms/` }, { label: 'Контакты', href: `${infoBasePath}/contact/` }, { label: 'Политика исправлений', href: `${infoBasePath}/corrections/` }, { label: 'Авторские права', href: `${infoBasePath}/copyright/` } ],
};

const currentMenu = infoMenus[lang] || infoMenus['en'];

const footerTextMap = {
  ja: { notice1: '24Watchin.com に掲載している記事、写真、画像、図表、その他のコンテンツの無断転載・無断利用を禁止します。', notice2: '著作権は The Dexent Media Enterprises または正当な権利者に帰属します。', copyright: '© 2026 The Dexent Media Enterprises. All Rights Reserved.' },
  en: { notice1: 'Unauthorized reproduction or use of any articles, photos, images, charts, or other content on 24Watchin.com is prohibited.', notice2: 'Copyright belongs to The Dexent Media Enterprises or respective rights holders.', copyright: '© 2026 The Dexent Media Enterprises. All Rights Reserved.' },
  'zh-cn': { notice1: '未经授权，禁止转载或使用24Watchin.com上的任何文章、照片、图像、图表或其他内容。', notice2: '版权归The Dexent Media Enterprises或相关权利持有人所有。', copyright: '© 2026 The Dexent Media Enterprises. 保留所有权利。' },
  'zh-tw': { notice1: '未經授權，禁止轉載或使用24Watchin.com上的任何文章、照片、圖像、圖表或其他內容。', notice2: '版權歸The Dexent Media Enterprises或相關權利持有人所有。', copyright: '© 2026 The Dexent Media Enterprises. 保留所有權利。' },
  es: { notice1: 'Queda prohibida la reproducción o el uso no autorizado de artículos, fotos, imágenes, gráficos u otros contenidos de 24Watchin.com.', notice2: 'Los derechos de autor pertenecen a The Dexent Media Enterprises o a los respectivos titulares de derechos.', copyright: '© 2026 The Dexent Media Enterprises. Todos los derechos reservados.' },
  fr: { notice1: 'Toute reproduction ou utilisation non autorisée des articles, photos, images, graphiques ou autres contenus de 24Watchin.com est interdite.', notice2: 'Les droits d\'auteur appartiennent à The Dexent Media Enterprises ou aux détenteurs de droits respectifs.', copyright: '© 2026 The Dexent Media Enterprises. Tous droits réservés.' },
  de: { notice1: 'Die unerlaubte Vervielfältigung oder Nutzung von Artikeln, Fotos, Bildern, Grafiken oder anderen Inhalten auf 24Watchin.com ist untersagt.', notice2: 'Das Urheberrecht liegt bei The Dexent Media Enterprises oder den jeweiligen Rechteinhabern.', copyright: '© 2026 The Dexent Media Enterprises. Alle Rechte vorbehalten.' },
  ru: { notice1: 'Несанкционированное воспроизведение или использование статей, фотографий, изображений, графиков или другого контента на 24Watchin.com запрещено.', notice2: 'Авторские права принадлежат The Dexent Media Enterprises или соответствующим правообладателям.', copyright: '© 2026 The Dexent Media Enterprises. Все права защищены.' },
};
const footerText = footerTextMap[lang] || footerTextMap['en'];
---

<footer class="site-footer" style={`--theme-color:${themeColor}; --sns-hover-color:${snsHoverColor};`}>
  <div class="footer-inner">
    <div class="top-row">
      <a href={homePath} class="footer-logo"><img src="/images/logo-24watchin-white.png" alt="24Watchin" /></a>
      
      {snsSuffix && (
        <div class="sns-links">
          <a href={`https://x.com/24watchin_${snsSuffix}`} target="_blank" rel="noopener noreferrer" class="sns-icon" aria-label="X (Twitter)">
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"/>
            </svg>
          </a>
          <a href={`https://www.facebook.com/24watchin.${snsSuffix}/`} target="_blank" rel="noopener noreferrer" class="sns-icon" aria-label="Facebook">
            {/* ▼ 修正1：Facebook専用のクラス（fb-svg）を追加しました */}
            <svg viewBox="0 0 24 24" fill="currentColor" class="fb-svg">
              <path d="M14 13.5h2.5l1-4H14v-2c0-1.03 0-2 2-2h1.5V2.14c-.326-.043-1.557-.14-2.857-.14C11.928 2 10 3.657 10 6.7v2.8H7v4h3V22h4v-8.5z"/>
            </svg>
          </a>
        </div>
      )}

    </div>
    <hr class="divider" />
    <div class="accordion-list">
      {globalRegions.map((region, i) => (
        <div class="region-group">
          <button class="region-header" data-index={i}><span class="region-name">{region.name}</span><span>▼</span></button>
          <div class="region-body" id={'footer-region-' + i}>
            {region.countries.map(c => <a href={`/${lang}/${c.code}/`} class="country-link">{c.label}</a>)}
          </div>
        </div>
      ))}
    </div>
    <div class="info-section">
      <div class="info-links">{(currentMenu || []).map(item => <a href={item.href} class="info-link">{item.label}</a>)}</div>
    </div>
  </div>
  <div class="footer-bottom">
    <p>{footerText.notice1}</p>
    <p>{footerText.notice2}</p>
    <p class="copyright-year">{footerText.copyright}</p>
  </div>
</footer>

<style>
  .site-footer { background-color: #393737; color: #f3f4f6; margin-top: 60px; }
  .footer-inner { max-width: 1100px; margin: 0 auto; padding: 36px 24px; }
  .top-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; }
  .footer-logo img { height: 48px; width: auto; filter: brightness(0) invert(1); }
  
  .sns-links { display: flex; gap: 14px; align-items: center; }
  
  .sns-icon {
    width: 38px; height: 38px;
    border-radius: 50%;
    background-color: rgba(255,255,255,0.1);
    display: flex; align-items: center; justify-content: center;
    color: #fff;
    transition: background-color 0.3s ease;
    text-decoration: none;
  }
  
  .sns-icon svg { width: 18px; height: 18px; }

  /* ▼ 修正2：Facebookの「f」アイコンのみ、1.4倍に拡大してバランスを取ります */
  .sns-icon .fb-svg {
    transform: scale(1.4);
  }

  .sns-icon:hover {
    background-color: var(--sns-hover-color);
  }
  
  .divider { border: none; border-top: 1px solid rgba(255,255,255,0.12); margin-bottom: 24px; }
  .accordion-list { display: flex; flex-direction: column; gap: 6px; }
  .region-group { border-radius: 8px; overflow: hidden; }
  
  .region-header { font-size: 16px; width: 100%; display: flex; justify-content: space-between; padding: 12px 16px; background: rgba(255,255,255,0.07); border: none; color: #fff; cursor: pointer; }
  .region-body { display: none; flex-wrap: wrap; gap: 8px; padding: 14px; background: rgba(255,255,255,0.05); }
  .region-body.open { display: flex; }
  
  .country-link { font-size: 13px; color: #d1d5db; padding: 5px 12px; border-radius: 20px; background: rgba(255,255,255,0.08); text-decoration: none; }
  
  .info-section { margin-top: 32px; padding-top: 24px; border-top: 1px solid rgba(255,255,255,0.12); }
  .info-links { display: flex; flex-wrap: wrap; gap: 12px 28px; }
  
  .info-link { font-size: 14px; color: #d1d5db; text-decoration: none; }
  
  .footer-bottom { background-color: #2b2a2a; padding: 32px 20px; text-align: center; }
  
  .footer-bottom p { margin: 0 0 8px; font-size: 13px; color: #9ca3af; }
</style>

<script is:inline>
  document.querySelectorAll('.region-header').forEach(btn => btn.addEventListener('click', () => {
    const body = document.getElementById('footer-region-' + btn.dataset.index);
    body.classList.toggle('open');
  }));
</script>
