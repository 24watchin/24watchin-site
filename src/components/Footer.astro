---

<footer class="site-footer" style={footerStyle}>
  <div class="footer-inner">
    <div class="top-row">
      <a href={'/' + lang + '/' + country + '/'} class="footer-logo">
        <img src="/images/logo-24watchin-white.png" alt="24Watchin" />
      </a>
      <div class="sns-row">
        {snsLinks.filter(s => s.show).map(s => (
          <a href={s.href} class="sns-btn" aria-label={s.label} target="_blank" rel="noopener noreferrer">
            {s.icon === 'x' && <span class="sns-icon">𝕏</span>}
            {s.icon === 'facebook' && <span class="sns-icon">f</span>}
          </a>
        ))}
      </div>
    </div>

    <hr class="divider" />

    {globalRegions.length > 0 && (
      <>
        <p class="footer-heading">{globalTitle}</p>
        <div class="accordion-list">
          {globalRegions.map((region, i) => (
            <div class="region-group">
              <button class="region-header" aria-expanded="false" data-index={i}>
                <span class="region-name">{region.name}</span>
                <span class="region-arrow">▼</span>
              </button>
              <div class="region-body" id={'footer-region-' + i}>
                {region.countries.map(c => (
                  <a href={'/' + lang + '/' + c.code + '/'} class="country-link">{c.label}</a>
                ))}
              </div>
            </div>
          ))}
        </div>
      </>
    )}

    <div class="info-section">
      <p class="footer-heading">{infoTitle}</p>
      <div class="info-links">
        {currentMenu.map(item => (
          <a href={item.href} class="info-link">{item.label}</a>
        ))}
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <p>{footerText.notice1}</p>
    <p>{footerText.notice2}</p>
    <p class="copyright-year">{footerText.copyright}</p>
  </div>
</footer>

<script is:inline>
  document.querySelectorAll('.region-header').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var index = btn.getAttribute('data-index');
      var body = document.getElementById('footer-region-' + index);
      var arrow = btn.querySelector('.region-arrow');
      if (body) {
        var isOpen = body.classList.contains('open');
        body.classList.toggle('open', !isOpen);
        btn.setAttribute('aria-expanded', String(!isOpen));
        if (arrow instanceof HTMLElement) {
          arrow.style.transform = isOpen ? '' : 'rotate(180deg)';
        }
        btn.classList.toggle('open', !isOpen);
      }
    });
  });
</script>

<style>
  .site-footer { background-color: #393737; color: #f3f4f6; font-family: sans-serif; margin-top: 60px; }
  .footer-inner { max-width: 1100px; margin: 0 auto; padding: 36px 24px 32px; }
  .top-row { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px; margin-bottom: 24px; }
  .footer-logo img { height: 48px; width: auto; display: block; filter: brightness(0) invert(1); }
  .sns-row { display: flex; gap: 14px; }
  .sns-btn { width: 42px; height: 42px; border-radius: 50%; background: rgba(255,255,255,0.12); display: flex; align-items: center; justify-content: center; text-decoration: none; transition: background 0.2s; }
  .sns-icon { font-size: 22px; color: #fff; font-weight: bold; line-height: 1; }
  .sns-btn:hover { background: var(--theme-color); }
  .divider { border: none; border-top: 1px solid rgba(255,255,255,0.12); margin: 0 0 24px; }
  .footer-heading { font-size: 13px; font-weight: bold; color: #fff; margin: 0 0 14px; padding-bottom: 8px; border-bottom: 2px solid var(--theme-color); display: inline-block; }
