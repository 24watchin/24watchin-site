---
// フッター（サイトの一番下の部分）の部品です。
// リンク先はすべて「#」としてダミーにしています。
---

<footer class="site-footer">
  <div class="footer-content">
    {/* 1列目：サイト情報とSNS */}
    <div class="footer-column">
      <div class="footer-logo">
        <span class="logo-icon">📰</span> NEWS
      </div>
      <p class="footer-desc">
        最新のニュースと情報をお届けする総合ニュースサイトです。
      </p>
      <div class="footer-sns">
        <span class="sns-label">公式SNS</span>
        {/* 背景を透明にして、白い丸枠と文字だけのアイコンにしました */}
        <a href="#" class="sns-icon">X</a>
        <a href="#" class="sns-icon">f</a>
        <a href="#" class="sns-icon" style="font-size: 10px;">LINE</a>
        <a href="#" class="sns-icon">▶</a>
        <a href="#" class="sns-icon">📷</a>
      </div>
    </div>

    {/* 2列目：カテゴリー */}
    <div class="footer-column">
      <h3 class="footer-heading">カテゴリー</h3>
      <ul class="footer-links">
        <li><a href="#">トップ</a></li>
        <li><a href="#">テクノロジー</a></li>
        <li><a href="#">ビジネス</a></li>
        <li><a href="#">スポーツ</a></li>
      </ul>
    </div>

    {/* 3列目：情報 */}
    <div class="footer-column">
      <h3 class="footer-heading">情報</h3>
      <ul class="footer-links">
        <li><a href="#">会社概要</a></li>
        <li><a href="#">利用規約</a></li>
        <li><a href="#">プライバシーポリシー</a></li>
        <li><a href="#">お問い合わせ</a></li>
      </ul>
    </div>

    {/* 4列目：フォロー */}
    <div class="footer-column">
      <h3 class="footer-heading">フォロー</h3>
      <ul class="footer-links">
        <li><a href="#">Twitter</a></li>
        <li><a href="#">Facebook</a></li>
        <li><a href="#">Instagram</a></li>
        <li><a href="#">YouTube</a></li>
      </ul>
    </div>
  </div>

  {/* 一番下のコピーライト部分 */}
  <div class="footer-bottom">
    <p>&copy; 2026 The Dexent Media Enterprises. All rights reserved.</p>
  </div>
</footer>

<style>
  /* フッター全体の背景色と文字色 */
  .site-footer {
    background-color: #111827; /* 濃いネイビー */
    color: #ffffff; /* 白文字 */
    font-family: sans-serif;
    padding-top: 40px;
  }

  /* 4つの列を横に並べる設定 */
  .footer-content {
    display: flex;
    justify-content: space-between;
    margin: 0 auto; /* 中央寄せ */
    padding: 0 20px 40px 20px;
    gap: 20px;
  }

  /* 各列の幅を均等にする */
  .footer-column {
    flex: 1;
  }

  /* ロゴ部分のデザイン */
  .footer-logo {
    font-size: 20px;
    font-weight: bold;
    margin-bottom: 15px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .logo-icon {
    color: #ef3332; /* 赤いアクセント */
  }

  /* サイト説明文 */
  .footer-desc {
    font-size: 13px;
    color: #9ca3af; /* 少し暗い白（グレー） */
    line-height: 1.6;
    margin-bottom: 20px;
  }

  /* SNSアイコンを並べるエリア */
  .footer-sns {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .sns-label {
    font-size: 12px;
    font-weight: bold;
    margin-right: 5px;
  }

  /* SNSアイコン（白文字・背景透過）の設定 */
  .sns-icon {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    width: 30px;
    height: 30px;
    border: 1px solid #ffffff; /* 白い枠線 */
    border-radius: 50%; /* 丸くする */
    color: #ffffff; /* 白文字 */
    text-decoration: none;
    font-size: 14px;
    font-weight: bold;
  }

  /* 各列の見出し（カテゴリー、情報など） */
  .footer-heading {
    font-size: 16px;
    font-weight: bold;
    margin-bottom: 15px;
  }

  /* リンクのリスト（縦並び） */
  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .footer-links li {
    margin-bottom: 10px;
  }
  .footer-links a {
    color: #9ca3af; /* 少し暗い白（グレー） */
    text-decoration: none;
    font-size: 13px;
  }

  /* 一番下のコピーライト部分 */
  .footer-bottom {
    text-align: center;
    border-top: 1px solid #1f2937; /* うっすらとした区切り線 */
    padding: 20px 0;
    font-size: 12px;
    color: #6b7280;
  }
</style>
