import { categoryLabelMap } from '../lib/categoryLabels.ts';
// ▼ カンペを読み込み
import { langCountryPairs, getBlogId } from '../lib/siteRoutes.ts';

const currentPath = Astro.url.pathname;
const pathParts = currentPath.split('/').filter(Boolean);
const lang = pathParts[0] || 'ja';
const country = pathParts[1] || 'jp';

let { allPosts = [] } = Astro.props;
const cacheKey = 'bloggerPostsCache_' + lang;

if ((!allPosts || allPosts.length === 0) && globalThis[cacheKey]) {
  allPosts = await globalThis[cacheKey];
}
if (!Array.isArray(allPosts)) {
  allPosts = [];
}

