---
// URLから現在の言語（日本語か英語か）を自動で読み取ります
const currentPath = Astro.url.pathname;
const pathParts = currentPath.split('/').filter(Boolean);
const region = pathParts[0] || 'ja'; // 例: 'ja', 'us'
const lang = pathParts[1] || 'ja';   // 例: 'ja', 'en'

// ▼ 日本語と英語のメニューを準備します（URLによって自動で切り替わります）
const menus = {
  jp: [
    { label: 'About 24Watchin', href: `/${region}/${lang}/about/` },
    { label: 'プライバシーポリシー', href: `/${region}/${lang}/privacy/` },
    { label: '利用規約', href: `/${region}/${lang}/terms/` },
    { label: 'お問い合わせ', href: `/${region}/${lang}/contact/` },
    { label: '訂正・修正ポリシー', href: `/${region}/${lang}/corrections/` },
    { label: '著作権・転載・引用について', href: `/${region}/${lang}/copyright/` }
  ],
  en: [
    { label: 'About 24Watchin', href: `/${region}/${lang}/about/` },
    { label: 'Privacy Policy', href: `/${region}/${lang}/privacy/` },
    { label: 'Terms of Use', href: `/${region}/${lang}/terms/` },
    { label: 'Contact', href: `/${region}/${lang}/contact/` },
    { label: 'Corrections Policy', href: `/${region}/${lang}/corrections/` },
    { label: 'Copyright / Reuse', href: `/${region}/${lang}/copyright/` }
  ]
};

// 現在の言語に合わせたメニューを選びます
const currentMenu = menus[lang] || menus.en;
const infoTitle = lang === 'ja' ? 'インフォメーション' : 'Information';
---

<footer class="site-footer">
  <div class="footer-content">
    
    {/* 1列目：ロゴとSNSアイコン */}
    <div class="footer-column logo-column">
      <div class="footer-logo">
        <span class="logo-icon">📰</span> 24Watchin
      </div>
      <div class="footer-sns">
        {/* SNSアイコン（デザインを整えるためにFontAwesomeを使っています） */}
        <a href="#" class="sns-icon" aria-label="X"><i class="fa-brands fa-x-twitter"></i></a>
        <a href="#" class="sns-icon" aria-label="Facebook"><i class="fa-brands fa-facebook-f"></i></a>
        <a href="#" class="sns-icon" aria-label="LINE"><i class="fa-brands fa-line"></i></a>
        <a href="#" class="sns-icon" aria-label="YouTube"><i class="fa-brands fa-youtube"></i></a>
        <a href="#" class="sns-icon" aria-label="Instagram"><i class="fa-brands fa-instagram"></i></a>
      </div>
    </div>

    {/* 2列目：規約などのリンク（自動で言語が切り替わります） */}
    <div class="footer-column menu-column">
      <h3 class="footer-heading">{infoTitle}</h3>
      <ul class="footer-links">
        {currentMenu.map(item => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </div>

    {/* 3列目：各国のトップページ（入口）へのリンク枠 */}
    <div class="footer-column global-column">
      <h3 class="footer-heading">Global Sites</h3>
      <ul class="footer-links">
        <li><a href="/jp/">Japan</a></li>
        <li><a href="/us/">USA</a></li>
        <li><a href="/tw/">Taiwan</a></li>
        <li><a href="/de/">Germany</a></li>
      </ul>
    </div>
    
  </div>

  {/* 一番下：ご指定の著作権表記 */}
  <div class="footer-bottom">
    <div class="copyright-text">
      <p>24Watchin.com に掲載している記事、写真、画像、図表、その他のコンテンツの無断転載・無断利用を禁止します。</p>
      <p>著作権は The Dexent Media Enterprises または正当な権利者に帰属します。</p>
      <p class="copyright-year">&copy; 2026 The Dexent Media Enterprises. All Rights Reserved.</p>
    </div>
  </div>
</footer>

<style>
  /* フッター全体の背景色（ご指定のグレー）と文字色 */
  .site-footer { 
    background-color: #393737; 
    color: #f3f4f6; 
    font-family: sans-serif; 
    padding-top: 50px; 
    margin-top: 60px; 
  }
  
  /* 3列を横に並べる設定 */
  .footer-content { 
    display: flex; 
    justify-content: space-between; 
    max-width: 1200px; 
    margin: 0 auto; 
    padding: 0 20px 40px 20px; 
    gap: 40px; 
  }
  .footer-column { flex: 1; }
  .logo-column { flex: 1.5; }
  .menu-column { flex: 1; }
  .global-column { flex: 1; }
  
  /* 左側のロゴデザイン */
  .footer-logo { 
    font-size: 24px; 
    font-weight: bold; 
    margin-bottom: 20px; 
    display: flex; 
    align-items: center; 
    gap: 8px; 
    color: #ffffff; 
  }
  .logo-icon { color: #872732; }
  
  /* SNSアイコンのデザイン */
  .footer-sns { display: flex; align-items: center; gap: 12px; }
  .sns-icon { 
    display: inline-flex; 
    justify-content: center; 
    align-items: center; 
    width: 36px; 
    height: 36px; 
    background-color: rgba(255, 255, 255, 0.1); 
    color: #ffffff; 
    border-radius: 50%; 
    text-decoration: none; 
    font-size: 16px; 
    transition: background-color 0.2s; 
  }
  .sns-icon:hover { background-color: #872732; }
  
  /* 各列のタイトルのデザイン */
  .footer-heading { 
    font-size: 16px; 
    font-weight: bold; 
    color: #ffffff; 
    margin-bottom: 20px; 
    border-bottom: 2px solid #872732; 
    padding-bottom: 8px; 
    display: inline-block; 
  }
  
  /* リンク文字のデザイン */
  .footer-links { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 12px; }
  .footer-links a { color: #d1d5db; text-decoration: none; font-size: 14px; transition: color 0.2s; }
  .footer-links a:hover { color: #ffffff; text-decoration: underline; }

  /* 一番下の著作権表記エリアのデザイン（少し暗い色で区切ります） */
  .footer-bottom { 
    background-color: #2b2a2a; 
    padding: 24px 20px; 
    text-align: center; 
  }
  .copyright-text p { 
    margin: 0 0 6px 0; 
    font-size: 12px; 
    color: #9ca3af; 
    line-height: 1.6; 
  }
  .copyright-year { 
    margin-top: 12px !important; 
    margin-bottom: 0 !important; 
    font-size: 13px !important; 
    color: #d1d5db !important; 
  }

  /* スマホで見た時は縦に並べ直す設定 */
  @media (max-width: 768px) {
    .footer-content { flex-direction: column; gap: 30px; }
  }
</style>
