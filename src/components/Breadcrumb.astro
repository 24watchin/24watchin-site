---
const {
  countryLabel = '日本',
  countryHref = '/ja/jp/',
  categoryLabel = 'ニュース',
  categoryHref = '',
} = Astro.props;
---

<nav class="breadcrumb" aria-label="パンくずリスト">
  <a href={countryHref} class="breadcrumb-link">{countryLabel}</a>
  <span class="breadcrumb-separator">＞</span>

  {categoryHref ? (
    <a href={categoryHref} class="breadcrumb-link current">{categoryLabel}</a>
  ) : (
    <span class="breadcrumb-link current">{categoryLabel}</span>
  )}
</nav>

<style>
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 14px;
    font-size: 13px;
    line-height: 1.4;
    color: #666;
    flex-wrap: wrap;
  }

  .breadcrumb-link {
    color: #666;
    text-decoration: none;
    cursor: pointer; /* ← 追加！指マークが出るように */
  }

  .breadcrumb-link.current {
    color: #1a1a1a;
    font-weight: 700;
  }

  .breadcrumb-link:hover,
  .breadcrumb-link:focus-visible {
    color: inherit;
    text-decoration: underline;
    text-decoration-color: #000;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
  }

  .breadcrumb-separator {
    color: #999;
  }
</style>
