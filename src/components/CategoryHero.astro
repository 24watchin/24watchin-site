---
// ジャンルページの「顔」となる、ヒーローエリアの部品です
// SEO対策：正しいHTML構造
// スマホ対策：フレキシブルなグリッド表示
const { posts, categoryName, getImageUrl } = Astro.props;

// 最初の1記事を「メイン」、続く4記事を「サブ」に分けます
const mainPost = posts[0];
const subPosts = posts.slice(1, 5);
---

<header class="category-header">
  <h1 class="category-title">{categoryName}ニュース</h1>
  <span class="article-count">最新記事: {posts.length}件</span>
</header>

<div class="hero-grid">
  {mainPost && (
    <article class="main-featured">
      {/* ★ 1箇所目：メイン記事のリンクを日本版（/jp/jp/）に修正しました！ */}
      <a href={`/jp/jp/news/${mainPost.id}/`} class="hero-link">
        <div class="main-image-wrapper">
          <img 
            src={getImageUrl(mainPost.content)} 
            alt={mainPost.title} 
            class="hero-image" 
          />
        </div>
        <div class="main-info">
          <h2 class="main-title">{mainPost.title}</h2>
          <time datetime={mainPost.published} class="hero-date">
            {new Date(mainPost.published).toLocaleDateString('ja-JP')}
          </time>
        </div>
      </a>
    </article>
  )}

  <div class="sub-featured-list">
    {subPosts.map((post) => (
      <article class="sub-item">
        {/* ★ 2箇所目：横に並ぶサブ記事リストのリンクを日本版（/jp/jp/）に修正しました！ */}
        <a href={`/jp/jp/news/${post.id}/`} class="hero-link sub-link">
          <div class="sub-image-wrapper">
            <img src={getImageUrl(post.content)} alt={post.title} class="hero-image" />
          </div>
          <div class="sub-info">
            <h3 class="sub-title">{post.title}</h3>
            <time datetime={post.published} class="hero-date">
              {new Date(post.published).toLocaleDateString('ja-JP')}
            </time>
          </div>
        </a>
      </article>
    ))}
  </div>
</div>

<style>
  /* ジャンル見出しのデザイン */
  .category-header { display: flex; justify-content: space-between; align-items: flex-end; border-bottom: 3px solid #1e3a8a; margin-bottom: 2rem; padding-bottom: 0.5rem; }
  .category-title { font-size: 1.8rem; margin: 0; color: #1a1a1a; font-weight: 800; }
  .article-count { font-size: 0.9rem; color: #666; }

  /* レイアウト：PCでは1.2対1の2列 */
  .hero-grid { display: grid; grid-template-columns: 1.2fr 1fr; gap: 1.5rem; margin-bottom: 3rem; }
  
  .hero-link { text-decoration: none; color: inherit; display: block; transition: opacity 0.2s; }
  .hero-link:hover { opacity: 0.8; }

  /* 写真の共通設定 */
  .main-image-wrapper, .sub-image-wrapper { background: #eee; border-radius: 8px; overflow: hidden; position: relative; }
  .main-image-wrapper { height: 350px; }
  .sub-image-wrapper { width: 100px; height: 70px; flex-shrink: 0; }
  .hero-image { width: 100%; height: 100%; object-fit: cover; }

  /* メイン記事のテキスト */
  .main-info { padding: 1rem 0; }
  .main-title { font-size: 1.5rem; margin: 0 0 0.5rem 0; line-height: 1.4; }
  
  /* サブ記事のリスト表示 */
  .sub-featured-list { display: flex; flex-direction: column; gap: 1rem; }
  .sub-link { display: flex; gap: 1rem; align-items: flex-start; }
  .sub-title { font-size: 1rem; margin: 0 0 0.3rem 0; line-height: 1.4; }
  .hero-date { font-size: 0.8rem; color: #888; display: block; }

  /* 【スマホ対策】画面が小さい時は1列にする */
  @media (max-width: 768px) {
    .hero-grid { grid-template-columns: 1fr; }
    .main-image-wrapper { height: 220px; }
    .main-title { font-size: 1.2rem; }
  }
</style>
