---
// ▼ lang と country を props で受け取るように追加！
const { posts, categoryName, getImageUrl, lang = 'ja', country = 'jp' } = Astro.props;

const mainPost = posts[0];
const subPosts = posts.slice(1, 5);

// ▼ 日付フォーマット：言語に合わせる
const localeMap: Record<string, string> = {
  ja: 'ja-JP', en: 'en-US', 'zh-cn': 'zh-CN', 'zh-tw': 'zh-TW',
  es: 'es-ES', fr: 'fr-FR', de: 'de-DE', ru: 'ru-RU',
};
const dateLocale = localeMap[lang] || 'en-US';

// ▼ カテゴリタイトルの「ニュース」suffix（多言語）
const newsSuffixMap: Record<string, string> = {
  ja: 'ニュース', en: ' News', 'zh-cn': '新闻', 'zh-tw': '新聞',
  es: ' Noticias', fr: ' Actualités', de: ' Nachrichten', ru: ' Новости',
};
const newsSuffix = newsSuffixMap[lang] || '';
---

<header class="category-header">
  <h1 class="category-title">{categoryName}{newsSuffix}</h1>
</header>

<div class="hero-grid">
  {mainPost && (
    <article class="main-featured">
      <!-- ▼ /ja/jp/ → /${lang}/${country}/ に修正！ -->
      <a href={`/${lang}/${country}/news/${mainPost.id}/`} class="hero-link">
        <div class="main-image-wrapper">
          <img
            src={getImageUrl(mainPost.content)}
            alt={mainPost.title}
            class="hero-image"
          />
        </div>
        <div class="main-info">
          <h2 class="main-title">{mainPost.title}</h2>
          <time datetime={mainPost.published} class="hero-date">
            {new Date(mainPost.published).toLocaleDateString(dateLocale)}
          </time>
        </div>
      </a>
    </article>
  )}

  <div class="sub-featured-list">
    {subPosts.map((post) => (
      <article class="sub-item">
        <!-- ▼ /ja/jp/ → /${lang}/${country}/ に修正！ -->
        <a href={`/${lang}/${country}/news/${post.id}/`} class="hero-link sub-link">
          <div class="sub-image-wrapper">
            <img src={getImageUrl(post.content)} alt={post.title} class="hero-image" />
          </div>
          <div class="sub-info">
            <h3 class="sub-title">{post.title}</h3>
            <time datetime={post.published} class="hero-date">
              {new Date(post.published).toLocaleDateString(dateLocale)}
            </time>
          </div>
        </a>
      </article>
    ))}
  </div>
</div>

<style>
  .category-header { display: flex; justify-content: space-between; align-items: flex-end; border-bottom: 3px solid var(--theme-color, #872732); margin-bottom: 2rem; padding-bottom: 0.5rem; }
  .category-title { font-size: 1.8rem; margin: 0; color: #1a1a1a; font-weight: 800; }
  .hero-grid { display: grid; grid-template-columns: 1.2fr 1fr; gap: 1.5rem; margin-bottom: 0; }
  .hero-link { text-decoration: none; color: inherit; display: block; transition: opacity 0.2s; }
  .hero-link:hover { opacity: 0.8; }
  .hero-link:hover .main-title, .hero-link:hover .sub-title, .hero-link:focus-visible .main-title, .hero-link:focus-visible .sub-title { text-decoration: underline; text-decoration-color: #000; text-decoration-thickness: 1px; text-underline-offset: 2px; }
  .main-image-wrapper, .sub-image-wrapper { background: #eee; border-radius: 8px; overflow: hidden; position: relative; }
  .main-image-wrapper { height: 350px; }
  .sub-image-wrapper { width: 100px; height: 70px; flex-shrink: 0; }
  .hero-image { width: 100%; height: 100%; object-fit: cover; }
  .main-info { padding: 1rem 0; }
  .main-title { font-size: 1.5rem; margin: 0 0 0.5rem 0; line-height: 1.4; font-weight: bold; color: #1a1a1a; }
  .sub-featured-list { display: flex; flex-direction: column; gap: 1rem; }
  .sub-link { display: flex; gap: 1rem; align-items: flex-start; }
  .sub-title { font-size: 1rem; margin: 0 0 0.3rem 0; line-height: 1.4; font-weight: bold; color: #1a1a1a; }
  .hero-date { font-size: 0.8rem; color: #888; display: block; }
  @media (max-width: 768px) {
    .hero-grid { grid-template-columns: 1fr; }
    .main-image-wrapper { height: 220px; }
    .main-title { font-size: 1.2rem; }
  }
</style>
