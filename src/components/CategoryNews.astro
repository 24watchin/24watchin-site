---
const { title, slug, posts = [], lang = 'ja', country = 'jp' } = Astro.props;

const getImageUrl = (content) => {
  const match = (content || '').match(/<img[^>]+src="([^">]+)"/);
  return match ? match[1] : 'https://placehold.co/120x80/eeeeee/999999?text=No+Image';
};

// 「〇〇 ページへ」の多言語対応
const pageToTexts = {
  ja: 'ページへ',
  en: 'View All',
  'zh-cn': '查看更多',
  'zh-tw': '查看更多',
  es: 'Ver más',
  fr: 'Voir plus',
  de: 'Mehr',
  ru: 'Все статьи',
};
const pageToText = pageToTexts[lang] || pageToTexts['ja'];

// 日付フォーマットも言語対応
const dateLocaleMap = {
  ja: 'ja-JP',
  en: 'en-US',
  'zh-cn': 'zh-CN',
  'zh-tw': 'zh-TW',
  es: 'es-ES',
  fr: 'fr-FR',
  de: 'de-DE',
  ru: 'ru-RU',
};
const dateLocale = dateLocaleMap[lang] || 'ja-JP';

const categoryPath = '/' + lang + '/' + country + '/category/' + slug + '/';
---

<section class="category-block">
  <div class="category-header">
    <h3>{title}</h3>
    <a href={categoryPath} class="view-all">
      {title} {pageToText} <i class="fas fa-chevron-right"></i>
    </a>
  </div>

  <div class="article-list">
    {posts.map((post) => (
      <a href={'/' + lang + '/' + country + '/news/' + post.id + '/'} class="article-item">
        <div class="article-img">
          <img src={getImageUrl(post.content)} alt={post.title} />
        </div>
        <div class="article-info">
          <h4>{post.title}</h4>
          <div class="article-meta">
            <span class="date">{new Date(post.published).toLocaleDateString(dateLocale)}</span>
          </div>
        </div>
      </a>
    ))}
  </div>
</section>

<style>
  .category-block { margin-bottom: 15px; }
  .category-header { display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #333; padding-bottom: 5px; margin-bottom: 15px; }
  .category-header h3 { font-size: 18px; margin: 0; font-weight: bold; }
  .view-all { font-size: 12px; color: #666666; text-decoration: none; font-weight: bold; }
  .view-all:hover { text-decoration: underline; text-decoration-color: #000000; text-decoration-thickness: 1px; }
  .article-list { display: flex; flex-direction: column; gap: 15px; }
  .article-item { display: flex; gap: 12px; text-decoration: none; color: #333; }
  .article-img { width: 120px; height: 80px; flex-shrink: 0; border-radius: 4px; overflow: hidden; }
  .article-img img { width: 100%; height: 100%; object-fit: cover; }
  .article-info { display: flex; flex-direction: column; min-height: 80px; flex: 1; min-width: 0; }
  .article-info h4 { font-size: 16px; margin: 0; line-height: 1.4; font-weight: bold; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  .article-item:hover .article-info h4 { text-decoration: underline; text-decoration-color: #000000; text-decoration-thickness: 1px; }
  .article-meta { font-size: 11px; color: #888; margin-top: auto; }
</style>
