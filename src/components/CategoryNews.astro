---
const { title, slug, posts = [] } = Astro.props;

const getImageUrl = (content) => {
  const match = (content || '').match(/<img[^>]+src="([^">]+)"/);
  return match ? match[1] : 'https://placehold.co/120x80/eeeeee/999999?text=No+Image';
};
---

<section class="category-block">
  <div class="category-header">
    <h3>{title}</h3>
    <a href={`/jp/jp/category/${slug}/`} class="view-all">{title} ページへ <i class="fas fa-chevron-right"></i></a>
  </div>

  <div class="article-list">
    {posts.map((post) => (
      <a href={`/jp/jp/news/${post.id}/`} class="article-item">
        <div class="article-img">
          <img src={getImageUrl(post.content)} alt={post.title} />
        </div>
        <div class="article-info">
          {/* cssを当てやすくするため class="article-title" を追加しました */}
          <h4 class="article-title">{post.title}</h4>
          <div class="article-meta">
            <span class="date">{new Date(post.published).toLocaleDateString('ja-JP')}</span>
          </div>
        </div>
      </a>
    ))}
  </div>
</section>

<style>
  /* ① カテゴリ間のスペースを 30px から 15px に狭くしました */
  .category-block { margin-bottom: 15px; }

  .category-header { display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #333; padding-bottom: 5px; margin-bottom: 15px; }
  .category-header h3 { font-size: 18px; margin: 0; font-weight: bold; }
  
  /* ③ 「〇〇 ページへ」をグレー(#666666)に変更 */
  .view-all { font-size: 12px; color: #666666; text-decoration: none; font-weight: bold; }
  /* ③ マウスを当てた時に黒い細線を出す */
  .view-all:hover { text-decoration: underline; text-decoration-color: #000000; text-decoration-thickness: 1px; }

  .article-list { display: flex; flex-direction: column; gap: 15px; }
  .article-item { display: flex; gap: 12px; text-decoration: none; color: #333; }

  .article-img { width: 120px; height: 80px; flex-shrink: 0; border-radius: 4px; overflow: hidden; }
  .article-img img { width: 100%; height: 100%; object-fit: cover; }

  /* ④ 日付を下に固定するための箱（レイアウト）の設定 */
  .article-info { 
    display: flex; 
    flex-direction: column; 
    justify-content: space-between; /* タイトルは上、日付は下へ押し分ける */
    height: 80px; /* 画像の高さと同じ80pxに固定 */
    flex: 1;
    min-width: 0; /* 長いタイトルでレイアウトが崩れないためのおまじない */
  }

  /* ② 文字の大きさを16pxにし、④ 3行までに制限する */
  .article-title { 
    font-size: 16px; 
    margin: 0; 
    line-height: 1.4; 
    font-weight: bold; 
    display: -webkit-box; 
    -webkit-line-clamp: 3; /* ここで3行までに制限しています */
    -webkit-box-orient: vertical; 
    overflow: hidden; 
  }

  /* ② マウスを当てた時に記事タイトルに黒い細線を出す */
  .article-item:hover .article-title {
    text-decoration: underline;
    text-decoration-color: #000000;
    text-decoration-thickness: 1px;
  }

  .article-meta { font-size: 11px; color: #888; }
</style>
