---
const { title, slug, posts = [] } = Astro.props;
const getImageUrl = (content) => {
  const match = (content || '').match(/<img[^>]+src="([^">]+)"/);
  return match ? match[1] : 'https://placehold.co/120x80/eeeeee/999999?text=No+Image';
};
---

<section class="category-block">
  <div class="category-header">
    <h3>{title}</h3>
    <a href={`/jp/jp/category/${slug}/`} class="view-all">{title} ページへ <i class="fas fa-chevron-right"></i></a>
  </div>

  <div class="article-list">
    {posts.map((post) => (
      <a href={`/jp/jp/news/${post.id}/`} class="article-item">
        <div class="article-img">
          <img src={getImageUrl(post.content)} alt={post.title} />
        </div>
        <div class="article-info">
          <h4>{post.title}</h4>
          <div class="article-meta">
            <span class="date">{new Date(post.published).toLocaleDateString('ja-JP')}</span>
            {/* タグを削除しました */}
          </div>
        </div>
      </a>
    ))}
  </div>
</section>

<style>
  .category-block { margin-bottom: 30px; }
  .category-header { display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #333; padding-bottom: 5px; margin-bottom: 15px; }
  .category-header h3 { font-size: 18px; margin: 0; font-weight: bold; }
  .view-all { font-size: 12px; color: #0066cc; text-decoration: none; font-weight: bold; }
  .article-list { display: flex; flex-direction: column; gap: 15px; }
  .article-item { display: flex; gap: 12px; text-decoration: none; color: #333; }
  .article-img { width: 120px; height: 80px; flex-shrink: 0; border-radius: 4px; overflow: hidden; }
  .article-img img { width: 100%; height: 100%; object-fit: cover; }
  .article-info h4 { font-size: 14px; margin: 0 0 5px; line-height: 1.4; font-weight: bold; }
  .article-meta { font-size: 11px; color: #888; }
</style>
