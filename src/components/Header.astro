---
import { categoryLabelMap } from '../lib/categoryLabels';
import { langCountryPairs } from '../lib/siteRoutes.ts';
import { getCountryLabel } from '../lib/countryData.ts';

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const pathParts = currentPath.split('/').filter(Boolean);
const lang = pathParts[0] || 'ja';
const country = pathParts[1] || 'jp';

// 読み込み設定
const localeKeyMap = { ja: 'jp', en: 'en', 'zh-cn': 'zh-cn', 'zh-tw': 'zh-tw', es: 'es', de: 'de', fr: 'fr', ru: 'ru' };
const localeKey = localeKeyMap[lang] || 'jp';
const labels = categoryLabelMap[localeKey] || categoryLabelMap.jp;
const basePath = '/' + lang + '/' + country;

const homeHref = basePath + '/';
const searchAction = basePath + '/search/';
const countryLabel = getCountryLabel(country, lang);

// メニューのタイトルを言語ごとに用意
let configLabel = 'Language / Region';
if (lang === 'ja') configLabel = '言語・地域';
if (lang === 'zh-cn') configLabel = '语言 / 地域';
if (lang === 'zh-tw') configLabel = '語言 / 地域';
if (lang === 'es') configLabel = 'Idioma / Región';
if (lang === 'fr') configLabel = 'Langue / Région';
if (lang === 'de') configLabel = 'Sprache / Region';
if (lang === 'ru') configLabel = 'Язык / Регион';

const activePairs = langCountryPairs.filter(p => p.active);

const categoryItems = (labels.headerCategories || []).map((item) => ({
  href: basePath + '/category/' + item.slug + '/',
  label: item.label,
  isActive: currentPath === (basePath + '/category/' + item.slug),
  slug: item.slug
}));

const mainItems = categoryItems.filter(item => !['health-life', 'weather', 'traffic'].includes(item.slug));
---

<header class="site-header">
  <div class="header-top">
    <div class="brand-area">
      <a href={homeHref} class="logo-link">
        <img src="/images/logo-24watchin.png" alt="24Watchin" class="logo-image" />
      </a>
      <div class="country-name-right">{countryLabel}</div>
    </div>

    <div class="right-area">
      <div class="search-and-menu">
        <form action={searchAction} method="get" class="search-form">
          <input type="text" name="q" class="search-input" placeholder={labels.searchPlaceholder} />
          <button type="submit" class="search-button">
            <svg class="search-icon" viewBox="0 0 24 24"><circle cx="11" cy="11" r="6.5"></circle><line x1="16" y1="16" x2="21" y2="21"></line></svg>
          </button>
        </form>
        
        <button id="menu-open-btn" class="menu-trigger" type="button">
          <svg viewBox="0 0 24 24" class="hamburger-icon"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
        </button>
      </div>

      <div class="header-status-row">
        <span class="current-setting-label">{labels.languageName} / {countryLabel}</span>
      </div>
    </div>
  </div>

  <nav class="category-bar">
    <div class="category-nav-inner">
      {mainItems.map((item) => (
        <a href={item.href} class={item.isActive ? 'category-link active' : 'category-link'}>{item.label}</a>
      ))}
    </div>
  </nav>
</header>

<div id="menu-overlay" class="menu-overlay"></div>
<div id="side-menu" class="side-menu">
  <div class="menu-header">
    <button id="menu-close-btn" class="close-btn" type="button">&times;</button>
    <div class="menu-title">{configLabel}</div>
  </div>
  
  <div class="menu-content">
    <div class="current-selection-box">
      <p class="small-title">Current Setting</p>
      <div class="current-value">{labels.languageName} / {countryLabel}</div>
    </div>

    <div class="language-list">
      {activePairs.map((pair) => {
        const pairCountryLabel = getCountryLabel(pair.country, lang);
        // 言語名の表示
        let langName = pair.lang;
        if (pair.lang === 'ja') langName = '日本語';
        else if (pair.lang === 'en') langName = 'English';
        else if (pair.lang === 'zh-cn') langName = '简体中文';
        else if (pair.lang === 'zh-tw') langName = '繁體中文';
        else if (pair.lang === 'es') langName = 'Español';
        else if (pair.lang === 'fr') langName = 'Français';
        else if (pair.lang === 'de') langName = 'Deutsch';
        else if (pair.lang === 'ru') langName = 'Русский';

        return (
          <a href={`/${pair.lang}/${pair.country}/`} class="lang-item">
            {langName} ({pairCountryLabel})
          </a>
        );
      })}
    </div>
  </div>
</div>

<script is:inline>
  (function() {
    function setupDrawer() {
      const openBtn = document.getElementById('menu-open-btn');
      const closeBtn = document.getElementById('menu-close-btn');
      const overlay = document.getElementById('menu-overlay');
      const menu = document.getElementById('side-menu');

      if (!openBtn || !closeBtn || !overlay || !menu) return;

      function openMenu() {
        menu.classList.add('open');
        overlay.classList.add('visible');
        document.body.style.overflow = 'hidden';
      }

      function closeMenu() {
        menu.classList.remove('open');
        overlay.classList.remove('visible');
        document.body.style.overflow = '';
      }

      openBtn.onclick = openMenu;
      closeBtn.onclick = closeMenu;
      overlay.onclick = closeMenu;
    }
    setupDrawer();
    document.addEventListener('astro:page-load', setupDrawer);
  })();
</script>

<style>
  .site-header { background: #fff; width: 100%; border-bottom: 1px solid #eee; }
  .header-top { max-width: 1280px; margin: 0 auto; padding: 10px 14px; display: flex; justify-content: space-between; align-items: flex-start; }
  
  .brand-area { display: flex; flex-direction: column; width: 200px; }
  .logo-image { width: 100%; height: auto; }
  /* ここで右揃えを設定 */
  .country-name-right { text-align: right; font-size: 16px; font-weight: 700; color: #000; margin-top: 2px; }

  .right-area { display: flex; flex-direction: column; align-items: flex-end; gap: 8px; }
  .search-and-menu { display: flex; align-items: center; gap: 15px; }
  .search-form { display: flex; align-items: center; background: #d8d3cc; border-radius: 8px; padding: 0 8px; }
  .search-input { border: none; background: transparent; height: 34px; width: 180px; outline: none; font-size: 14px; color: #333; }
  .search-button { background: none; border: none; cursor: pointer; display: flex; align-items: center; }
  .search-icon { width: 18px; height: 18px; stroke: #393737; stroke-width: 2.5; fill: none; }

  .menu-trigger { background: none; border: none; cursor: pointer; display: flex; align-items: center; }
  .hamburger-icon { width: 30px; height: 30px; stroke: #333; stroke-width: 2; fill: none; }
  
  .header-status-row { margin-right: 45px; }
  .current-setting-label { font-size: 16px; font-weight: 700; color: #000; }

  /* メニューの見た目 */
  .menu-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); visibility: hidden; opacity: 0; transition: 0.3s; z-index: 9998; }
  .menu-overlay.visible { visibility: visible; opacity: 1; }
  
  .side-menu { position: fixed; top: 0; right: -320px; width: 320px; height: 100%; background: #fff; transition: 0.3s; z-index: 9999; box-shadow: -5px 0 15px rgba(0,0,0,0.1); }
  .side-menu.open { right: 0; }
  
  .menu-header { padding: 20px; border-bottom: 1px solid #eee; display: flex; align-items: center; gap: 15px; }
  .close-btn { background: none; border: none; font-size: 30px; cursor: pointer; color: #666; }
  .menu-title { font-size: 18px; font-weight: 700; }
  
  .menu-content { padding: 20px; height: calc(100% - 70px); overflow-y: auto; }
  .current-selection-box { background: #f8f9fa; padding: 15px; border-radius: 8px; margin-bottom: 20px; border-left: 4px solid #872732; }
  .small-title { font-size: 11px; color: #666; margin-bottom: 4px; text-transform: uppercase; }
  .current-value { font-size: 15px; font-weight: 700; }

  .lang-item { display: block; padding: 12px 10px; border-bottom: 1px solid #f0f0f0; text-decoration: none; color: #333; font-size: 14px; }
  .lang-item:hover { background: #f0f0f0; color: #872732; }

  .category-bar { background: #393737; width: 100%; }
  .category-nav-inner { max-width: 1280px; margin: 0 auto; display: flex; overflow-x: auto; scrollbar-width: none; }
  .category-nav-inner::-webkit-scrollbar { display: none; }
  .category-link { padding: 15px 20px; color: #fff; text-decoration: none; font-weight: 700; font-size: 14px; white-space: nowrap; }
  .category-link.active { background: #872732; }
  
  @media (max-width: 768px) {
    .side-menu { width: 280px; }
    .search-input { width: 120px; }
    .header-status-row { display: none; }
  }
</style>
