---
import HeaderLink from './HeaderLink.astro';

const countryLabel = 'JAPAN';
const languageLabel = '日本語';
const searchAction = '/jp/jp/search';
const homeHref = '/jp/jp/';

const navCategories = [
  { label: '政治', slug: 'politics' },
  { label: '社会', slug: 'society' },
  { label: '国際', slug: 'international' },
  { label: '経済', slug: 'economy' },
  { label: '環境・エネルギー', slug: 'environment-energy' },
  { label: 'ビジネス', slug: 'business' },
  { label: 'テクノロジー・AI', slug: 'technology-ai' },
  { label: '文化・エンタメ', slug: 'culture-entertainment' },
  { label: 'スポーツ', slug: 'sports' },
];

const headerWords = [
  // ここに今後ワードや特集を入れます
  // 例:
  // { label: 'イラン情勢', href: '/jp/jp/search?q=イラン情勢' },
  // { label: '特集ページ', href: '/jp/jp/special/example' },
];
---

<header class="site-header">
  <div class="container header-inner">
    <div class="header-top">
      <a href={homeHref} class="brand-link" aria-label="24Watchin ホーム">
        <img
          src="/images/logo-24watchin.png"
          alt="24Watchin"
          class="brand-logo"
        />
        <div class="brand-country">{countryLabel}</div>
      </a>

      <div class="header-tools">
        <div class="language-label">{languageLabel}</div>

        <form action={searchAction} method="get" class="search-form">
          <input type="text" name="q" placeholder="検索" required />
          <button type="submit" aria-label="検索">
            <i class="fas fa-search"></i>
          </button>
        </form>
      </div>
    </div>

    <nav class="global-nav" aria-label="主要カテゴリ">
      <div class="nav-scroll">
        {navCategories.map((category) => (
          <HeaderLink
            href={`/jp/jp/category/${category.slug}`}
            activeMatch={`/jp/jp/category/${category.slug}`}
          >
            {category.label}
          </HeaderLink>
        ))}
      </div>
    </nav>

    <div class="header-word-row">
      {headerWords.map((word) => (
        <a href={word.href} class="header-word-link">{word.label}</a>
      ))}
    </div>

    <div class="header-accent-line" aria-hidden="true"></div>
  </div>
</header>

<style>
  .site-header {
    background: #fff;
    border-bottom: 1px solid #e5e5e5;
    position: sticky;
    top: 0;
    z-index: 1000;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .header-inner {
    padding-top: 18px;
    padding-bottom: 0;
  }

  .header-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 24px;
    margin-bottom: 14px;
  }

  .brand-link {
    display: inline-flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    min-width: 0;
  }

  .brand-logo {
    display: block;
    height: 72px;
    width: auto;
    max-width: 100%;
    object-fit: contain;
    border-radius: 0;
  }

  .brand-country {
    margin-top: 8px;
    font-size: 20px;
    font-weight: 800;
    letter-spacing: 0.04em;
    color: #111;
    line-height: 1;
    text-align: right;
    align-self: flex-end;
    padding-right: 2px;
  }

  .header-tools {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 10px;
  }

  .language-label {
    font-size: 16px;
    font-weight: 800;
    color: #111;
    line-height: 1;
  }

  .search-form {
    display: flex;
    align-items: center;
    gap: 0;
  }

  .search-form input {
    width: 180px;
    height: 38px;
    padding: 0 14px;
    border: none;
    background: #d7d1ca;
    color: #111;
    font-size: 14px;
    outline: none;
    border-radius: 8px 0 0 8px;
    box-sizing: border-box;
  }

  .search-form button {
    width: 42px;
    height: 38px;
    border: none;
    background: #d7d1ca;
    color: #111;
    cursor: pointer;
    border-radius: 0 8px 8px 0;
  }

  .global-nav {
    background: #393737;
    overflow: hidden;
  }

  .nav-scroll {
    display: flex;
    align-items: stretch;
    overflow-x: auto;
    white-space: nowrap;
    scrollbar-width: none;
  }

  .nav-scroll::-webkit-scrollbar {
    display: none;
  }

  .header-word-row {
    min-height: 46px;
    background: #fff;
    display: flex;
    align-items: center;
    gap: 32px;
    padding: 0 18px;
    overflow-x: auto;
    white-space: nowrap;
    scrollbar-width: none;
  }

  .header-word-row::-webkit-scrollbar {
    display: none;
  }

  .header-word-link {
    font-size: 16px;
    font-weight: 700;
    color: #111;
    text-decoration: none;
    line-height: 1;
  }

  .header-word-link:hover {
    text-decoration: underline;
  }

  .header-accent-line {
    height: 14px;
    background: #872732;
  }

  @media (max-width: 900px) {
    .header-top {
      flex-direction: column;
      align-items: flex-start;
    }

    .header-tools {
      width: 100%;
      align-items: flex-start;
    }
  }

  @media (max-width: 640px) {
    .container {
      padding: 0 14px;
    }

    .header-inner {
      padding-top: 14px;
    }

    .brand-logo {
      height: 58px;
    }

    .brand-country {
      font-size: 17px;
    }

    .language-label {
      font-size: 15px;
    }

    .search-form {
      width: 100%;
    }

    .search-form input {
      width: 100%;
      min-width: 0;
    }

    .header-word-row {
      min-height: 42px;
      padding: 0 14px;
      gap: 24px;
    }

    .header-word-link {
      font-size: 16px;
    }

    .header-accent-line {
      height: 12px;
    }
  }
</style>
