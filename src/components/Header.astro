---
import { categoryLabelMap } from '../lib/categoryLabels';
import { langCountryPairs } from '../lib/siteRoutes.ts';
import { getCountryLabel } from '../lib/countryData.ts';

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const pathParts = currentPath.split('/').filter(Boolean);
const lang = pathParts[0] || 'ja';
const country = pathParts[1] || 'jp';

const localeKeyMap = { ja: 'jp', en: 'en', 'zh-cn': 'zh-cn', 'zh-tw': 'zh-tw', es: 'es', de: 'de', fr: 'fr', ru: 'ru' };
const localeKey = localeKeyMap[lang] || 'jp';
const labels = categoryLabelMap[localeKey] || categoryLabelMap.jp;
const basePath = '/' + lang + '/' + country;

const homeHref = basePath + '/';
const searchAction = basePath + '/search/';
const countryLabel = getCountryLabel(country, lang);

const configLabels = { 
  ja: '言語 / 地域', en: 'Language / Region', 'zh-cn': '语言 / 地域', 'zh-tw': '語言 / 地域',
  es: 'Idioma / Región', fr: 'Langue / Région', de: 'Sprache / Region', ru: 'Язык / Регион' 
};
const configLabelText = configLabels[lang] || configLabels['en'];
const langNames = { ja: '日本語', en: 'English', 'zh-cn': '简体中文', 'zh-tw': '繁體中文', es: 'Español', fr: 'Français', de: 'Deutsch', ru: 'Русский' };

const allActivePairs = langCountryPairs.filter(p => p.active).sort((a, b) => {
  const nameA = langNames[a.lang] || a.lang;
  const nameB = langNames[b.lang] || b.lang;
  return nameA.localeCompare(nameB, lang === 'ja' ? 'ja' : 'en');
});

// カテゴリー分け（BKのロジックを復元）
const categoryItems = (labels.headerCategories || []).map((item) => ({
  href: basePath + '/category/' + item.slug + '/',
  label: item.label,
  isActive: currentPath === (basePath + '/category/' + item.slug),
  slug: item.slug
}));
const moreSlugs = ['health-life', 'weather', 'traffic'];
const mainItems = categoryItems.filter(item => !moreSlugs.includes(item.slug));
const moreItems = categoryItems.filter(item => moreSlugs.includes(item.slug));

const headerWords = []; // スペース確保用
---

<header class="site-header">
  <div class="header-top">
    <div class="brand-area">
      <a href={homeHref} class="logo-link">
        <img src="/images/logo-24watchin.png" alt="24Watchin" class="logo-image" />
      </a>
      <div class="country-name-aligned">{countryLabel}</div>
    </div>

    <div class="right-area">
      <div class="upper-row">
        <form action={searchAction} method="get" class="search-form-expandable" id="search-form">
          <input type="text" name="q" class="search-input-hidden" id="search-input" placeholder={labels.searchPlaceholder} />
          <button type="button" class="search-toggle-btn" id="search-trigger">
            <svg class="search-icon-large" viewBox="0 0 24 24"><circle cx="11" cy="11" r="6.5"></circle><line x1="16" y1="16" x2="21" y2="21"></line></svg>
          </button>
        </form>
      </div>

      <div class="lower-row">
        <span class="current-setting-label">{labels.languageName} / {countryLabel}</span>
        <button id="menu-open-btn" class="menu-combo-btn" type="button">
          <svg viewBox="0 0 24 24" class="hamburger-icon"><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
          <span class="menu-btn-text">{configLabelText}</span>
        </button>
      </div>
    </div>
  </div>

  <nav class="category-bar">
    <div class="category-nav-inner">
      <div class="pc-category-group">
        {mainItems.map((item) => (
          <a href={item.href} class={item.isActive ? 'category-link active' : 'category-link'}>
            <span class="category-text-with-underline">{item.label}</span>
          </a>
        ))}
        {moreItems.length > 0 && (
          <div class="more-dropdown">
            <button class="more-btn">
              <span class="category-text-with-underline">More</span>
              <svg class="arrow-icon" viewBox="0 0 24 24"><path d="M7 10l5 5 5-5z"></path></svg>
            </button>
            <div class="dropdown-content">
              {moreItems.map((item) => (
                <a href={item.href} class="dropdown-link">{item.label}</a>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>
  </nav>

  <div class="header-word-bar">
    <div class="header-word-inner">
      <span class="spacer-text">&nbsp;</span>
    </div>
  </div>

  <div class="bottom-line" style={`background: ${labels.themeColor || '#872732'}`}></div>
</header>

<div id="menu-overlay" class="menu-overlay"></div>
<div id="side-menu" class="side-menu dark-theme">
  <div class="menu-header">
    <button id="menu-close-btn" class="close-btn" type="button">&times;</button>
    <div class="menu-title">{configLabelText}</div>
  </div>
  <div class="menu-content">
    <div class="current-selection-box">
      <p class="small-title">Current Setting</p>
      <div class="current-value">{labels.languageName} / {countryLabel}</div>
    </div>
    <div id="full-lang-list">
      {allActivePairs.map((pair) => (
        <a href={`/${pair.lang}/${pair.country}/`} class="lang-item">
          {langNames[pair.lang] || pair.lang} ({getCountryLabel(pair.country, lang)})
        </a>
      ))}
    </div>
  </div>
</div>

<script is:inline>
  (function() {
    function setupHeader() {
      const searchTrigger = document.getElementById('search-trigger');
      const searchInput = document.getElementById('search-input');
      const searchForm = document.getElementById('search-form');
      searchTrigger?.addEventListener('click', () => {
        if (!searchForm.classList.contains('expanded')) {
          searchForm.classList.add('expanded');
          searchInput.focus();
        } else if (searchInput.value.trim() !== "") {
          searchForm.submit();
        } else {
          searchForm.classList.remove('expanded');
        }
      });

      const openBtn = document.getElementById('menu-open-btn');
      const closeBtn = document.getElementById('menu-close-btn');
      const overlay = document.getElementById('menu-overlay');
      const menu = document.getElementById('side-menu');
      if (openBtn && closeBtn && overlay && menu) {
        const toggle = (open) => {
          menu.classList.toggle('open', open);
          overlay.classList.toggle('visible', open);
          document.body.style.overflow = open ? 'hidden' : '';
        };
        openBtn.onclick = () => toggle(true);
        closeBtn.onclick = () => toggle(false);
        overlay.onclick = () => toggle(false);
      }
    }
    setupHeader();
    document.addEventListener('astro:page-load', setupHeader);
  })();
</script>

<style>
  /* --- PC版レイアウト設定 --- */
  .site-header { background: #fff; width: 100%; }
  .header-top { max-width: 1280px; margin: 0 auto; padding: 10px 14px 8px; display: flex; justify-content: space-between; align-items: flex-start; }
  
  .brand-area { width: 220px; display: flex; flex-direction: column; }
  .logo-image { width: 100%; height: auto; }
  .country-name-aligned { text-align: right; font-size: 16px; font-weight: 700; color: #000; height: 34px; line-height: 34px; margin-top: 4px; }

  .right-area { display: flex; flex-direction: column; align-items: flex-end; gap: 10px; }
  .upper-row { width: 100%; display: flex; justify-content: flex-end; }
  .lower-row { width: 100%; display: flex; justify-content: flex-end; align-items: center; gap: 12px; height: 34px; }

  /* 検索窓（34px固定） */
  .search-form-expandable { display: flex; align-items: center; border: 2px solid #666; border-radius: 8px; background: #fff; overflow: hidden; transition: width 0.3s; width: 34px; height: 34px; }
  .search-form-expandable.expanded { width: 220px; }
  .search-input-hidden { width: 0; padding: 0; border: none; outline: none; font-size: 14px; background: transparent; }
  .search-form-expandable.expanded .search-input-hidden { width: 100%; padding: 0 10px; }
  .search-toggle-btn { width: 34px; height: 34px; background: #fff; border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; }
  .search-icon-large { width: 22px; height: 22px; stroke: #666; stroke-width: 2.5; fill: none; }

  /* 設定ボタン */
  .menu-combo-btn { display: flex; align-items: center; gap: 8px; background: #d8d3cc; border: none; border-radius: 8px; cursor: pointer; height: 34px; padding: 0 12px; }
  .menu-btn-text { font-size: 14px; font-weight: 700; color: #333; }
  .hamburger-icon { width: 20px; height: 20px; stroke: #333; stroke-width: 2.5; fill: none; }
  .current-setting-label { font-size: 15px; font-weight: 700; color: #000; height: 34px; line-height: 34px; }

  /* カテゴリーバーとMoreドロップダウン */
  .category-bar { background: #393737; width: 100%; }
  .category-nav-inner { max-width: 1280px; margin: 0 auto; }
  .pc-category-group { display: flex; align-items: center; }
  .category-link, .more-btn { height: 54px; display: inline-flex; align-items: center; padding: 0 16px; color: #fff; text-decoration: none; font-size: 15px; font-weight: 700; background: transparent; border: none; cursor: pointer; position: relative; }
  .category-link.active { background: var(--theme-color); }
  .category-text-with-underline { position: relative; }
  .category-link:hover .category-text-with-underline::after, .more-btn:hover .category-text-with-underline::after { content: ""; position: absolute; left: 0; bottom: -4px; width: 100%; height: 2px; background-color: #fff; }

  .more-dropdown { position: relative; }
  .dropdown-content { display: none; position: absolute; top: 100%; left: 0; background: #393737; min-width: 160px; z-index: 100; box-shadow: 0 8px 16px rgba(0,0,0,0.2); }
  .more-dropdown:hover .dropdown-content { display: block; }
  .dropdown-link { color: #fff; padding: 12px 16px; text-decoration: none; display: block; font-size: 14px; }
  .dropdown-link:hover { background: rgba(255,255,255,0.1); }
  .arrow-icon { width: 16px; height: 16px; fill: #fff; margin-left: 4px; }

  /* 下部の余白と線 */
  .header-word-bar { background: #fff; height: 36px; display: flex; align-items: center; }
  .spacer-text { font-size: 16px; visibility: hidden; }
  .bottom-line { height: 10px; width: 100%; }

  /* ドロワー設定 */
  .menu-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); visibility: hidden; opacity: 0; z-index: 9998; transition: 0.3s; }
  .menu-overlay.visible { visibility: visible; opacity: 1; }
  .side-menu { position: fixed; top: 0; right: -350px; width: 350px; height: 100%; background: #2c2c2c; z-index: 9999; transition: 0.3s; padding: 20px; color: #fff; }
  .side-menu.open { right: 0; }
  .lang-item { display: block; padding: 10px; color: #ccc; text-decoration: none; border-bottom: 1px solid #444; }

  /* --- スマホ版は一旦シンプルに維持（あとで設定します） --- */
  @media (max-width: 768px) {
    .lower-row, .country-name-aligned { display: none; }
    .pc-category-group { overflow-x: auto; white-space: nowrap; }
    .more-dropdown { display: none; } /* スマホではMoreを使わず横スクロールにすることが多いため */
  }
</style>
