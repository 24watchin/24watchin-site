---
import { categoryLabelMap, type SiteLanguageKey } from '../lib/categoryLabels';

const SPACE_ID = import.meta.env.CONTENTFUL_SPACE_ID;
const DELIVERY_TOKEN = import.meta.env.CONTENTFUL_DELIVERY_TOKEN;

const SITE_ID = 'jp-ja';
const SLOT = 'header_words';

type HeaderWord = {
  label: string;
  url: string;
  displayOrder: number;
};

let headerWords: HeaderWord[] = [];

if (SPACE_ID && DELIVERY_TOKEN) {
  try {
    const params = new URLSearchParams({
      content_type: 'headerWord',
      'fields.siteId': SITE_ID,
      'fields.slot': SLOT,
      'fields.enabled': 'true',
      order: 'fields.displayOrder',
      limit: '20',
    });

    const res = await fetch(
      `https://cdn.contentful.com/spaces/${SPACE_ID}/environments/master/entries?${params.toString()}`,
      {
        headers: {
          Authorization: `Bearer ${DELIVERY_TOKEN}`,
        },
      }
    );

    if (res.ok) {
      const data = await res.json();

      headerWords = (data.items ?? [])
        .map((item: any) => ({
          label: item?.fields?.label ?? '',
          url: item?.fields?.url ?? '#',
          displayOrder: Number(item?.fields?.displayOrder ?? 9999),
          enabled: item?.fields?.enabled ?? false,
          siteId: item?.fields?.siteId ?? '',
          slot: item?.fields?.slot ?? '',
        }))
        .filter(
          (item: any) =>
            item.enabled === true &&
            item.siteId === SITE_ID &&
            item.slot === SLOT &&
            item.label
        )
        .sort((a: any, b: any) => a.displayOrder - b.displayOrder)
        .map((item: any) => ({
          label: item.label,
          url: item.url,
          displayOrder: item.displayOrder,
        }));
    }
  } catch (e) {
    headerWords = [];
  }
}

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

// /jp/jp/... or /jp/en/... を想定
const pathParts = currentPath.split('/').filter(Boolean);
const detectedLocale = pathParts[1] as SiteLanguageKey | undefined;
const locale: SiteLanguageKey =
  detectedLocale && detectedLocale in categoryLabelMap ? detectedLocale : 'jp';

const labels = categoryLabelMap[locale];
const basePath = `/jp/${locale}`;

const categoryItems = labels.headerCategories.map((item) => ({
  href: `${basePath}/category/${item.slug}`,
  label: item.label,
}));

const homeHref = `${basePath}/`;
const searchAction = `${basePath}/search`;
---

<header class="site-header">
  <div class="header-top">
    <div class="brand-area">
      <a href={homeHref} class="logo-link" aria-label={`24Watchin ${labels.countryName}`}>
        <img
          src="/images/logo-24watchin.png"
          alt="24Watchin"
          class="logo-image"
        />
      </a>
      <div class="country-name">{labels.countryName}</div>
    </div>

    <div class="right-area">
      <div class="language-name">{labels.languageName}</div>

      <form action={searchAction} method="get" class="search-form">
        <input
          type="text"
          name="q"
          class="search-input"
          placeholder={labels.searchPlaceholder}
          aria-label={labels.searchAriaLabel}
        />
        <button type="submit" class="search-button" aria-label={labels.searchAriaLabel}>
          <svg
            class="search-icon"
            viewBox="0 0 24 24"
            aria-hidden="true"
            focusable="false"
          >
            <circle cx="11" cy="11" r="6.5"></circle>
            <line x1="16" y1="16" x2="21" y2="21"></line>
          </svg>
        </button>
      </form>
    </div>
  </div>

  <nav class:list={['category-bar', `locale-${locale}`]} aria-label={labels.categoryBarAriaLabel}>
    <div class="category-inner">
      {categoryItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            'category-link',
            currentPath === item.href && 'active'
          ]}
        >
          {item.label}
        </a>
      ))}
    </div>
  </nav>

  <div class="header-word-bar">
    <div class="header-word-inner">
      {
        headerWords.length > 0 ? (
          headerWords.map((item, index) => (
            <>
              {index > 0 && <span class="header-word-separator" aria-hidden="true">|</span>}
              <a href={item.url} class="header-word-link">
                {item.label}
              </a>
            </>
          ))
        ) : (
          <div class="header-word-empty"></div>
        )
      }
    </div>
  </div>

  <div class="bottom-line"></div>
</header>

<style>
  .site-header {
    width: 100%;
    background: #ffffff;
  }

  .header-top {
    max-width: 1280px;
    margin: 0 auto;
    padding: 10px 14px 8px;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 24px;
  }

  .brand-area {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .logo-link {
    display: inline-block;
    text-decoration: none;
  }

  .logo-image {
    display: block;
    width: 240px;
    max-width: 100%;
    height: auto;
  }

  .country-name {
    margin-top: 6px;
    font-size: 18px;
    font-weight: 700;
    line-height: 1.1;
    color: #000000;
    letter-spacing: 0;
    align-self: flex-end;
    text-align: right;
  }

  .right-area {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 12px;
    padding-top: 8px;
    flex-shrink: 0;
  }

  .language-name {
    font-size: 16px;
    font-weight: 400;
    line-height: 1.1;
    color: #000000;
  }

  .search-form {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .search-input {
    width: 190px;
    height: 36px;
    padding: 0 12px;
    border: 1px solid #c7c1ba;
    border-radius: 8px;
    background: #d8d3cc;
    color: #000000;
    font-size: 16px;
    outline: none;
    box-sizing: border-box;
  }

  .search-input::placeholder {
    color: #000000;
    opacity: 1;
  }

  .search-button {
    width: 36px;
    height: 36px;
    padding: 0;
    border: 1px solid #d8d8d8;
    border-radius: 8px;
    background: #ffffff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-sizing: border-box;
  }

  .search-icon {
    width: 18px;
    height: 18px;
    stroke: #393737;
    stroke-width: 2.2;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .category-bar {
    width: 100%;
    background: #393737;
  }

  .category-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 14px;
    display: flex;
    align-items: center;
    gap: 0;
    overflow-x: auto;
    white-space: nowrap;
    scrollbar-width: thin;
  }

  .category-link {
  display: inline-flex;
  align-items: center;
  height: 54px;
  padding: 0 18px;
  color: #ffffff;
  text-decoration: none;
  font-size: 16px;
  font-weight: 700;
  line-height: 1;
  border-bottom: none;
  box-shadow: none;
}

.locale-en .category-link {
  padding: 0 11px;
  font-size: 14px;
}

  .category-link::before,
  .category-link::after {
    display: none;
    content: none;
  }

  .category-link:hover,
  .category-link.active {
    color: #ffffff;
    text-decoration-line: underline;
    text-decoration-color: #e8383d;
    text-decoration-thickness: 3px;
    text-underline-offset: 10px;
    text-decoration-skip-ink: none;
  }

  .header-word-bar {
    width: 100%;
    background: #ffffff;
  }

  .header-word-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 11px 32px 13px;
    display: flex;
    align-items: center;
    gap: 0;
    overflow-x: auto;
    white-space: nowrap;
    scrollbar-width: thin;
  }

  .header-word-link {
    color: #111111;
    text-decoration: underline;
    text-underline-offset: 2px;
    font-size: 16px;
    font-weight: 400;
    line-height: 1.2;
  }

  .header-word-link:hover {
    color: #111111;
  }

  .header-word-separator {
    display: inline-block;
    margin: 0 1em;
    color: #b9b9b9;
    font-size: 16px;
    font-weight: 400;
    line-height: 1;
  }

  .header-word-empty {
    min-height: 24px;
    width: 100%;
  }

  .bottom-line {
    width: 100%;
    height: 10px;
    background: #872732;
  }

  @media (max-width: 900px) {
    .header-top {
      flex-direction: column;
      align-items: stretch;
      gap: 14px;
    }

    .right-area {
      align-items: flex-start;
      padding-top: 0;
    }

    .language-name {
      font-size: 16px;
    }

    .country-name {
      font-size: 18px;
    }

    .logo-image {
      width: 215px;
    }

    .search-form {
      width: 100%;
    }

    .search-input {
      width: 100%;
      flex: 1;
    }
  }

  @media (max-width: 767px) {
    .header-top {
      padding: 10px 12px 8px;
    }

    .logo-image {
      width: 195px;
    }

    .country-name {
      font-size: 18px;
    }

    .language-name {
      font-size: 16px;
    }

    .search-input,
    .search-button {
      height: 36px;
      font-size: 15px;
    }

    .category-link {
      height: 48px;
      padding: 0 14px;
      font-size: 14px;
      text-underline-offset: 8px;
    }

    .header-word-inner {
      padding: 10px 14px 12px;
    }

    .header-word-link,
    .header-word-separator {
      font-size: 14px;
    }
  }
</style>
