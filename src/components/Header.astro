---
import { categoryLabelMap, type SiteLanguageKey } from '../lib/categoryLabels';

const SPACE_ID = import.meta.env.CONTENTFUL_SPACE_ID;
const DELIVERY_TOKEN = import.meta.env.CONTENTFUL_DELIVERY_TOKEN;

const SITE_ID = 'jp-ja';
const SLOT = 'header_words';

type HeaderWord = {
  label: string;
  url: string;
  displayOrder: number;
};
let headerWords: HeaderWord[] = [];

if (SPACE_ID && DELIVERY_TOKEN) {
  try {
    const params = new URLSearchParams({
      content_type: 'headerWord',
      'fields.siteId': SITE_ID,
      'fields.slot': SLOT,
      'fields.enabled': 'true',
      order: 'fields.displayOrder',
      limit: '20',
    });
    const res = await fetch(
      `https://cdn.contentful.com/spaces/${SPACE_ID}/environments/master/entries?${params.toString()}`,
      {
        headers: { Authorization: `Bearer ${DELIVERY_TOKEN}` },
      }
    );
    if (res.ok) {
      const data = await res.json();
      headerWords = (data.items ?? [])
        .map((item: any) => ({
          label: item?.fields?.label ?? '',
          url: item?.fields?.url ?? '#',
          displayOrder: Number(item?.fields?.displayOrder ?? 9999),
          enabled: item?.fields?.enabled ?? false,
          siteId: item?.fields?.siteId ?? '',
          slot: item?.fields?.slot ?? '',
        }))
        .filter((item: any) =>
          item.enabled === true &&
          item.siteId === SITE_ID &&
          item.slot === SLOT &&
          item.label
        )
        .sort((a: any, b: any) => a.displayOrder - b.displayOrder)
        .map((item: any) => ({
          label: item.label,
          url: item.url,
          displayOrder: item.displayOrder,
        }));
    }
  } catch (e) {
    headerWords = [];
  }
}

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const pathParts = currentPath.split('/').filter(Boolean);

const lang = pathParts[0] || 'ja';
const country = pathParts[1] || 'jp';

const localeKeyMap: Record<string, string> = {
  ja: 'jp', en: 'en', 'zh-cn': 'zh-cn',
  'zh-tw': 'zh-tw', es: 'es', de: 'de', fr: 'fr', ru: 'ru',
};
const localeKey = (localeKeyMap[lang] || 'jp') as SiteLanguageKey;
const labels = categoryLabelMap[localeKey] || categoryLabelMap.jp;

const basePath = '/' + lang + '/' + country;
const cleanCurrentPath = currentPath.endsWith('/') ? currentPath.slice(0, -1) : currentPath;

const categoryItems = labels.headerCategories.map((item) => {
  const href = basePath + '/category/' + item.slug + '/';
  const hrefClean = basePath + '/category/' + item.slug;
  const isActive = cleanCurrentPath === hrefClean;
  return { href, label: item.label, isActive, slug: item.slug };
});

const homeHref = basePath + '/';
const searchAction = basePath + '/search';

const languageName = labels.languageName;
const searchPlaceholder = labels.searchPlaceholder;
const searchAriaLabel = labels.searchAriaLabel;
const categoryBarAriaLabel = labels.categoryBarAriaLabel;

const countryNameMap: Record<string, string> = {
  jp: 'JAPAN', en: 'JAPAN', 'zh-cn': '日本',
  'zh-tw': '日本', es: 'JAPÓN', fr: 'JAPON',
  de: 'JAPAN', ru: 'ЯПОНИЯ',
};
const displayCountryName = countryNameMap[localeKey] || 'JAPAN';

const moreSlugsMap: Record<string, string[]> = {
  jp:      ['health-life', 'weather', 'traffic'],
  en:      ['environment-energy', 'sports', 'health-life', 'weather', 'traffic'],
  es:      ['environment-energy', 'sports', 'health-life', 'weather', 'traffic'],
  fr:      ['environment-energy', 'sports', 'health-life', 'weather', 'traffic'],
  de:      ['environment-energy', 'sports', 'health-life', 'weather', 'traffic'],
  ru:      ['environment-energy', 'sports', 'health-life', 'weather', 'traffic'],
  'zh-cn': [],
  'zh-tw': [],
};
const moreSlugs = moreSlugsMap[localeKey] || [];
const needsMore = moreSlugs.length > 0;

const mainItems = needsMore
  ? categoryItems.filter(item => !moreSlugs.includes(item.slug))
  : categoryItems;
const moreItems = needsMore
  ? categoryItems.filter(item => moreSlugs.includes(item.slug))
  : [];

const moreTextMap: Record<string, string> = {
  jp: 'さらに見る', en: 'More', es: 'Más', fr: 'Plus', de: 'Mehr', ru: 'Ещё',
};
const moreText = moreTextMap[localeKey] || 'More';
const moreHasActive = moreItems.some(item => item.isActive);

const languageOptions = [
  { code: 'ja',    key: 'jp',    label: '日本語',   barStyle: 'background:#872732' },
  { code: 'en',    key: 'en',    label: 'English',  barStyle: 'background:#001580' },
  { code: 'zh-cn', key: 'zh-cn', label: '简体中文', barStyle: 'background:#0e7c7b' },
  { code: 'zh-tw', key: 'zh-tw', label: '繁體中文', barStyle: 'background:#b33224' },
  { code: 'es',    key: 'es',    label: 'Español',  barStyle: 'background:#b38000' },
  { code: 'fr',    key: 'fr',    label: 'Français', barStyle: 'background:#3d3d99' },
  { code: 'de',    key: 'de',    label: 'Deutsch',  barStyle: 'background:#006600' },
  { code: 'ru',    key: 'ru',    label: 'Русский',  barStyle: 'background:#500d80' },
].map(opt => ({
  ...opt,
  href: '/' + opt.code + '/' + country + '/',
  linkClass: opt.key === localeKey ? 'lang-option current' : 'lang-option',
}));
---

<header class="site-header">
  <div class="header-top">
    <div class="brand-area">
      <a href={homeHref} class="logo-link" aria-label="24Watchin">
        <img src="/images/logo-24watchin.png" alt="24Watchin" class="logo-image" />
      </a>
      <div class="country-name">{displayCountryName}</div>
    </div>

    <div class="right-area">
      <form action={searchAction} method="get" class="search-form">
        <input type="text" name="q" class="search-input" placeholder={searchPlaceholder} aria-label={searchAriaLabel} />
        <button type="submit" class="search-button" aria-label={searchAriaLabel}>
          <svg class="search-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <circle cx="11" cy="11" r="6.5"></circle>
            <line x1="16" y1="16" x2="21" y2="21"></line>
          </svg>
        </button>
      </form>
      <div class="lang-switcher">
        <div class="lang-current">{languageName} ▾</div>
        <div class="lang-dropdown">
          {languageOptions.map((opt) => (
            <a href={opt.href} class={opt.linkClass}>
              <span class="lang-bar" style={opt.barStyle}></span>
              {opt.label}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>

  <nav class="category-bar" aria-label={categoryBarAriaLabel}>
    <div class="category-nav-inner">

      <button class="scroll-arrow arrow-left" id="arrow-left" aria-label="左へ" type="button">&#8249;</button>

      <div class="pc-category-group">
        <div class="category-scroll pc-scroll" id="pc-scroll">
          {mainItems.map((item) => (
            <a href={item.href} class={item.isActive ? 'category-link active' : 'category-link'}>
              <span class="category-link-text">{item.label}</span>
            </a>
          ))}
        </div>

        {needsMore && (
          <div class="more-wrapper pc-more">
            <div class={moreHasActive ? 'more-btn active' : 'more-btn'}>
              {moreText}
              <svg class="more-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <polyline points="6 9 12 15 18 9"></polyline>
              </svg>
            </div>
            <div class="more-dropdown">
              {moreItems.map((item) => (
                <a href={item.href} class={item.isActive ? 'more-link active' : 'more-link'}>
                  {item.label}
                </a>
              ))}
            </div>
          </div>
        )}
      </div>

      <div class="category-scroll sp-scroll">
        {categoryItems.map((item) => (
          <a href={item.href} class={item.isActive ? 'category-link active' : 'category-link'}>
            <span class="category-link-text">{item.label}</span>
          </a>
        ))}
      </div>

      <button class="scroll-arrow arrow-right" id="arrow-right" aria-label="右へ" type="button">&#8250;</button>

    </div>
  </nav>

  <div class="header-word-bar">
    <div class="header-word-inner">
      {headerWords.length > 0 ? (
        headerWords.map((item, index) => (
          <>
            {index > 0 && <span class="header-word-separator" aria-hidden="true">|</span>}
            <a href={item.url} class="header-word-link">{item.label}</a>
          </>
        ))
      ) : (
        <div class="header-word-empty"></div>
      )}
    </div>
  </div>
  <div class="bottom-line"></div>
</header>

<style>
  .site-header { width: 100%; background: #ffffff; }
  .header-top { max-width: 1280px; margin: 0 auto; padding: 10px 14px 8px; display: flex; justify-content: space-between; align-items: center; gap: 12px; }

  /* ▼ 変更①：align-items を flex-end に → JAPANがロゴ右端に揃う */
  .brand-area { display: flex; flex-direction: column; align-items: flex-end; flex-shrink: 0; }
  .logo-link { display: inline-block; text-decoration: none; }
  .logo-image { display: block; width: 200px; max-width: 100%; height: auto; }
  .country-name { margin-top: 4px; font-size: 16px; font-weight: 700; color: #000000; }
  .right-area { display: flex; flex-direction: column; align-items: flex-end; gap: 8px; flex-shrink: 0; }
  .search-form { display: flex; align-items: center; gap: 6px; }
  .search-input { width: 180px; height: 34px; padding: 0 10px; border: 1px solid #c7c1ba; border-radius: 8px; background: #d8d3cc; color: #000000; font-size: 15px; outline: none; }
  .search-button { width: 34px; height: 34px; border: 1px solid #d8d8d8; border-radius: 8px; background: #ffffff; display: flex; align-items: center; justify-content: center; cursor: pointer; flex-shrink: 0; }
  .search-icon { width: 16px; height: 16px; stroke: #393737; stroke-width: 2.2; fill: none; }
  .lang-switcher { position: relative; }
  .lang-current { font-size: 13px; color: #333;
