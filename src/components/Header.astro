  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(-5px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script is:inline>
  window.addEventListener('load', function() {
    // 既存機能（検索・地域パネル・スクロール）
    function setupSearch(btnId, inputId, formId) {
      const btn = document.getElementById(btnId), input = document.getElementById(inputId), form = document.getElementById(formId);
      btn?.addEventListener('click', (e) => {
        if (!input.classList.contains('active')) { e.preventDefault(); input.classList.add('active'); input.focus(); }
        else if (input.value.trim() === '') { e.preventDefault(); input.classList.remove('active'); }
        else form.submit();
      });
    }
    setupSearch('pc-search-icon-btn', 'pc-search-input', 'pc-search-form');
    setupSearch('sp-search-icon-btn', 'sp-search-input', 'sp-search-form');

    const pcRegionBtn = document.getElementById('pc-region-lang-btn'), spRegionBtn = document.getElementById('sp-region-lang-btn'), rlPanel = document.getElementById('rl-panel'), rlOverlay = document.getElementById('rl-overlay');
    const openRL = (btn) => {
      rlPanel.classList.add('open'); rlOverlay.classList.add('open');
      const activeLangBtn = document.querySelector('.rl-lang-btn[data-lang="' + btn.dataset.currentLang + '"]');
      activeLangBtn?.click();
    };
    pcRegionBtn?.addEventListener('click', () => openRL(pcRegionBtn));
    spRegionBtn?.addEventListener('click', () => openRL(spRegionBtn));

    const pcScroll = document.getElementById('pc-scroll'), pcBtnLeft = document.getElementById('pc-arrow-left'), pcBtnRight = document.getElementById('pc-arrow-right');
    const updateArrows = () => {
      if (!pcScroll || !pcBtnLeft || !pcBtnRight) return;
      if (window.innerWidth > 1000 || window.innerWidth <= 768) { pcBtnLeft.classList.remove('active'); pcBtnRight.classList.remove('active'); }
      else {
        pcScroll.scrollLeft <= 5 ? pcBtnLeft.classList.remove('active') : pcBtnLeft.classList.add('active');
        pcScroll.scrollLeft >= (pcScroll.scrollWidth - pcScroll.clientWidth - 5) ? pcBtnRight.classList.remove('active') : pcBtnRight.classList.add('active');
      }
    };
    pcBtnLeft?.addEventListener('click', () => pcScroll.scrollBy({ left: -200, behavior: 'smooth' }));
    pcBtnRight?.addEventListener('click', () => pcScroll.scrollBy({ left: 200, behavior: 'smooth' }));
    pcScroll?.addEventListener('scroll', updateArrows);
    window.addEventListener('resize', updateArrows);
    updateArrows();

    // ================================================= */
    // ▼▼▼ LanguageTopHeader から 1文字も変えずに移植したスクリプト ▼▼▼ */
    // ================================================= */
    var catCountryPanel = document.getElementById('cat-country-panel');
    var catCountryInner = document.getElementById('cat-country-panel-inner');
    var catCountryTitle = document.getElementById('cat-country-title');
    var catCountryClose = document.getElementById('cat-country-close');
    var countriesDataEl = document.getElementById('lang-top-countries-data');
    var currentPanelSlug = null;

    if (catCountryPanel && countriesDataEl) {
      var availableCountries = JSON.parse(countriesDataEl.textContent);
      var currentLang = document.documentElement.lang || 'ja';

      document.querySelectorAll('.cat-dropdown-trigger').forEach(function(btn) {
        btn.addEventListener('click', function(e) {
          e.preventDefault();
          e.stopPropagation();
          var slug = btn.getAttribute('data-slug');
          var catName = btn.textContent.trim();

          if (catCountryPanel.classList.contains('show') && currentPanelSlug === slug) {
            catCountryPanel.classList.remove('show');
            currentPanelSlug = null;
            return;
          }

          currentPanelSlug = slug;
          if (catCountryTitle) { catCountryTitle.textContent = catName; }
          var rect = btn.getBoundingClientRect();
          catCountryInner.innerHTML = ''; 

          availableCountries.forEach(function(c) {
            var a = document.createElement('a');
            a.className = 'cat-country-link';
            a.href = '/' + currentLang + '/' + c.code + '/category/' + slug + '/';
            a.innerHTML = '<span class="cat-country-icon">▶</span>' + c.name;
            catCountryInner.appendChild(a);
          });

          var top = rect.bottom + window.scrollY + 8;
          var left = rect.left + window.scrollX;

          // 計算数値も「220/240」に完全一致させています
          if (window.innerWidth <= 600) {
             left = (window.innerWidth - 220) / 2;
          } else if (left + 220 > window.innerWidth) {
             left = window.innerWidth - 240;
          }

          catCountryPanel.style.top = top + 'px';
          catCountryPanel.style.left = left + 'px';
          catCountryPanel.classList.add('show');
        });
      });

      if (catCountryClose) {
        catCountryClose.addEventListener('click', function(e) {
          e.stopPropagation();
          catCountryPanel.classList.remove('show');
          currentPanelSlug = null;
        });
      }

      document.addEventListener('click', function(e) {
        if (!e.target.closest('.cat-country-panel') && !e.target.closest('.cat-dropdown-trigger')) {
           catCountryPanel.classList.remove('show');
           currentPanelSlug = null;
        }
      });
    }
  });
</script>
