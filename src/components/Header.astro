<style>
  /* --- PC版レイアウト設定 --- */
  .site-header { background: #fff; width: 100%; }
  .header-top { max-width: 1280px; margin: 0 auto; padding: 10px 14px 8px; display: flex; justify-content: space-between; align-items: flex-start; }
  
  .brand-area { width: 220px; display: flex; flex-direction: column; }
  .logo-image { width: 100%; height: auto; }
  /* 国名の高さを34pxにして他と揃える */
  .country-name-aligned { text-align: right; font-size: 16px; font-weight: 700; color: #000; height: 34px; line-height: 34px; margin-top: 4px; }

  .right-area { display: flex; flex-direction: column; align-items: flex-end; gap: 10px; }
  .upper-row { width: 100%; display: flex; justify-content: flex-end; }
  .lower-row { width: 100%; display: flex; justify-content: flex-end; align-items: center; gap: 12px; height: 34px; }

  /* 検索窓 */
  .search-form-expandable { display: flex; align-items: center; border: 2px solid #666; border-radius: 8px; background: #fff; overflow: hidden; transition: width 0.3s; width: 34px; height: 34px; }
  .search-form-expandable.expanded { width: 220px; }
  .search-input-hidden { width: 0; padding: 0; border: none; outline: none; font-size: 14px; background: transparent; }
  .search-form-expandable.expanded .search-input-hidden { width: 100%; padding: 0 10px; }
  .search-toggle-btn { width: 34px; height: 34px; background: #fff; border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; }
  .search-icon-large { width: 22px; height: 22px; stroke: #666; stroke-width: 2.5; fill: none; }

  /* 設定ボタン（グレー枠） */
  .menu-combo-btn { display: flex; align-items: center; gap: 8px; background: #d8d3cc; border: none; border-radius: 8px; cursor: pointer; height: 34px; padding: 0 12px; }
  .menu-btn-text { font-size: 14px; font-weight: 700; color: #333; }
  .hamburger-icon { width: 20px; height: 20px; stroke: #333; stroke-width: 2.5; fill: none; }
  .current-setting-label { font-size: 15px; font-weight: 700; color: #000; height: 34px; line-height: 34px; }

  /* カテゴリーバー（BK復元） */
  .category-bar { background: #393737; width: 100%; }
  .category-nav-inner { max-width: 1280px; margin: 0 auto; }
  .pc-category-group { display: flex; align-items: center; }
  .category-link, .more-btn { height: 54px; display: inline-flex; align-items: center; padding: 0 16px; color: #fff; text-decoration: none; font-size: 15px; font-weight: 700; background: transparent; border: none; cursor: pointer; position: relative; }
  .category-link.active { background: var(--theme-color); }
  .category-text-with-underline { position: relative; }
  .category-link:hover .category-text-with-underline::after, .more-btn:hover .category-text-with-underline::after { content: ""; position: absolute; left: 0; bottom: -4px; width: 100%; height: 2px; background-color: #fff; }

  .more-dropdown { position: relative; }
  .dropdown-content { display: none; position: absolute; top: 100%; left: 0; background: #393737; min-width: 160px; z-index: 100; box-shadow: 0 8px 16px rgba(0,0,0,0.2); }
  .more-dropdown:hover .dropdown-content { display: block; }
  .dropdown-link { color: #fff; padding: 12px 16px; text-decoration: none; display: block; font-size: 14px; }
  .dropdown-link:hover { background: rgba(255,255,255,0.1); }
  .arrow-icon { width: 16px; height: 16px; fill: #fff; margin-left: 4px; }

  /* 下部の余白と線 */
  .header-word-bar { background: #fff; height: 36px; display: flex; align-items: center; }
  .spacer-text { font-size: 16px; visibility: hidden; }
  .bottom-line { height: 10px; width: 100%; }

  /* --- ドロワーメニュー設定（修正箇所） --- */
  .menu-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); visibility: hidden; opacity: 0; z-index: 9998; transition: 0.5s; }
  .menu-overlay.visible { visibility: visible; opacity: 1; }
  
  .side-menu { 
    position: fixed; top: 0; right: -350px; width: 350px; height: 100%; 
    background: #2c2c2c; color: #fff; z-index: 9999; 
    transition: 0.5s; box-shadow: -5px 0 20px rgba(0,0,0,0.5); 
    display: flex; flex-direction: column; 
    visibility: hidden; /* 最初は完全に消す */
  }
  .side-menu.open { right: 0; visibility: visible; }
  
  .menu-header { padding: 25px 20px; border-bottom: 1px solid #444; display: flex; align-items: center; gap: 15px; }
  .close-btn { background: none; border: none; font-size: 35px; color: #fff; cursor: pointer; line-height: 1; }
  .menu-title { font-size: 20px; font-weight: 700; }
  
  /* スクロール可能にするための修正 */
  .menu-content { padding: 20px; overflow-y: auto; flex: 1; -webkit-overflow-scrolling: touch; }
  .current-selection-box { background: rgba(255,255,255,0.05); padding: 20px; border-radius: 12px; margin-bottom: 20px; }
  .lang-item { display: block; padding: 14px 10px; border-bottom: 1px solid #3d3d3d; text-decoration: none; color: #ccc; font-size: 15px; transition: 0.3s; }
  .lang-item:hover { color: #fff; background: rgba(255,255,255,0.1); }

  @media (max-width: 768px) {
    .side-menu { width: 85%; right: -85%; }
    .lower-row, .country-name-aligned { display: none; }
    .pc-category-group { overflow-x: auto; white-space: nowrap; }
    .more-dropdown { display: none; }
  }
</style>

<script is:inline>
  (function() {
    function setupHeader() {
      // 検索窓
      const searchTrigger = document.getElementById('search-trigger');
      const searchInput = document.getElementById('search-input');
      const searchForm = document.getElementById('search-form');
      searchTrigger?.addEventListener('click', () => {
        if (!searchForm.classList.contains('expanded')) {
          searchForm.classList.add('expanded');
          searchInput.focus();
        } else if (searchInput.value.trim() !== "") {
          searchForm.submit();
        } else {
          searchForm.classList.remove('expanded');
        }
      });

      // ドロワーメニュー
      const openBtn = document.getElementById('menu-open-btn');
      const closeBtn = document.getElementById('menu-close-btn');
      const overlay = document.getElementById('menu-overlay');
      const menu = document.getElementById('side-menu');
      if (openBtn && closeBtn && overlay && menu) {
        const toggle = (open) => {
          menu.classList.toggle('open', open);
          overlay.classList.toggle('visible', open);
          document.body.style.overflow = open ? 'hidden' : '';
        };
        openBtn.onclick = () => toggle(true);
        closeBtn.onclick = () => toggle(false);
        overlay.onclick = () => toggle(false);
      }
    }
    setupHeader();
    document.addEventListener('astro:page-load', setupHeader);
  })();
</script>
