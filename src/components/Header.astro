---
import HeaderLink from './HeaderLink.astro';

const SPACE_ID = import.meta.env.CONTENTFUL_SPACE_ID;
const DELIVERY_TOKEN = import.meta.env.CONTENTFUL_DELIVERY_TOKEN;

const siteId = 'jp-ja';
const slot = 'header_words';

type HeaderWordItem = {
  label: string;
  url: string;
  displayOrder: number;
};

let headerWords: HeaderWordItem[] = [];

if (SPACE_ID && DELIVERY_TOKEN) {
  try {
    const query = new URLSearchParams({
      content_type: 'headerWord',
      'fields.siteId': siteId,
      'fields.slot': slot,
      'fields.enabled': 'true',
      order: 'fields.displayOrder',
      limit: '20',
    });

    const response = await fetch(
      `https://cdn.contentful.com/spaces/${SPACE_ID}/environments/master/entries?${query.toString()}`,
      {
        headers: {
          Authorization: `Bearer ${DELIVERY_TOKEN}`,
        },
      }
    );

    if (response.ok) {
      const data = await response.json();

      headerWords = (data.items ?? [])
        .map((item: any) => ({
          label: item?.fields?.label ?? '',
          url: item?.fields?.url ?? '#',
          displayOrder: Number(item?.fields?.displayOrder ?? 9999),
          enabled: item?.fields?.enabled ?? false,
          itemSiteId: item?.fields?.siteId ?? '',
          itemSlot: item?.fields?.slot ?? '',
        }))
        .filter(
          (item: any) =>
            item.enabled === true &&
            item.itemSiteId === siteId &&
            item.itemSlot === slot &&
            item.label
        )
        .sort((a: HeaderWordItem, b: HeaderWordItem) => a.displayOrder - b.displayOrder)
        .map(({ label, url, displayOrder }: HeaderWordItem) => ({
          label,
          url,
          displayOrder,
        }));
    }
  } catch (error) {
    headerWords = [];
  }
}

const menuItems = [
  { href: '/jp/jp/', label: 'ホーム' },
  { href: '/jp/jp/search?category=international', label: '国際' },
  { href: '/jp/jp/search?category=politics', label: '政治' },
  { href: '/jp/jp/search?category=economy', label: '経済' },
  { href: '/jp/jp/search?category=society', label: '社会' },
  { href: '/jp/jp/search?category=technology', label: 'テクノロジー' },
  { href: '/jp/jp/search?category=entertainment', label: 'エンタメ' },
  { href: '/jp/jp/search?category=sports', label: 'スポーツ' },
];
---

<header class="site-header">
  <div class="top-area">
    <a href="/jp/jp/" class="logo-area" aria-label="24Watchin Japan ホーム">
      <img src="/images/logo-24watchin.png" alt="24Watchin" class="logo-image" />
      <div class="country-name">JAPAN</div>
    </a>

    <div class="language-name">日本語</div>
  </div>

  <div class="header-word-bar" aria-label="注目ワード">
    {
      headerWords.length > 0 ? (
        <div class="header-word-list">
          {headerWords.map((item) => (
            <a href={item.url} class="header-word-link">
              {item.label}
            </a>
          ))}
        </div>
      ) : (
        <div class="header-word-empty"></div>
      )
    }
  </div>

  <nav class="menu-bar" aria-label="メインメニュー">
    <div class="menu-inner">
      {menuItems.map((item) => (
        <HeaderLink href={item.href}>{item.label}</HeaderLink>
      ))}
    </div>
  </nav>

  <div class="bottom-line"></div>
</header>

<style>
  .site-header {
    width: 100%;
    background: #ffffff;
  }

  .top-area {
    max-width: 1200px;
    margin: 0 auto;
    padding: 18px 16px 14px;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
  }

  .logo-area {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    text-decoration: none;
    color: inherit;
  }

  .logo-image {
    display: block;
    width: 220px;
    max-width: 100%;
    height: auto;
  }

  .country-name {
    margin-top: 6px;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: #393737;
  }

  .language-name {
    font-size: 14px;
    font-weight: 700;
    color: #393737;
    white-space: nowrap;
    padding-top: 4px;
  }

  .header-word-bar {
    width: 100%;
    background: #ffffff;
    border-top: 1px solid #ececec;
    border-bottom: 1px solid #ececec;
  }

  .header-word-list {
    max-width: 1200px;
    margin: 0 auto;
    padding: 10px 16px;
    display: flex;
    align-items: center;
    gap: 18px;
    overflow-x: auto;
    white-space: nowrap;
    scrollbar-width: thin;
  }

  .header-word-link {
    display: inline-block;
    font-size: 14px;
    line-height: 1.4;
    color: #393737;
    text-decoration: none;
  }

  .header-word-link:hover {
    color: #e8383d;
  }

  .header-word-empty {
    max-width: 1200px;
    margin: 0 auto;
    min-height: 42px;
    padding: 0 16px;
  }

  .menu-bar {
    width: 100%;
    background: #393737;
  }

  .menu-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 16px;
    display: flex;
    align-items: center;
    gap: 20px;
    overflow-x: auto;
    white-space: nowrap;
    scrollbar-width: thin;
  }

  .bottom-line {
    width: 100%;
    height: 4px;
    background: #872732;
  }

  @media (max-width: 767px) {
    .top-area {
      padding: 14px 12px 12px;
      gap: 12px;
    }

    .logo-image {
      width: 180px;
    }

    .country-name {
      font-size: 12px;
    }

    .language-name {
      font-size: 12px;
    }

    .header-word-list {
      padding: 9px 12px;
      gap: 14px;
    }

    .header-word-link {
      font-size: 13px;
    }

    .header-word-empty {
      min-height: 38px;
      padding: 0 12px;
    }

    .menu-inner {
      padding: 0 12px;
      gap: 16px;
    }
  }
</style>
