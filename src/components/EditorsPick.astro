---
// サイドバー用の「編集部のおすすめ」（縦並び）部品です
const API_KEY = import.meta.env.API_KEY;
const BLOG_ID = import.meta.env.BLOG_ID;
const url = `https://www.googleapis.com/blogger/v3/blogs/${BLOG_ID}/posts?key=${API_KEY}&maxResults=50`;

let allPosts = [];

// ▼ 【重要】APIの「取得しすぎ（429エラー）」を防ぐための記憶（キャッシュ）機能です！
// 100ページ分ビルドしても、Bloggerにデータを取りに行くのは最初の1回だけにします。
if (!globalThis.editorsPickCache) {
  try {
    const response = await fetch(url);
    if (response.ok) {
      const data = await response.json();
      globalThis.editorsPickCache = data.items || [];
    } else {
      globalThis.editorsPickCache = [];
    }
  } catch (e) {
    console.error("記事の取得に失敗しました", e);
    globalThis.editorsPickCache = [];
  }
}
// 記憶しておいたデータを、すべてのページで使い回します
allPosts = globalThis.editorsPickCache;

// ▼ 海外記事（us-jaなど）を弾くバリア
const isForeignPost = (post) => {
  if (!post.labels) return false;
  return post.labels.some(label => /^[a-z]{2}-ja$/.test(label) && label !== 'jp-ja');
};

// 安全な日本版の記事だけを抽出します
const safePosts = allPosts.filter(p => !isForeignPost(p));

// ▼ ここから「編集部①」などのタグを探して並べ替える仕組みです
const topPostsMap = new Map();
const topLabelRegex = /^編集部([①②③④⑤⑥⑦⑧⑨⑩])$/;
const numMap = { '①':1, '②':2, '③':3, '④':4, '⑤':5, '⑥':6, '⑦':7, '⑧':8, '⑨':9, '⑩':10 };

safePosts.forEach(post => {
  if (!post.labels) return;
  post.labels.forEach(label => {
    const match = label.match(topLabelRegex);
    if (match) {
      const num = numMap[match[1]];
      if (!topPostsMap.has(num)) {
        topPostsMap.set(num, post);
      }
    }
  });
});

// 指定された記事を順番に並べます
let finalPosts = Array.from(topPostsMap.entries())
  .sort((a, b) => a[0] - b[0])
  .map(entry => entry[1]);

// 足りない枠に入れるための「普通の最新記事」を準備します
const usedIds = new Set(finalPosts.map(p => p.id));
const normalPosts = safePosts.filter(p => !usedIds.has(p.id));

// 5件になるまで最新記事を補充します
while (finalPosts.length < 5 && normalPosts.length > 0) {
  finalPosts.push(normalPosts.shift());
}

const displayPosts = finalPosts.slice(0, 5);

// 補助機能（画像と時間）
const getImageUrl = (content) => {
  const match = (content || '').match(/<img[^>]+src="([^">]+)"/);
  return match ? match[1] : 'https://placehold.co/80x60/eeeeee/999999?text=No+Image';
};
const formatTime = (dateString) => {
  if (!dateString) return '';
  const date = new Date(dateString);
  return `${String(date.getHours()).padStart(2, '0')}:${String(date.getMinutes()).padStart(2, '0')}`;
};
---

<div class="editors-pick-container">
  <div class="ep-header">
    <h2>編集部のおすすめ</h2>
  </div>

  <ul class="ep-list">
    {displayPosts.map((post) => (
      <li class="ep-item">
        <div class="ep-text-area">
          <a href={`/jp/jp/news/${post.id}/`} class="ep-title">{post.title}</a>
          <div class="ep-meta">
            <span class="ep-time">{formatTime(post.published)}</span>
            <span class="ep-source">📰 24Watchin</span>
          </div>
        </div>
        
        <div class="ep-thumbnail">
          <img src={getImageUrl(post.content)} alt="サムネイル" />
        </div>
      </li>
    ))}
  </ul>
</div>

<style>
  .editors-pick-container { background-color: #fff; font-family: sans-serif; }
  
  .ep-header { background-color: #872732; color: #fff; padding: 10px 15px; border-radius: 8px 8px 0 0; }
  .ep-header h2 { font-size: 16px; font-weight: bold; margin: 0; }
  
  .ep-list { list-style: none; padding: 0; margin: 0; border: 1px solid #ccc; border-top: none; }
  .ep-item { display: flex; justify-content: space-between; padding: 12px 10px; border-bottom: 1px dotted #ccc; gap: 10px; }
  .ep-item:last-child { border-bottom: none; }
  
  .ep-text-area { flex: 1; display: flex; flex-direction: column; justify-content: space-between; }
  .ep-title { font-size: 14px; color: #333; text-decoration: none; font-weight: bold; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .ep-title:hover { text-decoration: underline; }
  
  .ep-meta { font-size: 11px; color: #666; margin-top: 5px; }
  .ep-time { margin-right: 8px; }
  
  .ep-thumbnail img { width: 80px; height: 60px; object-fit: cover; border: 1px solid #eee; border-radius: 4px;}
</style>
