---
// 編集部のおすすめ用のダミーデータ（仮のデータ）を準備します。
// 今回は5個の記事があるように見せかけます。
const dummyPosts = [
  { title: "前三原市長・天満祥典氏の公選法違反 竹原市長「公民権停止知らな…", time: "19時18分", source: "中国新聞", img: "https://placehold.co/80x60?text=No+Image" },
  { title: "【事件】浜田の農道で橋の名板12枚盗まれる", time: "19時15分", source: "中国新聞", img: "https://placehold.co/80x60?text=No+Image" },
  { title: "県民会館大ホールの空調が復旧、2月28日から通常利用を再開 防…", time: "19時10分", source: "新潟日報", img: "https://placehold.co/80x60?text=No+Image" },
  { title: "茨城県内中学校で卒業式 潮来・牛堀中 最後の35人、学びやに別れ", time: "19時06分", source: "茨城新聞", img: "https://placehold.co/80x60?text=No+Image" },
  { title: "3月10日の市長往来（広島県東部）", time: "19時05分", source: "中国新聞", img: "https://placehold.co/80x60?text=No+Image" }
];
---

<div class="editors-pick-container">
  {/* 赤いタイトルの部分です */}
  <div class="ep-header">
    <h2>編集部のおすすめ</h2>
  </div>

  {/* 記事のリスト部分です */}
  <ul class="ep-list">
    {/* 用意したダミーデータを順番に表示させる魔法のコードです */}
    {dummyPosts.map((post) => (
      <li class="ep-item">
        {/* 左側の文字エリア */}
        <div class="ep-text-area">
          <a href="#" class="ep-title">{post.title}</a>
          <div class="ep-meta">
            <span class="ep-time">{post.time}</span>
            {/* アイコンはひとまず雪の結晶の絵文字で代用しています */}
            <span class="ep-source">❄️ {post.source}</span>
          </div>
        </div>
        
        {/* 右側の画像エリア */}
        <div class="ep-thumbnail">
          <img src={post.img} alt="サムネイル" />
        </div>
      </li>
    ))}
  </ul>
</div>

<style>
  /* 全体の枠組みの設定です */
  .editors-pick-container {
    background-color: #fff;
    font-family: sans-serif;
  }

  /* 赤いタイトルのデザインです */
  .ep-header {
    background-color: #ef3332; /* 画像に近い赤色にしています */
    color: #fff;
    padding: 10px 15px;
    border-radius: 8px 8px 0 0; /* 上の角だけ少し丸くして優しい印象にします */
    border-bottom: 2px solid #ff9999; /* タイトル下にあるオレンジっぽい線を再現しています */
  }
  .ep-header h2 {
    font-size: 16px;
    font-weight: bold;
    margin: 0;
  }

  /* リスト全体の設定です */
  .ep-list {
    list-style: none; /* 初期設定の黒い「・」を消します */
    padding: 0;
    margin: 0;
    border: 1px solid #ccc; /* リスト全体を囲む枠線です */
    border-top: none; /* 上の線はタイトルと被るので消しています */
  }

  /* リスト1行ごとの設定です */
  .ep-item {
    display: flex; /* 左に文字、右に画像を横並びにするための設定です */
    justify-content: space-between; /* 文字と画像を左右の端に振り分けます */
    padding: 12px 10px;
    border-bottom: 1px dotted #ccc; /* 記事と記事の間の点線です */
    gap: 10px; /* 文字と画像の間に少し隙間を空けます */
  }
  .ep-item:last-child {
    border-bottom: none; /* 一番下の記事の下には点線を引かないようにします */
  }

  /* 左側の文字エリアの設定です */
  .ep-text-area {
    flex: 1; /* 余ったスペースを全部文字エリアとして使います */
    display: flex;
    flex-direction: column; /* タイトルと時間を縦並びにします */
    justify-content: space-between; /* タイトルを上、時間を下に振り分けます */
  }

  /* 記事のタイトルの設定です */
  .ep-title {
    font-size: 14px;
    color: #333;
    text-decoration: none;
    font-weight: bold;
    line-height: 1.4;
    /* 2行目まで表示し、入りきらない場合は末尾を「...」にする設定です */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* 時間と新聞社名のエリアの設定です */
  .ep-meta {
    font-size: 11px;
    color: #666;
    margin-top: 5px;
  }
  .ep-time {
    margin-right: 8px; /* 時間と新聞社名の間に隙間を空けます */
  }

  /* 右側の画像の設定です */
  .ep-thumbnail img {
    width: 80px;
    height: 60px;
    object-fit: cover; /* 画像が歪まないように、指定したサイズに合わせて切り取ります */
    border: 1px solid #eee;
  }
</style>
