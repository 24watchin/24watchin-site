---
import { langCountryPairs } from '../lib/siteRoutes.ts';
import { getCountryLabel } from '../lib/countryData.ts';

// 8つの言語リスト
const languages = [
  { code: 'ja', label: '日本語' },
  { code: 'en', label: 'English' },
  { code: 'zh-cn', label: '简体中文' },
  { code: 'zh-tw', label: '繁體中文' },
  { code: 'es', label: 'Español' },
  { code: 'fr', label: 'Français' },
  { code: 'de', label: 'Deutsch' },
  { code: 'ru', label: 'Русский' }
];

// 対応している国と地域の設定
const regions = {
  asia: { id: 'asia', name: 'アジア・オセアニア', countries: ['jp', 'tw', 'kr', 'sg', 'cn', 'th', 'in', 'my', 'ph', 'vn', 'id', 'au', 'nz'] },
  europe: { id: 'europe', name: 'ヨーロッパ・中東', countries: ['de', 'fr', 'gb', 'it', 'es', 'ae', 'za', 'eg', 'qa', 'om', 'sa', 'tr'] },
  americas: { id: 'americas', name: '南北アメリカ', countries: ['us', 'ca', 'mx', 'br', 'ar', 'co'] }
};

// 全言語・全対応国のリンクデータを生成してJSに渡す準備
const mapData: any = {};
languages.forEach(lang => {
  mapData[lang.code] = {};
  Object.values(regions).forEach(region => {
    mapData[lang.code][region.id] = region.countries
      .filter(countryCode => langCountryPairs.some(p => p.lang === lang.code && p.country === countryCode))
      .map(countryCode => ({
        code: countryCode,
        name: getCountryLabel(countryCode, lang.code),
        url: `/${lang.code}/${countryCode}/`
      }));
  });
});
---

<div class="interactive-world-map-container">
  {/* ▼ 1. 上部の8言語切り替えボタン */}
  <div class="map-lang-selector">
    {languages.map((lang, index) => (
      <button 
        class={`map-lang-btn ${index === 0 ? 'active' : ''}`} 
        data-lang={lang.code}
      >
        {lang.label}
      </button>
    ))}
  </div>

  <div class="map-display-area" id="map-display-area">
    
    {/* ▼ 2. 最初の画面（世界全体：3つの地域から選ぶ） */}
    <div class="map-view-global active" id="view-global">
      <h3 class="map-instruction">地域を選択してください</h3>
      <div class="region-cards">
        {Object.values(regions).map(region => (
          <button class="region-card-btn" data-region={region.id}>
            <div class={`region-icon icon-${region.id}`}></div>
            <span class="region-name">{region.name}</span>
          </button>
        ))}
      </div>
    </div>

    {/* ▼ 3. ズーム後の画面（選んだ地域の中の国リストが表示される） */}
    <div class="map-view-regional" id="view-regional">
      <button class="back-to-global-btn" id="back-to-global">&larr; 世界地図に戻る</button>
      <h3 class="map-instruction" id="regional-instruction">国を選択してください</h3>
      
      <div class="country-grid" id="country-grid">
        {/* ※ここはJavaScriptで選んだ言語・地域に合わせて自動で国ボタンが生成されます */}
      </div>
    </div>

  </div>
</div>

{/* ▼ JavaScriptにデータを渡すための隠しタグ */}
<script type="application/json" id="world-map-data" set:html={JSON.stringify(mapData)}></script>

<style>
  .interactive-world-map-container {
    width: 100%;
    background: #ffffff;
    border: 1px solid #e0e0e0;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.05);
    overflow: hidden;
    margin-bottom: 40px;
    display: flex;
    flex-direction: column;
  }

  /* --- 1. 言語切り替えボタンのデザイン --- */
  .map-lang-selector {
    display: flex;
    flex-wrap: wrap;
    background: #f8f9fa;
    border-bottom: 1px solid #e0e0e0;
    padding: 10px;
    gap: 8px;
    justify-content: center;
  }
  .map-lang-btn {
    background: #ffffff;
    border: 1px solid #cccccc;
    border-radius: 20px;
    padding: 6px 14px;
    font-size: 13px;
    font-weight: bold;
    color: #555555;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .map-lang-btn:hover { background: #eeeeee; }
  .map-lang-btn.active {
    background: var(--theme-color, #872732);
    color: #ffffff;
    border-color: var(--theme-color, #872732);
  }

  /* --- 2. 地図表示エリア（共通） --- */
  .map-display-area {
    position: relative;
    width: 100%;
    min-height: 380px;
    padding: 30px;
    box-sizing: border-box;
    /* ▼ 背景色と、世界地図の画像を設定しています */
    background-color: #f4f7f6;
    background-image: url('https://upload.wikimedia.org/wikipedia/commons/8/80/World_map_-_low_resolution.svg');
    background-size: cover;
    background-position: center;
    background-blend-mode: overlay;
    overflow: hidden;
  }
  .map-instruction {
    text-align: center;
    font-size: 20px;
    color: #333333;
    margin: 0 0 24px 0;
  }

  /* --- 画面の切り替えアニメーション設定 --- */
  .map-view-global, .map-view-regional {
    display: none;
    animation: fadeInZoom 0.4s cubic-bezier(0.1, 0.8, 0.3, 1);
  }
  .map-view-global.active, .map-view-regional.active {
    display: block;
  }
  @keyframes fadeInZoom {
    0% { opacity: 0; transform: scale(0.95); }
    100% { opacity: 1; transform: scale(1); }
  }

  /* --- 3. グローバルビュー（地域選択） --- */
  .region-cards {
    display: flex;
    justify-content: center;
    gap: 20px;
    flex-wrap: wrap;
  }
  .region-card-btn {
    background: #ffffff;
    border: 2px solid #dddddd;
    border-radius: 12px;
    width: 220px;
    height: 160px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 4px 10px rgba(0,0,0,0.05);
  }
  .region-card-btn:hover {
    transform: translateY(-5px);
    border-color: var(--theme-color, #872732);
    box-shadow: 0 8px 20px rgba(0,0,0,0.1);
  }
  .region-icon {
    width: 60px; height: 60px;
    background-color: #e0e0e0;
    border-radius: 50%;
    margin-bottom: 12px;
  }
  .region-name { font-size: 18px; font-weight: bold; color: #111111; }

  /* --- 4. リージョナルビュー（国選択） --- */
  .back-to-global-btn {
    position: absolute;
    top: 20px; left: 20px;
    background: #ffffff;
    border: 1px solid #cccccc;
    border-radius: 4px;
    padding: 6px 12px;
    font-size: 14px;
    font-weight: bold;
    color: #333333;
    cursor: pointer;
    transition: background 0.2s;
  }
  .back-to-global-btn:hover { background: #eeeeee; }
  
  .country-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
    max-width: 900px;
    margin: 0 auto;
  }
  /* JavaScriptで生成される国ボタンのデザイン */
  .country-btn-link {
    display: flex;
    align-items: center;
    justify-content: center;
    background: #ffffff;
    border: 1px solid #cccccc;
    border-radius: 8px;
    padding: 12px 20px;
    font-size: 16px;
    font-weight: bold;
    color: #111111;
    text-decoration: none;
    min-width: 120px;
    box-shadow: 0 2px 5px rgba(0,0,0,0.05);
    transition: all 0.2s ease;
  }
  .country-btn-link:hover {
    background: var(--theme-color, #872732);
    color: #ffffff;
    border-color: var(--theme-color, #872732);
    transform: translateY(-2px);
  }
  .no-country-msg {
    color: #666666; font-size: 16px; margin-top: 20px;
  }

  @media (max-width: 768px) {
    .region-card-btn { width: 100%; height: 100px; flex-direction: row; gap: 20px; }
    .region-icon { margin-bottom: 0; width: 40px; height: 40px; }
    .map-display-area { padding: 60px 20px 30px; }
  }
</style>

<script is:inline>
  window.addEventListener('load', function() {
    var dataEl = document.getElementById('world-map-data');
    if (!dataEl) return;
    
    var mapData = JSON.parse(dataEl.textContent);
    var currentLang = 'ja'; // 初期設定は日本語
    var currentRegion = null;

    var viewGlobal = document.getElementById('view-global');
    var viewRegional = document.getElementById('view-regional');
    var countryGrid = document.getElementById('country-grid');
    var backBtn = document.getElementById('back-to-global');
    
    // 1. 言語ボタンの切り替え
    var langBtns = document.querySelectorAll('.map-lang-btn');
    langBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        // 色を変える
        langBtns.forEach(function(b) { b.classList.remove('active'); });
        this.classList.add('active');
        
        // 言語を更新
        currentLang = this.getAttribute('data-lang');
        
        // もし国選択画面を開いていたら、その言語での国リストに更新する
        if (currentRegion) {
          renderCountries(currentRegion);
        }
      });
    });

    // 2. 地域カードをクリックした時（ズームイン）
    var regionBtns = document.querySelectorAll('.region-card-btn');
    regionBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        currentRegion = this.getAttribute('data-region');
        
        // 画面を切り替え
        viewGlobal.classList.remove('active');
        viewRegional.classList.add('active');
        
        // 選ばれた地域の国リストを表示
        renderCountries(currentRegion);
      });
    });

    // 3. 戻るボタンをクリックした時（ズームアウト）
    if (backBtn) {
      backBtn.addEventListener('click', function() {
        currentRegion = null;
        viewRegional.classList.remove('active');
        viewGlobal.classList.add('active');
      });
    }

    // 国ボタンを生成して並べる関数
    function renderCountries(regionId) {
      countryGrid.innerHTML = ''; // 一度リセット
      var countries = mapData[currentLang][regionId] || [];
      
      if (countries.length === 0) {
        countryGrid.innerHTML = '<p class="no-country-msg">この言語で対応している国はまだありません。</p>';
        return;
      }
      
      countries.forEach(function(c) {
        var a = document.createElement('a');
        a.href = c.url;
        a.className = 'country-btn-link';
        a.textContent = c.name;
        countryGrid.appendChild(a);
      });
    }
  });
</script>
