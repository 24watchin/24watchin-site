---
// SEOとスマホ表示を追求した「記事リスト」の部品です
const { posts, getImageUrl } = Astro.props;
---

<section class="more-news-section">
  <div class="more-news-list">
    {posts.map((post) => (
      <article class="list-item">
        <a href={`/news/${post.id}/`} class="item-link">
          <div class="image-wrapper">
            {/* object-fit: coverで、どんな形の写真も綺麗に枠に収めます */}
            <img 
              src={getImageUrl(post.content)} 
              alt={`${post.title}のアイキャッチ画像`} 
              class="list-image"
              loading="lazy" 
            />
          </div>
          <div class="list-content">
            <h4 class="list-title">{post.title}</h4>
            <div class="meta-info">
              <time datetime={post.published} class="date">
                {new Date(post.published).toLocaleDateString('ja-JP')}
              </time>
            </div>
          </div>
        </a>
      </article>
    ))}
  </div>
</section>

<style>
  /* 記事リスト全体の余白 */
  .more-news-section { margin-top: 2rem; }
  .more-news-list { display: flex; flex-direction: column; gap: 1.5rem; }

  /* リンク全体を囲う箱の設定 */
  .item-link {
    display: flex;
    gap: 1.2rem;
    text-decoration: none;
    color: #333;
    transition: opacity 0.2s;
  }
  .item-link:hover { opacity: 0.7; }

  /* 写真の枠：SEOを意識して固定比率にしています */
  .image-wrapper {
    width: 160px; /* PCでは少し大きめに */
    height: 100px;
    background: #f0f0f0;
    border-radius: 6px;
    overflow: hidden;
    flex-shrink: 0;
  }
  .list-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* 記事タイトルのデザイン：読みやすさを追求 */
  .list-title {
    font-size: 1.1rem;
    margin: 0 0 0.5rem 0;
    line-height: 1.5;
    font-weight: 600;
  }
  .date { font-size: 0.85rem; color: #666; }

  /* 【スマホ対策】画面が小さい時はレイアウトを変える */
  @media (max-width: 600px) {
    .image-wrapper {
      width: 120px; /* スマホでは写真を少し小さく */
      height: 80px;
    }
    .list-title { font-size: 1rem; }
  }
</style>