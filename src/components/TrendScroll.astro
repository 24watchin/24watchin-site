---
const API_KEY = import.meta.env.API_KEY;
const BLOG_ID = import.meta.env.BLOG_ID;
// 10件の記事を取得します
const url = `https://www.googleapis.com/blogger/v3/blogs/${BLOG_ID}/posts?key=${API_KEY}&maxResults=10`;

const response = await fetch(url).catch(() => null);
const data = response ? await response.json() : { items: [] };
const posts = data.items || [];

const getImageUrl = (content) => {
  const match = (content || '').match(/<img[^>]+src="([^">]+)"/);
  return match ? match[1] : 'https://placehold.co/300x200/eeeeee/999999?text=Trend';
};
---

<section class="bing-trend-section">
  <div class="trend-header">
    {/* ▼ タイトルを変更し、サブタイトルは消してスッキリさせました ▼ */}
    <h3>トレンドWatchin！</h3>
  </div>

  <div class="trend-scroll-outer">
    {/* ▼ 左に動かすボタンを追加しました ▼ */}
    <div class="scroll-arrow prev-arrow" id="btn-prev">
      <i class="fas fa-chevron-left"></i>
    </div>

    <div class="trend-scroll-container" id="trend-scroll">
      {posts.map((post) => (
        <a href={`/news/${post.id}/`} class="trend-item">
          <div class="trend-img-wrapper">
            <img src={getImageUrl(post.content)} alt={post.title} />
          </div>
          <h4 class="trend-title">{post.title}</h4>
        </a>
      ))}
    </div>

    {/* ▼ 右に動かすボタンを追加しました ▼ */}
    <div class="scroll-arrow next-arrow" id="btn-next">
      <i class="fas fa-chevron-right"></i>
    </div>
  </div>
</section>

<style>
  /* ▼ 6. 上の無駄なスペースを削り、キュッと詰めました ▼ */
  .bing-trend-section {
    padding: 10px 0 20px 0; 
    margin-top: 0; 
    background: #fff;
  }

  /* ▼ 3 & 4. 赤い下線（#8b0000）を引いたかっこいいタイトル設定 ▼ */
  .trend-header {
    margin-bottom: 20px;
  }
  .trend-header h3 {
    font-size: 24px;
    font-weight: bold;
    margin: 0;
    color: #111;
    display: inline-block;
    border-bottom: 4px solid #8b0000;
    padding-bottom: 5px;
  }

  .trend-scroll-outer {
    position: relative;
    display: flex;
    align-items: center;
  }

  .trend-scroll-container {
    display: flex;
    gap: 20px; 
    overflow-x: auto;
    padding: 10px 0; 
    scroll-behavior: smooth; /* スルスルと滑らかに動く魔法 */
    scrollbar-width: none;
    width: 100%;
  }
  .trend-scroll-container::-webkit-scrollbar {
    display: none;
  }

  /* ▼ 1. 画像のサイズを大きくし、画面に約6枚並ぶように計算しました ▼ */
  .trend-item {
    min-width: 180px; 
    max-width: 180px;
    text-decoration: none;
    color: #333;
    flex-shrink: 0;
  }

  .trend-img-wrapper {
    width: 100%;
    height: 120px; /* 高さを90pxから120pxにアップ */
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 10px;
    background: #f0f0f0;
  }

  .trend-img-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .trend-item:hover img {
    transform: scale(1.05); /* マウスオンで写真が少しズームします */
  }

  .trend-title {
    font-size: 14px; /* 読みやすく少し大きくしました */
    font-weight: bold; /* 太字にしました */
    line-height: 1.4;
    margin: 0;
    text-align: left;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ▼ 5. マウスオンで黒い細線を出す魔法です ▼ */
  .trend-item:hover .trend-title {
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-decoration-color: #333;
    text-underline-offset: 3px;
  }

  /* ▼ 2. 左右の「＜ ＞」ボタンのデザイン設定 ▼ */
  .scroll-arrow {
    position: absolute;
    background: #fff;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 8px rgba(0,0,0,0.2);
    cursor: pointer;
    z-index: 5;
    color: #333;
    font-size: 18px;
    transition: background 0.2s;
  }
  .scroll-arrow:hover {
    background: #f0f0f0;
  }
  /* ボタンが画像に少し被るように配置します */
  .prev-arrow { left: -15px; } 
  .next-arrow { right: -15px; } 

  @media (max-width: 768px) {
    .trend-item { min-width: 140px; max-width: 140px; }
    .trend-img-wrapper { height: 90px; }
    .prev-arrow { left: -5px; }
    .next-arrow { right: -5px; }
  }
</style>

{/* ▼▼▼ ここからが、ボタンを動かすための新しいプログラムです ▼▼▼ */}
<script>
  // 画面が表示されたら、このプログラムのスイッチを入れます
  document.addEventListener('DOMContentLoaded', () => {
    // スクロールする箱と、左右のボタンを探し出します
    const scrollContainer = document.getElementById('trend-scroll');
    const btnPrev = document.getElementById('btn-prev');
    const btnNext = document.getElementById('btn-next');

    if (scrollContainer && btnPrev && btnNext) {
      // 右ボタン（＞）を押したとき：横に400px進む
      btnNext.addEventListener('click', () => {
        scrollContainer.scrollBy({ left: 400, behavior: 'smooth' });
      });

      // 左ボタン（＜）を押したとき：横に400px戻る
      btnPrev.addEventListener('click', () => {
        scrollContainer.scrollBy({ left: -400, behavior: 'smooth' });
      });
    }
  });
</script>
