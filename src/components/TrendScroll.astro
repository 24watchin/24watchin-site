---
const API_KEY = import.meta.env.API_KEY;
const BLOG_ID = import.meta.env.BLOG_ID;
const url = `https://www.googleapis.com/blogger/v3/blogs/${BLOG_ID}/posts?key=${API_KEY}&maxResults=10`;

const response = await fetch(url).catch(() => null);
const data = response ? await response.json() : { items: [] };
const posts = data.items || [];

const getImageUrl = (content) => {
  const match = (content || '').match(/<img[^>]+src="([^">]+)"/);
  return match ? match[1] : 'https://placehold.co/300x200/eeeeee/999999?text=Trend';
};
---
<div class="trend-section">
  <div class="trend-header">
    <h3>Bing のトレンド</h3>
    <p>今日のトレンドを発見</p>
  </div>
  <div class="trend-scroll-container">
    {posts.map((post) => (
      <a href={`/news/${post.id}/`} class="trend-item">
        <div class="trend-img-wrapper"><img src={getImageUrl(post.content)} /></div>
        <h4>{post.title}</h4>
      </a>
    ))}
  </div>
</div>

<style>
  .trend-section { margin-top: 40px; border-top: 1px solid #ddd; padding-top: 20px; width: 100%; }
  .trend-header h3 { font-size: 20px; margin: 0; }
  .trend-header p { font-size: 14px; color: #666; margin: 5px 0 20px; }
  .trend-scroll-container { display: flex; gap: 15px; overflow-x: auto; padding-bottom: 20px; }
  .trend-item { min-width: 180px; text-decoration: none; color: #333; flex-shrink: 0; }
  .trend-img-wrapper { height: 110px; border-radius: 8px; overflow: hidden; margin-bottom: 10px; background: #eee; }
  .trend-img-wrapper img { width: 100%; height: 100%; object-fit: cover; }
  .trend-item h4 { font-size: 13px; margin: 0; line-height: 1.4; }
</style>
