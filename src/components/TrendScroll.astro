---
const { lang = 'ja', country = 'jp' } = Astro.props;
const targetTag = lang + '-' + country;

const API_KEY = import.meta.env.API_KEY;
const BLOG_ID = import.meta.env.BLOG_ID;

let allPosts = globalThis.bloggerPostsCache || [];

if (allPosts.length === 0) {
  const url = 'https://www.googleapis.com/blogger/v3/blogs/' + BLOG_ID + '/posts?key=' + API_KEY + '&maxResults=50';
  const response = await fetch(url).catch(() => null);
  if (response && response.ok) {
    const data = await response.json();
    allPosts = data.items || [];
    globalThis.bloggerPostsCache = allPosts;
  }
}

const posts = allPosts
  .filter(post => post.labels && post.labels.includes(targetTag))
  .slice(0, 10);

const getImageUrl = (content) => {
  const match = (content || '').match(/<img[^>]+src="([^">]+)"/);
  return match ? match[1] : 'https://placehold.co/300x200/eeeeee/999999?text=Trend';
};

const trendTitles = {
  ja:      'トレンドWatchin！',
  en:      'Watchin Trends!',
  'zh-cn': 'Watchin 趋势！',
  'zh-tw': 'Watchin 熱點！',
  es:      'Tendencias Watchin!',
  fr:      'Tendances Watchin!',
  de:      'Watchin Trends!',
  ru:      'Тренды Watchin!',
};
const trendTitle = trendTitles[lang] || trendTitles['ja'];

const loadingMessages = {
  ja:      'トレンド記事を読み込み中です...',
  en:      'Loading trending articles...',
  'zh-cn': '正在加载热点文章...',
  'zh-tw': '正在載入熱點文章...',
  es:      'Cargando artículos de tendencia...',
  fr:      'Chargement des articles tendance...',
  de:      'Beiträge werden geladen...',
  ru:      'Загрузка популярных статей...',
};
const loadingMessage = loadingMessages[lang] || loadingMessages['ja'];
---

<section class="bing-trend-section">
  <div class="trend-header">
    <h3>{trendTitle}</h3>
  </div>

  <div class="trend-scroll-outer">
    <div class="scroll-arrow prev-arrow" id="btn-prev">
      <i class="fas fa-chevron-left"></i>
    </div>

    <div class="trend-scroll-container" id="trend-scroll">
      {posts.length > 0 ? (
        posts.map((post) => (
          <a href={'/' + lang + '/' + country + '/news/' + post.id + '/'} class="trend-item">
            <div class="trend-img-wrapper">
              <img src={getImageUrl(post.content)} alt={post.title} />
            </div>
            <h4 class="trend-title">{post.title}</h4>
          </a>
        ))
      ) : (
        <p style="padding: 20px; color: #666;">{loadingMessage}</p>
      )}
    </div>

    <div class="scroll-arrow next-arrow" id="btn-next">
      <i class="fas fa-chevron-right"></i>
    </div>
  </div>
</section>

<style>
  .bing-trend-section { padding: 10px 0 20px 0; background: #fff; }
  /* ▼ テーマカラーを使用！ */
  .trend-header h3 { font-size: 24px; font-weight: bold; border-bottom: 4px solid var(--theme-color, #872732); padding-bottom: 5px; margin-bottom: 15px; }
  .trend-scroll-outer { position: relative; display: flex; align-items: center; }
  .trend-scroll-container { display: flex; gap: 20px; overflow-x: auto; scroll-behavior: smooth; scrollbar-width: none; padding-bottom: 10px; }
  .trend-scroll-container::-webkit-scrollbar { display: none; }
  .trend-item { min-width: 180px; text-decoration: none; color: #333; transition: opacity 0.2s; }
  .trend-item:hover { opacity: 0.8; }
  .trend-img-wrapper { width: 100%; height: 120px; border-radius: 8px; overflow: hidden; background: #eee; }
  .trend-img-wrapper img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .trend-title { font-size: 15px; font-weight: bold; margin-top: 10px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.4; }
  .scroll-arrow { position: absolute; background: #fff; width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 2px 8px rgba(0,0,0,0.2); cursor: pointer; z-index: 10; border: none; }
  .prev-arrow { left: -15px; }
  .next-arrow { right: -15px; }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const scrollContainer = document.getElementById('trend-scroll');
    const btnPrev = document.getElementById('btn-prev');
    const btnNext = document.getElementById('btn-next');
    if (scrollContainer && btnPrev && btnNext) {
      btnNext.addEventListener('click', () => scrollContainer.scrollBy({ left: 400, behavior: 'smooth' }));
      btnPrev.addEventListener('click', () => scrollContainer.scrollBy({ left: -400, behavior: 'smooth' }));
    }
  });
</script>
